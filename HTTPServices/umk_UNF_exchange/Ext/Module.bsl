	Возврат Ответ;
	
КонецФункции

//вспомогательные процедуры
Процедура ПолучитьДокументПартииДляВН(СтрокаТабличнойЧасти, Дата, Номер, Контрагент, ПлательщикНДС = Истина)
	
	Запрос = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	РеализацияТоваровУслуг.Ссылка,
		|	РеализацияТоваровУслуг.Дата КАК Дата
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|ГДЕ
		|	РеализацияТоваровУслуг.umk_номерФ2 = &Номер
		|	И РеализацияТоваровУслуг.Контрагент = &Контрагент
		|
		|УПОРЯДОЧИТЬ ПО
		|	Дата УБЫВ");
	
	Запрос.УстановитьПараметр("ДатаКонца", КонецДня(Дата));
	Запрос.УстановитьПараметр("ДатаНачала", НачалоДня(Дата));
	Запрос.УстановитьПараметр("Номер", Номер);
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда	
		ДокументРТиУ = Выборка.Ссылка	
	Иначе
		ДокументРТиУ = Документы.РеализацияТоваровУслуг.ПустаяСсылка();	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокументРТиУ) Тогда
		
		СтрокаТабличнойЧасти.ДокументПартии = ДокументРТиУ;		
		
	КонецЕсли;
	
	Если ПлательщикНДС Тогда
		УстановитьНалоговуюНакладную(СтрокаТабличнойЧасти);
	КонецЕсли;
		
КонецПроцедуры

Процедура УстановитьНалоговуюНакладную(СтрокаТабличнойЧасти)
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НалоговаяНакладная.Ссылка
		|ИЗ
		|	Документ.НалоговаяНакладная КАК НалоговаяНакладная
		|ГДЕ
		|	НалоговаяНакладная.ДокументОснование = &ДокументОснование";
	
	Запрос.УстановитьПараметр("ДокументОснование", СтрокаТабличнойЧасти.ДокументПартии);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		СтрокаТабличнойЧасти.umk_НалоговаяНакладная = Выборка.Ссылка;
	Иначе
		СтрокаТабличнойЧасти.umk_НалоговаяНакладная = Документы.НалоговаяНакладная.ПустаяСсылка();
	КонецЕсли;
	 
КонецПроцедуры

//Вернуть КодСинхронизации по номенклатуре
Функция ПолучитьКодСинхронизации(КодНоменклатуры, Период)
	
	Попытка
		КодНоменклатуры = Число(КодНоменклатуры);
	Исключение
		КодНоменклатуры = 0;
	КонецПопытки;
	
	КодНоменклатуры = Формат(КодНоменклатуры,"ЧЦ=9; ЧДЦ=0; ЧН=; ЧВН=; ЧГ=");
	
	Номенклатура = Справочники.Номенклатура.НайтиПоКоду(КодНоменклатуры);	
	
	Возврат umk_Доработки.КодСинхронизацииПоНоменклатуре(Номенклатура, Период);
	
КонецФункции

//Получим организацию из договора контрагена
Функция ПолучитьОрганизациюИзДоговораКонтрагента(Контрагент, ВидДоговора)
	
	Запрос = Новый Запрос(	
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ДоговорыКонтрагентов.Организация,
	|	ДоговорыКонтрагентов.Номер КАК Номер,
	|	ДоговорыКонтрагентов.Дата КАК Дата
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|ГДЕ
	|	ДоговорыКонтрагентов.Владелец = &Контрагент
	|	И ДоговорыКонтрагентов.ПометкаУдаления = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата УБЫВ,
	|	Номер УБЫВ");
	
	//Запрос.УстановитьПараметр("ВидДоговора", ВидДоговора);
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий()Тогда
