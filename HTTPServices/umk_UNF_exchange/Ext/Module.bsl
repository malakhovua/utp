
Функция QualityCertificateGET(Запрос)
	
	КодУзла = Запрос.ПараметрыURL["node"]; 
	Стутус = Запрос.ПараметрыURL["status"]; 
	
	Узел = ПланыОбмена.umk_ПланОбменаУНФ.НайтиПоКоду(КодУзла);
	
	Если Не ЗначениеЗаполнено(Узел) Тогда
		Возврат Новый HTTPСервисОтвет(404)
	КонецЕсли;
	
	Если  Стутус = "success" Тогда
		ПланыОбмена.УдалитьРегистрациюИзменений(Узел, Метаданные.Документы.УдостоверениеКачества);
		Возврат  Новый HTTPСервисОтвет(200)
	Иначе         		
		ArrayDocs  = Новый Массив;
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Узел", Узел);
		Запрос.Текст = 
		
		"ВЫБРАТЬ
		|	ХранилищеДополнительнойИнформации.Хранилище,
		|	ХранилищеДополнительнойИнформации.Ссылка,
		|	УдостоверениеКачестваИзменения.Ссылка КАК УдостоверениеКачества,
		|	УдостоверениеКачестваИзменения.Ссылка.Дата КАК Дата,
		|	УдостоверениеКачестваИзменения.Ссылка.Номер КАК Номер
		|ИЗ
		|	Документ.УдостоверениеКачества.Изменения КАК УдостоверениеКачестваИзменения
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ХранилищеДополнительнойИнформации КАК ХранилищеДополнительнойИнформации
		|		ПО УдостоверениеКачестваИзменения.Ссылка = ХранилищеДополнительнойИнформации.Объект
		|ГДЕ
		|	НЕ ХранилищеДополнительнойИнформации.ПометкаУдаления
		|	И УдостоверениеКачестваИзменения.Узел = &Узел
		|	И УдостоверениеКачестваИзменения.Ссылка.Проведен";
		
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			HeaderStructure = Новый Структура("DocDate, DocNumber", Выборка.Дата, Выборка.Номер);
			
			
			Данные = Выборка.Хранилище.Получить();
			
			Попытка
				Данные.Записать(КаталогВременныхФайлов() + "\UK_Table.mxl");
			Исключение
				Возврат Новый HTTPСервисОтвет(404);
			КонецПопытки;
			
			ArrayLines = Новый Массив; 
			Таблица = Новый ТабличныйДокумент;
			Таблица.Прочитать(КаталогВременныхФайлов() + "\UK_Table.mxl");
			
			Для Инд = 1 По Таблица.ВысотаТаблицы Цикл
				Расшифровка = СокрЛП(Таблица.Область(Инд, 2).Расшифровка);
				Если Расшифровка <> "" Тогда
					SyncCode = ПолучитьКодСинхронизации(Расшифровка, Выборка.Дата); 
					LineStructure = Новый Структура();
					LineStructure.Вставить("SyncCode",SyncCode);
					LineStructure.Вставить("CertDate",ПреобразоватьВДату(Таблица.Область(Инд, 9).Текст)); 
					ArrayLines.Добавить(LineStructure);				
				КонецЕсли; 
			КонецЦикла;
			
			УдалитьФайлы(КаталогВременныхФайлов() + "\UK_Table.mxl");	
			
			DataStructure = Новый Структура("Header,Lines",HeaderStructure,ArrayLines);
			
			ArrayDocs.Добавить(DataStructure);
			
		КонецЦикла;
		
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ArrayDocs);
		СтрокаДляОтвета = ЗаписьJSON.Закрыть();
		
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.Заголовки.Вставить("Content-type", "application/JSON;  charset=utf-8");
		Ответ.УстановитьТелоИзСтроки(СтрокаДляОтвета, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
		
		Возврат Ответ;
		
	КонецЕсли;
	
	
КонецФункции

Функция ПреобразоватьВДату(ДатаСтрока)
	
	Попытка 
		Дата = Дата(Прав(ДатаСтрока,4) + Сред(ДатаСтрока,4,2) + Лев(ДатаСтрока,2) + "000000");
	Исключение
		Дата = '00010101000000';
	КонецПопытки;
	
	Возврат Дата
	
КонецФункции

Функция PeriodicValuesNomenclatureGET(Запрос)
	
	КодУзла = Запрос.ПараметрыURL["node"]; 
	Стутус = Запрос.ПараметрыURL["status"]; 
	product_code = Запрос.ПараметрыURL["product_code"];
	
	Узел = ПланыОбмена.umk_ПланОбменаУНФ.НайтиПоКоду(КодУзла);
	
	Если Не ЗначениеЗаполнено(Узел) Тогда
		Возврат Новый HTTPСервисОтвет(404)
	КонецЕсли;
	
	Если  Стутус = "success" Тогда
		ПланыОбмена.УдалитьРегистрациюИзменений(Узел, Метаданные.Справочники.Номенклатура);
		ПланыОбмена.УдалитьРегистрациюИзменений(Узел, Метаданные.РегистрыСведений.umk_ДопРеквизитыНоменклатуры);
		Возврат  Новый HTTPСервисОтвет(200)
	Иначе         		
		DataArray  = Новый Массив;
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Узел", Узел);
		Запрос.УстановитьПараметр("product_code", product_code);
		
		Если product_code = "null" Тогда
			Текст = 
			"ВЫБРАТЬ
			|	ДопРеквизитыНоменклатурыСрезПоследних.ЕстьКодС КАК SyncCode,
			|	ДопРеквизитыНоменклатурыСрезПоследних.БлокироватьВыписку КАК BlockStatement,
			|	ДопРеквизитыНоменклатурыСрезПоследних.Номенклатура.НаименованиеПолное КАК FullName,
			|	ДопРеквизитыНоменклатурыСрезПоследних.КодСинхронизации КАК Code
			|ИЗ
			|	Справочник.Номенклатура.Изменения КАК НоменклатураИзменения
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.umk_ДопРеквизитыНоменклатуры.СрезПоследних КАК ДопРеквизитыНоменклатурыСрезПоследних
			|		ПО НоменклатураИзменения.Ссылка = ДопРеквизитыНоменклатурыСрезПоследних.Номенклатура
			|ГДЕ
			|	НоменклатураИзменения.Узел = &Узел";
		Иначе  //отбор по номенклатуре
			Текст = 
			"ВЫБРАТЬ
			|	ДопРеквизитыНоменклатурыСрезПоследних.ЕстьКодС КАК SyncCode,
			|	ДопРеквизитыНоменклатурыСрезПоследних.БлокироватьВыписку КАК BlockStatement,
			|	ДопРеквизитыНоменклатурыСрезПоследних.Номенклатура.НаименованиеПолное КАК FullName,
			|	ДопРеквизитыНоменклатурыСрезПоследних.КодСинхронизации КАК Code
			|ИЗ
			|	РегистрСведений.umk_ДопРеквизитыНоменклатуры.СрезПоследних КАК ДопРеквизитыНоменклатурыСрезПоследних
			|ГДЕ
			|	ДопРеквизитыНоменклатурыСрезПоследних.КодСинхронизации = &product_code";
		КонецЕсли;
		
		Запрос.Текст = Текст;
		
		
		Табл = Запрос.Выполнить().Выгрузить();
		Табл.Свернуть("Code,SyncCode,BlockStatement,FullName");
		
		Для Каждого СтрокаТабл Из Табл Цикл			
			
			DataStructure = Новый Структура("Code,SyncCode,BlockStatement,FullName");
			ЗаполнитьЗначенияСвойств(DataStructure, СтрокаТабл);
			
			DataArray.Добавить(DataStructure);
			
		КонецЦикла;
		
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, DataArray);
		СтрокаДляОтвета = ЗаписьJSON.Закрыть();
		
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.Заголовки.Вставить("Content-type", "application/JSON;  charset=utf-8");
		Ответ.УстановитьТелоИзСтроки(СтрокаДляОтвета, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
		
		Возврат Ответ;
		
	КонецЕсли;
	
КонецФункции

Функция LoadInvoicePOST(Запрос)
	
	POST_txt =Запрос.ПолучитьТелоКакСтроку();
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(POST_txt);
	Объект_JSON = ПрочитатьJSON(ЧтениеJSON);  
	ЧтениеJSON.Закрыть();

	HeaderStructure = Объект_JSON.HeaderStructure;
	датаф2 =  ПрочитатьДатуJSON(HeaderStructure.Date, ФорматДатыJSON.ISO);
	ЕДРПОУ = СокрП(HeaderStructure.FiscalCode);
	НомерФ2 = HeaderStructure.Number;
	КатЦенФ2 = HeaderStructure.PriceType;
	ПодразделениеКод = СокрЛП(HeaderStructure.subdivisionCode);
	
	ДатаЗаказаКлиентаФ2 =  ПрочитатьДатуJSON(HeaderStructure.CustomerOrderDate, ФорматДатыJSON.ISO);
	НомерЗаказаКлиентаФ2 = HeaderStructure.CustomerOrderNumber;
	ДатаДоставкиКлиентаФ2 =  ПрочитатьДатуJSON(HeaderStructure.CustomerShipmentDate, ФорматДатыJSON.ISO);
	
	МассивСтрокТовары =  Объект_JSON.TableProducts;
	
	//Создадим документ расходная накладная.
	//user - admin

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РеализацияТоваровУслуг.Ссылка
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|ГДЕ
		|	РеализацияТоваровУслуг.umk_номерФ2 = &номерФ2
		|	И РеализацияТоваровУслуг.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода";
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоГода(датаф2));
	Запрос.УстановитьПараметр("номерФ2", НомерФ2);
	Запрос.УстановитьПараметр("ОкончаниеПериода", КонецГода(датаф2));
	
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		ДокОбъект = Выборка.Ссылка.ПолучитьОбъект();
	Иначе
		ДокОбъект = Документы.РеализацияТоваровУслуг.СоздатьДокумент();
		мВалютаРегламентированногоУчета   = глЗначениеПеременной("ВалютаРегламентированногоУчета");
		ЗаполнениеДокументов.ЗаполнитьШапкуДокумента(ДокОбъект, глЗначениеПеременной("глТекущийПользователь"), мВалютаРегламентированногоУчета, "Продажа");	
		ОбщегоНазначения.ЗаполнитьОбязательныеРеквизитыШапкиНовогоДокумента(ДокОбъект, глЗначениеПеременной("глТекущийПользователь"));
	КонецЕсли;
	
	ИмяТабЧасти = "Товары";
	
	мУказаниеСкладов = глЗначениеПеременной("УказаниеСкладовВТабличнойЧастиДокументов");
	мУказаниеСкладовВТЧ = (мУказаниеСкладов = Перечисления.ВариантыУказанияСкладовВТабличнойЧастиДокументов.ДляДокументовПоступленияРеализации)
	Или (мУказаниеСкладов = Перечисления.ВариантыУказанияСкладовВТабличнойЧастиДокументов.ДляДокументовРеализации);
	
	//ТипЦены = Константы.umk_ТипЦеныПриИмпорте.Получить();
	//НомерКолЦены = ?(ТипЦены = 1, 5, 4);
	
	ДокОбъект.Дата = датаф2;
	ДокОбъект.umk_КатЦенФ2 = КатЦенФ2;
	ДокОбъект.Организация = Константы.umk_ГоловнаяОрганизация.Получить();
	 
	ДокОбъект.umk_НомерЗаказаФ2  = НомерЗаказаКлиентаФ2; 
	ДокОбъект.umk_ДатаЗаказаФ2   = ДатаЗаказаКлиентаФ2;
	ДокОбъект.umk_ДатаДоставкиФ2 = ДатаДоставкиКлиентаФ2;
	ДокОбъект.umk_номерФ2 = НомерФ2;
	ДокОбъект.umk_Импортирована = Истина;
	ДокОбъект.СуммаВключаетНДС = Ложь;
	ДокОбъект.АвторасчетНДС = Истина;
	ДокОбъект.УчитыватьНДС = Истина;
	ДокОбъект.Подразделение = Справочники.Подразделения.НайтиПоКоду(ПодразделениеКод);
	
	//Счета учета по умолчанию 
	ДокОбъект.СчетУчетаРасчетовСКонтрагентом    = ПланыСчетов.Хозрасчетный.РасчетыСОтечественнымиПокупателями;
	ДокОбъект.СчетУчетаРасчетовПоАвансам        = ПланыСчетов.Хозрасчетный.РасчетыПоАвансамПолученнымВНациональнойВалюте;
	
	ДокОбъект.СчетУчетаНДС 				        = ПланыСчетов.Хозрасчетный.НалоговыеОбязательстваНеподтвержденные;
	ДокОбъект.СчетУчетаНДСПодтвержденный        = ПланыСчетов.Хозрасчетный.НалоговыеОбязательства;
	

	
	ПлательщикНДС = Истина;
	
	Если ЗначениеЗаполнено(ЕДРПОУ) Тогда
		КонтрагентСсылка = Справочники.Контрагенты.НайтиПоРеквизиту("КодПоЕДРПОУ", ЕДРПОУ);
		Если Не КонтрагентСсылка.Пустая() Тогда
			
			ДокОбъект.Контрагент = КонтрагентСсылка;
			
			Организация = ПолучитьОрганизациюИзДоговораКонтрагента(КонтрагентСсылка, Перечисления.ВидыДоговоровКонтрагентов.СПокупателем);
			
			Если ЗначениеЗаполнено(Организация) Тогда
				
				ДокОбъект.Организация = Организация;
				
				СхемаНО = ОбщегоНазначения.ПолучитьСхемуНалогообложения(ДокОбъект.Дата, ДокОбъект.Организация);
				
				Если НЕ СхемаНО.Ссылка = Справочники.СхемыНалогообложения.ЕдиныйНалогИНДС
					И Не СхемаНО.Ссылка = Справочники.СхемыНалогообложения.НалогНаПрибыльИНДС ТОгда
					ПлательщикНДС = Ложь;
					ДокОбъект.УчитыватьНДС =Ложь;
				КонецЕсли;
				
			КонецЕсли;

			// Выполняем общие действия для всех документов при изменении Контрагент.
			мСтруктураПараметровДляПолученияДоговора = ЗаполнениеДокументов.ПолучитьСтруктуруПараметровДляПолученияДоговораПродажи();
			ЗаполнениеДокументов.ПриИзмененииЗначенияКонтрагента(ДокОбъект, мСтруктураПараметровДляПолученияДоговора);
			
			//Установим счета учера расчетов
			СчетаУчета = УправлениеВзаиморасчетами.ПолучитьСчетаРасчетовСКонтрагентом(ДокОбъект.Организация, ДокОбъект.Контрагент, ДокОбъект.ДоговорКонтрагента);
			
			Если ДокОбъект.ДоговорКонтрагента.ВидДоговора = Перечисления.ВидыДоговоровКонтрагентов.СКомиссионером Тогда
				ДокОбъект.СчетУчетаРасчетовСКонтрагентом = СчетаУчета.СчетРасчетовПокупателя;
				ДокОбъект.СчетУчетаРасчетовПоАвансам     = СчетаУчета.СчетАвансовПокупателя;
			ИначеЕсли ДокОбъект.ДоговорКонтрагента.ВидДоговора = Перечисления.ВидыДоговоровКонтрагентов.Бартерный Тогда
				ДокОбъект.СчетУчетаРасчетовСКонтрагентом = СчетаУчета.СчетРасчетовПокупателяПриБартере;
				ДокОбъект.СчетУчетаРасчетовПоАвансам     = СчетаУчета.СчетАвансовПокупателяПриБартере;
			Иначе
				ДокОбъект.СчетУчетаРасчетовСКонтрагентом = СчетаУчета.СчетРасчетовПокупателя;
				ДокОбъект.СчетУчетаРасчетовПоАвансам     = СчетаУчета.СчетАвансовПокупателя;
			КонецЕсли;
			
			ДокОбъект.СчетУчетаРасчетовПоТаре          = СчетаУчета.СчетУчетаТарыПокупателя;
			ДокОбъект.СчетУчетаРасчетовПоТареПоАвансам = СчетаУчета.СчетАвансовПоТареПокупателя;
			ДокОбъект.СчетУчетаНДС 					 = СчетаУчета.СчетУчетаНДСПродаж;
			ДокОбъект.СчетУчетаНДСПодтвержденный  	 = СчетаУчета.СчетУчетаНДСПродажПодтвержденный;
		КонецЕсли;
	КонецЕсли;
	
	ДокОбъект.Товары.Очистить();
	
	Для Каждого СтрокаТовары Из МассивСтрокТовары Цикл
		
		СтрокаТабличнойЧасти = ДокОбъект.Товары.Добавить();
		
		Номенклатура = umk_Доработки.НоменклатураПоКодуСинхронизации(СокрП(СтрокаТовары.code), ДокОбъект.Дата);
		ЕдИзмер = Справочники.ЕдиницыИзмерения.НайтиПоНаименованию(СтрокаТовары.Unit, Истина, , Номенклатура);
		
		СтрокаТабличнойЧасти.Номенклатура = Номенклатура;
		// Характиристика номенклатуры
		Если  ЗначениеЗаполнено(СтрокаТовары.PackName) И ЗначениеЗаполнено(СтрокаТабличнойЧасти.Номенклатура) Тогда
			
			 СтрокаТабличнойЧасти.ХарактеристикаНоменклатуры = Справочники.ХарактеристикиНоменклатуры.НайтиПоРеквизиту("umk_КодУпаковки",СтрокаТовары.PackCode,,СтрокаТабличнойЧасти.Номенклатура);
			
		КонецЕсли;
		//Конец Характеристика
		
		Если Не ЗначениеЗаполнено(ЕдИзмер) Тогда
			 ЕдИзмер = Номенклатура.ЕдиницаХраненияОстатков;
		КонецЕсли;
		 
		ОбработкаТабличныхЧастей.ПриИзмененииНоменклатурыТабЧасти(СтрокаТабличнойЧасти, ДокОбъект);
		СтрокаТабличнойЧасти.ЕдиницаИзмерения = ЕдИзмер;
		ОбработкаТабличныхЧастей.ПриИзмененииЕдиницыТабЧасти(СтрокаТабличнойЧасти, ДокОбъект); 	
		СтрокаТабличнойЧасти.СтавкаНДС = ?(ПлательщикНДС, Перечисления.СтавкиНДС.НДС20,Перечисления.СтавкиНДС.БезНДС);
		
		УчетСерийныхНомеров.ПроверитьСерийныеНомера(СтрокаТабличнойЧасти, ДокОбъект);
		
		//ЗаполнитьСчетаУчетаВСтрокеТабЧасти
		ДокОбъект.ЗаполнитьСчетаУчетаВСтрокеТабЧасти(СтрокаТабличнойЧасти, ИмяТабЧасти, Истина, Истина); 
		
		// Ввод состава набора
		УправлениеЗапасами.ДобавитьСоставНабора(СтрокаТабличнойЧасти, ДокОбъект);
		СтрокаТабличнойЧасти.Цена =  ?(ПлательщикНДС, 
		            СтрокаТовары.Price/(1 +(УчетНДС.ПолучитьСтавкуНДС(СтрокаТабличнойЧасти.СтавкаНДС))/100),
					           СтрокаТовары.Price);
		
		
		СтрокаТабличнойЧасти.Количество = СтрокаТовары.Quantity;
		// Рассчитать реквизиты табличной части.
		ОбработкаТабличныхЧастей.РассчитатьКоличествоМестТабЧасти(СтрокаТабличнойЧасти, ДокОбъект);
		
		// Рассчитать реквизиты табличной части.
		ОбработкаТабличныхЧастей.РассчитатьСуммуТабЧасти(СтрокаТабличнойЧасти, ДокОбъект);
		ОбработкаТабличныхЧастей.РассчитатьСуммуНДСТабЧасти(СтрокаТабличнойЧасти, ДокОбъект);
		
		//Доп. значения 
		// запись в регистр сроки годности.
		ЕдСрокаГодности = СтрокаТовары.ExpiryDate;  
		СрокГодности =  СтрокаТовары.UnitTime;
		Если  ЗначениеЗаполнено(СрокГодности) И ЗначениеЗаполнено(ЕдСрокаГодности) Тогда
			ПараметрыСрокаГодности = Новый Структура("ВидСрокаГодности,СрокГодности",ЕдСрокаГодности,СрокГодности);
			umk_Доработки.СоздатьЗаписьСрокГодности(СтрокаТабличнойЧасти ,ПараметрыСрокаГодности);
		КонецЕсли;
		
		//упаковка на печать
		СтрокаТабличнойЧасти.umk_УпаковкаНаПечать = СтрокаТовары.PackPrintName;

		//код клиента
		СтрокаТабличнойЧасти.umk_КодКлиента = СтрокаТовары.ClientCode;
		
		//штрихкод номенклатуры
		Если ЗначениеЗаполнено(СтрокаТовары.Barcode) Тогда
			umk_Доработки.НовыйШтрихкод(СтрокаТабличнойЧасти, СтрокаТовары.Barcode); 
		КонецЕсли;
		
	КонецЦикла;
	
	Попытка
		ДокОбъект.Записать();
	Исключение
		Ответ = Новый HTTPСервисОтвет(500);
		Возврат Ответ;		
	КонецПопытки;
	
	Ответ = Новый HTTPСервисОтвет(200);
	Возврат Ответ;
	
КонецФункции

Функция LoadReturnableInvoicePOST(Запрос)
	
	POST_txt =Запрос.ПолучитьТелоКакСтроку();
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(POST_txt);
	Объект_JSON = ПрочитатьJSON(ЧтениеJSON);  
	ЧтениеJSON.Закрыть();

	HeaderStructure = Объект_JSON.HeaderStructure;
	датаф2 =  ПрочитатьДатуJSON(HeaderStructure.Date, ФорматДатыJSON.ISO);
	ЕДРПОУ = СокрП(HeaderStructure.FiscalCode);
	НомерФ2 = HeaderStructure.Number;
	КатЦенФ2 = HeaderStructure.PriceType;
	ПодразделениеКод = СокрЛП(HeaderStructure.subdivisionCode);
	
		
	МассивСтрокТовары =  Объект_JSON.TableProducts;
	
	//Создадим документ возвратная накладная.
	//user - admin

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВозвратТоваровОтПокупателя.Ссылка
		|ИЗ
		|	Документ.ВозвратТоваровОтПокупателя КАК ВозвратТоваровОтПокупателя
		|ГДЕ
		|	ВозвратТоваровОтПокупателя.umk_номерФ2 = &номерФ2
		|	И ВозвратТоваровОтПокупателя.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода";
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоГода(датаф2));
	Запрос.УстановитьПараметр("номерФ2", НомерФ2);
	Запрос.УстановитьПараметр("ОкончаниеПериода", КонецГода(датаф2));
	
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		ДокОбъект = Выборка.Ссылка.ПолучитьОбъект();
	Иначе
		ДокОбъект = Документы.ВозвратТоваровОтПокупателя.СоздатьДокумент();
		мВалютаРегламентированногоУчета   = глЗначениеПеременной("ВалютаРегламентированногоУчета");
		ЗаполнениеДокументов.ЗаполнитьШапкуДокумента(ДокОбъект, глЗначениеПеременной("глТекущийПользователь"), мВалютаРегламентированногоУчета, "Продажа");	
		ОбщегоНазначения.ЗаполнитьОбязательныеРеквизитыШапкиНовогоДокумента(ДокОбъект, глЗначениеПеременной("глТекущийПользователь"));
	КонецЕсли;
	
	ДокОбъект.УчитыватьНДС     = Истина;
	ДокОбъект.СуммаВключаетНДС = Ложь;
	
	// Заполним склад 
	Если Не ЗначениеЗаполнено(ДокОбъект.СкладОрдер) Тогда
		ДокОбъект.СкладОрдер = УправлениеПользователями.ПолучитьЗначениеПоУмолчанию(глЗначениеПеременной("глТекущийПользователь"), "ОсновнойСклад");	
	КонецЕсли;
	
	ИмяТабЧасти = "Товары";
	
	мУказаниеСкладов = глЗначениеПеременной("УказаниеСкладовВТабличнойЧастиДокументов");
	мУказаниеСкладовВТЧ = (мУказаниеСкладов = Перечисления.ВариантыУказанияСкладовВТабличнойЧастиДокументов.ДляДокументовПоступленияРеализации)
	Или (мУказаниеСкладов = Перечисления.ВариантыУказанияСкладовВТабличнойЧастиДокументов.ДляДокументовРеализации);
	
	//ТипЦены = Константы.umk_ТипЦеныПриИмпорте.Получить();
	//НомерКолЦены = ?(ТипЦены = 1, 5, 4);
	
	ДокОбъект.Дата = датаф2;
	ДокОбъект.Подразделение = Справочники.Подразделения.НайтиПоКоду(ПодразделениеКод);
	ДокОбъект.Организация  = Константы.umk_ГоловнаяОрганизация.Получить(); 
	ДокОбъект.umk_номерФ2 = НомерФ2;
	ДокОбъект.umk_Импортирована = Истина;
	
	//Счета учета по умолчанию 
	ДокОбъект.СчетУчетаРасчетовСКонтрагентом    = ПланыСчетов.Хозрасчетный.РасчетыСОтечественнымиПокупателями;
	ДокОбъект.СчетУчетаРасчетовПоАвансам        = ПланыСчетов.Хозрасчетный.РасчетыПоАвансамПолученнымВНациональнойВалюте;
	
	ДокОбъект.СчетУчетаНДС 				        = ПланыСчетов.Хозрасчетный.НалоговыеОбязательстваНеподтвержденные;
	ДокОбъект.СчетУчетаНДСПодтвержденный        = ПланыСчетов.Хозрасчетный.НалоговыеОбязательства;
		
	
	ПлательщикНДС = Истина;
	
	Если ЗначениеЗаполнено(ЕДРПОУ) Тогда
		КонтрагентСсылка = Справочники.Контрагенты.НайтиПоРеквизиту("КодПоЕДРПОУ", ЕДРПОУ);
		Если Не КонтрагентСсылка.Пустая() Тогда
			
			ДокОбъект.Контрагент = КонтрагентСсылка;
			Организация = ПолучитьОрганизациюИзДоговораКонтрагента(КонтрагентСсылка, Перечисления.ВидыДоговоровКонтрагентов.СПокупателем);
			
			Если ЗначениеЗаполнено(Организация) Тогда
				
				ДокОбъект.Организация = Организация;
				
				СхемаНО = ОбщегоНазначения.ПолучитьСхемуНалогообложения(ДокОбъект.Дата, ДокОбъект.Организация);
				
				Если НЕ СхемаНО.Ссылка = Справочники.СхемыНалогообложения.ЕдиныйНалогИНДС
					И Не СхемаНО.Ссылка = Справочники.СхемыНалогообложения.НалогНаПрибыльИНДС ТОгда
					ПлательщикНДС = Ложь;
					ДокОбъект.УчитыватьНДС = Ложь;
				КонецЕсли;
				
			КонецЕсли;

			
			// Выполняем общие действия для всех документов при изменении Контрагент.
			мСтруктураПараметровДляПолученияДоговора = ЗаполнениеДокументов.ПолучитьСтруктуруПараметровДляПолученияДоговораПродажи();
			ЗаполнениеДокументов.ПриИзмененииЗначенияКонтрагента(ДокОбъект, мСтруктураПараметровДляПолученияДоговора);
			
			//Установим счета учера расчетов
			СчетаУчета = УправлениеВзаиморасчетами.ПолучитьСчетаРасчетовСКонтрагентом( ДокОбъект.Организация,  ДокОбъект.Контрагент,  ДокОбъект.ДоговорКонтрагента);
			
			Если ДокОбъект.ДоговорКонтрагента.ВидДоговора = Перечисления.ВидыДоговоровКонтрагентов.СКомиссионером Тогда
				ДокОбъект.СчетУчетаРасчетовСКонтрагентом = СчетаУчета.СчетРасчетовПокупателя;
			ИначеЕсли ДокОбъект.ДоговорКонтрагента.ВидДоговора = Перечисления.ВидыДоговоровКонтрагентов.Бартерный Тогда
				ДокОбъект.СчетУчетаРасчетовСКонтрагентом = СчетаУчета.СчетРасчетовПокупателяПриБартере;
			Иначе
				ДокОбъект.СчетУчетаРасчетовСКонтрагентом = СчетаУчета.СчетРасчетовПокупателя;
			КонецЕсли;
			
			ДокОбъект.СчетУчетаРасчетовПоАвансам     = ДокОбъект.СчетУчетаРасчетовСКонтрагентом;
			
			ДокОбъект.СчетУчетаРасчетовПоТаре          = СчетаУчета.СчетУчетаТарыПокупателя;
			ДокОбъект.СчетУчетаРасчетовПоТареПоАвансам =  ДокОбъект.СчетУчетаРасчетовПоТаре;
			ДокОбъект.СчетУчетаНДС 					 = СчетаУчета.СчетУчетаНДСПродаж;
			ДокОбъект.СчетУчетаНДСПодтвержденный  	 = СчетаУчета.СчетУчетаНДСПродажПодтвержденный;
			
		КонецЕсли;
	КонецЕсли;
	
	ДокОбъект.Товары.Очистить();
	
	Для Каждого СтрокаТовары Из МассивСтрокТовары Цикл
		
		СтрокаТабличнойЧасти = ДокОбъект.Товары.Добавить();
		НомерНакладной = СтрокаТовары.InvoiceNumber;
		
		ДокументРТиУ = Документы.ВозвратТоваровОтПокупателя.ДокументРеализацииПоНомеру77(НомерНакладной, ДокОбъект.Контрагент);
		
		Если ЗначениеЗаполнено(ДокументРТиУ) Тогда //Найдем номенклатуру по коду на дату РТиУ
			Номенклатура =  umk_Доработки.НоменклатураПоКодуСинхронизации(СтрокаТовары.Code, ДокументРТиУ.Дата);
			СтрокаТабличнойЧасти.ДокументПартии = ДокументРТиУ;
		Иначе // на дату документа
			Номенклатура =  umk_Доработки.НоменклатураПоКодуСинхронизации(СтрокаТовары.Code, ДокОбъект.Дата);
		КонецЕсли; 
		
		ЕдИзмер = Справочники.ЕдиницыИзмерения.НайтиПоНаименованию(СтрокаТовары.Unit, Истина, , Номенклатура);
		
		СтрокаТабличнойЧасти.Номенклатура = Номенклатура;
		
		//Документ Партия и НН 
		ДатаНакладной = ПрочитатьДатуJSON(СтрокаТовары.InvoiceDate, ФорматДатыJSON.ISO);
		ПолучитьДокументПартииДляВН(СтрокаТабличнойЧасти, ДатаНакладной, НомерНакладной, ДокОбъект.Контрагент,ПлательщикНДС);
		
		// Характиристика номенклатуры
		Если  ЗначениеЗаполнено(СтрокаТовары.PackName) И ЗначениеЗаполнено(СтрокаТабличнойЧасти.Номенклатура) Тогда
			
			СтрокаТабличнойЧасти.ХарактеристикаНоменклатуры = Справочники.ХарактеристикиНоменклатуры.НайтиПоРеквизиту("umk_КодУпаковки",СтрокаТовары.PackCode,,СтрокаТабличнойЧасти.Номенклатура);
			
		КонецЕсли;
		//Конец Характеристика
		
		Если Не ЗначениеЗаполнено(ЕдИзмер) Тогда
			 ЕдИзмер = Номенклатура.ЕдиницаХраненияОстатков;
		КонецЕсли;
		 
		ОбработкаТабличныхЧастей.ПриИзмененииНоменклатурыТабЧасти(СтрокаТабличнойЧасти, ДокОбъект);
		СтрокаТабличнойЧасти.ЕдиницаИзмерения = ЕдИзмер;
		ОбработкаТабличныхЧастей.ПриИзмененииЕдиницыТабЧасти(СтрокаТабличнойЧасти, ДокОбъект); 
		
		СтрокаТабличнойЧасти.СтавкаНДС = ?(ПлательщикНДС, Перечисления.СтавкиНДС.НДС20,Перечисления.СтавкиНДС.БезНДС);
		СтрокаТабличнойЧасти.Качество = Справочники.Качество.Новый;
		
		//ЗаполнитьСчетаУчетаВСтрокеТабЧасти
		ДокОбъект.ЗаполнитьСчетаУчетаВСтрокеТабЧасти(СтрокаТабличнойЧасти, ИмяТабЧасти, Истина, Истина); 
		
		СтрокаТабличнойЧасти.Цена =  ?(ПлательщикНДС, 
		            СтрокаТовары.Price/(1 +(УчетНДС.ПолучитьСтавкуНДС(СтрокаТабличнойЧасти.СтавкаНДС))/100),
					           СтрокаТовары.Price);
		СтрокаТабличнойЧасти.Количество = СтрокаТовары.Quantity;
		
		// Рассчитать реквизиты табличной части.
		ОбработкаТабличныхЧастей.РассчитатьКоличествоМестТабЧасти(СтрокаТабличнойЧасти, ДокОбъект);
		//
		// Рассчитать реквизиты табличной части.
		ОбработкаТабличныхЧастей.РассчитатьСуммуТабЧасти(СтрокаТабличнойЧасти, ДокОбъект);
		ОбработкаТабличныхЧастей.РассчитатьСуммуНДСТабЧасти(СтрокаТабличнойЧасти, ДокОбъект);
		
		//Накладная основание
		//СтрокаТабличнойЧасти.ДокументПартии = Документы.РеализацияТоваровУслуг.НайтиПоНомеру(СтрокаТовары.InvoiceNumber,
		//                                         ПрочитатьДатуJSON(СтрокаТовары.InvoiceDate, ФорматДатыJSON.ISO));		
		////Доп. значения 		
		//упаковка на печать
		СтрокаТабличнойЧасти.umk_УпаковкаНаПечать = СтрокаТовары.PackPrintName;
			
	КонецЦикла;
	
	Попытка
		ДокОбъект.Записать();
	Исключение
		Ответ = Новый HTTPСервисОтвет(500);
		Возврат Ответ;		
	КонецПопытки;
	
	Ответ = Новый HTTPСервисОтвет(200);
	Возврат Ответ;
	
КонецФункции

//Вернуть коды синхронизации на текущую дату тех позиций для которых они стали равными ""
//
Функция AllCodesSyncNomenGET(Запрос)
	
	КодУзла = Запрос.ПараметрыURL["node"]; 
	Стутус = Запрос.ПараметрыURL["status"]; 
	
	Узел = ПланыОбмена.umk_ПланОбменаУНФ.НайтиПоКоду(КодУзла);
	
	Если Не ЗначениеЗаполнено(Узел) Тогда
		Возврат Новый HTTPСервисОтвет(404)
	КонецЕсли;
	
	Если  Стутус = "success" Тогда
		
		ПланыОбмена.УдалитьРегистрациюИзменений(Узел, Метаданные.РегистрыСведений.КодыСинхронизацииУНФ);
		Возврат  Новый HTTPСервисОтвет(200)
		
	Иначе         		
		
		DataArray  = Новый Массив;
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Узел", Узел);
		Запрос.УстановитьПараметр("Период", ТекущаяДата());
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	КодыСинхр.Код КАК code_sync
		|ИЗ
		|	РегистрСведений.КодыСинхронизацииУНФ.Изменения КАК КодыСинхрИзменения
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КодыСинхронизацииУНФ.СрезПоследних(&Период, ) КАК КодыСинхр
		|		ПО КодыСинхрИзменения.Номенклатура = КодыСинхр.Номенклатура
		|			И КодыСинхрИзменения.Период = КодыСинхр.Период
		|ГДЕ
		|	КодыСинхр.НовыйКод = """"
		|	И КодыСинхрИзменения.Узел = &Узел";
		
		Табл = Запрос.Выполнить().Выгрузить();
		
		Для Каждого СтрокаТабл Из Табл Цикл			
			
			DataStructure = Новый Структура("code_sync");
			ЗаполнитьЗначенияСвойств(DataStructure, СтрокаТабл);
			
			DataArray.Добавить(DataStructure);
			
		КонецЦикла;
		
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, DataArray);
		СтрокаДляОтвета = ЗаписьJSON.Закрыть();
		
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.Заголовки.Вставить("Content-type", "application/JSON;  charset=utf-8");
