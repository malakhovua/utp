		Если Запрос.Параметры.ТаблицаТоваров = Неопределено Тогда
			
			СхемаЗапроса.ПакетЗапросов[1].Операторы[0].Источники[0].Соединения.Очистить();
			СхемаЗапроса.ПакетЗапросов[2].Операторы[0].Источники[0].Соединения.Очистить();	
			СхемаЗапроса.ПакетЗапросов.Удалить(0);
			
		КонецЕсли;
		
		Запрос.Текст = СхемаЗапроса.ПолучитьТекстЗапроса();
		
	КонецЕсли;
	
КонецПроцедуры // ЗаполнитьЗапросПоСписанию()

Функция ПолучитьСписокВершин(Таб, Приемники)  
	
	Если Таб.Количество()=0 Тогда
		Возврат новый массив;
	КонецЕсли;
	
	массивПриемников = новый массив;
	Для каждого Строка Из Приемники Цикл
		массивПриемников.Добавить(Строка.ключ);
	КонецЦикла;
		
	Запрос = Новый Запрос;
			
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Различные ВнешнийИсточник.Источник как Источник 
		|Поместить ВРтаблица 
		|Из &ВнешнийИсточник КАК ВнешнийИсточник
		|ГДЕ ВнешнийИсточник.Количество<>0 и Не ВнешнийИсточник.Источник в (&МассивПриемников)
		|; 
		|ВЫБРАТЬ
		|	ВнешнийИсточник.Источник как Источник 
		|
		|Из ВРтаблица КАК ВнешнийИсточник";
		
	Запрос.УстановитьПараметр("ВнешнийИсточник", Таб );
	Запрос.УстановитьПараметр("МассивПриемников", массивПриемников);
	
	Таб = Запрос.Выполнить().Выгрузить();
	
	Возврат Таб.ВыгрузитьКолонку("Источник");
	
КонецФункции

Процедура ДополнитьТаблицуТоваровКомплектациями(ТаблицаТоваров, ДатаНач, ДатаКон, ДопПараметры)
	
	ТаблицаКомплектаций = Неопределено;
	Если ТипЗнч(ДопПараметры) = Тип("Структура") Тогда 
		ДопПараметры.Свойство("ТаблицаКомплектаций", ТаблицаКомплектаций);
	КонецЕсли;
	
	Если ТаблицаКомплектаций = Неопределено Тогда
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("ДатаНач", ДатаНач);
		Запрос.УстановитьПараметр("ДатаКон", ДатаКон);
		
		Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Источник.Номенклатура,
		|	Источник.ДокументОприходования,
		|	Приемник.Номенклатура КАК НоменклатураНовая,
		|	Приемник.ДокументОприходования КАК ДокументОприходованияНовый
		|ИЗ
		|	РегистрНакопления.ПартииТоваровНаСкладах КАК Источник
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ПартииТоваровНаСкладах КАК Приемник
		|		ПО Источник.Регистратор = Приемник.Регистратор
		|			И Источник.НомерКорСтроки = Приемник.НомерСтроки
		|ГДЕ
		|	Источник.Период МЕЖДУ &ДатаНач И &ДатаКон
		|	И Приемник.Период МЕЖДУ &ДатаНач И &ДатаКон
		|	И Источник.КодОперации = ЗНАЧЕНИЕ(Перечисление.КодыОперацийПартииТоваров.Комплектация)
		|	И Источник.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
		|	И Источник.Активность";
		
		ТаблицаКомплектаций = Запрос.Выполнить().Выгрузить();
		
		Если ТипЗнч(ДопПараметры) = Тип("Структура") Тогда 
			ДопПараметры.Вставить("ТаблицаКомплектаций", ТаблицаКомплектаций);
		КонецЕсли;
		
	КонецЕсли;
	
	ТаблицаИсточников = ТаблицаТоваров;
	ДобавленныеСтроки = ТаблицаТоваров.СкопироватьКолонки();
	
	Пока Истина Цикл
		
		Для каждого СтрокаИсточника Из ТаблицаИсточников Цикл
			
			//поиск вперед
			СтрокиКомплектаций = ТаблицаКомплектаций.НайтиСтроки(
			Новый Структура("Номенклатура, ДокументОприходования", СтрокаИсточника.Номенклатура, СтрокаИсточника.ДокументОприходования));
			
			Для каждого СтрокаКомплектации ИЗ СтрокиКомплектаций Цикл
				
				//проверим зацикливание, что результат комплектации уже находится в таблице товаров
				СуществующиеСвязи = ТаблицаТоваров.НайтиСтроки(
				Новый Структура("Номенклатура, ДокументОприходования", СтрокаКомплектации.НоменклатураНовая, СтрокаКомплектации.ДокументОприходованияНовый));
				
				Если СуществующиеСвязи.Количество() = 0 Тогда
					
					НоваяСтрока = ТаблицаТоваров.Добавить();
					НоваяСтрока.Номенклатура = СтрокаКомплектации.НоменклатураНовая;
					НоваяСтрока.ДокументОприходования = СтрокаКомплектации.ДокументОприходованияНовый;
					
					ДобавленнаяСтрока = ДобавленныеСтроки.Добавить();
					ЗаполнитьЗначенияСвойств(ДобавленнаяСтрока, НоваяСтрока);
					
				КонецЕсли;
				
			КонецЦикла;
			
			//поиск назад
			СтрокиКомплектаций = ТаблицаКомплектаций.НайтиСтроки(
			Новый Структура("НоменклатураНовая, ДокументОприходованияНовый", СтрокаИсточника.Номенклатура, СтрокаИсточника.ДокументОприходования));
			
			Для каждого СтрокаКомплектации ИЗ СтрокиКомплектаций Цикл
				
				//проверим зацикливание, что результат комплектации уже находится в таблице товаров
				СуществующиеСвязи = ТаблицаТоваров.НайтиСтроки(
				Новый Структура("Номенклатура, ДокументОприходования", СтрокаКомплектации.Номенклатура, СтрокаКомплектации.ДокументОприходования));
				
				Если СуществующиеСвязи.Количество() = 0 Тогда
					
					НоваяСтрока = ТаблицаТоваров.Добавить();
					НоваяСтрока.Номенклатура = СтрокаКомплектации.Номенклатура;
					НоваяСтрока.ДокументОприходования = СтрокаКомплектации.ДокументОприходования;
					
					ДобавленнаяСтрока = ДобавленныеСтроки.Добавить();
					ЗаполнитьЗначенияСвойств(ДобавленнаяСтрока, НоваяСтрока);
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;
		
		Если ДобавленныеСтроки.Количество() = 0 Тогда
			Прервать;
		КонецЕсли;
		
		//повторяем цикл для добавленных строк
		ТаблицаИсточников = ДобавленныеСтроки;
		ДобавленныеСтроки = ТаблицаИсточников.СкопироватьКолонки();
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ДополнитьМассивНоменклатурыКомплектациямиБух(МассивНоменклатуры, ДатаНач, ДатаКон, ДопПараметры)
	
	Если МассивНоменклатуры = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаКомплектаций = Неопределено;
	Если ТипЗнч(ДопПараметры) = Тип("Структура") Тогда 
		ДопПараметры.Свойство("ТаблицаКомплектаций", ТаблицаКомплектаций);
	КонецЕсли;
	
	Если ТаблицаКомплектаций = Неопределено Тогда
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("ДатаНач", ДатаНач);
		Запрос.УстановитьПараметр("ДатаКон", ДатаКон);
		Запрос.УстановитьПараметр("СписокСчетов", ДопПараметры.СписокСчетов);
		
		Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ХозрасчетныйОбороты.Субконто1 КАК Номенклатура,
		|	ХозрасчетныйОбороты.КорСубконто1 КАК НоменклатураНовая
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.Обороты(&ДатаНач, &ДатаКон, , Счет В (&СписокСчетов), ЗНАЧЕНИЕ(ПланВидовХарактеристик.ВидыСубконтоХозрасчетные.Номенклатура), , КорСчет В (&СписокСчетов), ЗНАЧЕНИЕ(ПланВидовХарактеристик.ВидыСубконтоХозрасчетные.Номенклатура)) КАК ХозрасчетныйОбороты
		|ГДЕ
		|	ХозрасчетныйОбороты.Субконто1 <> ХозрасчетныйОбороты.КорСубконто1";
		
		ТаблицаКомплектаций = Запрос.Выполнить().Выгрузить();
		
		Если ТипЗнч(ДопПараметры) = Тип("Структура") Тогда 
			ДопПараметры.Вставить("ТаблицаКомплектаций", ТаблицаКомплектаций);
		КонецЕсли;
		
	КонецЕсли;
	
	МассивИсточников = МассивНоменклатуры;
	ДобавленныеНоменклатуры = Новый Массив;
	
	Пока Истина Цикл
		
		Для каждого ТекНоменклатура Из МассивИсточников Цикл
			
			//поиск вперед
			СтрокиКомплектаций = ТаблицаКомплектаций.НайтиСтроки(Новый Структура("Номенклатура", ТекНоменклатура));
			
			Для каждого СтрокаКомплектации ИЗ СтрокиКомплектаций Цикл
				
				//проверим зацикливание, что результат комплектации уже находится в массиве товаров
				Если МассивНоменклатуры.Найти(СтрокаКомплектации.НоменклатураНовая) = Неопределено Тогда
					
					МассивНоменклатуры.Добавить(СтрокаКомплектации.НоменклатураНовая);
					ДобавленныеНоменклатуры.Добавить(СтрокаКомплектации.НоменклатураНовая);
					
				КонецЕсли;
				
			КонецЦикла;
			
			//поиск назад
			СтрокиКомплектаций = ТаблицаКомплектаций.НайтиСтроки(Новый Структура("НоменклатураНовая", ТекНоменклатура));
			
			Для каждого СтрокаКомплектации ИЗ СтрокиКомплектаций Цикл
				
				//проверим зацикливание, что результат комплектации уже находится в таблице товаров
				Если МассивНоменклатуры.Найти(СтрокаКомплектации.Номенклатура) = Неопределено Тогда
					
					МассивНоменклатуры.Добавить(СтрокаКомплектации.Номенклатура);
					ДобавленныеНоменклатуры.Добавить(СтрокаКомплектации.Номенклатура);
					
				КонецЕсли;
				
				
			КонецЦикла;
			
		КонецЦикла;
		
		Если ДобавленныеНоменклатуры.Количество() = 0 Тогда
			Прервать;
		КонецЕсли;
		
		//повторяем цикл для добавленных строк
		МассивИсточников = ДобавленныеНоменклатуры;
		ДобавленныеНоменклатуры = Новый Массив;
		
	КонецЦикла;
	
КонецПроцедуры