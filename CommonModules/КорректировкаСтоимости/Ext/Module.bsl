		|		ВЫБОР КОГДА СуммовойУчетДт.Субконто2 ТОГДА ХозрасчетныйОбороты.СубконтоДт2 ИНАЧЕ Неопределено КОНЕЦ,
		|		ВЫБОР КОГДА СуммовойУчетДт.Субконто3 ТОГДА ХозрасчетныйОбороты.СубконтоДт3 ИНАЧЕ Неопределено КОНЕЦ,
		|		ВЫБОР КОГДА СуммовойУчетДт.Субконто4 ТОГДА ХозрасчетныйОбороты.СубконтоДт4 ИНАЧЕ Неопределено КОНЕЦ) КАК ВложенныйЗапрос
		|
		|ГДЕ
		|	(ВложенныйЗапрос.СчетДт <> ВложенныйЗапрос.СчетКт ИЛИ ВложенныйЗапрос.СубконтоКт1 <> ВложенныйЗапрос.СубконтоДт1 ИЛИ ВложенныйЗапрос.СубконтоКт2 <> ВложенныйЗапрос.СубконтоДт2 ИЛИ ВложенныйЗапрос.СубконтоКт3 <> ВложенныйЗапрос.СубконтоДт3 ИЛИ ВложенныйЗапрос.СубконтоКт4 <> ВложенныйЗапрос.СубконтоДт4 ИЛИ ВложенныйЗапрос.НалоговоеНазначениеДт <> ВложенныйЗапрос.НалоговоеНазначениеКт)" +
		?(ТаблицаТоваров <> Неопределено, "
		|	И (ВложенныйЗапрос.НоменклатураКт В (&СписокТоваров))", "") + 
		?(НЕ СтруктураДопПараметров.ОбрабатыватьКомплектацииКакПеремещения, "
		|	И (ВложенныйЗапрос.НоменклатураКт = ВложенныйЗапрос.НоменклатураДт)", "");
	
	Запрос.УстановитьПараметр("ДатаНач", ДатаНач);
	Запрос.УстановитьПараметр("ДатаКон", ДатаКон);
	Запрос.УстановитьПараметр("Организация", СтруктураДопПараметров.Организация);
	Запрос.УстановитьПараметр("СписокСчетов", СтруктураДопПараметров.СписокСчетов);
	Запрос.УстановитьПараметр("СписокТоваров", ТаблицаТоваров);
		
	Таб = Запрос.Выполнить().Выгрузить();
	
	Возврат Таб;
	
КонецФункции // ПолучитьТаблицуПеремещенийБух()

// Добавляет данные о начальном остатке и внешнем поступлении в состояниях
