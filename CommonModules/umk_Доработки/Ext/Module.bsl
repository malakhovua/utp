// Установим последовательно время документа
Процедура umk_УстановитьВремяДокументаПередЗаписью(Источник, Отказ, РежимЗаписи, РежимПроведения) Экспорт
	
	Если Источник.РучнУстановкаВремени Тогда
		Возврат
	КонецЕсли;
	
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		
		Если РежимПроведения = РежимПроведенияДокумента.Оперативный Тогда
			РежимПроведения = РежимПроведенияДокумента.Неоперативный
		КонецЕсли;
		
		
		Если ТипЗнч(Источник) = Тип("ДокументОбъект.ОтчетПроизводстваЗаСмену") Тогда
			Источник.Дата = НачалоДня(Источник.Дата)  // 0
		ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.КомплектацияНоменклатуры") Тогда
			Если Источник.ВидОперации = Перечисления.ВидыОперацийКомплектацияНоменклатуры.Разукомплектация Тогда 
				//Источник.Дата = НачалоДня(Источник.Дата) + 51060 //14:11
			Иначе
				Источник.Дата = НачалоДня(Источник.Дата) + 3 //0:03 //комплектация 
			КонецЕсли;
		ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
			Если Источник.umk_ОснованиеПеремещение.umk_ДатаПеремещения Тогда
				Возврат;
			КонецЕсли;
			Источник.Дата = НачалоДня(Источник.Дата) + 50400 // 14:00
		ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.ВозвратТоваровОтПокупателя") Тогда
			Если Источник.Дата < '20230901000000' Тогда
				Источник.Дата = НачалоДня(Источник.Дата) // 00:00
			Иначе
				Источник.Дата = НачалоДня(Источник.Дата) + 51000 // 14:10
			КонецЕсли;
		ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.ПеремещениеТоваров") Тогда
			Если ЗначениеЗаполнено(Источник.umk_Основание) Тогда
				Источник.Дата = НачалоДня(Источник.Дата) + 1 // 00:01 - Если перемещение по возврату	
			Иначе
				Источник.Дата = НачалоДня(Источник.Дата) + 39600 // 11
			КонецЕсли;
		ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.СписаниеТоваров") Тогда
			Если Источник.Дата < '20230901000000' Тогда
				Источник.Дата = НачалоДня(Источник.Дата) + 43200//12:00
			Иначе
				Источник.Дата = НачалоДня(Источник.Дата) + 51300 //14:25	
			КонецЕсли;
		ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.ПоступлениеТоваровУслуг") Тогда
			Источник.Дата = НачалоДня(Источник.Дата) + 1 // 0:01
		ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.ЗаказПокупателя") Тогда
			Источник.Дата = НачалоДня(Источник.Дата)//00
		ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.ПлатежноеПоручениеВходящее") Тогда
			Источник.Дата = НачалоДня(Источник.Дата) + 50401 // 14:01
		ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.ПлатежноеПоручениеИсходящее") Тогда
			Источник.Дата = НачалоДня(Источник.Дата) + 50401 // 14:01
		ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.ПутевойЛист") Тогда
			Источник.Дата = НачалоДня(Источник.Дата) + 50401 // 14:01
		КонецЕсли;
		


	КонецЕсли;

КонецПроцедуры
// Записать данные о документе поступления 
Процедура umk_ЗаписатьДопРеквизитыПоПоступлениюПриЗаписи(Источник, Отказ) Экспорт
	
	Для Каждого СтрокаТовары Из Источник.Товары Цикл
		
		Если ЗначениеЗаполнено(СтрокаТовары.Номенклатура)
			И (
			ЗначениеЗаполнено(СтрокаТовары.ВидДокументаУК) ИЛИ
			ЗначениеЗаполнено(СтрокаТовары.НомерУК) ИЛИ
			ЗначениеЗаполнено(СтрокаТовары.ДатаУК) ИЛИ
			ЗначениеЗаполнено(СтрокаТовары.КонечныйСрок) ИЛИ
			ЗначениеЗаполнено(СтрокаТовары.ВидДокументаУК1) ИЛИ
			ЗначениеЗаполнено(СтрокаТовары.НомерУК1) ИЛИ
			ЗначениеЗаполнено(СтрокаТовары.ДатаУК1) ИЛИ
			ЗначениеЗаполнено(СтрокаТовары.КонечныйСрок1) ИЛИ
			ЗначениеЗаполнено(СтрокаТовары.ВидДокументаУК2) ИЛИ
			ЗначениеЗаполнено(СтрокаТовары.НомерУК2) ИЛИ
			ЗначениеЗаполнено(СтрокаТовары.ДатаУК2) ИЛИ
			ЗначениеЗаполнено(СтрокаТовары.КонечныйСрок2) ИЛИ
			ЗначениеЗаполнено(СтрокаТовары.ПримСтр) ИЛИ
			ЗначениеЗаполнено(СтрокаТовары.ПримСтр1) ИЛИ
			ЗначениеЗаполнено(СтрокаТовары.ПримСтр2))
			Тогда
			
			СоздатьЗаписьВРегистре(Источник,СтрокаТовары,СтрокаТовары.Номенклатура, НачалоДня(Источник.Дата));
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры
//Добавим запись в регистр
Процедура СоздатьЗаписьВРегистре(Источник, СтрокаТовары, Номенклатура, Период)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	umk_ДопРеквизитыНоменклатурыСрезПоследних.Номенклатура,
		|	umk_ДопРеквизитыНоменклатурыСрезПоследних.БлокироватьВыписку,
		|	umk_ДопРеквизитыНоменклатурыСрезПоследних.БлокироватьПроизводство,
		|	umk_ДопРеквизитыНоменклатурыСрезПоследних.Выход,
		|	umk_ДопРеквизитыНоменклатурыСрезПоследних.ЕстьКодС
		|ИЗ
		|	РегистрСведений.umk_ДопРеквизитыНоменклатуры.СрезПоследних(&Период, Номенклатура = &Номенклатура) КАК umk_ДопРеквизитыНоменклатурыСрезПоследних";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Период", Период);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Запись = РегистрыСведений.umk_ДопРеквизитыНоменклатуры.СоздатьМенеджерЗаписи();
	
	Если Выборка.Следующий() Тогда
		
	    ЗаполнитьЗначенияСвойств(Запись, Выборка);
		ЗаполнитьЗначенияСвойств(Запись, СтрокаТовары);
		
	Иначе
		ЗаполнитьЗначенияСвойств(Запись, СтрокаТовары);
	КонецЕсли;
	Запись.ДокументПоступления = Источник.Ссылка; 
	Запись.Период = Период;
	Запись.Записать(Истина);
	 
КонецПроцедуры

#Область ФормированиеДокументовСписаниеРазукомплектация

//Перед записью возврата покупателя проверяем наличее непроведенных зависимых документов
Процедура ВозвратТовараПроведениеНепроведенныхДокументовПередЗаписью(Источник, Отказ, РежимЗаписи, РежимПроведения) Экспорт
	
	Если Не Источник.Ссылка.Проведен И РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДокументыВозвратТоваров.ВозвратТовара,
		|	ДокументыВозвратТоваров.ЗависимыйДокумент
		|ИЗ
		|	РегистрСведений.ДокументыВозвратТоваров КАК ДокументыВозвратТоваров
		|ГДЕ
		|	ДокументыВозвратТоваров.ВозвратТовара = &ВозвратТовара
		|	И ДокументыВозвратТоваров.ЗависимыйДокумент.Проведен = ЛОЖЬ
		|	И ДокументыВозвратТоваров.ЗависимыйДокумент.ПометкаУдаления = ЛОЖЬ";
		
		Запрос.УстановитьПараметр("ВозвратТовара", Источник.Ссылка);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			Попытка
				Документ = Выборка.ЗависимыйДокумент.ПолучитьОбъект();
				Документ.Записать(РежимЗаписиДокумента.Проведение);
			Исключение
				Отказ = Истина;
			КонецПопытки;
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

//Проведение
//
Процедура ВозвратТовараСоздатьСписаниеКомплектациюОбработкаПроведения(Источник, Отказ, РежимПроведения) Экспорт
	
	НовыйМеханизмУчетаВозвратаДата =  Константы.НовыйМеханизмУчетаВозврата.Получить();
	ПрименятьНовыйМеханизмУчетаВозврата = ЗначениеЗаполнено(НовыйМеханизмУчетаВозвратаДата) 
	И Источник.Дата >= НовыйМеханизмУчетаВозвратаДата;
	
	Если Источник.НеСоздаватьДокументыСписания Тогда
		Возврат
	КонецЕсли; 

	ПрименятьМеханизм = Константы.ФормироватьДокументыВозврата.Получить();
	
	Если Не ЗначениеЗаполнено(ПрименятьМеханизм) Тогда
		Возврат
	КонецЕсли;
	
	Если Источник.Дата < ПрименятьМеханизм Тогда
		Возврат
	КонецЕсли;
	
	
	ОбновляемДокументы = Ложь;
	МассивДокументов = Новый Массив;
	Подразделение = Справочники.Подразделения.НайтиПоКоду("000000001");
	СтатьяЗатрат = Справочники.СтатьиЗатрат.НайтиПоКоду("100000081");
	
	// Товары для перемещения. Срок годности не истек.
	ТаблицаДляСписания = Новый ТаблицаЗначений;
	ТаблицаДляСписания.Колонки.Добавить("Номенклатура");
	ТаблицаДляСписания.Колонки.Добавить("Количество");
	ТаблицаДляСписания.Колонки.Добавить("ЕдиницаИзмерения");
	ТаблицаДляСписания.Колонки.Добавить("ЕдиницаИзмеренияМест");
	ТаблицаДляСписания.Колонки.Добавить("Коэффициент");
	ТаблицаДляСписания.Колонки.Добавить("Цена");
	ТаблицаДляСписания.Колонки.Добавить("СерияНоменклатуры");
	ТаблицаДляСписания.Колонки.Добавить("ХарактеристикаНоменклатуры");
	ТаблицаДляСписания.Колонки.Добавить("СчетУчетаБУ");
	ТаблицаДляСписания.Колонки.Добавить("Качество");
	ТаблицаДляСписания.Колонки.Добавить("НалоговоеНазначение");
	ТаблицаДляСписания.Колонки.Добавить("НоменклатурнаяПозиция");
	
	ТаблицаРазукомплектаций = ТаблицаДляСписания.Скопировать();
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ *
	|ИЗ
	|	Документ.ВозвратТоваровОтПокупателя.Товары КАК Товары
	|ГДЕ
	|	Товары.Ссылка = &ОбъектСсылка");
	
	Запрос.УстановитьПараметр("ОбъектСсылка", Источник.ссылка);
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл 
		
		Если ПодлежитРазукомплектации(Источник.Ссылка, Выборка)
			Тогда
			НоваяСтрокаРазукомплектация = ТаблицаРазукомплектаций.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаРазукомплектация, Выборка);
		Иначе
			НоваяСтрокаСписание  = ТаблицаДляСписания.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаСписание, Выборка);
		КонецЕсли;
		
	КонецЦикла;
	
	//Свернем таблицы
	ТаблицаДляСписания.Свернуть("Номенклатура,ЕдиницаИзмерения,ЕдиницаИзмеренияМест,Коэффициент,
	|Цена,СерияНоменклатуры,ХарактеристикаНоменклатуры,СчетУчетаБУ,Качество,НалоговоеНазначение,НоменклатурнаяПозиция","Количество");
	
	ТаблицаРазукомплектаций.Свернуть("Номенклатура,ЕдиницаИзмерения,ЕдиницаИзмеренияМест,Коэффициент,
	|Цена,СерияНоменклатуры,ХарактеристикаНоменклатуры,СчетУчетаБУ,Качество,НалоговоеНазначение,НоменклатурнаяПозиция","Количество");
	
	//Проверяем наличие таблиц
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВозвратТоваровТаблицы.ТаблицаСписания,
	|	ВозвратТоваровТаблицы.ТаблицаКомплектов
	|ИЗ
	|	РегистрСведений.ВозвратТоваровТаблицы КАК ВозвратТоваровТаблицы
	|ГДЕ
	|	ВозвратТоваровТаблицы.ВозвратТовара = &ВозвратТовара";
	
	Запрос.УстановитьПараметр("ВозвратТовара",  Источник.ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		//Сравниваем таблицы
		ТаблицаСписанияКэш = Выборка.ТаблицаСписания.Получить(); 
		ТаблицаКомплектовКэш = Выборка.ТаблицаКомплектов.Получить(); 
		
		Если НастройкаПравДоступа.СравнитьТаблицыНаборовЗаписей(ТаблицаДляСписания, ТаблицаСписанияКэш) И 
			НастройкаПравДоступа.СравнитьТаблицыНаборовЗаписей(ТаблицаРазукомплектаций, ТаблицаКомплектовКэш) Тогда
			КорректирвкаДат(Источник, Отказ,ПрименятьНовыйМеханизмУчетаВозврата);
			Возврат
		Иначе
			ОбновляемДокументы = Истина;	 	
		КонецЕсли; 
	КонецЕсли;
	
	Если ОбновляемДокументы Тогда
		//Удалим все зависимые документы.
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДокументыВозвратТоваров.ЗависимыйДокумент КАК Ссылка
		|ИЗ
		|	РегистрСведений.ДокументыВозвратТоваров КАК ДокументыВозвратТоваров
		|ГДЕ
		|	ДокументыВозвратТоваров.ВозвратТовара = &ВозвратТовара
		|	И ДокументыВозвратТоваров.ЗависимыйДокумент.ПометкаУдаления = ЛОЖЬ";
		
		Запрос.УстановитьПараметр("ВозвратТовара",  Источник.ссылка);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			Документ = Выборка.Ссылка.ПолучитьОбъект();
			Если Документ.Проведен Тогда
				Режим = РежимЗаписиДокумента.ОтменаПроведения;
			Иначе
				Режим = РежимЗаписиДокумента.Запись;
			КонецЕсли;
			Документ.ПометкаУдаления = Истина;
			Попытка
				Документ.Записать(Режим);
			Исключение
				Сообщить(ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;
		
	КонецЕсли; //удаляем документы
	
	//Обновляем таблицы в регистре
	Запись = РегистрыСведений.ВозвратТоваровТаблицы.СоздатьМенеджерЗаписи();
	Запись.ВозвратТовара = Источник.Ссылка;
	Запись.ТаблицаКомплектов = Новый ХранилищеЗначения(ТаблицаРазукомплектаций);
	Запись.ТаблицаСписания =   Новый ХранилищеЗначения(ТаблицаДляСписания);
	Запись.Записать(Истина);
	
	// Создаем документы
	
	Для Каждого СтрокаТЧ Из ТаблицаРазукомплектаций Цикл 
		
		Комплектация = Документы.КомплектацияНоменклатуры.СоздатьДокумент();
		// Заполнить реквизиты значениями по умолчанию.
		ЗаполнениеДокументов.ЗаполнитьШапкуДокумента(Комплектация, глЗначениеПеременной("глТекущийПользователь"),,,,);
		ОбщегоНазначения.ЗаполнитьОбязательныеРеквизитыШапкиНовогоДокумента(Комплектация, глЗначениеПеременной("глТекущийПользователь"));
		
		Комплектация.ВидОперации = Перечисления.ВидыОперацийКомплектацияНоменклатуры.Разукомплектация;
		ЗаполнитьЗначенияСвойств(Комплектация,СтрокаТЧ);
		Комплектация.Склад = Источник.СкладОрдер;
		
		Если ПрименятьНовыйМеханизмУчетаВозврата Тогда //разукомплектовуем со склада возврат на склад ГП
			Комплектация.Склад = Источник.СкладОрдер;
			Комплектация.СкладМатериалов = Константы.umk_СкладПродукции.Получить();
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Комплектация.Подразделение)  Тогда
		  Комплектация.Подразделение = Подразделение;
		КонецЕсли; 
		
		Комплектация.Дата =  ?(ПрименятьНовыйМеханизмУчетаВозврата,
		НачалоДня(Источник.Дата) + 86460, //Следующим днем в 00-01-00
		НачалоДня(Источник.Дата) + 39601);
		
		НоваяСтрока = Комплектация.Комплектующие.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаТЧ,,"ХарактеристикаНоменклатуры");
		НоваяСтрока.ДоляСтоимости = 1;
		Комплектация.ЗаполнитьСчетаУчетаВСтрокеТабЧасти(НоваяСтрока, "КомплектацияНоменклатуры" , Истина, Истина);
		Комплектация.НалоговоеНазначение = Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_Облагаемая;
		Комплектация.Комментарий = "##СозданАвтоматически##";
		Попытка 
			Комплектация.Записать(РежимЗаписиДокумента.Проведение)
		Исключение
			Сообщить(ОписаниеОшибки());
			Комплектация.Записать(РежимЗаписиДокумента.Запись)
		КонецПопытки;
		
		МассивДокументов.Добавить(Комплектация.Ссылка);
		
	КонецЦикла;
	
	//Списание
	Если Не ТаблицаДляСписания.Количество() = 0 Тогда
		
		Списание = Документы.СписаниеТоваров.СоздатьДокумент();
		// Заполнить реквизиты значениями по умолчанию.
		ЗаполнениеДокументов.ЗаполнитьШапкуДокумента(Списание, глЗначениеПеременной("глТекущийПользователь"),,,,);
		ОбщегоНазначения.ЗаполнитьОбязательныеРеквизитыШапкиНовогоДокумента(Списание, глЗначениеПеременной("глТекущийПользователь"));
		Списание.Комментарий = "##СозданАвтоматически##";
		Списание.Склад = Источник.СкладОрдер;
		Списание.Дата  = Источник.Дата;
		Списание.СчетДт = ПланыСчетов.Хозрасчетный.ОбщепроизводственныеРасходы;
		Списание.СубконтоДт1 = Константы.umk_ОсновноеПодразделениеОрганизации.Получить();
		Списание.СубконтоДт2 = СтатьяЗатрат;
		Списание.umk_Основание = Источник.Ссылка;
		Списание.мУчетнаяПолитикаНУ = ОбщегоНазначения.ПолучитьПараметрыУчетнойПолитики(Списание.Дата, Ложь, Списание.Организация, "Нал");
		ЗаплолнитьТЧТовары(Списание.Товары, ТаблицаДляСписания);
		Попытка 
			Списание.Записать(РежимЗаписиДокумента.Проведение)
		Исключение
			Сообщить(ОписаниеОшибки());
			Списание.Записать(РежимЗаписиДокумента.Запись)
		КонецПопытки;
		
		МассивДокументов.Добавить(Списание.Ссылка);
		
	КонецЕсли;
		
		Для каждого Документ  Из МассивДокументов  Цикл
			Запись = РегистрыСведений.ДокументыВозвратТоваров.СоздатьМенеджерЗаписи();
			Запись.ВозвратТовара = Источник.Ссылка;
			Запись.ЗависимыйДокумент = Документ;
			Запись.Записать(Истина);
		КонецЦикла;
		
		
	КорректирвкаДат(Источник, Отказ,ПрименятьНовыйМеханизмУчетаВозврата);
		
КонецПроцедуры

Процедура КорректирвкаДат(Источник, Отказ, ПрименятьНовыйМеханизмУчетаВозврата)
	
	//Проверим соответствие дат документов
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДокументыВозвратТоваров.ВозвратТовара,
	|	ДокументыВозвратТоваров.ЗависимыйДокумент
	|ИЗ
	|	РегистрСведений.ДокументыВозвратТоваров КАК ДокументыВозвратТоваров
	|ГДЕ
	|	ДокументыВозвратТоваров.ВозвратТовара = &ВозвратТовара";
	
	Запрос.УстановитьПараметр("ВозвратТовара", Источник.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Если Не НачалоДня(Выборка.ВозвратТовара.Дата) = 
			?(ПрименятьНовыйМеханизмУчетаВозврата, НачалоДня(Выборка.ЗависимыйДокумент.Дата-60*60*24)
			,НачалоДня(Выборка.ЗависимыйДокумент.Дата)) Тогда
			РежимЗаписи = ?(Выборка.ЗависимыйДокумент.Проведен, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись);
			Попытка
				Документ = Выборка.ЗависимыйДокумент.ПолучитьОбъект();
				Документ.Дата = ?(ПрименятьНовыйМеханизмУчетаВозврата,
				НачалоДня(Выборка.ВозвратТовара.Дата) + 86460, //Следующим днем в 00-01-00
				Выборка.ВозвратТовара.Дата);
				Документ.Записать(РежимЗаписи);
			Исключение
				Отказ = Истина;
			КонецПопытки;
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры


//Отмена проведения
//
Процедура ВозвратТовараОтменаПроведенияСписаниеКомплектациюОбработкаУдаленияПроведения(Источник, Отказ) Экспорт
	
	Если Источник.НеСоздаватьДокументыСписания Тогда
		Возврат
	КонецЕсли; 

	ПрименятьМеханизм = Константы.ФормироватьДокументыВозврата.Получить();
	
	Если Не ЗначениеЗаполнено(ПрименятьМеханизм) Тогда
		Возврат
	КонецЕсли;
	
	Если Источник.Дата < ПрименятьМеханизм Тогда
		Возврат
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДокументыВозвратТоваров.ЗависимыйДокумент КАК Ссылка
	|ИЗ
	|	РегистрСведений.ДокументыВозвратТоваров КАК ДокументыВозвратТоваров
	|ГДЕ
	|	ДокументыВозвратТоваров.ВозвратТовара = &ВозвратТовара
	|	И ДокументыВозвратТоваров.ЗависимыйДокумент.Проведен = ИСТИНА";
	
	Запрос.УстановитьПараметр("ВозвратТовара",  Источник.ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Документ = Выборка.Ссылка.ПолучитьОбъект();
		Документ.ПометкаУдаления = Источник.ПометкаУдаления;
		Попытка
			Документ.Записать(РежимЗаписиДокумента.ОтменаПроведения);
		Исключение
			Сообщить(ОписаниеОшибки());
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаплолнитьТЧТовары(Товары, ТаблицаИсточник)
	
	Для Каждого СтрокаТЧ Из ТаблицаИсточник Цикл
		НоваяСтрока = Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
		СтрокаТЧ.НалоговоеНазначение = Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_Облагаемая;
	КонецЦикла;
	
КонецПроцедуры

функция ПодлежитРазукомплектации(Объект,Выборка)
	
	НовыйМеханизмУчетаВозвратаДата = Константы.НовыйМеханизмУчетаВозврата.Получить();
	
	Если ЗначениеЗаполнено(Выборка.ДокументПартии) Тогда
		
		//Если применяем новый мехнизм, то разукомплектовуем всю продукцию
		Если ЗначениеЗаполнено(НовыйМеханизмУчетаВозвратаДата) И  Объект.Дата >= НовыйМеханизмУчетаВозвратаДата Тогда
			Возврат Истина
		КонецЕсли;
		
		Если (КонецДня(Объект.Дата) - НачалоДня(Выборка.ДокументПартии.Дата)) / 86400 <= Выборка.Номенклатура.umk_СрокГодности
			Тогда
			Возврат Истина
		Иначе
			Возврат Ложь
		КонецЕсли;
		
	Иначе
		Сообщить("В строке: " + (Выборка.НомерСтроки) + " для товара " + Строка(Выборка.Номенклатура) + " на заполнен документ партии.");
		Возврат Ложь
	КонецЕсли
	
КонецФункции

