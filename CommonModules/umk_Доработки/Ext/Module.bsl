	Иначе
		Возврат ""	
	КонецЕсли;
	
КонецФункции

//Возвращает данные из РС по номенклатуре МЕДОК
Функция ПолучитьНоменклатуруМЕДОК(СтруктураСтроки) Экспорт
	
	СтруктураРеквизитов = Новый Структура();
	
	Если Не СтруктураСтроки.Свойство("ТипДокумента") Тогда
		 ТипДокумента = Перечисления.ТипДокументаМедок.НН
	 Иначе
		 ТипДокумента = СтруктураСтроки.ТипДокумента;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НаименованиеТоваровМЕДОК.НаименованиеТовара,
		|	НаименованиеТоваровМЕДОК.Цена,
		|	НаименованиеТоваровМЕДОК.КодУКТЗЕД
		|ИЗ
		|	РегистрСведений.umk_НаименованиеТоваровМЕДОК КАК НаименованиеТоваровМЕДОК
		|ГДЕ
		|	НаименованиеТоваровМЕДОК.НомерДок = &НомерДок
		|	И НаименованиеТоваровМЕДОК.ДатаДок = &ДатаДок
		|	И НаименованиеТоваровМЕДОК.НомерСтрокиНН = &НомерСтрокиНН";
	
	Запрос.УстановитьПараметр("ДатаДок", СтруктураСтроки.Дата);
	Запрос.УстановитьПараметр("НомерДок", СтруктураСтроки.Номер);
	Запрос.УстановитьПараметр("НомерСтрокиНН", СтруктураСтроки.НомерСтрокиНН);
	//Запрос.УстановитьПараметр("ТипДокумента", ТипДокумента);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
		СтруктураРеквизитов.Вставить(Колонка.Имя, "");
	КонецЦикла;
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(СтруктураРеквизитов,Выборка);
	КонецЕсли;
	
	Возврат СтруктураРеквизитов
	
КонецФункции

#КонецОбласти

#Область ДинамическиеСписки

Функция УдалитьОтбор(СписокОтборов, ИмяПоля = "") Экспорт
	Если ПустаяСтрока(ИмяПоля) Тогда
		СписокОтборов.Элементы.Очистить();
		Возврат Истина;
	КонецЕсли;
	Поле = Новый ПолеКомпоновкиДанных(ИмяПоля);
	ОтборУдален = Ложь;
	Для каждого ЭлементОтбора Из СписокОтборов.Элементы Цикл
		Если ЭлементОтбора.Использование И ЭлементОтбора.ЛевоеЗначение = Поле Тогда
			СписокОтборов.Элементы.Удалить(ЭлементОтбора);
			ОтборУдален = Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат ОтборУдален;
КонецФункции
	
#КонецОбласти

#Область РегламентныхЗаданий

Процедура ПровестиОтложенныеДокументыРТиУ() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РеализацияТоваровУслуг.Ссылка
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|ГДЕ
		|	РеализацияТоваровУслуг.umk_ОтложенноеПроведение = ИСТИНА
		|	И РеализацияТоваровУслуг.ПометкаУдаления = ЛОЖЬ";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Попытка
			ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();
			ДокументОбъект.umk_ОтложенноеПроведение = Ложь;
			ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
		КонецПопытки;	
	КонецЦикла;
	
КонецПроцедуры // ПровестиОтложенныеДокументыРТиУ()

#КонецОбласти
