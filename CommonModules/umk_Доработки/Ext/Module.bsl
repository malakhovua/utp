// Возвращает копию набора записей регистра расчета в виде
//Таблицы значений
Функция НаборЗаписейКопия(НаборЗаписейРегистра) Экспорт
	
	НаборЗаписейРегистраКопия = Новый ТаблицаЗначений;
	НаборЗаписейРегистраКопия.Колонки.Добавить("Сотрудник");
	НаборЗаписейРегистраКопия.Колонки.Добавить("ВидРасчета");
	НаборЗаписейРегистраКопия.Колонки.Добавить("Результат");
	НаборЗаписейРегистраКопия.Колонки.Добавить("РезультатУпр");
	
	Для Каждого Запись Из НаборЗаписейРегистра Цикл
		НоваяЗапись = НаборЗаписейРегистраКопия.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяЗапись, Запись);
	КонецЦикла;
	
	НаборЗаписейРегистраКопия.Свернуть("Сотрудник,ВидРасчета", "Результат,РезультатУпр"); 
	
	Возврат НаборЗаписейРегистраКопия
	
КонецФункции

