// Возвращает штрихкод для строки документа
Функция ВывестиШтрихкод(ТекущаяСтрока, ТипШтрихкода) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Штрихкоды.Штрихкод
		|ИЗ
		|	РегистрСведений.Штрихкоды КАК Штрихкоды
		|ГДЕ
		|	Штрихкоды.Владелец = &Владелец
		|	И Штрихкоды.ТипШтрихкода = &ТипШтрихкода
		|	И Штрихкоды.ХарактеристикаНоменклатуры = &ХарактеристикаНоменклатуры";
	
	Запрос.УстановитьПараметр("Владелец", ТекущаяСтрока.Номенклатура);
	Запрос.УстановитьПараметр("ТипШтрихкода", ТипШтрихкода);
	Запрос.УстановитьПараметр("ХарактеристикаНоменклатуры", ТекущаяСтрока.ХарактеристикаНоменклатуры);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка.Штрихкод
	
КонецФункции

Процедура СоздатьЗаписьСрокГодности(ТекущаяСтрока, ПараметрыСрокаГодности) Экспорт
	
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если Не ЗначениеЗаполнено(ТекущаяСтрока.Номенклатура) Тогда
		Возврат;
	КонецЕсли;
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	umk_СрокиГодности.Номенклатура,
		|	umk_СрокиГодности.Характеристика,
		|	umk_СрокиГодности.СрокГодности,
		|	umk_СрокиГодности.ВидСрокаГодности
		|ИЗ
		|	РегистрСведений.umk_СрокиГодности КАК umk_СрокиГодности
		|ГДЕ
		|	umk_СрокиГодности.Номенклатура = &Номенклатура
		|	И umk_СрокиГодности.Характеристика = &Характеристика
		|	И umk_СрокиГодности.СрокГодности = &СрокГодности
		|	И umk_СрокиГодности.ВидСрокаГодности = &ВидСрокаГодности";
	
	Запрос.УстановитьПараметр("ВидСрокаГодности", Перечисления.umk_ВидыСроковГодности[ПараметрыСрокаГодности["ВидСрокаГодности"]]);
	Запрос.УстановитьПараметр("Номенклатура", ТекущаяСтрока.Номенклатура);
	Запрос.УстановитьПараметр("СрокГодности",  ПараметрыСрокаГодности["СрокГодности"]);
	Запрос.УстановитьПараметр("Характеристика", ТекущаяСтрока.ХарактеристикаНоменклатуры);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат  // Есть запись с такими значениями, не создаем
	КонецЕсли;
	
	ТекЗапись = РегистрыСведений.umk_СрокиГодности.СоздатьМенеджерЗаписи();
	
	ТекЗапись.Номенклатура        = ТекущаяСтрока.Номенклатура;
	ТекЗапись.Характеристика = ТекущаяСтрока.ХарактеристикаНоменклатуры;
	ТекЗапись.СрокГодности     = ПараметрыСрокаГодности["СрокГодности"];
	ТекЗапись.ВидСрокаГодности = Перечисления.umk_ВидыСроковГодности[ПараметрыСрокаГодности["ВидСрокаГодности"]];
	
	//Попытка //Пусть лучше вылетит ошибка. 
		ТекЗапись.Записать(Истина);
	//Исключение
	//КонецПопытки;
		
КонецПроцедуры

//Прелбразует строку 77 в дату
Функция ПреобразоватьДату77(СтрокаДата) Экспорт
	//01.01.2020
	Если СтрДлина(СтрокаДата) = 10 Тогда
		Возврат Дата(Прав(СтрокаДата,4),Сред(СтрокаДата,4,2),Лев(СтрокаДата,2))
	ИначеЕсли СтрДлина(СтрокаДата) = 8 Тогда  // 01.01.20
		Возврат Дата("20" + Прав(СтрокаДата,2),Сред(СтрокаДата,4,2),Лев(СтрокаДата,2))
	Иначе
		Возврат '00010101000000' 
	КонецЕсли;
	
КонецФункции

Функция ГруппыКонтрагентовПоПодразделению(Подразделение) Экспорт
	
	СтруктураГрупп = Новый Структура();
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КонтрагентыПодразделений.ГруппаКонтрагентов
		|ИЗ
		|	РегистрСведений.КонтрагентыПодразделений КАК КонтрагентыПодразделений
		|ГДЕ
		|	КонтрагентыПодразделений.Подразделение = &Подразделение";
	
	Запрос.УстановитьПараметр("Подразделение", Подразделение);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	ГруппыКонтрагентов = РезультатЗапроса.ВыгрузитьКолонку("ГруппаКонтрагентов");
	
	СтруктураГрупп.Вставить("ГруппыКонтрагентов", ГруппыКонтрагентов);
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Контрагенты.Ссылка
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.ЭтоГруппа = ИСТИНА
		|	И НЕ Контрагенты.Ссылка В (&ГруппыКонтрагентов)";
	
	Запрос.УстановитьПараметр("ГруппыКонтрагентов", ГруппыКонтрагентов);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	 СтруктураГрупп.Вставить("ГруппыИсключений", РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Ссылка"));
	 
	 Возврат СтруктураГрупп
	
КонецФункции

