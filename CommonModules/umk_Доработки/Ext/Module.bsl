Функция ПолучитьВыборкуДокументов(ИмяДокумента, НачалоПериода = Неопределено, ОкончаниеПериода = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НачалоПериода", 		?(НачалоПериода = Неопределено, Неопределено, НачалоДня(НачалоПериода)));
	Запрос.УстановитьПараметр("ОкончаниеПериода", 	?(ОкончаниеПериода = Неопределено, Неопределено, КонецДня(ОкончаниеПериода)));
	Запрос.УстановитьПараметр("Организация",  Константы.umk_ГоловнаяОрганизация.Получить());
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Документ.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.%ИмяДокумента% КАК Документ
	|ГДЕ
	|	Документ.Проведен
	|	И Документ.Организация = &Организация
	|	И ВЫБОР КОГДА &НачалоПериода = НЕОПРЕДЕЛЕНО ИЛИ &ОкончаниеПериода = НЕОПРЕДЕЛЕНО ТОГДА ИСТИНА ИНАЧЕ Документ.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода КОНЕЦ";
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ИмяДокумента%", ИмяДокумента);
	Запрос.Текст = ТекстЗапроса;
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат Выборка; 
	
КонецФункции

