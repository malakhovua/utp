Функция ПолучитьГруппуХарактеристики(КодГруппы,НаименованиеГруппы)
	
	ГруппаСсылка = Справочники.umk_ГруппыХарактеристик.НайтиПоКоду(КодГруппы);
	
	Если ГруппаСсылка.Пустая() Тогда 
		ГруппаХарактеристик = Справочники.umk_ГруппыХарактеристик.СоздатьЭлемент();
		ГруппаХарактеристик.Наименование = НаименованиеГруппы;
		ГруппаХарактеристик.Код = КодГруппы;
		ГруппаХарактеристик.Записать();
		ГруппаСсылка = ГруппаХарактеристик.Ссылка;
	Иначе
		Если Не ГруппаСсылка.Наименование = НаименованиеГруппы Тогда // Обновим наименование
			ГруппаХарактеристик = ГруппаСсылка.ПолучитьОбъект();
			ГруппаХарактеристик.Наименование = НаименованиеГруппы;
			ГруппаХарактеристик.Записать();
			ГруппаСсылка = ГруппаХарактеристик.Ссылка;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ГруппаСсылка
	
КонецФункции

Процедура ЗаписатьХарактеристикуДляпечати(ХарактеристикаНоменклатуры, НаименованиеДляПечатиУпак, Период)  Экспорт
	
	//Исключим Вак и Газ, характерно для ВН 
	Если ХарактеристикаНоменклатуры.Наименование = "Вак" Или
		ХарактеристикаНоменклатуры.Наименование = "Газ" Тогда
		Возврат
	КонецЕсли;
	
	// Проверим наличие существующей
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ХарактеристикаДляПечати.НаименованиеДляПечати
		|ИЗ
		|	РегистрСведений.umk_ХарактеристикаДляПечати.СрезПоследних(&Период, ХарактеристикаНоменклатуры = &Характеристика) КАК ХарактеристикаДляПечати
		|ГДЕ
		|	ХарактеристикаДляПечати.НаименованиеДляПечати = &НаименованиеДляПечати";
	
	Запрос.УстановитьПараметр("НаименованиеДляПечати", НаименованиеДляПечатиУпак);
	Запрос.УстановитьПараметр("Период", Период);
	Запрос.УстановитьПараметр("Характеристика", ХарактеристикаНоменклатуры);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат
	Иначе // Если название не совпали то создаем	
		Запись = РегистрыСведений.umk_ХарактеристикаДляПечати.СоздатьМенеджерЗаписи();
		Запись.Период = Период;
		Запись.ХарактеристикаНоменклатуры = ХарактеристикаНоменклатуры;
		Запись.НаименованиеДляПечати = НаименованиеДляПечатиУпак;
		Запись.Записать(Истина);
	КонецЕсли;
	
КонецПроцедуры

Процедура СоздатьХарактеристику(ТипДок, Период, СтрокаТабличнойЧасти, ВидУпаковки, КодУпаковки, НаименованиеУпак,
	КодГруппыУпаковок,НаименованиеГруппыУпаковок, НаименованиеДляПечатиУпак) Экспорт
	
	Если Не КодУпаковки = ""  И Не КодУпаковки = 0 //26.11.20 замена
		//Если Не ВидУпаковки = "Нет" И Не ВидУпаковки = "" //НаименованиеУпак = "Нет" 
		И ЗначениеЗаполнено(СтрокаТабличнойЧасти.Номенклатура) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ХарактеристикиНоменклатуры.Ссылка КАК Упаковка
		|ИЗ
		|	Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
		|ГДЕ
		|	ХарактеристикиНоменклатуры.umk_КодУпаковки = &КодУпаковки
		|	И НЕ ХарактеристикиНоменклатуры.umk_КодУпаковки = 0
		|	И ХарактеристикиНоменклатуры.Владелец = &Владелец
		|	И ХарактеристикиНоменклатуры.ПометкаУдаления = ЛОЖЬ";
		
		Запрос.УстановитьПараметр("КодУпаковки", КодУпаковки);
		Запрос.УстановитьПараметр("Владелец", СтрокаТабличнойЧасти.Номенклатура);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
		// Упаковка как характеристика
		Если Выборка.Следующий() Тогда
			СтрокаТабличнойЧасти.ХарактеристикаНоменклатуры = Выборка.Упаковка;
			Если НЕ СтрокаТабличнойЧасти.ХарактеристикаНоменклатуры.Наименование = НаименованиеУпак
				Тогда // Обновим наименование характеристики
				Упаковка = Выборка.Упаковка.ПолучитьОбъект();
				Упаковка.Наименование = НаименованиеУпак;
				Упаковка.Записать();
			КонецЕсли;
			
		Иначе
			Упаковка = Справочники.ХарактеристикиНоменклатуры.СоздатьЭлемент();
			Упаковка.Наименование = НаименованиеУпак;
			Упаковка.umk_КодУпаковки = КодУпаковки;
			Упаковка.umk_ГруппаХарактеристики = ПолучитьГруппуХарактеристики(КодГруппыУпаковок,НаименованиеГруппыУпаковок);
			Упаковка.Владелец = СтрокаТабличнойЧасти.Номенклатура; 
			ЗаписатьЗначенияСвойств(Упаковка.Наименование);
			Попытка
				Упаковка.Записать();
			Исключение
				Сообщить(ОписаниеОшибки() + " "  + "Упаковка " + НаименованиеУпак + " не записана.");
			КонецПопытки;
			СтрокаТабличнойЧасти.ХарактеристикаНоменклатуры = Упаковка.Ссылка;
		КонецЕсли;
		
		
		СтрокаТабличнойЧасти.umk_УпаковкаНаПечать = НаименованиеДляПечатиУпак;
		
		// Если Документ Возврат покупателя, то проверим сначала наличие характеристики в самой Расходной накладной
		// Это временно, пока не уйдут старые характеристики. Ключем будет НаименованиеДляПечатиУпак
		Если ТипДок = "ВН" Тогда
			ХарактеристикаРТиУ = НайтиХарактеристикуРТиУ(СтрокаТабличнойЧасти.ДокументПартии,СтрокаТабличнойЧасти.Номенклатура,
			НаименованиеДляПечатиУпак);
			
			Если ЗначениеЗаполнено(ХарактеристикаРТиУ) Тогда											  
				СтрокаТабличнойЧасти.ХарактеристикаНоменклатуры = ХарактеристикаРТиУ; 
			КонецЕсли;
		КонецЕсли;
		
		// Запишем характеристику для печати
		Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.ХарактеристикаНоменклатуры) Тогда
			ЗаписатьХарактеристикуДляпечати(СтрокаТабличнойЧасти.ХарактеристикаНоменклатуры, НаименованиеДляПечатиУпак, Период);
		КонецЕсли;
		
	КонецЕсли;	
	
КонецПроцедуры

//Только для документа Возврат покупателя
//НаименованиеДляПечатиУпак будет ключем связи
Функция НайтиХарактеристикуРТиУ(ДокументПартии, Номенклатура, УпаковкаНаПечать)
	
	ПустаяХарактеристика = Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка();
	
	Если Не ЗначениеЗаполнено(ДокументПартии) Или  Не ТипЗнч(ДокументПартии) = Тип("ДокументСсылка.РеализацияТоваровУслуг")
		Тогда
		Возврат ПустаяХарактеристика
	КонецЕсли;
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РеализацияТоваровУслугТовары.ХарактеристикаНоменклатуры КАК Характеристика
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
		|ГДЕ
		|	РеализацияТоваровУслугТовары.Ссылка = &Ссылка
		|	И РеализацияТоваровУслугТовары.umk_УпаковкаНаПечать = &УпаковкаНаПечать
		|	И РеализацияТоваровУслугТовары.Номенклатура = &Номенклатура";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Ссылка", ДокументПартии);
	Запрос.УстановитьПараметр("УпаковкаНаПечать", УпаковкаНаПечать);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Характеристика
	Иначе
		Возврат ПустаяХарактеристика	
	КонецЕсли;
	 	
	
КонецФункции

Процедура ЗаписатьЗначенияСвойств(НаименованиеУпак)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НаименованиеУпак",НаименованиеУпак);
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ХарактеристикиНоменклатуры.Наименование
		|ИЗ
		|	Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
		|ГДЕ
		|	ХарактеристикиНоменклатуры.Наименование = &НаименованиеУпак";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат   // Если уже есть, то не создаем. 
	Иначе
		Значение = Справочники.ЗначенияСвойствОбъектов.СоздатьЭлемент();
		Значение.Наименование = НаименованиеУпак;
		Значение.Владелец = Константы.umk_СвойствоОбъекта.Получить();
		Значение.Записать();
		
	КонецЕсли;
			
КонецПроцедуры

//Номенклатура по коду синхронизации 7.7
Функция НоменклатураПоКодуСинхронизации(КодСинхронизации, Период = Неопределено) Экспорт
	
	Если Период = Неопределено Тогда
		Период = ТекущаяДата();
	КонецЕсли; 
	
	Номенклатура = Справочники.Номенклатура.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ДопРеквизитыНоменклатуры.Номенклатура
	|ИЗ
	|	РегистрСведений.umk_ДопРеквизитыНоменклатуры КАК ДопРеквизитыНоменклатуры
	|ГДЕ
	|	ДопРеквизитыНоменклатуры.Период <= &Период
	|	И ДопРеквизитыНоменклатуры.КодСинхронизации = &КодСинхронизации
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДопРеквизитыНоменклатуры.Период УБЫВ";
	
	Запрос.УстановитьПараметр("КодСинхронизации", КодСинхронизации);
	Запрос.УстановитьПараметр("Период", Период);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Номенклатура = Выборка.Номенклатура;
	КонецЕсли;
	
	Возврат Номенклатура
	 	

КонецФункции // Поиск номенклатуры по коду синхронизации 7.7()

//Возвращает код синхронизации номенклатуры с производственной базой на дату 
