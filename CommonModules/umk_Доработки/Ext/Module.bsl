Функция ОкруглитьВБольшую(Числ, ПорядокОкругления = 0) Экспорт
	Перем Рез;
    
	Если ПорядокОкругления = 0 Тогда
		Возврат Числ;
	КонецЕсли;
    // округление к верхней границе по заданному порядку 
    // преобразуем порядок округления число
    Порядок            = ПорядокОкругления; 
    // вычислим количество интервалов, входящих в число
    КолвоИнтервал    = Числ / Порядок;   
    // вычислим целое количество интервалов.
    КолвоИнтервалЦел= Цел(КолвоИнтервал);  
    Если КолвоИнтервал = КолвоИнтервалЦел Тогда
        // Числа поделились нацело. Округлять не нужно.
        Рез    = Числ;
    Иначе
        Рез    = Порядок * (КолвоИнтервалЦел + 1);
    КонецЕсли;
         
    Возврат Рез;
	
КонецФункции // глОкруглить()

Процедура ПоказатьДополнительныеРеквизитыНоменклатуры(КолонкиТабПоля, ЯчейкиСтрокиТабПоля, СтруктураДанных, Период = Неопределено) Экспорт

	ЯчейкиСтрокиТабПоля.ЕстьКодС.ОтображатьФлажок = Истина;
	
	Если СтруктураДанных.Номенклатура <> Неопределено Тогда
		СтруктураРеквизитов = ПолучитьДополнительныеРеквизитыНоменклатуры(СтруктураДанных.Номенклатура, Период);
		СтруктураОстатков 	= ПолучитьОстаткиНоменклатуры(СтруктураДанных.Номенклатура, СтруктураДанных.Склад, Период);
		
		СписокДниБлокировки = Новый СписокЗначений;
		СписокДниБлокировки.Добавить("Пн");
		СписокДниБлокировки.Добавить("Вт");
		СписокДниБлокировки.Добавить("Ср");
		СписокДниБлокировки.Добавить("Чт");
		СписокДниБлокировки.Добавить("Пт");
		СписокДниБлокировки.Добавить("Сб");
		СписокДниБлокировки.Добавить("Вс");
		
		СтрокаДниБлокировки = "";
		
		Для н = 1 По СтрДлина(СтруктураРеквизитов.БлокироватьПроизводство) Цикл
			
			Признак = Сред(СтруктураРеквизитов.БлокироватьПроизводство, н, 1);
			
			Если Признак = "1" Тогда
				СтрокаДниБлокировки = СтрокаДниБлокировки + СписокДниБлокировки.Получить(н-1);
			КонецЕсли;
			
		КонецЦикла;	
		
		ЯчейкиСтрокиТабПоля.ЕстьКодС.Флажок = ?(СтруктураРеквизитов.ЕстьКодС = Неопределено, Ложь, СтруктураРеквизитов.ЕстьКодС);
		ЯчейкиСтрокиТабПоля.Выход.УстановитьТекст(СтруктураРеквизитов.Выход);
		ЯчейкиСтрокиТабПоля.ДниБлокировкиВыпуска.УстановитьТекст(СтрокаДниБлокировки);
		ЯчейкиСтрокиТабПоля.Остаток.УстановитьТекст(?(СтруктураОстатков = Неопределено, "", СтруктураОстатков.Количество));
	Иначе
		ЯчейкиСтрокиТабПоля.ЕстьКодС.Флажок = Ложь;
		ЯчейкиСтрокиТабПоля.Выход.УстановитьТекст("");
		ЯчейкиСтрокиТабПоля.ДниБлокировкиВыпуска.УстановитьТекст("");
		ЯчейкиСтрокиТабПоля.Остаток.УстановитьТекст("");
	КонецЕсли;

КонецПроцедуры

Функция ПолучитьДополнительныеРеквизитыНоменклатуры(Номенклатура, Период = Неопределено) Экспорт
	
	СтруктураРеквизитов = Новый Структура;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период", 		?(Период = Неопределено, ТекущаяДата(), Период));
	Запрос.УстановитьПараметр("Номенклатура", 	Номенклатура);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДопРеквизитыНоменклатуры.БлокироватьВыписку 		КАК БлокироватьВыписку,
	|	ДопРеквизитыНоменклатуры.БлокироватьПроизводство 	КАК БлокироватьПроизводство,
	|	ДопРеквизитыНоменклатуры.Выход 						КАК Выход,
	|	ДопРеквизитыНоменклатуры.ВидДокументаУК 			КАК ВидДокументаУК,
	|	ДопРеквизитыНоменклатуры.ВидДокументаУК1 			КАК ВидДокументаУК1,
	|	ДопРеквизитыНоменклатуры.ВидДокументаУК2 			КАК ВидДокументаУК2,
	|	ДопРеквизитыНоменклатуры.ЕстьКодС 					КАК ЕстьКодС,
	|	ДопРеквизитыНоменклатуры.НомерУК 					КАК НомерУК,
	|	ДопРеквизитыНоменклатуры.НомерУК1 					КАК НомерУК1,
	|	ДопРеквизитыНоменклатуры.НомерУК2 					КАК НомерУК2,
	|	ДопРеквизитыНоменклатуры.ДатаУК 					КАК ДатаУК,
	|	ДопРеквизитыНоменклатуры.ДатаУК1 					КАК ДатаУК1,
	|	ДопРеквизитыНоменклатуры.ДатаУК2 					КАК ДатаУК2,
	|	ДопРеквизитыНоменклатуры.КонечныйСрок 				КАК КонечныйСрок,
	|	ДопРеквизитыНоменклатуры.КонечныйСрок1 				КАК КонечныйСрок1,
	|	ДопРеквизитыНоменклатуры.КонечныйСрок2 				КАК КонечныйСрок2,
	|	ДопРеквизитыНоменклатуры.ПримСтр 					КАК ПримСтр,
	|	ДопРеквизитыНоменклатуры.ПримСтр1 					КАК ПримСтр1,
	|	ДопРеквизитыНоменклатуры.ПримСтр2 					КАК ПримСтр2
	|ИЗ
	|	РегистрСведений.umk_ДопРеквизитыНоменклатуры.СрезПоследних(&Период, Номенклатура = &Номенклатура) КАК ДопРеквизитыНоменклатуры
	|";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
		СтруктураРеквизитов.Вставить(Колонка.Имя, Неопределено);
	КонецЦикла;
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат СтруктураРеквизитов;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	ЗаполнитьЗначенияСвойств(СтруктураРеквизитов, Выборка);
	
	Возврат СтруктураРеквизитов;
	
КонецФункции

Функция ПолучитьОстаткиНоменклатуры(Номенклатура, Склад, Период = Неопределено) Экспорт
	
	СтруктураРеквизитов = Новый Структура;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период", 		?(Период = Неопределено, ТекущаяДата(), КонецДня(Период)));
	Запрос.УстановитьПараметр("Номенклатура", 	Номенклатура);
	Запрос.УстановитьПараметр("Склад", 			Склад);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТоварыОрганизацийОстатки.Номенклатура КАК Номенклатура,
	|	ТоварыОрганизацийОстатки.Склад КАК Склад,
	|	ТоварыОрганизацийОстатки.КоличествоОстаток КАК Количество,
	|	ВложенныйЗапрос.КоличествоХарактеристика
	|ИЗ
	|	РегистрНакопления.ТоварыОрганизаций.Остатки(
	|			&Период,
	|			Номенклатура = &Номенклатура
	|				И Склад = &Склад) КАК ТоварыОрганизацийОстатки,
	|	(ВЫБРАТЬ
	|		ЕСТЬNULL(ТоварыОрганизацийОстатки.КоличествоОстаток, 0) КАК КоличествоХарактеристика
	|	ИЗ
	|		РегистрНакопления.ТоварыОрганизаций.Остатки(
	|				&Период,
	|				Номенклатура = &Номенклатура
	|					И Склад = &Склад
	|					И НЕ ХарактеристикаНоменклатуры = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)) КАК ТоварыОрганизацийОстатки) КАК ВложенныйЗапрос";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
		СтруктураРеквизитов.Вставить(Колонка.Имя, Неопределено);
	КонецЦикла;
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	ЗаполнитьЗначенияСвойств(СтруктураРеквизитов, Выборка);
	
	Возврат СтруктураРеквизитов;
	
КонецФункции

