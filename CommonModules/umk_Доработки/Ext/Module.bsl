Функция ПолучитьКонкатенациюРегионов (СсылкаНаОбъект) Экспорт
	
	Направления = "";
	ПерваяСтрока = Истина;
	
	Маршруты = СсылкаНаОбъект.Маршруты;
	
	Для Каждого Строка Из Маршруты Цикл
		
		Направления = Направления + ?(ПерваяСтрока,"",", ") + Строка.Регион;
		ПерваяСтрока = Ложь;
	КонецЦикла;
	
	Возврат Направления;
	
КонецФункции

