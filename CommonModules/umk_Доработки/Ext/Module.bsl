// Выводит на печать подготовленный макет 
//
//  ПечДокумент            - ТабличыйДокумент, макет на печать,
//  КоличествоЭкземпляров  - Число, количество экземпляров на печать,
//  НаПринтер              - Булево, Если истина, то выводим сразу на принтер.
//  Заголовок              - Заголовок окна табличного документа
//  НепосредственнаяПечать - используется только для режи
Процедура НапечататьДокумент(ПечДокумент, КоличествоЭкземпляров = 1, НаПринтер = Ложь, Заголовок = "", Ссылка = Неопределено, ИсточникМакета = Неопределено, Редактировать = Ложь, ОбъектСохраненияФайла = Неопределено) Экспорт

	Если ПечДокумент = Неопределено тогда
		Возврат;
	КонецЕсли;

	// Получить необходимое количество копий
	Если КоличествоЭкземпляров > 0 Тогда
		ПечДокумент.КоличествоЭкземпляров = КоличествоЭкземпляров;
	КонецЕсли;

	Если НЕ ПечДокумент.АвтоМасштаб
	   И НЕ ЗначениеЗаполнено(ПечДокумент.ИмяПринтера) Тогда
		ПечДокумент.АвтоМасштаб = Истина;
	КонецЕсли;

	Если ТипЗнч(НаПринтер) = Тип("Булево") Тогда
		Если НаПринтер Тогда
			ПечДокумент.Вывод = ИспользованиеВывода.Разрешить;
			ПечДокумент.Напечатать();
		Иначе
			ФормаПечати = ПолучитьОбщуюФорму("umk_ПечатьДокументов",, Новый УникальныйИдентификатор);
			ФормаПечати.ОбъектПечати     = Ссылка;
			ФормаПечати.ОбъектСохраненияФайла = ОбъектСохраненияФайла;
			ФормаПечати.ПечатныйДокумент = ПечДокумент;
			ФормаПечати.Заголовок        = Заголовок;
			ФормаПечати.Защита           = УправлениеДопПравамиПользователей.ЗащитаТаблиц();
			ФормаПечати.Редактировать    = Редактировать;
			//ФормаПечати.ИсточникМакета   = ИсточникМакета;
			ФормаПечати.Открыть();
		КонецЕсли;
	ИначеЕсли ТипЗнч(НаПринтер) = Тип("Массив") Тогда
		ПечДокумент.Вывод = ИспользованиеВывода.Разрешить;
		ПечДокумент.Напечатать();

		НаПринтер.Добавить(ПечДокумент);
	КонецЕсли;

КонецПроцедуры // НапечататьДокумент()
// Проверим есть ли по регистратору сохраненный в базу табл. документ
Функция ВыборкаПоОбъектуПечати(ОбъектПечати) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ХранилищеДополнительнойИнформации.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ХранилищеДополнительнойИнформации КАК ХранилищеДополнительнойИнформации
		|ГДЕ
		|	ХранилищеДополнительнойИнформации.Объект = &ОбъектПечати
		|	И ХранилищеДополнительнойИнформации.ПометкаУдаления = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	Ссылка УБЫВ";
	
	Запрос.УстановитьПараметр("ОбъектПечати", ОбъектПечати);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выбрать();
	
	
КонецФункции
// Возвращает родителя вкерхнего уровня
Функция ПолучитьРодителяВерхнегоУровня(ИмяСправочника,СпрСсылка) Экспорт
	
	Если Не СпрСсылка = Неопределено И Не СпрСсылка = Null Тогда
		
		Пока Истина  Цикл
			Если Спрссылка.Родитель =  Справочники[ИмяСправочника].Пустаяссылка()
				Тогда
				Возврат Спрссылка
			Иначе
				Спрссылка = Спрссылка.Родитель;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
КонецФункции
// Устанавливает флаг оригинал в списках документов
Функция ДокументПолучен(ИмяРегистра, Документ, Записать = Ложь) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДокументыРегистра.ДокументПолучен
		|ИЗ РегистрСведений." + ИмяРегистра + " КАК ДокументыРегистра
		|ГДЕ
		|	ДокументыРегистра.Документ = &Документ";
	
	Запрос.УстановитьПараметр("Документ", Документ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Если Записать Тогда
			Менеджер = РегистрыСведений[ИмяРегистра].СоздатьМенеджерЗаписи();
			Менеджер.Документ = Документ;
			Менеджер.ДокументПолучен = Не Выборка.ДокументПолучен;
			Менеджер.Записать(Истина);
			
			Возврат  Менеджер.ДокументПолучен;
		Иначе
			Возврат Выборка.ДокументПолучен
		КонецЕсли;
		
	Иначе
		Если Записать Тогда
			Менеджер = РегистрыСведений[ИмяРегистра].СоздатьМенеджерЗаписи();
			Менеджер.Документ = Документ;
			Менеджер.ДокументПолучен = Истина;
			Менеджер.Записать(Истина);
			
			Возврат  Менеджер.ДокументПолучен;
			
		Иначе
			Возврат Ложь
		КонецЕсли;
		
	КонецЕсли;
		
КонецФункции

// Возвращает среднюю стоимость реализованной продукции в базе 7.7. 
Функция СтоимостьПартииРН_77(ДокументПартии, Номенклатура) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументРеализации",ДокументПартии);
	Запрос.УстановитьПараметр("Номенклатура",Номенклатура);
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА umk_СебестоимостьРеализацииБаза77.Количество = 0
		|			ТОГДА 0
		|		ИНАЧЕ umk_СебестоимостьРеализацииБаза77.СебестоимостьРеализации / umk_СебестоимостьРеализацииБаза77.Количество
		|	КОНЕЦ КАК Стоимость
		|ИЗ
		|	РегистрСведений.umk_СебестоимостьРеализацииБаза77 КАК umk_СебестоимостьРеализацииБаза77
		|ГДЕ
		|	umk_СебестоимостьРеализацииБаза77.ДокументРеализации = &ДокументРеализации
		|	И umk_СебестоимостьРеализацииБаза77.Номенклатура = &Номенклатура";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		
	    Возврат	Выборка.Стоимость 
		
	Иначе
		
		Возврат 0
		
	КонецЕсли;
	
	
КонецФункции

// Вызывает паузу в выполнении кода
Процедура Пауза(Секунды) Экспорт
	 
	ВремяОкончания = ТекущаяДата() + Секунды;
