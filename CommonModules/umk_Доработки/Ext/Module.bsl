	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Номенклатура", 		Номенклатура);
	Запрос.УстановитьПараметр("ВидНоменклатуры", 	Номенклатура.ВидНоменклатуры);
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	СчетаУчетаНоменклатуры.СчетУчетаБУ КАК СчетУчета
	|ИЗ
	|	РегистрСведений.СчетаУчетаНоменклатуры КАК СчетаУчетаНоменклатуры
	|
	|ГДЕ
	|	СчетаУчетаНоменклатуры.Номенклатура = &Номенклатура
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	СчетаУчетаНоменклатуры.СчетУчетаБУ КАК СчетУчета
	|ИЗ
	|	РегистрСведений.СчетаУчетаНоменклатуры КАК СчетаУчетаНоменклатуры
	|
	|ГДЕ
	|	СчетаУчетаНоменклатуры.ВидНоменклатуры = &ВидНоменклатуры
	|";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
