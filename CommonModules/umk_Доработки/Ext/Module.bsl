	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьЦеныНоменклатуры(Номенклатура = Неопределено, Период = Неопределено, ТипЦен = Неопределено) Экспорт
	
	Результат 						= Новый Массив;
	Период 							= ?(Период = Неопределено, ТекущаяДата(), Период);
	//ТипЦен 							= ?(ТипЦен = Неопределено, Справочники.ТипыЦенНоменклатуры.Плановая, ТипЦен);
	ВалютаРегламентированногоУчета 	= Константы.ВалютаРегламентированногоУчета.Получить();
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период",			Период);
	Запрос.УстановитьПараметр("ТипЦен", 		ТипЦен);
	Запрос.УстановитьПараметр("Номенклатура", 	Номенклатура);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЦеныНоменклатуры.Период 		КАК Период,
	|	ЦеныНоменклатуры.Номенклатура 	КАК Номенклатура,
	|	ЦеныНоменклатуры.ТипЦен 		КАК ТипЦен,
	|	ЦеныНоменклатуры.Валюта 		КАК Валюта,
	|	ЦеныНоменклатуры.Цена 			КАК Цена
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|			&Период,
	|			ВЫБОР КОГДА &Номенклатура = НЕОПРЕДЕЛЕНО ТОГДА ИСТИНА ИНАЧЕ Номенклатура = &Номенклатура КОНЕЦ
	|			И ВЫБОР КОГДА &ТипЦен = НЕОПРЕДЕЛЕНО ТОГДА ИСТИНА ИНАЧЕ ТипЦен В (&ТипЦен) КОНЕЦ) КАК ЦеныНоменклатуры
	|";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Результат.Добавить(ПолучитьСтруктуруЦен());
		Возврат Результат;
	КонецЕсли;

	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		СтруктураРезультат = ПолучитьСтруктуруЦен();
		
		ЗаполнитьЗначенияСвойств(СтруктураРезультат, Выборка);
	
    	ПолученнаяЦена 	= Выборка.Цена;

		ПолученнаяЦена 	= Ценообразование.ОкруглитьЦену(ПолученнаяЦена, Выборка.ТипЦен.ПорядокОкругления, Выборка.ТипЦен.ОкруглятьВБольшуюСторону);
		ПолученнаяЦена 	= Ценообразование.ПересчитатьЦенуПриИзмененииВалюты(ПолученнаяЦена, Выборка.Валюта, ВалютаРегламентированногоУчета, 1, 1, Период);
		
		СтруктураРезультат.Цена = ПолученнаяЦена;
		
		Результат.Добавить(СтруктураРезультат);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьСтруктуруЦен()
	
	Возврат Новый Структура("Период, Номенклатура, ТипЦен, Валюта, Цена",
							Дата(1, 1, 1),
							Справочники.Номенклатура.ПустаяСсылка(),
							Справочники.ТипыЦенНоменклатуры.ПустаяСсылка(),
							Справочники.Валюты.ПустаяСсылка(),
							0);
	
КонецФункции
						
Функция ПолучитьТаблицуОстатков(Период, СтрокаСчетов) Экспорт
	
	МассивСчетов = ОбщегоНазначения.РазложитьСтрокуВМассивПодстрок(СтрокаСчетов,",");
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ХозрасчетныйОстатки.Субконто1 КАК Номенклатура,
		|	ХозрасчетныйОстатки.СуммаОстаток,
		|	ХозрасчетныйОстатки.КоличествоОстаток
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.Остатки(&Период, Счет.Код В (&МассивСчетов), , Организация = &Организация) КАК ХозрасчетныйОстатки";
	
	Запрос.УстановитьПараметр("МассивСчетов", МассивСчетов);
	Запрос.УстановитьПараметр("Период", ?(Период = Неопределено, ТекущаяДата(), Новый Граница(КонецДня(Период), ВидГраницы.Включая)));
	Запрос.УстановитьПараметр("Организация",Константы.umk_ГоловнаяОрганизация.Получить()); //Временно 
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Возврат Выборка
						
КонецФункции

