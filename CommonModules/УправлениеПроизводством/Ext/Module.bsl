// Процедура установки значений субконто 
//
Процедура ПриВыбореСчетаЗатратВТабличномПоле(ОтражатьВБухгалтерскомУчете, СтрокаТабличнойЧасти, СтруктураНаименованийРеквизитов, Организация) Экспорт
	
	УстановитьСубконтоПодразделениеОрганизацииВТабЧасти(ОтражатьВБухгалтерскомУчете, СтрокаТабличнойЧасти, СтруктураНаименованийРеквизитов, Организация);
	УстановитьСубконтоСтатьяЗатратВТабЧасти(ОтражатьВБухгалтерскомУчете, СтрокаТабличнойЧасти, СтруктураНаименованийРеквизитов);
	УстановитьСубконтоНоменклатурнаяГруппаВТабЧасти(ОтражатьВБухгалтерскомУчете, СтрокаТабличнойЧасти, СтруктураНаименованийРеквизитов);
	УстановитьСубконтоОбъектСтроительстваВТабЧасти(ОтражатьВБухгалтерскомУчете, СтрокаТабличнойЧасти, СтруктураНаименованийРеквизитов);
	УстановитьСубконтоНалоговоеНазначениеВТабЧасти(ОтражатьВБухгалтерскомУчете, СтрокаТабличнойЧасти, СтруктураНаименованийРеквизитов);
	
КонецПроцедуры // ПриВыбореСчетаЗатратВТабличномПоле

// Процедура заполняет значение счета затрат в табличной части документа в зависимости от статьи затрат.
//
Процедура ЗаполнитьСчетЗатратВСтрокеТабличногоПоля(СтрокаТабличнойЧасти, ПодразделениеОрганизации, СтатьяЗатрат, ИмяСчетаЗатрат = "СчетЗатрат", ЗаполнятьБУ = Истина) Экспорт
	
	Если ЗаполнятьБУ = Истина Тогда
		СчетУчета = УправлениеПроизводством.ПолучитьСчетУчетаСтатьиЗатрат(ПодразделениеОрганизации, СтатьяЗатрат);
		СтрокаТабличнойЧасти[ИмяСчетаЗатрат] = СчетУчета;
	ИначеЕсли ЗаполнятьБУ = Ложь Тогда
		СтрокаТабличнойЧасти[ИмяСчетаЗатрат] = ПланыСчетов.Хозрасчетный.ПустаяСсылка();
	КонецЕсли;
	
КонецПроцедуры // ЗаполнитьСчетЗатратВСтрокеТабличногоПоля()


#КонецЕсли
