	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Документ.Контрагент.GLN)
		#Если клиент  Тогда
			Тогда Сообщить("Не заполнено значение GLN клиента, выгрузка в EDIN не выполнена."); 
