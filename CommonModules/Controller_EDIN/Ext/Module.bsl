	Шапка = РезультатЗапроса[0].Выбрать();
	Товары = РезультатЗапроса[1].Выбрать(); 
	
	//Запишем результат в xml
	
	file_XML  = Новый ЗаписьXML();
	file_XML.УстановитьСтроку("UTF-8");
	
	file_XML.ЗаписатьОбъявлениеXML();
	
	Шапка.Следующий();
	
	КодЯзыкаПечать = Локализация.ПолучитьЯзыкФормированияПечатныхФорм(УправлениеПользователями.ПолучитьЗначениеПоУмолчанию(глЗначениеПеременной("глТекущийПользователь"), "РежимФормированияПечатныхФорм"));
	
	СведенияОПоставщике = УправлениеКонтактнойИнформацией.СведенияОЮрФизЛице(Шапка.Поставщик, Шапка.DATE,,,КодЯзыкаПечать);
	СведенияОПокупателе = УправлениеКонтактнойИнформацией.СведенияОЮрФизЛице(Шапка.Покупатель, Шапка.DATE,,,КодЯзыкаПечать);
	
	
	INVOICE_XDTO = ФабрикаXDTO.Создать(ФабрикаXDTO.Тип("http://umk2.com.ua","INVOICE"));
	INVOICE_XDTO.DOCUMENTNAME = "380";
	
	
	INVOICE_XDTO.NUMBER             = XMLСтрока(Шапка.NUMBER);//"4489279826";
	INVOICE_XDTO.DATE               = XMLСтрока(Формат(Шапка.DATE,"ДФ=гггг-ММ-дд"));//2020-09-26";
	INVOICE_XDTO.INVOICETYPE        = 0;
	INVOICE_XDTO.DELIVERYDATE       = XMLСтрока(Формат(Шапка.DELIVERYDATE,"ДФ=гггг-ММ-дд"));//"2020-09-26";
	INVOICE_XDTO.DELIVERYTIME       = ДанныеЗаказа.DELIVERYTIME; //берем из заказа.;//XMLСтрока(Формат(Шапка.DELIVERYTIME,"ДФ=ЧЧ:мм"));//"00:00";
	INVOICE_XDTO.CURRENCY           =  "UAH";
	
	INVOICE_XDTO.ORDERNUMBER        = XMLСтрока(Шапка.ORDERNUMBER);//"4489279826";
	INVOICE_XDTO.ORDERDATE          = XMLСтрока(Формат(Шапка.ORDERDATE,"ДФ=гггг-ММ-дд"));//"2020-09-25";
	INVOICE_XDTO.DELIVERYNOTENUMBER = XMLСтрока(Формат(Шапка.DELIVERYNOTENUMBER,"ДФ=гггг-ММ-дд"));//"11-26-09-20";
	INVOICE_XDTO.DELIVERYNOTEDATE   = XMLСтрока(Формат(Шапка.DELIVERYNOTEDATE,"ДФ=гггг-ММ-дд"));//"2020-09-26";
	INVOICE_XDTO.VAT                = 20;//
	
	
	HEAD_XDTO = ФабрикаXDTO.Создать(ФабрикаXDTO.Тип("http://umk2.com.ua","HEAD"));
	
	HEAD_XDTO.SUPPLIER         = XMLСтрока(Шапка.SUPPLIER);//"9864232343295";
	HEAD_XDTO.SUPPLIERNAME     = XMLСтрока(Шапка.SUPPLIERNAME);
	HEAD_XDTO.SUPPLIERADRESS   = XMLСтрока(Шапка.SUPPLIERADRESS);
	HEAD_XDTO.SUPPLIERCITY     = XMLСтрока(Шапка.SUPPLIERCITY);
	HEAD_XDTO.SUPPLIERZIP      = XMLСтрока(Шапка.SUPPLIERZIP);
	HEAD_XDTO.BUYER            = XMLСтрока(Шапка.BUYER);//"9864066987535";
	HEAD_XDTO.BUYERNAME        = СведенияОПокупателе.Представление; //Ім’я покупця
	HEAD_XDTO.BUYERADRESS      = СведенияОПокупателе.ЮридическийАдрес; //Адреса покупця
	HEAD_XDTO.BUYERCITY        = ""; //Місто покупця
	HEAD_XDTO.BUYERZIP         = "-";//Індекс покупця
	HEAD_XDTO.BUYERKPP         = "-";
	HEAD_XDTO.BUYERINN         = СведенияОПокупателе.ИНН;//ІПН покупця;
	HEAD_XDTO.DELIVERYPLACE    = ДанныеЗаказа.DELIVERYPLACE; //берем из заказа.
	HEAD_XDTO.INVOICEPARTNER   = ""; //GLN платника;
	HEAD_XDTO.SENDER           = XMLСтрока(Шапка.SENDER);//"9864232343295";  GLN відправника повідомлення
	HEAD_XDTO.RECIPIENT        = XMLСтрока(Шапка.RECIPIENT);//"9864066987535"; GLN одержувача повідомлення
	
	//Если Не ЗначениеЗаполнено(Документ.Контрагент.Префикс) Или 
	Если Не ЗначениеЗаполнено(Документ.Контрагент.ЗначСимволы)
		Тогда 
		//Парам_ШК_заполнены = Ложь;
		#Если Клиент Тогда
			Сообщить("В справочнике контрагента не заполнены значения параметров штрихкода, строки заказа клиента не будут найдены.");
		#КонецЕсли
	КонецЕсли;
	
	DOC_SUM = 0;
	
	Пока Товары.Следующий() Цикл 
		
		POSITION_XDTO = ФабрикаXDTO.Создать(ФабрикаXDTO.Тип("http://umk2.com.ua","POSITION"));
		
		POSITION_XDTO.POSITIONNUMBER = XMLСтрока(Товары.POSITIONNUMBER);//"1";
		POSITION_XDTO.PRODUCT = XMLСтрока(Товары.PRODUCT);//"2086668100007"; ///Из строки документа.
		POSITION_XDTO.UNITPRICE = 0;
		POSITION_XDTO.INVOICEDQUANTITY = XMLСтрока(Товары.DELIVEREDQUANTITY);//берем из накладной;
		
		//Строки из заказа клиента
		ORDER_STRING = НайтиСтрокуЗаказа(POSITION_XDTO.PRODUCT, Товары, ДанныеЗаказа.POSITIONS,
		Документ.Контрагент.Префикс, Документ.Контрагент.ЗначСимволы);
		POSITION_XDTO.PRODUCTIDBUYER = XMLСтрока(ORDER_STRING.PRODUCTIDBUYER);//берем из заказа."866681";
		POSITION_XDTO.INVOICEUNIT = XMLСтрока(ORDER_STRING.ORDERUNIT);//берем из заказа. 
		POSITION_XDTO.UNITPRICE = ORDER_STRING.ORDERPRICE; //берем из заказа. 
		POSITION_XDTO.PRODUCT = XMLСтрока(ORDER_STRING.PRODUCT); //берем из заказа.
		
		POSITION_XDTO.AMOUNT = XMLСтрока(Товары.AMOUNT);//
		
		Если Документ.УчитыватьНДС И НЕ Документ.СуммаВключаетНДС Тогда
			GROSSPRICE =  Формат(POSITION_XDTO.UNITPRICE *(1+УчетНДС.ПолучитьСтавкуНДС(Товары.TAXRATE)/100),"ЧЦ=15; ЧДЦ=2; ЧРД=.; ЧГ=");
			Попытка
				GROSSPRICE = Число(GROSSPRICE);	
			Исключение
				GROSSPRICE = 0;
			КонецПопытки;
			POSITION_XDTO.GROSSPRICE =  GROSSPRICE;//С НДС
		КонецЕсли;
		POSITION_XDTO.DESCRIPTION = XMLСтрока(ПредставлениеНоменклатуры(Товары.Номенклатура, Товары.Характеристика, Товары.Дата));//"Ковбаса Баликова_варена 1г целофан_в/у вагова Український МК";
		POSITION_XDTO.AMOUNTWITHVAT = GROSSPRICE * POSITION_XDTO.INVOICEDQUANTITY;
		
		TAX_XDTO =  ФабрикаXDTO.Создать(ФабрикаXDTO.Тип("http://umk2.com.ua","TAX")); 
		TAX_XDTO.TAXTYPECODE = "VAT";
		TAX_XDTO.TAXRATE     = XMLСтрока(УчетНДС.ПолучитьСтавкуНДС(Товары.TAXRATE));
		TAX_XDTO.TAXAMOUNT   = POSITION_XDTO.INVOICEDQUANTITY*(POSITION_XDTO.GROSSPRICE-POSITION_XDTO.UNITPRICE);
		TAX_XDTO.CATEGORY    = "S";
		
		POSITION_XDTO.TAX.Добавить(TAX_XDTO);
		HEAD_XDTO.POSITION.Добавить(POSITION_XDTO);		
		
		DOC_SUM = DOC_SUM + (POSITION_XDTO.GROSSPRICE)*POSITION_XDTO.INVOICEDQUANTITY; //цена с НДС из заказа на количество из накладной.
		
	КонецЦикла;
	
	Отклонение = DOC_SUM - Документ.СуммаДокумента;
	
	Если Отклонение < -1 Или Отклонение > 1 Тогда
		#Если Клиент Тогда
			Сообщить("Не совпадают суммы накладной и счета.", СтатусСообщения.Важное);
		#КонецЕсли	
	КонецЕсли;
	
	INVOICE_XDTO.HEAD.Добавить(HEAD_XDTO);
	
	ФабрикаXDTO.ЗаписатьXML(file_XML, INVOICE_XDTO);
	
	Возврат file_XML.Закрыть();
	
КонецФункции

