
#Область Заказы_покупателя

//Возвращает уведомление об отгрузке в xml
Функция desadv_ФайлСтрокой(Документ) Экспорт
	
	Если Не ЗначениеЗаполнено(Документ.ORDERNUMBER)
		#Если клиент  Тогда
			Тогда Предупреждение("Не заполнено значение номера заказа клиента, выгрузка в EDIN не выполнена.");
		#КонецЕсли
		Возврат ""
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Документ.Контрагент.GLN)
		#Если клиент  Тогда
			Тогда Предупреждение("Не заполнено значение GLN клиента, выгрузка в EDIN не выполнена."); 
		#КонецЕсли
		Возврат ""
	КонецЕсли;
	
	Контрагент_GLN = ?(ЗначениеЗаполнено(Документ.EDIN_Контрагент), Документ.EDIN_Контрагент.GLN,
	Документ.Контрагент.GLN);
	
	ЦеныИзРасходнойНакладной = Документ.Контрагент.EDIN_УведомлениеОтгрузкаЦеныИзРН;
	
	ДанныеЗаказа = ПолучитьДанныеЗаказаПокупателя(Документ.ORDERNUMBER, Контрагент_GLN,
	Документ.Контрагент.НезначСправа);
	
	Если Не ЗначениеЗаполнено(ДанныеЗаказа) Тогда
		#Если клиент  Тогда
			Сообщить("Не найдены данные заказа в базе EDIN, выгрузка не выполнена.");
		#КонецЕсли
		Возврат ""
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РеализацияТоваровУслуг.DATE_ КАК DATE,
	|	РеализацияТоваровУслуг.NUMBER_ КАК NUMBER,
	|	РеализацияТоваровУслуг.DELIVERYDATE,
	|	РеализацияТоваровУслуг.DELIVERYTIME,
	|	РеализацияТоваровУслуг.ORDERNUMBER,
	|	РеализацияТоваровУслуг.ORDERDATE,
	|	РеализацияТоваровУслуг.DELIVERYNOTENUMBER,
	|	РеализацияТоваровУслуг.DELIVERYNOTEDATE,
	|	РеализацияТоваровУслуг.SHIPMENTS,
	|	РеализацияТоваровУслуг.INFO,
	|	РеализацияТоваровУслуг.CAMPAIGNNUMBER,
	|	РеализацияТоваровУслуг.TRANSPORTTYPE,
	|	РеализацияТоваровУслуг.TRANSPORTERTYPE,
	|	РеализацияТоваровУслуг.Организация.GLN КАК SUPPLIER,
	|	РеализацияТоваровУслуг.Организация.GLN КАК SENDER,
	|	ВЫБОР
	|		КОГДА РеализацияТоваровУслуг.EDIN_Контрагент <> ЗНАЧЕНИЕ(Справочник.EDIN_Контрагент.ПустаяСсылка)
	|			ТОГДА РеализацияТоваровУслуг.EDIN_Контрагент.GLN
	|		ИНАЧЕ РеализацияТоваровУслуг.Контрагент.GLN
	|	КОНЕЦ КАК BUYER,
	|	ВЫБОР
	|		КОГДА РеализацияТоваровУслуг.EDIN_Контрагент <> ЗНАЧЕНИЕ(Справочник.EDIN_Контрагент.ПустаяСсылка)
	|			ТОГДА РеализацияТоваровУслуг.EDIN_Контрагент.GLN
	|		ИНАЧЕ РеализацияТоваровУслуг.Контрагент.GLN
	|	КОНЕЦ КАК RECIPIENT,
	|	"""" КАК DELIVERYPLACE,
	|	"""" КАК EDIINTERCHANGEID
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|ГДЕ
	|	РеализацияТоваровУслуг.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	""1"" КАК HIERARCHICALID,
	|	РеализацияТоваровУслугТовары.НомерСтроки КАК POSITIONNUMBER,
	|	РеализацияТоваровУслугТовары.umk_КодКлиента КАК PRODUCT,
	|	РеализацияТоваровУслугТовары.EDIN_штрихкод,
	|	РеализацияТоваровУслугТовары.EDIN_артикулПокупателя КАК EDIN_артикулПокупателя,
	|	РеализацияТоваровУслугТовары.EDIN_артикулПродавца,
	|	РеализацияТоваровУслугТовары.Количество КАК DELIVEREDQUANTITY,
	|	"""" КАК ORDEREDQUANTITY,
	|	ВЫБОР
	|		КОГДА РеализацияТоваровУслугТовары.Ссылка.СуммаВключаетНДС
	|			ТОГДА РеализацияТоваровУслугТовары.Сумма - РеализацияТоваровУслугТовары.СуммаНДС
	|		ИНАЧЕ РеализацияТоваровУслугТовары.Сумма
	|	КОНЕЦ КАК AMOUNT,
	|	РеализацияТоваровУслугТовары.Цена КАК PRICE,
	|	РеализацияТоваровУслугТовары.Номенклатура.НаименованиеПолное КАК Номенклатура,
	|	РеализацияТоваровУслугТовары.ХарактеристикаНоменклатуры КАК Характеристика,
	|	РеализацияТоваровУслугТовары.Ссылка.Дата,
	|	"""" КАК PRICEWITHVAT,
	|	РеализацияТоваровУслугТовары.СтавкаНДС КАК TAXRATE,
	|	КлассификаторЕдиницИзмерения.UNIT КАК DELIVEREDUNIT,
	|	"""" КАК ORDERUNIT
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлассификаторЕдиницИзмерения КАК КлассификаторЕдиницИзмерения
	|		ПО РеализацияТоваровУслугТовары.ЕдиницаИзмерения.ЕдиницаПоКлассификатору = КлассификаторЕдиницИзмерения.Ссылка
	|ГДЕ
	|	РеализацияТоваровУслугТовары.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	POSITIONNUMBER";
	
	Запрос.УстановитьПараметр("Ссылка", Документ);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Шапка = РезультатЗапроса[0].Выбрать();
	Товары = РезультатЗапроса[1].Выбрать(); 
	
	//Запишем результат в xml	
	file_XML  = Новый ЗаписьXML();
	file_XML.УстановитьСтроку("UTF-8");
	
	file_XML.ЗаписатьОбъявлениеXML();
	
	Шапка.Следующий();
	
	DESADV_XDTO = ФабрикаXDTO.Создать(ФабрикаXDTO.Тип("http://umk.com.ua","DESADV"));
	
	DESADV_XDTO.NUMBER             = XMLСтрока(Шапка.NUMBER);//"4489279826";
	DESADV_XDTO.DATE               = XMLСтрока(Формат(Шапка.DATE,"ДФ=гггг-ММ-дд"));//2020-09-26";
	DESADV_XDTO.DELIVERYDATE       = XMLСтрока(Формат(Шапка.DELIVERYDATE,"ДФ=гггг-ММ-дд"));//"2020-09-26";
	DESADV_XDTO.DELIVERYTIME       = ДанныеЗаказа.DELIVERYTIME; //берем из заказа.;//XMLСтрока(Формат(Шапка.DELIVERYTIME,"ДФ=ЧЧ:мм"));//"00:00";
	DESADV_XDTO.ORDERNUMBER        = XMLСтрока(Шапка.ORDERNUMBER);//"4489279826";
	DESADV_XDTO.ORDERDATE          = XMLСтрока(Формат(Шапка.ORDERDATE,"ДФ=гггг-ММ-дд"));//"2020-09-25";
	DESADV_XDTO.DELIVERYNOTENUMBER = XMLСтрока(Формат(Шапка.DELIVERYNOTENUMBER,"ДФ=гггг-ММ-дд"));//"11-26-09-20";
	DESADV_XDTO.DELIVERYNOTEDATE   = XMLСтрока(Формат(Шапка.DELIVERYNOTEDATE,"ДФ=гггг-ММ-дд"));//"2020-09-26";
	DESADV_XDTO.SHIPMENTS          = XMLСтрока(Шапка.SHIPMENTS);//"1";
	DESADV_XDTO.INFO               = XMLСтрока(Шапка.INFO);//"Заказ № 4489279826";
	DESADV_XDTO.CAMPAIGNNUMBER     = XMLСтрока(Шапка.CAMPAIGNNUMBER);//"NF4600046889";
	DESADV_XDTO.TRANSPORTTYPE      = XMLСтрока(Шапка.TRANSPORTTYPE);//"30";
	DESADV_XDTO.TRANSPORTERTYPE    = XMLСтрока(Шапка.TRANSPORTERTYPE);//"31";
	
	HEAD_XDTO = ФабрикаXDTO.Создать(ФабрикаXDTO.Тип("http://umk.com.ua","HEAD"));
	
	HEAD_XDTO.SUPPLIER         = XMLСтрока(Шапка.SUPPLIER);//"9864232343295";
	HEAD_XDTO.BUYER            = XMLСтрока(Шапка.BUYER);//"9864066987535";
	HEAD_XDTO.DELIVERYPLACE    = ДанныеЗаказа.DELIVERYPLACE; //берем из заказа.
	HEAD_XDTO.SENDER           = XMLСтрока(Шапка.SENDER);//"9864232343295";
	HEAD_XDTO.RECIPIENT        = XMLСтрока(Шапка.RECIPIENT);//"9864066987535";
	HEAD_XDTO.EDIINTERCHANGEID = XMLСтрока(Шапка.EDIINTERCHANGEID);//"4489279826";
	
	PACKINGSEQUENCE_XDTO = ФабрикаXDTO.Создать(ФабрикаXDTO.Тип("http://umk.com.ua","PACKINGSEQUENCE"));
	PACKINGSEQUENCE_XDTO.HIERARCHICALID = "1";
	
	DOC_SUM = 0;
	
	Пока Товары.Следующий() Цикл 
		
		POSITION_XDTO = ФабрикаXDTO.Создать(ФабрикаXDTO.Тип("http://umk.com.ua","POSITION"));
		
		POSITION_XDTO.POSITIONNUMBER = XMLСтрока(Товары.POSITIONNUMBER);//"1";
		POSITION_XDTO.PRODUCT = XMLСтрока(Товары.PRODUCT);//"2086668100007"; ///Из строки документа.
		POSITION_XDTO.PRICE = 0;
		
		//Строки из заказа клиента
		ORDER_STRING = НайтиСтрокуЗаказа(POSITION_XDTO.PRODUCT,Товары,ДанныеЗаказа.POSITIONS,
		Документ.Контрагент.Префикс, Документ.Контрагент.ЗначСимволы);
		POSITION_XDTO.PRODUCTIDBUYER = XMLСтрока(ORDER_STRING.PRODUCTIDBUYER);//берем из заказа."866681";
		POSITION_XDTO.ORDERUNIT = XMLСтрока(ORDER_STRING.ORDERUNIT);//берем из заказа. 
		POSITION_XDTO.ORDEREDQUANTITY = XMLСтрока(ORDER_STRING.ORDEREDQUANTITY);//берем из заказа."6";
		POSITION_XDTO.PRODUCT = XMLСтрока(ORDER_STRING.PRODUCT); //берем из заказа.
		
		//Цена из заказа EDIN
		ORDER_PRICE = ?(ORDER_STRING.ORDERPRICE = Неопределено, 0, ORDER_STRING.ORDERPRICE); 
		
		//В зависимости от условий контрагента берем цену из заказа edin или из нашей накладной 
		PRICE =?(ЦеныИзРасходнойНакладной, XMLСтрока(Товары.PRICE), ORDER_PRICE);
		
		POSITION_XDTO.PRICE = PRICE;
		
		POSITION_XDTO.DELIVEREDQUANTITY = XMLСтрока(Товары.DELIVEREDQUANTITY);//"5.7";
		POSITION_XDTO.AMOUNT = XMLСтрока(Товары.AMOUNT);//"271.49";
		
		//Цена с НДС Из Заказа
		ORDER_PRICEWITHVAT = ORDER_STRING.PRICEWITHVAT;			
		Если НЕ ЗначениеЗаполнено(ORDER_PRICEWITHVAT) И (Документ.УчитыватьНДС И НЕ Документ.СуммаВключаетНДС)Тогда
			ORDER_PRICEWITHVAT =  Формат(POSITION_XDTO.PRICE *(1+УчетНДС.ПолучитьСтавкуНДС(Товары.TAXRATE)/100),"ЧЦ=15; ЧДЦ=2; ЧРД=.; ЧГ=");
			Попытка
				ORDER_PRICEWITHVAT = Число(ORDER_PRICEWITHVAT);	
			Исключение
				ORDER_PRICEWITHVAT = 0;
			КонецПопытки;
		КонецЕсли;
		
		//Цена с НДС Из Накладной
		DOC_PRICEWITHVAT = XMLСтрока(Товары.PRICE);
		Если Документ.УчитыватьНДС И НЕ Документ.СуммаВключаетНДС Тогда
			DOC_PRICEWITHVAT =  Формат(Товары.PRICE *(1+УчетНДС.ПолучитьСтавкуНДС(Товары.TAXRATE)/100),"ЧЦ=15; ЧДЦ=2; ЧРД=.; ЧГ=");
			Попытка
				DOC_PRICEWITHVAT = Число(DOC_PRICEWITHVAT);	
			Исключение
				DOC_PRICEWITHVAT = 0;
			КонецПопытки;
		КонецЕсли;
		
		//В зависимости от условий контрагента берем цену с НДС из заказа edin или из нашей накладной 
		PRICEWITHVAT = ?(ЦеныИзРасходнойНакладной, DOC_PRICEWITHVAT, ORDER_PRICEWITHVAT);
		
		Попытка 
			POSITION_XDTO.PRICEWITHVAT = Число(PRICEWITHVAT);
		Исключение
			POSITION_XDTO.PRICEWITHVAT = 0;
		КонецПопытки;
		
		POSITION_XDTO.TAXRATE = XMLСтрока(УчетНДС.ПолучитьСтавкуНДС(Товары.TAXRATE)); 
		POSITION_XDTO.DELIVEREDUNIT = XMLСтрока(Товары.DELIVEREDUNIT);
		POSITION_XDTO.DESCRIPTION = XMLСтрока(ПредставлениеНоменклатуры(Товары.Номенклатура, Товары.Характеристика, Товары.Дата));//"Ковбаса Баликова_варена 1г целофан_в/у вагова Український МК";
		
		PACKINGSEQUENCE_XDTO.POSITION.Добавить(POSITION_XDTO);
		
		//Цена с НДС из заказа на количество из накладной.Контрольна сумма для расчета отклонения
		DOC_SUM = DOC_SUM + ORDER_PRICEWITHVAT*POSITION_XDTO.DELIVEREDQUANTITY; 		
		
	КонецЦикла;
	
	Отклонение = DOC_SUM - Документ.СуммаДокумента;
	
	Если Отклонение < -1 Или Отклонение > 1 Тогда
		#Если Клиент Тогда
			Предупреждение("Не совпадают суммы накладной и уведомления об отгрузке.");
		#КонецЕсли	
	КонецЕсли;
	
	HEAD_XDTO.PACKINGSEQUENCE.Добавить(PACKINGSEQUENCE_XDTO);
	DESADV_XDTO.HEAD.Добавить(HEAD_XDTO);
	                             	
	ФабрикаXDTO.ЗаписатьXML(file_XML, DESADV_XDTO);
	
	Возврат file_XML.Закрыть();
	
КонецФункции

//Возвращает уведомление об отгрузке в xml
