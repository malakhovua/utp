			PRICE = Товары.PRICE;
		КонецЕсли;
		
		POSITION_XDTO.PRICE = PRICE; //берем из накладной.   Ціна продукту без ПДВ
		POSITION_XDTO.TAXRATE = XMLСтрока(УчетНДС.ПолучитьСтавкуНДС(Товары.TAXRATE)); //Ставка ПДВ (20%, 19%, 16%, 14%, 7%, 2%, 0%)
		POSITION_XDTO.AMOUNT = XMLСтрока(Товары.AMOUNT);//Сума товару без ПДВ
		
		POSITION_XDTO.GOODDATE  = '00010101';//?  Термін придатності
		POSITION_XDTO.BRUTTOWEIGHT = 0;//Вага брутто
		
		PACKINGSEQUENCE_XDTO.POSITION.Добавить(POSITION_XDTO);
				
	КонецЦикла;
	
	HEAD_XDTO.PACKINGSEQUENCE.Добавить(PACKINGSEQUENCE_XDTO);
	DESADV_XDTO.HEAD.Добавить(HEAD_XDTO);
	
	ФабрикаXDTO.ЗаписатьXML(file_XML, DESADV_XDTO);
	
	Возврат file_XML.Закрыть();
	
