	   "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	   |	ВзносыВФонды.Сотрудник,
	   |	ВЫБОР
	   |	 КОГДА ВзносыВФонды.КоэффициентСтавки <> 0 И ВзносыВФонды.КоэффициентСтавки <> &КоэффициентСтавки 
	   |	 ТОГДА ВзносыВФонды.БазаВзноса*ВзносыВФонды.Ставка*&КоэффициентСтавки 
	   |	 ИНАЧЕ ВзносыВФонды.Результат
	   |	КОНЕЦ КАК Результат
	   |ПОМЕСТИТЬ ВТВзносы
	   |ИЗ
       |	РегистрРасчета.ВзносыВФонды КАК ВзносыВФонды
	   |ГДЕ
	   |    ВзносыВФонды.Организация = &Организация
	   |    И ВзносыВФонды.ПериодРегистрации = &МесяцНачисления
	   |    И ВзносыВФонды.ВидРасчета.СпособРасчета = ЗНАЧЕНИЕ(Перечисление.СпособыРасчетаОплатыТруда.ВзносыФОТ)
	   |    И ВзносыВФонды.БазаВзноса <> 0
	   |;
	   |
	   |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	   |	Начисления.Сотрудник,
	   |	Начисления.Результат
	   |ПОМЕСТИТЬ ВТНачисления
	   |ИЗ
       |	РегистрРасчета.Начисления КАК Начисления
	   |ГДЕ
	   |    Начисления.Организация = &Организация
	   |    И Начисления.ПериодРегистрации = &МесяцНачисления
	   |    И Начисления.ВидРасчета.СчетУчета = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РасчетыПоЗаработнойПлате)
	   |    И Начисления.Результат <> 0
	   |;
	   |
	   |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	   |	Начисления.Сотрудник,
	   |	КОЛИЧЕСТВО( РАЗЛИЧНЫЕ Начисления.ПериодРегистрации) КАК КоличествоМесяцев,
	   |	СУММА(Начисления.Результат) КАК Результат
	   |ПОМЕСТИТЬ ВТНачисления2014
	   |ИЗ
       |	РегистрРасчета.Начисления КАК Начисления
	   |ГДЕ
	   |    Начисления.Организация = &Организация
	   |    И ГОД(Начисления.ПериодРегистрации) = 2014
	   |    И Начисления.ВидРасчета.СчетУчета = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РасчетыПоЗаработнойПлате)
	   |    И Начисления.Результат <> 0
	   |СГРУППИРОВАТЬ ПО
	   |    Начисления.Сотрудник
	   |;
	   |
	   |ВЫБРАТЬ
	   |   КОЛИЧЕСТВО( РАЗЛИЧНЫЕ ВзносыВФонды.Сотрудник) КАК КоличествоСотрудниковВзносы,
	   |   СУММА(ВзносыВФонды.Результат) КАК РезультатВзносы
	   |ИЗ 
	   |   ВТВзносы КАК ВзносыВФонды
	   |;
	   |
	   |ВЫБРАТЬ
	   |   КОЛИЧЕСТВО( РАЗЛИЧНЫЕ Начисления.Сотрудник) КАК КоличествоСотрудниковНачисления,
	   |   СУММА(Начисления.Результат) КАК РезультатНачисления
	   |ИЗ 
	   |   ВТНачисления КАК Начисления
   	   |;
	   |
	   |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	   |	МинимальнаяОплатаТруда.Размер
	   |ИЗ
       |	РегистрСведений.МинимальнаяОплатаТруда.СрезПоследних(&МесяцНачисления) КАК МинимальнаяОплатаТруда
	   |;
	   |
	   |ВЫБРАТЬ
	   |   КОЛИЧЕСТВО( РАЗЛИЧНЫЕ Начисления.Сотрудник) КАК КоличествоСотрудниковНачисления2014,
	   |   СУММА(Начисления.Результат/Начисления.КоличествоМесяцев) КАК РезультатНачисления2014
	   |ИЗ 
	   |   ВТНачисления2014 КАК Начисления
   	   |
	   |";

	   
	   
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = РезультатЗапроса[3].Выбрать();
	Если Выборка.Следующий() Тогда
		Если Выборка.КоличествоСотрудниковВзносы = 0 Тогда
			Результат.СреднийПлатеж = 0;
		Иначе
			Результат.СреднийПлатеж = Окр(Выборка.РезультатВзносы/Выборка.КоличествоСотрудниковВзносы,2);
		КонецЕсли
	Иначе
		Результат.СреднийПлатеж = 0;
	КонецЕсли;
	
	Выборка = РезультатЗапроса[4].Выбрать();
	Если Выборка.Следующий() Тогда
		Если Выборка.КоличествоСотрудниковНачисления = 0 Тогда
			Результат.СредняяЗП = 0;
		Иначе
			Результат.СредняяЗП = Окр(Выборка.РезультатНачисления/Выборка.КоличествоСотрудниковНачисления,2);
		КонецЕсли
	Иначе
		Результат.СредняяЗП = 0;
	КонецЕсли;
	
	Выборка = РезультатЗапроса[5].Выбрать();
	Если Выборка.Следующий() Тогда
		Результат.МинимальнаяЗП =  Выборка.Размер;
	Иначе
		Результат.МинимальнаяЗП = 0;
	КонецЕсли;
	
	Выборка = РезультатЗапроса[6].Выбрать();
	Если Выборка.Следующий() Тогда
		Если Выборка.КоличествоСотрудниковНачисления2014 = 0 Тогда
			Результат.СредняяЗП2014 = 0;
		Иначе
			Результат.СредняяЗП2014 = Окр(Выборка.РезультатНачисления2014/Выборка.КоличествоСотрудниковНачисления2014,2);
		КонецЕсли
	Иначе
		Результат.СредняяЗП2014 = 0;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПроверитьУсловияКоэффициентСтавки1863(Организация, МесяцНачисления, КоэффициентСтавки, КоличествоЗЛ, КоличествоЗЛ2014) Экспорт
	
	Результат = Новый Структура("СреднийПлатеж, СреднийПлатеж2014"); 
	
	Если НЕ ЗначениеЗаполнено(Организация) ИЛИ НЕ ЗначениеЗаполнено(МесяцНачисления) Тогда
		Результат.СреднийПлатеж = 0;
		Результат.СреднийПлатеж2014 = 0;
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос();
	
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("МесяцНачисления", МесяцНачисления);
	Запрос.УстановитьПараметр("КоэффициентСтавки", КоэффициентСтавки);
	
	Запрос.УстановитьПараметр("МассивНалогиБезКоэффициента",СписокНалогиБезКоэффициента());
	
	Запрос.Текст = 
	   "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	   |	ВзносыВФонды.Сотрудник.ФизЛицо КАК Сотрудник,
	   |	ВЫБОР
	   |	 КОГДА ВзносыВФонды.КоэффициентСтавки <> 0 И ВзносыВФонды.КоэффициентСтавки <> &КоэффициентСтавки 
	   |	 ТОГДА ВзносыВФонды.БазаВзноса*ВзносыВФонды.Ставка*&КоэффициентСтавки 
	   |	 ИНАЧЕ ВзносыВФонды.Результат
	   |	КОНЕЦ КАК Результат
	   |ПОМЕСТИТЬ ВТВзносы
	   |ИЗ
       |	РегистрРасчета.ВзносыВФонды КАК ВзносыВФонды
	   |ГДЕ
	   |    ВзносыВФонды.Организация = &Организация
	   |    И ВзносыВФонды.ПериодРегистрации = &МесяцНачисления
	   |    И ВзносыВФонды.ВидРасчета.СпособРасчета = ЗНАЧЕНИЕ(Перечисление.СпособыРасчетаОплатыТруда.ВзносыФОТ)
	   |    И ВзносыВФонды.БазаВзноса <> 0
	   |    И ВзносыВФонды.Налог НЕ В (&МассивНалогиБезКоэффициента)
	   |;
	   |
	   |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	   |	ВзносыВФонды.ПериодРегистрации,
	   |	СУММА(ВзносыВФонды.Результат) КАК Результат2014
	   |ПОМЕСТИТЬ ВТВзносы2014
	   |ИЗ
	   |	РегистрРасчета.ВзносыВФонды КАК ВзносыВФонды
	   |ГДЕ
	   |   ВзносыВФонды.Организация = &Организация
	   |   И ГОД(ВзносыВФонды.ПериодРегистрации) = 2014
	   |   И ВзносыВФонды.ВидРасчета.СпособРасчета = ЗНАЧЕНИЕ(Перечисление.СпособыРасчетаОплатыТруда.ВзносыФОТ)
	   |   И ВзносыВФонды.Налог НЕ В (&МассивНалогиБезКоэффициента)
	   |СГРУППИРОВАТЬ ПО
	   |    ВзносыВФонды.ПериодРегистрации
	   |;
	   |
	   |ВЫБРАТЬ
	   |   СУММА(ВзносыВФонды.Результат) КАК РезультатВзносы
	   |ИЗ 
	   |   ВТВзносы КАК ВзносыВФонды
	   |;
	   |
	   |ВЫБРАТЬ
	   |   СУММА(ВзносыВФонды.Результат2014)/КОЛИЧЕСТВО(ВзносыВФонды.ПериодРегистрации) КАК РезультатВзносы2014
	   |ИЗ 
	   |   ВТВзносы2014 КАК ВзносыВФонды
   	   |
	   |";

	   
	   
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = РезультатЗапроса[2].Выбрать();
	Если Выборка.Следующий() Тогда
		Если КоличествоЗЛ = 0 ИЛИ Выборка.РезультатВзносы = NULL Тогда
			Результат.СреднийПлатеж = 0;
		Иначе
			Результат.СреднийПлатеж = Окр(Выборка.РезультатВзносы/КоличествоЗЛ,2);
		КонецЕсли;
	Иначе
		Результат.СреднийПлатеж = 0;
	КонецЕсли;
	
	Выборка = РезультатЗапроса[3].Выбрать();
	Если Выборка.Следующий() Тогда
		Если КоличествоЗЛ2014 = 0 ИЛИ Выборка.РезультатВзносы2014 = NULL Тогда
			Результат.СреднийПлатеж2014 = 0;
		Иначе
			Результат.СреднийПлатеж2014 = Окр(Выборка.РезультатВзносы2014/КоличествоЗЛ2014,2);
		КонецЕсли;
	Иначе
		Результат.СреднийПлатеж2014 = 0;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

