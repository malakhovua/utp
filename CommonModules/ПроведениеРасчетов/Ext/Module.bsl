			//
			ТекстЗапросаВТ = "
			|  	ВЫБРАТЬ
			|		Основной.Сотрудник    				КАК Сотрудник,
			|		Основной.НалоговыйПериод    		КАК НалоговыйПериод,
			|		СУММА( Начисления.Результат )		КАК Доход
