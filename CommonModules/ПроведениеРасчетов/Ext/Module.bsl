Функция РассчитатьКоэффициентСтавки(Организация, МесяцНачисления) Экспорт
	
	Результат = Новый Структура("База,База2014,КоэффициентСтавки");
	
	Если НЕ ЗначениеЗаполнено(Организация) ИЛИ НЕ ЗначениеЗаполнено(МесяцНачисления) Тогда
		Результат.База = 0;
		Результат.База2014 = 0;
		Результат.КоэффициентСтавки = 0;
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос();
	
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("МесяцНачисления", МесяцНачисления);
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
   	|	СУММА(ВзносыВФонды.База) КАК База2014,
	|	КОЛИЧЕСТВО (РАЗЛИЧНЫЕ ВзносыВФонды.ПериодРегистрации) КАК Месяцев2014
	|ПОМЕСТИТЬ ВТБаза2014
	|ИЗ
    |	РегистрРасчета.ВзносыВФонды КАК ВзносыВФонды
	|ГДЕ
	|   ВзносыВФонды.Организация = &Организация
	|   И ГОД(ВзносыВФонды.ПериодРегистрации) = 2014
	|   И (ВзносыВФонды.ВидРасчета = ЗНАЧЕНИЕ(ПланВидовРасчета.ВзносыВФонды.ЕСВФОТ)
	|      ИЛИ ВзносыВФонды.ВидРасчета = ЗНАЧЕНИЕ(ПланВидовРасчета.ВзносыВФонды.ЕСВФОТГПХ))
	|;
	|
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
   	|	СУММА(ВзносыВФонды.База) КАК База
	|ПОМЕСТИТЬ ВТБаза
	|ИЗ
    |	РегистрРасчета.ВзносыВФонды КАК ВзносыВФонды
	|ГДЕ
	|   ВзносыВФонды.Организация = &Организация
	|   И ВзносыВФонды.ПериодРегистрации = &МесяцНачисления
	|   И (ВзносыВФонды.ВидРасчета = ЗНАЧЕНИЕ(ПланВидовРасчета.ВзносыВФонды.ЕСВФОТ)
	|      ИЛИ ВзносыВФонды.ВидРасчета = ЗНАЧЕНИЕ(ПланВидовРасчета.ВзносыВФонды.ЕСВФОТГПХ))
	|;
	|
	|ВЫБРАТЬ
	|  ЕСТЬNULL(ТаблицаБаза.База, 0) КАК База,
	|  ЕСТЬNULL(ТаблицаБаза2014.База2014, 0) КАК База2014,
	|  ЕСТЬNULL(ТаблицаБаза2014.Месяцев2014, 0) КАК Месяцев2014
	|ИЗ
	|	ВТБаза КАК ТаблицаБаза
	|	ПОЛНОЕ СОЕДИНЕНИЕ
	|	ВТБаза2014 КАК ТаблицаБаза2014
	|	ПО ИСТИНА
	|";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Результат.База2014 = ?(Выборка.Месяцев2014 = 0, 0,Выборка.База2014/Выборка.Месяцев2014 );
		Результат.База = Выборка.База;
		Если Результат.База = 0 Тогда
			Результат.КоэффициентСтавки = 1;
		Иначе
			Результат.КоэффициентСтавки = МИН(МАКС(0.4, Результат.База2014/Результат.База),1);
		КонецЕсли;	
	Иначе
		Результат.База2014 = 0;
		Результат.База = 0;
		Результат.КоэффициентСтавки = 0;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция РассчитатьКоэффициентСтавки1863(Организация, МесяцНачисления, БазаСОграничением) Экспорт
	
	Результат = Новый Структура("База,База2014,КоличествоЗЛ,КоличествоЗЛ2014,КоэффициентСтавки");
	
	Если НЕ ЗначениеЗаполнено(Организация) ИЛИ НЕ ЗначениеЗаполнено(МесяцНачисления) Тогда
		Результат.База = 0;
		Результат.База2014 = 0;
		Результат.КоличествоЗЛ = 0;
		Результат.КоличествоЗЛ2014 = 0;
		Результат.КоэффициентСтавки = 0;
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос();
	
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("МесяцНачисления", МесяцНачисления);
	
	Запрос.УстановитьПараметр("МассивНалогиБезКоэффициента",СписокНалогиБезКоэффициента());
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВзносыВФонды.ПериодРегистрации,
	|	СУММА(ВзносыВФонды.База) КАК База2014,
	|	КОЛИЧЕСТВО (РАЗЛИЧНЫЕ ВзносыВФонды.Сотрудник.ФизЛицо) КАК Сотрудники2014
	|ПОМЕСТИТЬ ВТБаза2014
	|ИЗ
    |	РегистрРасчета.ВзносыВФонды КАК ВзносыВФонды
	|ГДЕ
	|   ВзносыВФонды.Организация = &Организация
	|   И ГОД(ВзносыВФонды.ПериодРегистрации) = 2014
	|   И ВзносыВФонды.ВидРасчета.СпособРасчета = ЗНАЧЕНИЕ(Перечисление.СпособыРасчетаОплатыТруда.ВзносыФОТ)
	|   И ВзносыВФонды.Налог НЕ В (&МассивНалогиБезКоэффициента)
	|   И ВзносыВФонды.База <> 0	
	|СГРУППИРОВАТЬ ПО
	|    ВзносыВФонды.ПериодРегистрации
	|;
	|
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВзносыВФонды.Сотрудник.ФизЛицо КАК Сотрудник,
	|	СУММА(ВзносыВФонды.База) КАК База
	|ПОМЕСТИТЬ ВТБаза
	|ИЗ
    |	РегистрРасчета.ВзносыВФонды КАК ВзносыВФонды
	|ГДЕ
	|   ВзносыВФонды.Организация = &Организация
	|   И ВзносыВФонды.ПериодРегистрации = &МесяцНачисления
	|   И ВзносыВФонды.ВидРасчета.СпособРасчета = ЗНАЧЕНИЕ(Перечисление.СпособыРасчетаОплатыТруда.ВзносыФОТ)
	|   И ВзносыВФонды.Налог НЕ В (&МассивНалогиБезКоэффициента)
	|   И ВзносыВФонды.База <> 0	
	|СГРУППИРОВАТЬ ПО
	|    ВзносыВФонды.Сотрудник.ФизЛицо
	|;
	|
    |ВЫБРАТЬ
    |   КОЛИЧЕСТВО( РАЗЛИЧНЫЕ Взносы.Сотрудник) КАК КоличествоСотрудников,
    |   СУММА(Взносы.База) КАК База
    |ИЗ 
    |   ВТБаза КАК Взносы
    |;
    |
	|ВЫБРАТЬ
	|   СУММА(Взносы.Сотрудники2014)/КОЛИЧЕСТВО(Взносы.ПериодРегистрации) КАК Сотрудников2014,
	|   КОЛИЧЕСТВО(Взносы.ПериодРегистрации) КАК Месяцев2014,
	|   СУММА(Взносы.База2014) КАК База2014
	|ИЗ 
	|   ВТБаза2014 КАК Взносы
	|";
	
	Если БазаСОграничением Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"ВзносыВФонды.База","ВзносыВФонды.БазаВзноса");	
	КонецЕсли;
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = РезультатЗапроса[2].Выбрать();
	
	Если Выборка.Следующий() Тогда
		Результат.База = ?(Выборка.КоличествоСотрудников = 0, 0,Выборка.База/Окр(Выборка.КоличествоСотрудников) );
		Результат.КоличествоЗЛ = Выборка.КоличествоСотрудников
	Иначе
		Результат.База = 0;
		Результат.КоличествоЗЛ = 0;
	КонецЕсли;
	
	Выборка = РезультатЗапроса[3].Выбрать();
	
	Если Выборка.Следующий() Тогда
		Результат.База2014 = ?(Выборка.Сотрудников2014 = 0 ИЛИ Выборка.Месяцев2014 = 0, 0,Выборка.База2014/Выборка.Месяцев2014/Окр(Выборка.Сотрудников2014) );
		Результат.КоличествоЗЛ2014 = Выборка.Сотрудников2014
	Иначе
		Результат.База2014 = 0;
		Результат.КоличествоЗЛ2014 = 0;
	КонецЕсли;
	
	Если Результат.База = 0 Тогда
		Результат.КоэффициентСтавки = 1;
	Иначе
		Результат.КоэффициентСтавки = Окр(МИН(МАКС(0.4, Результат.База2014/Результат.База),1),3);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПроверитьУсловияКоэффициентСтавки(Организация, МесяцНачисления, КоэффициентСтавки) Экспорт
	
