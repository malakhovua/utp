				    |    	КОГДА Основной.ПериодРегистрации >= ДАТАВРЕМЯ(2024,12,1)
				    |    	    И Основной.НалоговыйПериод < ДАТАВРЕМЯ(2024,12,1)
					|    	    И ЕСТЬNULL(НастройкиУчетаЗарплаты.ВС2024Больничные, Ложь) = ИСТИНА
				    //Больничные в декабре 2024 или позже с периодом до декабря 2024
				    |			ТОГДА Основной.НалоговыйПериод
				    |    	КОГДА Основной.ПериодРегистрации < ДАТАВРЕМЯ(2024,12,1)
				    |    	    И Основной.НалоговыйПериод >= ДАТАВРЕМЯ(2024,12,1)
					|    	    И &парамПериодРегистрации >= ДАТАВРЕМЯ(2024,12,1)
					|    	    И ЕСТЬNULL(НастройкиУчетаЗарплаты.ВС2024Отпускные, Ложь) = ИСТИНА
					//Отпускные до декабря 2024 с периодом декабрь 2024 или позже
				    |			ТОГДА Основной.НалоговыйПериод
				    |		ИНАЧЕ Основной.ПериодРегистрации 
				    |	КОНЕЦ КАК НалоговыйПериод,
					|		Основной.ПериодРегистрации    		КАК ПериодРегистрации,
					|		Основной.ДоходНДФЛ.ОблагаетсяВоеннымСбором2021	КАК ДоходНДФЛ,
					|		Основной.Доход 						КАК Доход
					|ПОМЕСТИТЬ ВТДоходВС
					|	ИЗ	ВТДоходБезУчетаВС КАК Основной
					|   ЛЕВОЕ СОЕДИНЕНИЕ
					|   РегистрСведений.ПараметрыРасчетаЗарплатыОрганизаций КАК НастройкиУчетаЗарплаты
					|   ПО НастройкиУчетаЗарплаты.Организация = &парамОрганизация
				    |
