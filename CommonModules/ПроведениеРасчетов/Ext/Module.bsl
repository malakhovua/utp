			КонецЕсли;	
			Запрос.Текст = ТекстЗапросаВТ;
			Запрос.Выполнить();
			ТекстЗапросаВТДоход = "ВТДоход";
		КонецЕсли;
		Запрос.Текст = "ВЫБРАТЬ * ИЗ ВТДоход";
		
		// ВТДоходЛьготы
		Если Истина Тогда
			// Получает суммы начисленного дохода Сотрудников в разрезе ПериодовДействия и Видов доходов
