		КодЯзыкаПечать = "uk";
		
	ИначеЕсли РежимФормированияПечатныхФормОтчетов = Перечисления.РежимФормированияПечатныхФорм.НаЯзыкеИнтерфейсаПользователя Тогда		
		
		КодЯзыкаПечать = ЛокализацияПовтИсп.КодЯзыкаИнтерфейса();
		
