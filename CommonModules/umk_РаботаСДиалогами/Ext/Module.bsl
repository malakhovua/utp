// ПРОЦЕДУРЫ И ФУНКЦИИ ПОДГОТОВКИ ИНФОРМАЦИИ В ФОРМЕ

// Формирует текст о долге контрагента для вывода его в форме документа
//
// Параметры: 
//  ДоговорКонтрагента - ссылка на элемент справочника, определяет договор контрагента
//  Долг                  - число, сумма долга.
//
// Возвращаемое значение:
//  Строка, сформированный текст про долг контрагента.
//
Функция ПолучитьТекстДолга(ДоговорКонтрагента, Знач Долг, Знач ДолгОбщий) Экспорт

	// Общий долг
	ТекстПодписиОбщий = "";

	Если ДолгОбщий = Неопределено Тогда
		ТекстПодписиОбщий = ТекстПодписиОбщий + "В бух. учете долг не рассчитан";

	ИначеЕсли ДолгОбщий = 0 Тогда
		ТекстПодписиОбщий = ТекстПодписиОбщий + "В бух. учете нет долга";

	Иначе
		Если ДолгОбщий > 0 Тогда
			ТекстПодписиОбщий = ТекстПодписиОбщий + "В бух. учете долг контрагента";
		Иначе
			ТекстПодписиОбщий = ТекстПодписиОбщий + "В бух. учете долг компании";
			ДолгОбщий = (-1) * ДолгОбщий;
		КонецЕсли;

		ТекстПодписиОбщий = ТекстПодписиОбщий + " " +
		               ОбщегоНазначения.ФорматСумм(ДолгОбщий);

	КонецЕсли;

	
	
	// Долг по сделке.
	Если НЕ ЗначениеЗаполнено(ДоговорКонтрагента) Тогда
		Возврат "Введена не вся информация для расчета долга по сделке(договору).";
	КонецЕсли;

	ТекстПодписи = ?(ДоговорКонтрагента.ВедениеВзаиморасчетов = Перечисления.ВедениеВзаиморасчетовПоДоговорам.ПоДоговоруВЦелом,
	               "В т.ч. по договору","В т.ч. по сделке");

	Если ДоговорКонтрагента.ВидДоговора = Перечисления.ВидыДоговоровКонтрагентов.Прочее Тогда
		ТекстПодписи = ТекстПодписи + " """ + Нрег(ДоговорКонтрагента.ВидДоговора) + """";
	Иначе
		ТекстПодписи = ТекстПодписи + " " + Нрег(ДоговорКонтрагента.ВидДоговора);
	КонецЕсли;

	Если Долг = Неопределено Тогда
		ТекстПодписи = ТекстПодписи + " долг не рассчитан";

	ИначеЕсли Долг = 0 Тогда
		ТекстПодписи = ТекстПодписи + " нет долга";

	Иначе
		Если Долг > 0 Тогда
			ТекстПодписи = ТекстПодписи + " долг контрагента";
		Иначе
			ТекстПодписи = ТекстПодписи + " долг компании";
			Долг = (-1) * Долг;
		КонецЕсли;

		ТекстПодписи = ТекстПодписи + " " +
		               ОбщегоНазначения.ФорматСумм(Долг, ДоговорКонтрагента.ВалютаВзаиморасчетов);

	КонецЕсли;
				  
	ТекстПодписи = ТекстПодписиОбщий + ". "  + ТекстПодписи;			   

	Возврат ТекстПодписи;

КонецФункции // ПолучитьТекстДолга()

// Вычисляет текущий долг контрагента по заданному договору и сделке в валюте взаиморасчетов 
// по данному договору
//
// Параметры: 
//  Договор - ссылка на элемент справочника, определяет договор контрагента, по которому надо получить долг, 
//  Сделка  - ссылка на документ, определяет сделку (заказ, накладную, платежный документ) по которому надо получить долг.
//  СсылкаДокумент           - ссылка на документ, для которого рассчитывается долг.
//
// Возвращаемое значение:
//  Число -  текущий размер долга, если удалось вычислить текущий долг, иначе - 0.
//
Функция ТекущийДолг(Договор, Сделка = Неопределено, СсылкаДокумент, МассивСчетов, ПоСделке = Ложь) Экспорт

	ТекущийДолг = 0;
	
		ТекстЗапроса = 
			"ВЫБРАТЬ
			|	ХозрасчетныйОстатки.СуммаОстаток КАК Остаток
			|ИЗ
			|	РегистрБухгалтерии.Хозрасчетный.Остатки(
			|			,
			|			Счет В ИЕРАРХИИ (&Счета),
			|			,
			|			Субконто1 = &Контрагент
			|				И Субконто2 = &Договор
			|				И Субконто3 = &Сделка) КАК ХозрасчетныйОстатки";
		
	
	Если ЗначениеЗаполнено(Договор) Тогда
		
		Если Договор.ВедениеВзаиморасчетов = Перечисления.ВедениеВзаиморасчетовПоДоговорам.ПоДоговоруВЦелом Тогда			
						
			Текст = СтрЗаменить(ТекстЗапроса, "И Субконто3 = &Сделка","");
			
			Если Не ПоСделке Тогда
				 Текст = СтрЗаменить(Текст, "И Субконто2 = &Договор", "");
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.Текст = Текст;
			
			Запрос.УстановитьПараметр("Договор", Договор);
			Запрос.УстановитьПараметр("Контрагент", Договор.Владелец);
			Запрос.УстановитьПараметр("Счета", МассивСчетов);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			Выборка = РезультатЗапроса.Выбрать();
			
			Если Выборка.Следующий() Тогда
				
				ТекущийДолг = Выборка.Остаток;
				
			КонецЕсли;
			
		Иначе // Взаиморасчеты ведутся по сделкам
			Если ЗначениеЗаполнено(Сделка) Тогда
				
				Запрос = Новый Запрос;
								
				Если Не ПоСделке Тогда
					ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И Субконто3 = &Сделка","");
					ТекстЗапроса= СтрЗаменить(ТекстЗапроса, "И Субконто2 = &Договор", "");
				КонецЕсли;
				
				Запрос.Текст = ТекстЗапроса;


				
				Запрос.УстановитьПараметр("Договор", Договор);
				Запрос.УстановитьПараметр("Контрагент", Договор.Владелец);
				Запрос.УстановитьПараметр("Сделка", Сделка);
				Запрос.УстановитьПараметр("Счета", МассивСчетов);
				
				РезультатЗапроса = Запрос.Выполнить();
				
				Выборка = РезультатЗапроса.Выбрать();
				
				Если Выборка.Следующий() Тогда
					
					ТекущийДолг = Выборка.Остаток;
					
				КонецЕсли;
				
			КонецЕсли; 
		КонецЕсли; 
		
	КонецЕсли; 
	
	Возврат ТекущийДолг;
	
КонецФункции // ТекущийДолг()

//Возвращает количество товара в расходной накладной и остаток с учетом всех возвратов
//ДокументСсылка - расходная накладная
Функция ВыборкаОстаткаПоТоварамНакладной(ДокументСсылка,Номенклатура,ХарактеристикаНоменклатуры,УпаковкаНаПечать) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РеализацияТоваровУслугТовары.Количество,
		|	РеализацияТоваровУслугТовары.Цена,
		|	ВложенныйЗапрос.ВозвратКоличество,
		|	РеализацияТоваровУслугТовары.Количество - ЕСТЬNULL(ВложенныйЗапрос.ВозвратКоличество, 0) КАК Остаток,
		|	ВложенныйЗапрос.ВозвратКоличество КАК Вернули
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		|			СУММА(ВозвратТоваровОтПокупателяТовары.Количество) КАК ВозвратКоличество,
		|			ВозвратТоваровОтПокупателяТовары.Номенклатура КАК Номенклатура,
		|			ВозвратТоваровОтПокупателяТовары.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры
		|		ИЗ
		|			Документ.ВозвратТоваровОтПокупателя.Товары КАК ВозвратТоваровОтПокупателяТовары
		|		ГДЕ
		|			ВозвратТоваровОтПокупателяТовары.Номенклатура = &Номенклатура
		|			И ВозвратТоваровОтПокупателяТовары.ХарактеристикаНоменклатуры = &ХарактеристикаНоменклатуры
		|			И ВозвратТоваровОтПокупателяТовары.ДокументПартии = &ДокументСсылка
		|			И ВозвратТоваровОтПокупателяТовары.Ссылка.Проведен = ИСТИНА
		|		
		|		СГРУППИРОВАТЬ ПО
		|			ВозвратТоваровОтПокупателяТовары.Номенклатура,
		|			ВозвратТоваровОтПокупателяТовары.ХарактеристикаНоменклатуры) КАК ВложенныйЗапрос
		|		ПО РеализацияТоваровУслугТовары.Номенклатура = ВложенныйЗапрос.Номенклатура
		|			И РеализацияТоваровУслугТовары.ХарактеристикаНоменклатуры = ВложенныйЗапрос.ХарактеристикаНоменклатуры
		|ГДЕ
		|	РеализацияТоваровУслугТовары.Номенклатура = &Номенклатура
		|	И РеализацияТоваровУслугТовары.ХарактеристикаНоменклатуры = &ХарактеристикаНоменклатуры
		|	И РеализацияТоваровУслугТовары.Ссылка = &ДокументСсылка";
	
	
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("ХарактеристикаНоменклатуры", ХарактеристикаНоменклатуры);
	//Запрос.УстановитьПараметр("umk_УпаковкаНаПечать", УпаковкаНаПечать);

	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выбрать();

	
КонецФункции

