&НаКлиенте
Процедура УстановитьВалютуДокумента()

	Если ЗначениеЗаполнено(Объект.ДоговорКонтрагента) Тогда
			
		Если    Объект.ПоДаннымУправленческогоУчета  
			ИЛИ ЗначениеРеквизитаСервер(Объект.ДоговорКонтрагента,"Внешнеэкономический") Тогда
			
			Объект.ВалютаДокумента = ЗначениеРеквизитаСервер(Объект.ДоговорКонтрагента,"ВалютаВзаиморасчетов");
				
		Иначе
				
			Объект.ВалютаДокумента = мВалютаРегламентированногоУчета;
				
		КонецЕсли;
			
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимость()
	Если ЗначениеЗаполнено(Объект.ДоговорКонтрагента) Тогда
		Элементы.РазбитьПоДоговорам.Доступность = Ложь;
		Объект.РазбитьПоДоговорам= Ложь;
		Элементы.ПоДаннымОрганизацииДоговорКонтрагента.Видимость = Ложь; 
		Элементы.ПоДаннымКонтрагентаДоговорКонтрагента.Видимость = Ложь; 
	Иначе
		Элементы.РазбитьПоДоговорам.Доступность = Истина;
		Элементы.ПоДаннымОрганизацииДоговорКонтрагента.Видимость = Истина; 
		Элементы.ПоДаннымКонтрагентаДоговорКонтрагента.Видимость = Истина;
	КонецЕсли;
	
    Если Объект.РазбитьПоДоговорам Тогда
    	Элементы.ПоДаннымОрганизацииДоговорКонтрагента.Видимость = Истина; 
    	Элементы.ПоДаннымКонтрагентаДоговорКонтрагента.Видимость = Истина; 
		Объект.ПоДаннымОрганизации.Сортировать("ДоговорКонтрагента, Дата,Документ,Представление");		
    Иначе
		Объект.ПоДаннымОрганизации.Сортировать("Дата,Документ,Представление");	
    	Элементы.ПоДаннымОрганизацииДоговорКонтрагента.Видимость = Ложь; 
    	Элементы.ПоДаннымКонтрагентаДоговорКонтрагента.Видимость = Ложь; 
	КонецЕсли;
    Если Объект.ВыводитьПолныеНазванияДокументов Тогда
    	Элементы.ПоДаннымОрганизацииДокумент.Видимость = Ложь; 
    Иначе
    	Элементы.ПоДаннымОрганизацииДокумент.Видимость = Истина;
	КонецЕсли;	

КонецПроцедуры

&НаКлиенте
Процедура УстановитьДоступность()
	
	Если Объект.СверкаСогласована = Истина Тогда
		Элементы.Организация.Доступность		  = Ложь;
		Элементы.ПоДаннымКонтрагента.Доступность  = Ложь;
		Элементы.ПоДаннымОрганизации.Доступность  = Ложь;
		Элементы.Контрагент.Доступность           = Ложь;
		Элементы.ДоговорКонтрагента.Доступность   = Ложь;
		Элементы.ОстатокНаНачало.Доступность      = Ложь;
		Элементы.СписокСчетов.Доступность 		  = ложь;
		Элементы.ВалютаДокумента.Доступность 	  = ложь;
		Элементы.ПериодСверки.Доступность = ложь;
		
		Элементы.ПоДаннымОрганизации.КоманднаяПанель.Доступность	= Ложь;
		Элементы.ПоДаннымКонтрагента.КоманднаяПанель.Доступность	= Ложь;
		Элементы.СписокСчетов.КоманднаяПанель.Доступность        = Ложь;
		Элементы.ПоДаннымУчета.Доступность = Ложь;
		
	Иначе
		Элементы.Организация.Доступность 		  = Истина;
		
		Если ЗначениеРеквизитаСервер(Объект.ДоговорКонтрагента,"ВедениеВзаиморасчетов") 
			    = ПредопределенноеЗначение("Перечисление.ВедениеВзаиморасчетовПоДоговорам.ПоДоговоруВЦелом") Тогда
			Элементы.Сделка.Доступность = Ложь;
		Иначе
			Элементы.Сделка.Доступность = Истина;
		КонецЕсли;
		Элементы.ПоДаннымКонтрагента.Доступность = Истина;
		Элементы.ПоДаннымОрганизации.Доступность = Истина;
		Элементы.Контрагент.Доступность          = Истина;
		Элементы.ДоговорКонтрагента.Доступность  = Истина;
		Элементы.ОстатокНаНачало.Доступность     = Истина;
		Элементы.СписокСчетов.Доступность 		 = Истина;
		
		Если Не ЗначениеЗаполнено(Объект.ДоговорКонтрагента) Тогда
			Элементы.ВалютаДокумента.Доступность   = Истина;
		Иначе
			Элементы.ВалютаДокумента.Доступность   = Ложь;
		КонецЕсли;
		
		Элементы.ПериодСверки.Доступность = Истина;
		
		Элементы.ПоДаннымОрганизации.КоманднаяПанель.Доступность    = Истина;
		Элементы.ПоДаннымКонтрагента.КоманднаяПанель.Доступность    = Истина;
		Элементы.СписокСчетов.КоманднаяПанель.Доступность       	= Истина;
		
		Элементы.ПоДаннымУчета.Доступность = Истина;
		
		Элементы.ГруппаСчетаРасчетов.Видимость = НЕ Объект.ПоДаннымУправленческогоУчета;
		
		//КнопкаЗаполнить = ЭлементыФормы.КоманднаяПанельПоДаннымОрганизации.Кнопки.ПодменюЗаполнить.Кнопки.Заполнить;
		//КнопкаЗаполнить.Текст = НСтр("ru='Заполнить по данным ';uk='Заповнити за даними '") + ?(ПоДаннымУправленческогоУчета, "упр.", "бух.") + НСтр("ru=' учета';uk=' обліку'");
		//КнопкаЗаполнить.Подсказка = НСтр("ru='Заполнить по данным ';uk='Заповнити за даними '") + ?(ПоДаннымУправленческогоУчета, "управленческого", "бухгалтерского") + НСтр("ru=' учета';uk=' обліку'");
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОчиститьТабличныеЧасти(ИмяРеквизита, ОчиститьТЧ = Истина)
	
	Если Объект.ПоДаннымКонтрагента.Количество() > 0 ИЛИ Объект.ПоДаннымОрганизации.Количество() > 0 Тогда
		ТекстВопроса = НСтр("ru='Табличные части ""По данным организации"" и ""По данным контрагента"" будут очищены. Продолжить?';uk='Табличні частини ""За даними організації"" і ""За даними контрагента"" будуть очищені. Продовжити?'");
		ПоказатьВопрос(новый ОписаниеОповещения(ИмяРеквизита + "ПриИзмененииЗавершение",ЭтаФорма),ТекстВопроса,РежимДиалогаВопрос.ДаНет);
	Иначе
		ОчиститьТЧ = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ЗначениеРеквизитаСервер(ОбъектСсылка,ИмяРекизита)
	Возврат ОбъектСсылка[ИмяРекизита] 	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьСписокСчетовЗначениямиПоУмолчанию(ВыдаватьСообщения = Ложь)
	
	Если Объект.СписокСчетов.Количество() > 0 тогда
		
		Если ВыдаватьСообщения Тогда
			
			ТекстВопроса = НСтр("ru='Перед заполнением табличная часть будет очищена. Заполнить?';uk='Перед заповненням таблична частина буде очищена. Заповнити?'");
			ПоказатьВопрос(новый ОписаниеОповещения("ЗаполнитьСписокСчетовЗначениямиПоУмолчаниюЗавершение",ЭтаФорма),ТекстВопроса,РежимДиалогаВопрос.ДаНет);
			Возврат;
		КонецЕсли;
		
		Объект.СписокСчетов.Очистить();
		
	КонецЕсли;
	
	ЗаполнитьСписокСчетов();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСписокСчетовЗначениямиПоУмолчаниюЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Объект.СписокСчетов.Очистить();
		ЗаполнитьСписокСчетов();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокСчетов()
	
	СчетаПоУмолчанию = Новый Массив();
	СчетаПоУмолчанию.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПоставщикамиИПодрядчиками);
	СчетаПоУмолчанию.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПокупателямиИЗаказчиками);
	СчетаПоУмолчанию.Добавить(ПланыСчетов.Хозрасчетный.РасчетыПоВыданнымАвансам);
	СчетаПоУмолчанию.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСДругимиДебиторами);
	СчетаПоУмолчанию.Добавить(ПланыСчетов.Хозрасчетный.РасчетыПоАвансамПолученным);
	СчетаПоУмолчанию.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСДругимиКредиторами);
	
	Для Счетчик =1  По СчетаПоУмолчанию.Количество() Цикл
		СтрокаСчета = Объект.СписокСчетов.Добавить();
		СтрокаСчета.УчаствуетВРасчетах = Истина;
		СтрокаСчета.Счет = СчетаПоУмолчанию[Счетчик-1];
	КонецЦикла; 
		
КонецПроцедуры

&НаСервере
Процедура ПересчитатьОстатки()

	ОстатокНаКонец = Объект.ОстатокНаНачало + Объект.ПоДаннымОрганизации.Итог("Дебет") - Объект.ПоДаннымОрганизации.Итог("Кредит");
	ОстатокНаНачалоКонтрагент= - Объект.ОстатокНаНачало;
	ОстатокНаКонецКонтрагент = - Объект.ОстатокНаНачало + Объект.ПоДаннымКонтрагента.Итог("Дебет") - Объект.ПоДаннымКонтрагента.Итог("Кредит");
	
	Если Расхождение <> ОстатокНаКонец + ОстатокНаКонецКонтрагент Тогда
		Расхождение = ОстатокНаКонец + ОстатокНаКонецКонтрагент;
	КонецЕсли; 
	
	РасхождениеКонтрагент = Расхождение*(-1);
	
	Объект.Расхождение = Расхождение;

КонецПроцедуры

&НаСервере
Процедура СброситьУстановленныйКодНомер()
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	МеханизмНумерацииОбъектов.СброситьУстановленныйКодНомерОбъекта(ДокументОбъект, "Номер");
	ЗначениеВРеквизитФормы(ДокументОбъект, "Объект");
КонецПроцедуры	

#КонецОбласти
