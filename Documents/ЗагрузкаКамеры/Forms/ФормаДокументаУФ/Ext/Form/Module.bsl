// Модуль формы документа ЗагрузкаКамеры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ОбновитьДекорации();
КонецПроцедуры // ПриСозданииНаСервере // + claude

&НаСервере
Процедура ОбновитьДекорации()
	// К-во рам в камере
	Если ЗначениеЗаполнено(Объект.КамераТермообработки) Тогда
		Элементы.КвоРамВКамере.Заголовок = "К-во рам в камере: " + Формат(Объект.КамераТермообработки.КоличествоРам, "ЧДц=0");
	Иначе
		Элементы.КвоРамВКамере.Заголовок = "К-во рам в камере: 0";
	КонецЕсли;

	// Итого к-во ТМЦ
	ИтогоКво = 0;
	Для Каждого Строка Из Объект.ТМЦ Цикл
		ИтогоКво = ИтогоКво + Строка.Кво;
	КонецЦикла;
	Элементы.ИтогоКвоТекст.Заголовок = "Итого к-во: " + Формат(ИтогоКво, "Ч12.2");

	// Итого рам + предупреждение о превышении
	Элементы.ТекстМногоРам.Заголовок = ВернутьКвоРам();
КонецПроцедуры // ОбновитьДекорации // + claude

&НаСервере
Функция ВернутьКвоРам()
	ТЗ = Объект.ТМЦ.Выгрузить();
	ТЗ.Свернуть("ВидРамы", "КвоРам");
	КвоРамИтого = 0;
	Для Каждого Строка Из ТЗ Цикл
		КвоРамИтого = КвоРамИтого + Строка.КвоРам;
	КонецЦикла;

	Если ЗначениеЗаполнено(Объект.КамераТермообработки)
		И Объект.КамераТермообработки.КоличествоРам > 0
		И КвоРамИтого > Объект.КамераТермообработки.КоличествоРам Тогда
		Возврат "Превышено кол-во рам в камере!!!";
	КонецЕсли;

	Возврат "Итого к-во рам: " + Формат(КвоРамИтого, "ЧДц=0");
КонецФункции // ВернутьКвоРам // + claude

&НаКлиенте
Процедура КамераТермообработкиПриИзменении(Элемент)
	КамераТермообработкиПриИзменении_НаСервере();
КонецПроцедуры // КамераТермообработкиПриИзменении // + claude

&НаСервере
Процедура КамераТермообработкиПриИзменении_НаСервере()
	ОбновитьДекорации();
КонецПроцедуры // КамераТермообработкиПриИзменении_НаСервере // + claude

&НаКлиенте
Процедура ПодПрограммаПриИзменении(Элемент)
	ПодПрограммаПриИзменении_НаСервере();
КонецПроцедуры // ПодПрограммаПриИзменении // + claude

&НаСервере
Процедура ПодПрограммаПриИзменении_НаСервере()
	// Пересчитываем время освобождения камеры
	РассчитатьВремяОсвобождения_НаСервере();

	// Очищаем камеру если подпрограмма выполняется вне камеры
	Если ЗначениеЗаполнено(Объект.ПодПрограмма) И Объект.ПодПрограмма.ВнеКамеры Тогда
		Объект.КамераТермообработки = Справочники.КамерыТермообработки.ПустаяСсылка();
	КонецЕсли;

	ОбновитьДекорации();
КонецПроцедуры // ПодПрограммаПриИзменении_НаСервере // + claude

&НаСервере
Процедура РассчитатьВремяОсвобождения_НаСервере()
	Если НЕ ЗначениеЗаполнено(Объект.ПодПрограмма) Тогда
		Возврат;
	КонецЕсли;

	ТекЧасовПрограммы = 0;
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ПроцессПодПрограммыТермообработки.ДлинаПроцесса КАК ДлинаПроцесса
		|ИЗ
		|	Справочник.ПроцессПодПрограммыТермообработки КАК ПроцессПодПрограммыТермообработки
		|ГДЕ
		|	ПроцессПодПрограммыТермообработки.Владелец = &ПодПрограмма
		|	И НЕ ПроцессПодПрограммыТермообработки.ПометкаУдаления";
	Запрос.УстановитьПараметр("ПодПрограмма", Объект.ПодПрограмма);
	Результат = Запрос.Выполнить().Выбрать();
	Пока Результат.Следующий() Цикл
		ТекЧасовПрограммы = ТекЧасовПрограммы + Результат.ДлинаПроцесса;
	КонецЦикла; // Пока Результат.Следующий // + claude

	Объект.ЗанятаМинуты = ТекЧасовПрограммы * 60;

	// Рассчитываем дату и время освобождения камеры
	ОбщоМинут             = (Объект.ЗагруженаЧасы * 60) + Объект.ЗагруженаМинуты + Объект.ЗанятаМинуты;
	Объект.СвободнаДата   = Объект.Дата + Цел(ОбщоМинут / 1440);
	ОстатокМинут          = ОбщоМинут - Цел(ОбщоМинут / 1440) * 1440;
	Объект.СвободнаЧасы  = Цел(ОстатокМинут / 60);
	Объект.СвободнаМинуты = ОстатокМинут - Цел(ОстатокМинут / 60) * 60;

КонецПроцедуры // РассчитатьВремяОсвобождения_НаСервере // + claude

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	// Суммируем итоговое к-во рам по документу
	КвоРамИтого = 0;
	Для Каждого Строка Из ТекущийОбъект.ТМЦ Цикл
		КвоРамИтого = КвоРамИтого + Строка.КвоРам;
	КонецЦикла;
	ТекущийОбъект.ИтогРамПоДокументу = КвоРамИтого;
КонецПроцедуры // ПередЗаписьюНаСервере // + claude

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	// Обновляем поля документа-основания НачалоТермообработки
	Если ЗначениеЗаполнено(ТекущийОбъект.ДокументОснование) Тогда
		ДокОснование = ТекущийОбъект.ДокументОснование.ПолучитьОбъект();
		ДокОснование.НачалоЧасы     = ТекущийОбъект.ЗагруженаЧасы;
		ДокОснование.НачалоМинуты   = ТекущийОбъект.ЗагруженаМинуты;
		ДокОснование.ДокументЗагрузка = ТекущийОбъект.Ссылка;
		ДокОснование.Записать(РежимЗаписиДокумента.Запись);
	КонецЕсли;
КонецПроцедуры // ПослеЗаписиНаСервере // + claude
