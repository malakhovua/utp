// Проверка заполнения шапки
Функция ПроверитьШапку(ОбъектДок, Отказ)

	Если НЕ ЗначениеЗаполнено(ОбъектДок.КамераТермообработки) Тогда
		СообщениеОбОшибке = Новый СообщениеПользователю;
		СообщениеОбОшибке.Текст = "Не заполнена Камера термообработки!";
		СообщениеОбОшибке.Поле = "КамераТермообработки";
		СообщениеОбОшибке.УстановитьДанные(ОбъектДок);
		СообщениеОбОшибке.Сообщить();
		Отказ = Истина;
	КонецЕсли; // Если НЕ ЗначениеЗаполнено КамераТермообработки // + claude

	Если НЕ ЗначениеЗаполнено(ОбъектДок.ПодПрограмма) Тогда
		СообщениеОбОшибке = Новый СообщениеПользователю;
		СообщениеОбОшибке.Текст = "Не заполнена Подпрограмма!";
		СообщениеОбОшибке.Поле = "ПодПрограмма";
		СообщениеОбОшибке.УстановитьДанные(ОбъектДок);
		СообщениеОбОшибке.Сообщить();
		Отказ = Истина;
	КонецЕсли; // Если НЕ ЗначениеЗаполнено ПодПрограмма // + claude

КонецФункции // ПроверитьШапку // + claude

// Проверка заполнения строк ТЧ
Функция ПроверитьСтроки(ОбъектДок, Отказ)

	Для Каждого Строка Из ОбъектДок.ТМЦ Цикл

		Если НЕ ЗначениеЗаполнено(Строка.ТМЦ) Тогда
			СообщениеОбОшибке = Новый СообщениеПользователю;
			СообщениеОбОшибке.Текст = "Не заполнено поле ТМЦ в строке " + Строка.НомерСтроки + "!";
			СообщениеОбОшибке.Поле = "ТМЦ[" + (Строка.НомерСтроки - 1) + "].ТМЦ";
			СообщениеОбОшибке.УстановитьДанные(ОбъектДок);
			СообщениеОбОшибке.Сообщить();
			Отказ = Истина;
			Возврат Ложь;
		КонецЕсли; // Если НЕ ЗначениеЗаполнено ТМЦ // + claude

	КонецЦикла; // Для Каждого Строка // + claude

	Возврат Истина;

КонецФункции // ПроверитьСтроки // + claude

// Расчет времени освобождения камеры на основании подпрограммы
Процедура РассчитатьВремяОсвобождения(ОбъектДок)

	Если НЕ ЗначениеЗаполнено(ОбъектДок.ПодПрограмма) Тогда
		Возврат;
	КонецЕсли; // Если НЕ ЗначениеЗаполнено ПодПрограмма // + claude

	ТекЧасовПрограммы = 0;
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ПроцессПодПрограммыТермообработки.ДлинаПроцесса КАК ДлинаПроцесса
		|ИЗ
		|	Справочник.ПроцессПодПрограммыТермообработки КАК ПроцессПодПрограммыТермообработки
		|ГДЕ
		|	ПроцессПодПрограммыТермообработки.Владелец = &ПодПрограмма
		|	И НЕ ПроцессПодПрограммыТермообработки.ПометкаУдаления";
	Запрос.УстановитьПараметр("ПодПрограмма", ОбъектДок.ПодПрограмма);
	Результат = Запрос.Выполнить().Выбрать();
	Пока Результат.Следующий() Цикл
		ТекЧасовПрограммы = ТекЧасовПрограммы + Результат.ДлинаПроцесса;
	КонецЦикла; // Пока Результат.Следующий // + claude

	ОбъектДок.ЗанятаМинуты = ТекЧасовПрограммы * 60;

	// Рассчитываем время освобождения камеры
	ОбщоМинут                 = (ОбъектДок.ЗагруженаЧасы * 60) + ОбъектДок.ЗагруженаМинуты + ОбъектДок.ЗанятаМинуты;
	ОбъектДок.СвободнаДата    = ОбъектДок.Дата + Цел(ОбщоМинут / 1440);
	ОстатокМинут              = ОбщоМинут % 1440;
	ОбъектДок.СвободнаЧасы   = Цел(ОстатокМинут / 60);
	ОбъектДок.СвободнаМинуты = ОстатокМинут % 60;

КонецПроцедуры // РассчитатьВремяОсвобождения // + claude

// Обработка проведения документа
Процедура ОбработкаПроведения(Отказ, РежимПроведения)

	ПроверитьШапку(ЭтотОбъект, Отказ);
	Если Отказ Тогда
		Возврат;
	КонецЕсли; // Если Отказ // + claude

	ПроверитьСтроки(ЭтотОбъект, Отказ);

КонецПроцедуры // ОбработкаПроведения // + claude

// Заполнение на основании НачалоТермообработки
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)

	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.НачалоТермообработки") Тогда

		СтандартнаяОбработка = Ложь;
		ДокОснование = ДанныеЗаполнения.ПолучитьОбъект();

		ДокументОснование = ДанныеЗаполнения;
		ПодПрограмма      = ДокОснование.ПодПрограмма;
		Дата              = ДокОснование.Дата;

		Для Каждого СтрокаОснования Из ДокОснование.ТМЦ Цикл
			НоваяСтрока                      = ТМЦ.Добавить();
			НоваяСтрока.ТМЦ                  = СтрокаОснования.ТМЦ;
			НоваяСтрока.ВидРамы              = СтрокаОснования.ВидРамы;
			НоваяСтрока.Кво                  = СтрокаОснования.Кво;
			НоваяСтрока.КвоРам               = СтрокаОснования.КвоРам;
			НоваяСтрока.ОтчетПроизводства    = ДокОснование.ОтчетПроизводства;
			НоваяСтрока.НачалоТермообработки = ДанныеЗаполнения;
		КонецЦикла; // Для Каждого СтрокаОснования // + claude

		РассчитатьВремяОсвобождения(ЭтотОбъект);

	КонецЕсли; // Если ТипЗнч НачалоТермообработки // + claude

КонецПроцедуры // ОбработкаЗаполнения // + claude
