Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	
	// Дерево значений, содержащее имена необходимых полей в запросе по шапке.
	Перем ДеревоПолейЗапросаПоШапке;
	
	// Выполним проверку реквизитов необхоимых для проведения
	ТекстОшибки = "";
	ВыполнитьПроверкуРеквизитов(Отказ, ТекстОшибки);
	
	#Если Клиент Тогда
		Если Отказ Тогда
			Текст = "Ошибка проведения документа. " + ТекстОшибки;
		    Сообщить(Текст, СтатусСообщения.Важное);
		КонецЕсли;
	#КонецЕсли	


	Если мУдалятьДвижения Тогда
		ОбщегоНазначения.УдалитьДвиженияРегистратора(ЭтотОбъект, Отказ);
	КонецЕсли;

	СтруктураШапкиДокумента = ОбщегоНазначения.СформироватьСтруктуруШапкиДокумента(ЭтотОбъект);
	
	// Заголовок для сообщений об ошибках проведения.
	Заголовок = ОбщегоНазначения.ПредставлениеДокументаПриПроведении(СтруктураШапкиДокумента);
	
	Если СтруктураШапкиДокумента.ОтражатьВБухгалтерскомУчете Тогда		
		ПроверкаАктуальностиУчета(СтруктураШапкиДокумента, Заголовок);
	КонецЕсли;

	// Заполним по шапке документа дерево параметров, нужных при проведении.
	ДеревоПолейЗапросаПоШапке = ОбщегоНазначения.СформироватьДеревоПолейЗапросаПоШапке();
	ОбщегоНазначения.ДобавитьСтрокуВДеревоПолейЗапросаПоШапке(ДеревоПолейЗапросаПоШапке, "Константы",        "ВалютаУправленческогоУчета",                 "ВалютаУправленческогоУчета");
	ОбщегоНазначения.ДобавитьСтрокуВДеревоПолейЗапросаПоШапке(ДеревоПолейЗапросаПоШапке, "Константы",        "КурсВалютыУправленческогоУчета",             "КурсВалютыУправленческогоУчета");
	ОбщегоНазначения.ДобавитьСтрокуВДеревоПолейЗапросаПоШапке(ДеревоПолейЗапросаПоШапке, "УчетнаяПолитика" , "ВестиПартионныйУчетПоСкладам",               "ВестиПартионныйУчетПоСкладам");
	ОбщегоНазначения.ДобавитьСтрокуВДеревоПолейЗапросаПоШапке(ДеревоПолейЗапросаПоШапке, "Склад",            "ВидСклада",                                  "ВидСклада");
	ОбщегоНазначения.ДобавитьСтрокуВДеревоПолейЗапросаПоШапке(ДеревоПолейЗапросаПоШапке, "Склад",            "СуммовойУчет",                      		 "СуммоваяРозница");

	// Сформируем запрос на дополнительные параметры, нужные при проведении, по данным шапки документа
	СтруктураШапкиДокумента = УправлениеЗапасами.СформироватьЗапросПоДеревуПолей(ЭтотОбъект, ДеревоПолейЗапросаПоШапке, СтруктураШапкиДокумента, мВалютаРегламентированногоУчета);

	// Получим данные учетной политики
	ПодготовитьПараметрыУчетнойПолитики(СтруктураШапкиДокумента, Отказ, Заголовок);

	// Проверим правильность заполнения шапки документа
	ПроверитьЗаполнениеШапки(СтруктураШапкиДокумента, Отказ, Заголовок);

	// Подготовим таблицы для проведения.
	ТаблицаПоТоварам = ПодготовитьТаблицуТоваров(СтруктураШапкиДокумента);
	

	// Движения по документу
	Если Не Отказ Тогда
		ДвиженияПоРегистрам(РежимПроведения, СтруктураШапкиДокумента, ТаблицаПоТоварам,  Отказ, Заголовок);
	КонецЕсли;
	
	Движения.Хозрасчетный.ВыполнитьДействияПередЗаписьюДвижений();
	
	// Движения по регистру Показания Спидометра
	ПоказанияСпидометра = Движения.umk_ПоказанияСпидометраАвто;
	Движение = ПоказанияСпидометра.Добавить();
	Движение.Период = Дата;
	Движение.ОсновноеСредство = Автомобиль;
	Движение.ПоказаниеСпидометра = СпидометрПр; // по приезду
	Движение.Регистратор = Ссылка;
	Движение.Активность = Истина;
	
	Движения.Хозрасчетный.Записывать = Истина;
	Движения.ТоварыОрганизаций.Записывать = Истина;
	Движения.СписанныеТовары.Записывать = Истина;
	Движения.ПартииТоваровНаСкладах.Записывать = Истина;	
	Движения.umk_ПоказанияСпидометраАвто.Записывать = Истина;
	
КонецПроцедуры // ОбработкаПроведения()

// Выполним проверку реквизитов необхоимых для проведения
Процедура ВыполнитьПроверкуРеквизитов(Отказ, Текст)
	
	Текст = "";
	
	ТМЦ_  =  ЗначениеЗаполнено(ТМЦ);
	ТМЦА_ =  ЗначениеЗаполнено(ТМЦА);
	
	КвоГорючего_  = ЗначениеЗаполнено(КвоГорючего);
	КвоАГорючего_ = ЗначениеЗаполнено(КвоАГорючего);
	
	КвоЗаправлено_  = ЗначениеЗаполнено(КвоЗаправлено);
	КвоЗаправленоА_ = ЗначениеЗаполнено(КвоЗаправленоА);
	
	СкладПрих_ = ЗначениеЗаполнено(СкладПрих);
	
	КвоКуплено_  = ЗначениеЗаполнено(КвоКуплено);
	КвоКупленоА_ = ЗначениеЗаполнено(КвоКупленоА);
	
	СуммаПокупки_ = ЗначениеЗаполнено(СуммаПокупки);
	СуммаПокупкиА_ = ЗначениеЗаполнено(СуммаПокупкиА);
		
	Если  (КвоГорючего_ 
		ИЛИ КвоЗаправлено_  
		ИЛИ КвоКуплено_) И
		ТМЦ_ = Ложь
		Тогда
		Отказ = Истина;
		Текст = "Не заполнен реквизит ""Топливо"" .";
		Возврат;
	КонецЕсли;
	
	Если  (КвоАГорючего_ 
		ИЛИ КвоЗаправленоА_  
		ИЛИ КвоКупленоА_) И
		ТМЦА_ = Ложь
		Тогда
		Отказ = Истина;
		Текст = "Не заполнен реквизит ""Топливо альт."" .";
		Возврат;
	КонецЕсли;
	
	Если  (КвоЗаправлено_ 
		ИЛИ КвоЗаправленоА_) И
		СкладПрих_ = Ложь
		Тогда
		Отказ = Истина;
		Текст = "Не заполнен реквизит ""Склад прихода"" .";
		Возврат;
	КонецЕсли;
	
	Если  КвоКуплено_  И
		СуммаПокупки_ = Ложь
		Тогда
		Отказ = Истина;
		Текст = "Не заполнен реквизит ""Сумма"" .";
		Возврат;
	КонецЕсли;
	
	Если  КвоКупленоА_  И
		СуммаПокупкиА_ = Ложь
		Тогда
		Отказ = Истина;
		Текст = "Не заполнен реквизит ""Сумма альт."" .";
		Возврат;
	КонецЕсли;
	
	Если НЕ ТМЦ_
		И НЕ ТМЦА_
		Тогда
		Отказ = Истина;
		Текст = "Не заполнены реквизиты ""Топливо"" .";
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

// Заправка ГСМ
Процедура СоздатьДокументПеремещение(Отказ, РежимЗаписи) Экспорт
		
	Если (НЕ ЗначениеЗаполнено(КвоЗаправлено) ИЛИ  НЕ ЗначениеЗаполнено(КвоЗаправленоА)) // Убрали топливо. Уберем перемещение.
		И ЗначениеЗаполнено(ПеремещениеЗапр) Тогда 
		
		ПеремещениеОбъект = ПеремещениеЗапр.ПолучитьОбъект();
		ПеремещениеОбъект.Товары.Очистить();
		
		Попытка
			ПеремещениеОбъект.Записать(РежимЗаписи);
		Исключение
			Сообщить("Не удалось записать документ Перемещение товаров.", СтатусСообщения.Важное);
			Отказ = Истина;
		КонецПопытки;
	КонецЕсли;
	
	// Создадим перемещение.
	
	Если ЗначениеЗаполнено(КвоЗаправлено) ИЛИ  ЗначениеЗаполнено(КвоЗаправленоА) Тогда 
		
		Если НЕ ЗначениеЗаполнено(ПеремещениеЗапр) Тогда
			ПеремещениеОбъект = Документы.ПеремещениеТоваров.СоздатьДокумент();
		Иначе
			ПеремещениеОбъект = ПеремещениеЗапр.ПолучитьОбъект();
		КонецЕсли;	
		
		ПеремещениеОбъект.Дата = НачалоДня(Дата);
		
		// Заполнить реквизиты значениями по умолчанию.
		ЗаполнениеДокументов.ЗаполнитьШапкуДокумента(ПеремещениеОбъект, глЗначениеПеременной("глТекущийПользователь"));
		ОбщегоНазначения.ЗаполнитьОбязательныеРеквизитыШапкиНовогоДокумента(ПеремещениеОбъект, глЗначениеПеременной("глТекущийПользователь"));
		ПеремещениеОбъект.ВидОперации      = Перечисления.ВидыОперацийПеремещениеТоваров.ТоварыПродукция;
		
		ПеремещениеОбъект.СкладОтправитель = СкладПрих;
		ПеремещениеОбъект.СкладПолучатель  = Склад;
		ПеремещениеОбъект.Комментарий = "##Путевой лист. Заправка ГСМ.##";
		ПеремещениеОбъект.Товары.Очистить();
		
		Если ЗначениеЗаполнено(КвоЗаправлено) тогда
			ДобавитьСтрокуВПеремещение(ПеремещениеОбъект, КвоЗаправлено, ТМЦ);	
		КонецЕсли;
		
		Если ЗначениеЗаполнено(КвоЗаправленоА) тогда
			ДобавитьСтрокуВПеремещение(ПеремещениеОбъект, КвоЗаправленоА, ТМЦА)
		КонецЕсли;
			
	
	Попытка
		ПеремещениеОбъект.Записать(РежимЗаписи);
		ПеремещениеЗапр = ПеремещениеОбъект.Ссылка;
	Исключение
		Сообщить("Не удалось записать документ Перемещение товаров.", СтатусСообщения.Важное);
		Отказ = Истина;
	КонецПопытки;
	
	КонецЕсли;

		
КонецПроцедуры

Процедура ДобавитьСтрокуВПеремещение(ПеремещениеОбъект, Количество, Номенклатура)
	
	СтрокаТабличнойЧасти = ПеремещениеОбъект.Товары.Добавить();
	СтрокаТабличнойЧасти.Номенклатура = Номенклатура;
	СтрокаТабличнойЧасти.Количество = Количество;
	// Выполнить общие действия для всех документов при изменении номенклатуры.
	ОбработкаТабличныхЧастей.ПриИзмененииНоменклатурыТабЧасти(СтрокаТабличнойЧасти, ПеремещениеОбъект);
	
	// Берем из самого реквизита Номенклатура
	СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтрокаТабличнойЧасти.Номенклатура.ЕдиницаХраненияОстатков;
	СтрокаТабличнойЧасти.Коэффициент      = СтрокаТабличнойЧасти.ЕдиницаИзмерения.Коэффициент;
	
	ОбработкаТабличныхЧастей.ЗаполнитьЕдиницуМестТабЧасти(СтрокаТабличнойЧасти, ПеремещениеОбъект);
	СтрокаТабличнойЧасти.Качество = Справочники.Качество.Новый;
    	
	ПеремещениеОбъект.ЗаполнитьСчетаУчетаВСтрокеТабЧасти(СтрокаТабличнойЧасти, "Товары", ПеремещениеОбъект.ОтражатьВБухгалтерскомУчете, ПеремещениеОбъект.ОтражатьВБухгалтерскомУчете);
	СтрокаТабличнойЧасти.НалоговоеНазначение = Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_Облагаемая;
	
КонецПроцедуры

// Процедура определяет параметры учетной политики
//
Процедура ПодготовитьПараметрыУчетнойПолитики(СтруктураШапкиДокумента, Отказ, Заголовок)
	
	УчетнаяПолитикаНеЗадана = Ложь;
	мУчетнаяПолитикаБУ = ОбщегоНазначения.ПолучитьПараметрыУчетнойПолитики(Ссылка.Дата, УчетнаяПолитикаНеЗадана, Ссылка.Организация, "Бух");

	УчетнаяПолитикаНеЗадана = Ложь;
	мУчетнаяПолитикаНУ = ОбщегоНазначения.ПолучитьПараметрыУчетнойПолитики(Ссылка.Дата, УчетнаяПолитикаНеЗадана, Ссылка.Организация, "Нал");
		
	СтруктураШапкиДокумента.Вставить("ЕстьНалогНаПрибыльДо2015", мУчетнаяПолитикаНУ.ЕстьНалогНаПрибыльДо2015);
	СтруктураШапкиДокумента.Вставить("ЕстьНДС", 			мУчетнаяПолитикаНУ.ЕстьНДС);
	
КонецПроцедуры // ПодготовитьПараметрыУчетнойПолитики()

Процедура ПроверкаАктуальностиУчета(СтруктураШапкиДокумента, Заголовок)
	
	Если Константы.НеИспользоватьДатуАктуальностиУчета.Получить() ИЛИ НЕ Константы.ИнформироватьЕслиУчетНеАктуален.Получить() Тогда
		Возврат;
	КонецЕсли;
	
	МассивРазделовУчета = Новый Массив;
	// в каких видах учета должен отражаться документ
	МассивРазделовУчета.Добавить(Перечисления.РазделыУчета.ОценкаМПЗ);
	ОбщегоНазначения.СообщитьОНеактуальностиУчета(СтруктураШапкиДокумента, МассивРазделовУчета, Заголовок);

КонецПроцедуры

Процедура ОбновитьПараметрыУчетнойПолитики(Дата,Организация, СообщатьОбОшибке = Истина) Экспорт 
	
	УчетнаяПолитикаНеЗадана = Ложь;
	мУчетнаяПолитикаБУ = ОбщегоНазначения.ПолучитьПараметрыУчетнойПолитики(Ссылка.Дата, УчетнаяПолитикаНеЗадана, Ссылка.Организация, "Бух", СообщатьОбОшибке);

	УчетнаяПолитикаНеЗадана = Ложь;
	мУчетнаяПолитикаНУ = ОбщегоНазначения.ПолучитьПараметрыУчетнойПолитики(Ссылка.Дата, УчетнаяПолитикаНеЗадана, Ссылка.Организация, "Нал", СообщатьОбОшибке);

	БУ = ПланыСчетов.Хозрасчетный.ТоварыВРозничнойТорговлеВПродажныхЦенахНТТ.ПолучитьОбъект();
	мИспользоватьОборотнуюНоменклатуру = ?(БУ.ВидыСубконто.Найти(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Номенклатура, "ВидСубконто") = Неопределено, Ложь, Истина);
	мРазделятьПоСтавкамНДС  = ?(БУ.ВидыСубконто.Найти(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.СтавкиНДС, "ВидСубконто") = Неопределено, Ложь, Истина);

	БУ = ПланыСчетов.Хозрасчетный.ТоварыНаСкладе.ПолучитьОбъект();

	ВестиСкладскойУчетБУ  = ?(БУ.ВидыСубконто.Найти(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Склады, "ВидСубконто") = Неопределено, Ложь, Истина);
	ВестиУчетПоДопРазрезамРегл  = ?(БУ.ВидыСубконто.Найти(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.НоменклатурныеПозиции, "ВидСубконто") = Неопределено, Ложь, Истина);

КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	
	ОбщегоНазначения.УдалитьДвиженияРегистратора(ЭтотОбъект, Отказ);

КонецПроцедуры

мВалютаРегламентированногоУчета = глЗначениеПеременной("ВалютаРегламентированногоУчета");

ОбновитьПараметрыУчетнойПолитики(Ссылка.Дата,Ссылка.Организация, Ложь);
