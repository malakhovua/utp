// ЭКСПОРТНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ ДОКУМЕНТА

#Если Клиент Тогда
		
// Функция формирует табличный документ с печатной формой накладной,
// разработанной методистами
//
// Возвращаемое значение:
//  Табличный документ - печатная форма накладной
//
Функция ПечатьДокумента()
	
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ПутевойЛист";

	
    Макет = ПолучитьМакет("ПутевойЛист");
 	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПутевойЛист.Дата,
		|	ПутевойЛист.Спидометр,
		|	ПутевойЛист.Автомобиль.НаименованиеПолное КАК Автомобиль,
		|	ПутевойЛист.ДатаВыезда,
		|	ПутевойЛист.ВремяВыезда,
		|	ПутевойЛист.Водитель.ФизЛицо.Ссылка КАК Водитель1,
		|	ПутевойЛист.Водитель2.Физлицо.Ссылка КАК Водитель2,
		|	ПутевойЛист.ТМЦ КАК Горючее,
		|	ПутевойЛист.КвоЗаправлено + ПутевойЛист.КвоЗаправленоА КАК КвоЗаправлено,
		|	ПутевойЛист.КвоКуплено + ПутевойЛист.КвоКупленоА КАК КвоКуплено,
		|	ПутевойЛист.КвоГорючего,
		|	ПутевойЛист.Организация.НаименованиеПолное КАК Организация,
		|	ПутевойЛист.Организация.Ссылка,
		|	ПутевойЛист.КвоЗаправленоА,
		|	ПутевойЛист.КвоКупленоА
		|ИЗ
		|	Документ.ПутевойЛист КАК ПутевойЛист
		|ГДЕ
		|	ПутевойЛист.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	
	Выборка.Следующий();
	
	Шапка = Макет.ПолучитьОбласть("Шапка");
	Шапка.Параметры.Заполнить(Выборка);
	
	Водитель_ = "";
	
	Если ЗначениеЗаполнено(Выборка.Водитель1) Тогда
		
		ДанныеФЛ = ОбщегоНазначения.ДанныеФизЛица(Выборка.ОрганизацияСсылка, Выборка.Водитель1, Выборка.Дата);

		Водитель_ = Водитель_ + ДанныеФЛ.Представление + " №" + 
		ПолучитьНомерДокумента(Выборка.Водитель1, Перечисления.umk_ВидыДокументов.ВП);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Выборка.Водитель2) Тогда
		
		ДанныеФЛ = ОбщегоНазначения.ДанныеФизЛица(Выборка.ОрганизацияСсылка, Выборка.Водитель2, Выборка.Дата);
		
		Водитель_ = Водитель_ + ", " + ДанныеФЛ.Представление + " №" + 
		ПолучитьНомерДокумента(Выборка.Водитель2, Перечисления.umk_ВидыДокументов.ВП);
	КонецЕсли;
	
	Шапка.Параметры.Водитель = Водитель_;
	
	ДатаВремяВыезда = Выборка.ДатаВыезда + 
	(Выборка.ВремяВыезда - НачалоДня(Выборка.ВремяВыезда));
	
	Шапка.Параметры.ДатаВремяВыезда = ДатаВремяВыезда;
	
	//КоличествоГСМ = ОстатокГорючего() + Выборка.КвоЗаправлено + Выборка.КвоКуплено - Выборка.КвоГорючего;  // тут ???
	КоличествоГСМ = Выборка.КвоЗаправлено + Выборка.КвоКуплено;
	
	Шапка.Параметры.КоличествоГСМ = КоличествоГСМ;
	
	ТабДокумент.Вывести(Шапка);
	
	Регион = Макет.ПолучитьОбласть("Регион");
	
	Регион.Параметры.Заполнить(Выборка);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПутевойЛистМаршруты.Регион,
		|	ПутевойЛистМаршруты.КМ,
		|	ПутевойЛистМаршруты.ВесГруза / 1000 КАК ВесГруза
		|ИЗ
		|	Документ.ПутевойЛист.Маршруты КАК ПутевойЛистМаршруты
		|ГДЕ
		|	ПутевойЛистМаршруты.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Результат = Запрос.Выполнить();
	
	ТаблицаПоРегионам = Результат.Выгрузить();
	Регион.Параметры.ИтогКМ = ТаблицаПоРегионам.Итог("КМ");
	Регион.Параметры.ВесГруза = ТаблицаПоРегионам.Итог("ВесГруза"); 
	
	ВыборкаПоРегионам = Результат.Выбрать();
	
	Регионы = "";
	
	Пока ВыборкаПоРегионам.Следующий() Цикл
		Регионы = Регионы + ?(ВыборкаПоРегионам.Регион = "","","-") + 
		            СокрЛП(ВыборкаПоРегионам.Регион.Наименование);
	КонецЦикла;
	
	Регион.Параметры.Регионы = Регионы;
	
	ТабДокумент.Вывести(Регион);
	ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
	
	Страница2 = Макет.ПолучитьОбласть("Страница2");
	
	Страница2.Параметры.Заполнить(Выборка);
    Страница2.Параметры.ИтогКМ = ТаблицаПоРегионам.Итог("КМ");
	
	ТабДокумент.Вывести(Страница2);

	
	Возврат ТабДокумент
	
КонецФункции // ПечатьДокумента()

Функция ПолучитьНомерДокумента(ФизЛицо, ВидДокумента)
	 	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	umk_НомераДокументов.Номер
		|ИЗ
		|	РегистрСведений.umk_НомераДокументов КАК umk_НомераДокументов
		|ГДЕ
		|	umk_НомераДокументов.ФизЛицо = &ФизЛицо
		|	И umk_НомераДокументов.ВидыДокументов = &ВидыДокументов";
	
	Запрос.УстановитьПараметр("ВидыДокументов", ВидДокумента);
	Запрос.УстановитьПараметр("ФизЛицо", ФизЛицо);
	
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	
	Выборка.Следующий();
	
	Возврат Выборка.Номер
	
КонецФункции

Функция ОстатокГорючего(Номенклатура) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ХозрасчетныйОстатки.КоличествоОстаток
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.Остатки(
		|			&Дата,
		|			Счет В ИЕРАРХИИ (&Счет),
		|			,
		|			Субконто1 = &Номенклатура" + 
		?(ЗначениеЗаполнено(Склад)," И Субконто2 = &Склад", "") +
        ?(ЗначениеЗаполнено(Партия) И 
		      НЕ Партия = "Партия по умолчанию" ," И Субконто3 = &Партия","") + " ) КАК ХозрасчетныйОстатки";
	
	Запрос.УстановитьПараметр("Дата", КонецДня(Дата));
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Партия", Партия);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Счет", ПланыСчетов.Хозрасчетный.ПроизводственныеЗапасы);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.КоличествоОстаток
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции

// Процедура осуществляет печать документа. Можно направить печать на 
// экран или принтер, а также распечатать необходмое количество копий.
//
//  Название макета печати передается в качестве параметра,
// по переданному названию находим имя макета в соответствии.
//
// Параметры:
//  НазваниеМакета - строка, название макета.
//
Процедура Печать(ИмяМакета, КоличествоЭкземпляров = 1, НаПринтер = Ложь, НепосредственнаяПечать = Ложь) Экспорт
	
	// Получить экземпляр документа на печать
	Если ИмяМакета = "ПутевойЛист" Тогда
		ТабДокумент = ПечатьДокумента();
	КонецЕсли;
		
	УниверсальныеМеханизмы.НапечататьДокумент(ТабДокумент, КоличествоЭкземпляров, НаПринтер, ОбщегоНазначения.СформироватьЗаголовокДокумента(ЭтотОбъект), Ссылка);

КонецПроцедуры // Печать

#КонецЕсли

// Возвращает доступные варианты печати документа
//
// Вовращаемое значение:
//  Струткура, каждая строка которой соответствует одному из вариантов печати
//  
Функция ПолучитьСтруктуруПечатныхФорм() Экспорт
	
	СтруктураМакетов = Новый Структура();
	
	СтруктураМакетов.Вставить("ПутевойЛист"    , "Путевой лист");
	
	Возврат СтруктураМакетов;
	
КонецФункции // ПолучитьСтруктуруПечатныхФорм()

