// ОБРАБОТЧИКИ СОБЫТИЙ

//  Формирует движения по взаиморасчетам с работниками
//
// Параметры:
//		ВыборкаПоШапкеДокумента - спозиционированная выборка по шапке документа
//		НаборЗаписей - набор записей 
//      Перерасчет - признак проведения перерасчетов, по умолчанию - Ложь
//      Физлица - список физлиц, по которым производится расчет, по умолчанию - отсутствует
//
// Возвращаемое значение:
//  Нет.
//		
Процедура СформироватьОстаткиВзаиморасчетыСРаботниками(ВыборкаПоШапкеДокумента, НаборЗаписей )
	
	Запрос = Новый Запрос();
	
	// Установим параметры запроса
	Запрос.УстановитьПараметр("парамСсылка"  , Ссылка);
	
	ТекстЗапроса = "
	|	ВЫБРАТЬ     
	|		Основные.Сотрудник 					КАК Сотрудник,
	|		Основные.Счет 						КАК Счет,
	|		Основные.БазовыйПериодНачало 		КАК БазовыйПериодНачало,
	|		СУММА(Основные.Результат) 			КАК Сумма
	|
	|	ИЗ	Документ.ВводНачальныхОстатковПоЗарплате.Начисления КАК Основные
	|	ГДЕ	  Основные.Ссылка = &парамСсылка
	|
	|СГРУППИРОВАТЬ ПО
	|		Основные.Сотрудник,
	|		Основные.Счет,
	|		Основные.БазовыйПериодНачало
	|";
	
	Запрос.Текст = ТекстЗапроса;
	
	Доходы = Запрос.Выполнить().Выбрать();
	// сформируем движения ВзаиморасчетыСРаботникамиОрганизаций
	Пока Доходы.Следующий() Цикл
		
		Если Доходы.Сумма = 0  Тогда
			Продолжить;
		КонецЕсли;
		
		Движение = НаборЗаписей.Добавить();
		
		// свойства                              
		Движение.Период 				= ВыборкаПоШапкеДокумента.ПериодРегистрации;
		Движение.ВидДвижения			= ВидДвиженияНакопления.Приход;
		
		// измерения 
		Движение.Сотрудник 				= Доходы.Сотрудник;
		Движение.Организация 			= ВыборкаПоШапкеДокумента.Организация;          
		Движение.ПериодВзаиморасчетов 	= ВыборкаПоШапкеДокумента.ПериодРегистрации;
		Движение.СчетУчета				= Доходы.Счет;
		
		Движение.КодОперации			= Перечисления.КодыОперацийВзаиморасчетыСРаботникамиОрганизаций.Начисления;

		СтруктураКурса = РегистрыСведений.КурсыВалютДляРасчетовСПерсоналом.ПолучитьПоследнее(ПериодРегистрации, Новый Структура("Валюта", глЗначениеПеременной("ВалютаУправленческогоУчета")));
		мКурс = СтруктураКурса.Курс*СтруктураКурса.Кратность;
		// ресурсы
		Если ОтражатьВРеглУчете И Не ОтражатьВУпрУчете Тогда
			Движение.СуммаВзаиморасчетов 	= Доходы.Сумма;
		ИначеЕсли ОтражатьВУпрУчете И Не ОтражатьВРеглУчете Тогда
			Движение.СуммаВзаиморасчетовУпр 	= Доходы.Сумма;
		Иначе
			Движение.СуммаВзаиморасчетов 	= Доходы.Сумма;
			Движение.СуммаВзаиморасчетовУпр = ?(мКурс = 0, 0, Доходы.Сумма/мКурс);
		КонецЕсли;
			
	КонецЦикла;
	
КонецПроцедуры   // СформироватьОстаткиВзаиморасчетыСРаботниками

Процедура СформироватьОстаткиВзаиморасчетыПоВзносамВФонды( ВыборкаПоШапкеДокумента, НаборЗаписей )
	
	Запрос = Новый Запрос();
	
	// Установим параметры запроса
	Запрос.УстановитьПараметр("парамСсылка"  , Ссылка);
	
	ТекстЗапроса = 
	"ВЫБРАТЬ                          
	|	Доходы.СтатьяНалоговойДекларации    КАК СтатьяНалоговойДекларации,
	|	Доходы.БазовыйПериодНачало        	КАК БазовыйПериодНачало,
	|	Доходы.Налог        				КАК Налог,
	|	СУММА(Доходы.БазаВзноса)     		КАК База,
	|	СУММА(Доходы.БазаВзноса) 			КАК БазаВзноса,
	|	СУММА(Доходы.Результат) 			КАК Результат
	|	
	|	ИЗ	Документ.ВводНачальныхОстатковПоЗарплате.Взносы КАК Доходы
	|	ГДЕ   Доходы.Ссылка = &парамСсылка
	|
	|СГРУППИРОВАТЬ ПО
	|	Доходы.СтатьяНалоговойДекларации,
	|	Доходы.БазовыйПериодНачало,
	|	Доходы.Налог
	|";
	
	Запрос.Текст = ТекстЗапроса;
	Доходы = Запрос.Выполнить().Выбрать();
	
	// сформируем движения ВзаиморасчетыСРаботникамиОрганизаций
	Пока Доходы.Следующий() Цикл
		
		Если Доходы.БазаВзноса = 0 И Доходы.Результат  = 0 Тогда
			Продолжить;
		КонецЕсли; 
		
		Если Доходы.СтатьяНалоговойДекларации = Неопределено
			ИЛИ Доходы.СтатьяНалоговойДекларации  = Справочники.СтатьиНалоговыхДеклараций.ПустаяСсылка()
			Тогда
			Продолжить;
		КонецЕсли; 
		
		Движение = НаборЗаписей.Добавить();
		
		// свойства                              
		Движение.Период 				= ВыборкаПоШапкеДокумента.ПериодРегистрации;
		Движение.ВидДвижения			= ВидДвиженияНакопления.Приход;
		
		// измерения 
		Движение.Организация 			= Организация; 
		
		Движение.СтатьяНалоговойДекларации  = Доходы.СтатьяНалоговойДекларации;
		Движение.ПериодВзаиморасчетов		= ВыборкаПоШапкеДокумента.ПериодРегистрации;
		Движение.Налог						= Доходы.Налог;
		
		// ресурсы
		Движение.База		= Доходы.БазаВзноса;
		Движение.БазаВзноса	= Доходы.БазаВзноса;
		Движение.Результат	= Доходы.Результат;
		
	КонецЦикла;
	
КонецПроцедуры   // СформироватьОстаткиВзаиморасчетыПоВзносамВФонды

Процедура СформироватьОстаткиВзаиморасчетыПоНДФЛ( ВыборкаПоШапкеДокумента ) Экспорт
	
	// Создадим запрос и установим параметры запроса
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("парамРегистратор", Ссылка);
	
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	СтрокиНДФЛ.Сотрудник,
	|	СтрокиНДФЛ.БазовыйПериодНачало,
	|	СтрокиНДФЛ.ДоходНДФЛ,
	|	СтрокиНДФЛ.ВидСтавки,
	|	СтрокиНДФЛ.Льгота,
	|	СтрокиНДФЛ.КоличествоЛьгот,
	|	СУММА(СтрокиНДФЛ.Доход) КАК Доход,
	|	СУММА(СтрокиНДФЛ.Результат) КАК Налог,
	|	СУММА(СтрокиНДФЛ.ДоходВыплата) КАК ДоходВыплата,
	|	СУММА(СтрокиНДФЛ.РезультатВыплата) КАК НалогВыплата
	|ИЗ
	|	Документ.ВводНачальныхОстатковПоЗарплате.НДФЛ КАК СтрокиНДФЛ
	|
	|ГДЕ  СтрокиНДФЛ.Ссылка  = &парамРегистратор
	|
	|СГРУППИРОВАТЬ ПО
	|	СтрокиНДФЛ.Сотрудник,
	|	СтрокиНДФЛ.БазовыйПериодНачало,
	|	СтрокиНДФЛ.ДоходНДФЛ,
	|	СтрокиНДФЛ.ВидСтавки,
	|	СтрокиНДФЛ.Льгота,
	|	СтрокиНДФЛ.КоличествоЛьгот
	|";
	
	ВыборкаПоСтрокамДокумента = Запрос.Выполнить().Выбрать();
	
	СтруктураКурса = РегистрыСведений.КурсыВалютДляРасчетовСПерсоналом.ПолучитьПоследнее(ПериодРегистрации, Новый Структура("Валюта", глЗначениеПеременной("ВалютаУправленческогоУчета")));
	мКурс = СтруктураКурса.Курс*СтруктураКурса.Кратность;
	
	// сформируем движения ВзаиморасчетыСРаботникамиОрганизаций
	Пока ВыборкаПоСтрокамДокумента.Следующий() Цикл
		
		Если ВыборкаПоСтрокамДокумента.Налог <> 0 ИЛИ ВыборкаПоСтрокамДокумента.Доход <> 0 Тогда
			Движение = Движения.ВзаиморасчетыПоНДФЛ.Добавить();
			
			Движение.Период			= НачалоМесяца(ВыборкаПоШапкеДокумента.ПериодРегистрации);
			Движение.ВидДвижения	= ВидДвиженияНакопления.Приход;
			
			// Измерения
			Движение.Сотрудник		= ВыборкаПоСтрокамДокумента.Сотрудник;
			Движение.Организация	= ВыборкаПоШапкеДокумента.Организация;
			
			Движение.НалоговыйПериод 	= НачалоМесяца(ВыборкаПоСтрокамДокумента.БазовыйПериодНачало); 

			// если это переасчет, то путь он ляжет на поледний месяц периода
			Движение.ПериодВзаиморасчетов	= ВыборкаПоСтрокамДокумента.БазовыйПериодНачало;
			Движение.ДоходНДФЛ			= ВыборкаПоСтрокамДокумента.ДоходНДФЛ;
			Движение.ВидСтавки			= ВыборкаПоСтрокамДокумента.ВидСтавки;
			Движение.Льгота				= ВыборкаПоСтрокамДокумента.Льгота;
			
			// Ресурсы
			Движение.Налог		= ВыборкаПоСтрокамДокумента.Налог;
			Движение.Доход		= ВыборкаПоСтрокамДокумента.Доход;
			Если ОтражатьВРеглУчете И ОтражатьВУпрУчете Тогда
				Движение.НалогУпр = ?(мКурс = 0, 0, ВыборкаПоСтрокамДокумента.Налог/мКурс);
			КонецЕсли;
			
			// Реквизиты 
			Движение.КоличествоЛьгот = ВыборкаПоСтрокамДокумента.КоличествоЛьгот;
			
		КонецЕсли;
		
		Если ВыборкаПоСтрокамДокумента.НалогВыплата <> 0 ИЛИ ВыборкаПоСтрокамДокумента.ДоходВыплата <> 0 Тогда
			Движение = Движения.ВзаиморасчетыПоНДФЛ.Добавить();
			
			Движение.Период			= НачалоМесяца(ВыборкаПоШапкеДокумента.ПериодРегистрации);
			Движение.ВидДвижения	= ВидДвиженияНакопления.Расход;
			
			// Измерения
			Движение.Сотрудник		= ВыборкаПоСтрокамДокумента.Сотрудник;
			Движение.Организация	= ВыборкаПоШапкеДокумента.Организация;
			
			// если это переасчет, то путь он ляжет на поледний месяц периода
			Движение.ПериодВзаиморасчетов	= ВыборкаПоСтрокамДокумента.БазовыйПериодНачало;
			Движение.ДоходНДФЛ			= ВыборкаПоСтрокамДокумента.ДоходНДФЛ;
			Движение.ВидСтавки			= ВыборкаПоСтрокамДокумента.ВидСтавки;
			Движение.Льгота				= ВыборкаПоСтрокамДокумента.Льгота;
			
			// Ресурсы
			Движение.Налог		= ВыборкаПоСтрокамДокумента.НалогВыплата;
			Движение.Доход		= ВыборкаПоСтрокамДокумента.ДоходВыплата;
			Если ОтражатьВРеглУчете И ОтражатьВУпрУчете Тогда
				Движение.НалогУпр = ?(мКурс = 0, 0, ВыборкаПоСтрокамДокумента.Налог/мКурс);
			КонецЕсли;
			
			// Реквизиты 
			Движение.КоличествоЛьгот = ВыборкаПоСтрокамДокумента.КоличествоЛьгот;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры // СформироватьОстаткиВзаиморасчетыПоНДФЛ()



Процедура ОбработкаПроведения(Отказ, Режим)
	
	Если мУдалятьДвижения Тогда
    	ОбщегоНазначения.УдалитьДвиженияРегистратора(ЭтотОбъект, Отказ);
	КонецЕсли;
	
	// Сформируем структуру реквизитов шапки документа
	СтруктураШапкиДокумента = ОбщегоНазначения.СформироватьСтруктуруШапкиДокумента(ЭтотОбъект);
	
	// Заголовок для сообщений об ошибках проведения.
	Заголовок = ОбщегоНазначения.ПредставлениеДокументаПриПроведении(СтруктураШапкиДокумента);
	
	Если ОтражатьВУпрУчете И НЕ ОтражатьВРеглУчете И НЕ ЗначениеЗаполнено(Организация) Тогда
		НеПроверятьОрганизацию = Истина;
	Иначе
		// Получим данные учетной политики
		СтруктураПолейУчетнойПолитикиНУ = Новый Структура("ЕстьНалогНаПрибыль");
		ОбщегоНазначения.ДополнитьПоложениямиУчетнойПолитики(СтруктураШапкиДокумента, СтруктураШапкиДокумента.Дата, Отказ, СтруктураШапкиДокумента.Организация, "Нал",СтруктураПолейУчетнойПолитикиНУ);
		НеПроверятьОрганизацию = Ложь;
	КонецЕсли;
	
		
	// При получении учетной политики произошли ошибки
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	
	ПроверитьЗаполнениеШапки(Отказ, НеПроверятьОрганизацию);
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	ВыборкаПоОтражениюВУчете = СформироватьЗапросПоОтражениюВУчете().Выбрать();
	ВалютаРеглУчета  = глЗначениеПеременной("ВалютаРегламентированногоУчета");
	
	Пока ВыборкаПоОтражениюВУчете.Следующий() Цикл
		
		ПроверитьЗаполнениеСтрокиОтраженияВУчете(ВыборкаПоОтражениюВУчете, Отказ, Заголовок);
		
		Если Не Отказ Тогда
			ДобавитьСтрокуВДвиженияПоОтражениюВУчете(СтруктураШапкиДокумента, ВыборкаПоОтражениюВУчете, ВалютаРеглУчета);
		КонецЕсли;
		
	КонецЦикла;
	
	Движения.Хозрасчетный.ВыполнитьДействияПередЗаписьюДвижений();
	
	
	////////////////////////////////////////////////////////////////////////
	// взаиморасчеты с работниками
	
	// сформируем начисления к выплате по начислениям документа
	СформироватьОстаткиВзаиморасчетыСРаботниками(СтруктураШапкиДокумента, Движения.ВзаиморасчетыСРаботникамиОрганизаций );
	
	////////////////////////////////////////////////////////////////////////
	// Взаиморасчеты с бюджетом по взносам в фонды
	СформироватьОстаткиВзаиморасчетыПоВзносамВФонды( СтруктураШапкиДокумента, Движения.ВзаиморасчетыПоВзносамВФонды );
	
	//////////////////////////////////////////////////////////////////////////
	//// НДФЛ
	// получим реквизиты табличной части
	СформироватьОстаткиВзаиморасчетыПоНДФЛ( СтруктураШапкиДокумента );
	
КонецПроцедуры // ОбработкаПроведения()

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	КраткийСоставДокумента = ПроцедурыУправленияПерсоналом.ЗаполнитьКраткийСоставДокумента(РаботникиОрганизации);
	ПроцедурыУправленияПерсоналом.ЗаполнитьФизЛицоПоТЧ(РаботникиОрганизации);
	
	мУдалятьДвижения = НЕ ЭтоНовый();
	
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	
	ОбщегоНазначения.УдалитьДвиженияРегистратора(ЭтотОбъект, Отказ);
	
КонецПроцедуры

мПустойСчет = ПланыСчетов.Хозрасчетный.ПустаяСсылка();
мСведенияОСчетах = Новый Соответствие;
мСведенияОСтатьяхЗатрат = Новый Соответствие;
