// Формирует запрос по шапке документа
//
// Параметры: 
//  нет
//
// Возвращаемое значение:
//  Результат запроса
//
Функция СформироватьЗапросПоШапке() Экспорт
	
	Запрос = Новый Запрос;
	
	// Установим параметры запроса
	Запрос.УстановитьПараметр("ДокументСсылка" , Ссылка);
	Запрос.УстановитьПараметр("парамПустаяОрганизация", Справочники.Организации.ПустаяСсылка());
	
	Запрос.Текст = "
	|ВЫБРАТЬ 
	|	Дата                                               	КАК Дата, 
	|	ПериодРегистрации                                  	КАК ПериодРегистрации, 
	|	ВЫБОР КОГДА Организация.ГоловнаяОрганизация = &парамПустаяОрганизация 
	|			ТОГДА Организация 
	|			ИНАЧЕ Организация.ГоловнаяОрганизация 
	|		  КОНЕЦ                                         КАК ГоловнаяОрганизация, 
	|	Организация											КАК Организация, 
	|	Организация											КАК ОбособленноеПодразделение, 
	| 	Ссылка                                              КАК Ссылка
	| 
	|	ИЗ	Документ.ВводНачальныхОстатковПоЗарплате
	| 
	|ГДЕ	Ссылка = &ДокументСсылка
	|";
	
	Возврат Запрос.Выполнить();
	
КонецФункции // СформироватьЗапросПоШапке()

// проверяет должен ли быть указан или нет счет учета по НУ
//
// Параметры
//  СчетДт,СчетКт - счета хозрасчетного плана счетов
//  СчетДтНУ	  - счет налогового плана счетов - будущий счет дебета
//
// Возвращаемое значение:
//   булево   – если сочетание корректно, то истина
//
Функция КорректноеСочетаниеСчетов(Выборка,Сообщение)
	
	Сообщение = "";
	
	СчетКт = Выборка.СчетКт;
	СчетДт = Выборка.СчетДт;
	
	Если (СчетДт = ПланыСчетов.Хозрасчетный.РасчетыПоОплатеТруда 
		или СчетДт = ПланыСчетов.Хозрасчетный.ПрочиеФинансовыеДоходы) Тогда
		Сообщение = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Проводки в дебет %1 не должны отражаться в налоговом учете!';uk='Проводки в дебет %1 не повинні відображатись в податковому обліку!'"), Выборка.НаименованиеСчетДт);
	КонецЕсли;
	
	Возврат НЕ ЗначениеЗаполнено(Сообщение)
	
КонецФункции // КорректноеСочетаниеСчетов()


////////////////////////////////////////////////////////////////////////////////
// ЭКСПОРТНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

Процедура АвтозаполнениеПроводок() Экспорт
	
	ОтражениеВУчете.Очистить();
	Записать();  // запишем документ, чтобы обратится к нему через запрос
	
	СформироватьПроводкиНачисления();
	СформироватьПроводкиВзносы();
	СформироватьПроводкиНДФЛ();
	
КонецПроцедуры  // АвтозаполнениеПроводок

// Заполняет табличную часть РаботникиОрганизации, всеми физ лицами, которые числятся на конец периода по указанным координатам, 
// их дыижения и внутреннее совместительство 
// Всех не уволенных на конец ПериодаРасчета документа
// А за одно и создает пустые строки по табличным частям
//
Функция АвтозаполнениеРаботникиОрганизации() экспорт
	
	Запрос = Новый Запрос;
	
	// Установим параметры запроса
	Запрос.УстановитьПараметр("парамНачало" , НачалоМесяца(ПериодРегистрации));
	Запрос.УстановитьПараметр("парамКонец" , КонецМесяца(ПериодРегистрации));
	Запрос.УстановитьПараметр("парамОрганизация" , Организация);
	Запрос.УстановитьПараметр("парамПользователь" , Ответственный);
	Запрос.УстановитьПараметр("парамПодразделение" , ПодразделениеОрганизации);
	Запрос.УстановитьПараметр("парамВнутреннийСовместитель" , Перечисления.ВидыЗанятостиВОрганизации.ВнутреннееСовместительство);
	
	Запрос.УстановитьПараметр("Уволен", Перечисления.ПричиныИзмененияСостояния.Увольнение);
	
 	// Проверим ответсвенного - является ли он расчетчиком вообще и для заданного 
 	// подразделения (если оно задано)
 
 	ПустоеПодразделение = Справочники.ПодразделенияОрганизаций.ПустаяСсылка();
	// Описание условий	
	Если ПодразделениеОрганизации = ПустоеПодразделение Тогда
		
		ПоВсемПодразделениямОрганизации = Истина;
		УсловиеНаПодразделение = "ПодразделениеОрганизации.Владелец = &парамОрганизация";
		
	Иначе
		
		ПоВсемПодразделениямОрганизации = Ложь;
		УсловиеНаПодразделение = "ПодразделениеОрганизации В ИЕРАРХИИ (&парамПодразделение)";
		
	КонецЕсли;
	
	// Текст запроса: срез работников на конец месяца
	Если ЗначениеЗаполнено(Организация) Тогда
		ТекстЗапросаАвтозаполнениеРаботники = "
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Работники.Сотрудник КАК Сотрудник
		|ИЗ
		|	РегистрСведений.РаботникиОрганизаций.СрезПоследних(&парамКонец, Организация = &парамОрганизация) КАК Работники
		|		
		|ГДЕ 
		|	Работники.ЗанимаемыхСтавок > 0 
		|	И Работники.Сотрудник.ОсновноеНазначение = ЗНАЧЕНИЕ(Справочник.СотрудникиОрганизаций.ПустаяСсылка) 
		|	"+?(ПоВсемПодразделениямОрганизации, "", "И Работники."+УсловиеНаПодразделение)+"
		|";
	Иначе
		ТекстЗапросаАвтозаполнениеРаботники = "
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Работники.Ссылка КАК Сотрудник
		|ИЗ
		|	Справочник.СотрудникиОрганизаций КАК Работники
		|		
		|ГДЕ 
		|	Работники.Организация = &парамОрганизация 
		|	И Работники.ДатаНачала < &парамНачало 
		|	"+?(ПоВсемПодразделениямОрганизации, "", "И Работники."+УсловиеНаПодразделение)+"
		|";
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапросаАвтозаполнениеРаботники;
	
	РезультатЗапроса = Запрос.Выполнить();
    РаботникиОрганизации.Загрузить(РезультатЗапроса.Выгрузить());
	АвтозаполнениеСтрокиРаботникаОрганизации(РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Сотрудник"));

КонецФункции // АвтозаполнениеРаботникиОрганизации()

Процедура АвтозаполнениеСтрокиРаботникаОрганизации(Сотрудники)

	// Создадим запрос и установим его параметры
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("парамРегистратор" , Ссылка);
	Запрос.УстановитьПараметр("парамОрганизация" , Организация);
	Запрос.УстановитьПараметр("ПериодРегистрации", ПериодРегистрации);
	Запрос.УстановитьПараметр("парамСотрудник"   , Сотрудники);
	
	//	ВТВзносыПоСотрудникамПоПериодам
	Если Истина Тогда 
		//	Описание:
		// 		Все сотрудники из табличной части, их внутренние совместительства и все сотрудники которых замещали
		//		Для п.1.
		ТекстЗапроса = "
		|	ВЫБРАТЬ
		|		ВзносыПоПериодам.Сотрудник		КАК Сотрудник,
		|		ВзносыПоПериодам.Налог			КАК Налог,
		|		ВзносыПоПериодам.Период			КАК Период,
		|		ВзносыАктуальность.Актуальность	КАК Актуальность
		|ПОМЕСТИТЬ ВТВзносыПоСотрудникамПоПериодам	
		|	ИЗ	(
		|		ВЫБРАТЬ
		|			Взносы.Сотрудник			КАК Сотрудник,
		|			Взносы.Налог				КАК Налог,
		|			МАКСИМУМ( Взносы.Период )	КАК Период
		|
		|		ИЗ	РегистрСведений.ВзносыВФондыРаботниковОрганизаций КАК Взносы
		|
		|		ГДЕ		Взносы.Сотрудник в ( &парамСотрудник )
		| 			И   Взносы.Организация в ( &парамОрганизация )
		|       	И	(Взносы.Период < &ПериодРегистрации
		|           // прием на работу
		|       	ИЛИ	Взносы.Актуальность И НАЧАЛОПЕРИОДА(Взносы.Период, МЕСЯЦ) = &ПериодРегистрации)
		|           // увольнение с работы
		|       	И	НЕ (НЕ Взносы.Актуальность И НАЧАЛОПЕРИОДА(Взносы.Период, МЕСЯЦ) = &ПериодРегистрации)
		|		СГРУППИРОВАТЬ ПО
		|			Взносы.Сотрудник,
		|			Взносы.Налог
		|)	КАК ВзносыПоПериодам
		|
		|	ЛЕВОЕ СОЕДИНЕНИЕ	( 
		|		ВЫБРАТЬ
		|			Взносы.Сотрудник			КАК Сотрудник,
		|			Взносы.Налог				КАК Налог,
		|			Взносы.Период				КАК Период,
		|			Взносы.Актуальность			КАК Актуальность
		|
		|		ИЗ	РегистрСведений.ВзносыВФондыРаботниковОрганизаций КАК Взносы
		|
		|		ГДЕ		Взносы.Сотрудник в ( &парамСотрудник )
		| 			И   Взносы.Организация в ( &парамОрганизация )
		|       	И	НАЧАЛОПЕРИОДА(Взносы.Период, МЕСЯЦ) <= &ПериодРегистрации
		
		| )	КАК ВзносыАктуальность
		|	ПО		ВзносыАктуальность.Сотрудник	= ВзносыПоПериодам.Сотрудник
		|		И	ВзносыАктуальность.Налог		= ВзносыПоПериодам.Налог
		|		И	ВзносыАктуальность.Период		= ВзносыПоПериодам.Период
		|
		|	ГДЕ ВзносыАктуальность.Актуальность
		|
		|";
		Запрос.Текст = ТекстЗапроса;
		Запрос.Выполнить();
	КонецЕсли; 
	Запрос.Текст = "ВЫБРАТЬ * ИЗ ВТВзносыПоСотрудникамПоПериодам";
	
	ТекстЗапроса = "
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Работники.Сотрудник								КАК Сотрудник,
	|	СведенияОВзносах.Налог							КАК Налог,
	|	Параметры.СчетУчета								КАК СчетУчета,
	|	ШкалаСтавокНалогов.СтатьяНалоговойДекларации	КАК СтатьяНалоговойДекларации
	|
	|ИЗ	РегистрСведений.РаботникиОрганизаций.СрезПоследних(&ПериодРегистрации, Организация в (&парамОрганизация)) КАК Работники
	|
	|ЛЕВОЕ СОЕДИНЕНИЕ ВТВзносыПоСотрудникамПоПериодам КАК СведенияОВзносах
	| ПО    СведенияОВзносах.Сотрудник	=	Работники.Сотрудник
	//|		И &ПериодРегистрации	>=	СведенияОВзносах.Период
	|				
	|ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ШкалаСтавокНалогов.СрезПоследних(&ПериодРегистрации,НомерПорога = ЗНАЧЕНИЕ(Перечисление.ПорогиШкалыСтавокНалогов.Порог1)) КАК ШкалаСтавокНалогов
	|	ПО	ШкалаСтавокНалогов.Налог	=	СведенияОВзносах.Налог
	|	И	ШкалаСтавокНалогов.НомерПорога	= ЗНАЧЕНИЕ(Перечисление.ПорогиШкалыСтавокНалогов.Порог1)
	|				
	|ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПараметрыПлатежныхДокументовПоВзносамВФонды КАК Параметры
	|ПО Работники.Организация = Параметры.Организация
	|И (ШкалаСтавокНалогов.СтатьяНалоговойДекларации.Родитель = Параметры.СтатьяНалоговойдекларации
	|   ИЛИ ШкалаСтавокНалогов.СтатьяНалоговойдекларации = """" И Параметры.СтатьяНалоговойдекларации = &пустаяСтатьяНалоговойдекларации)
	|				
	|ГДЕ Работники.Сотрудник в (&парамСотрудник)	            
	|				
	|ИТОГИ ПО Сотрудник
	|				
	|";
	
	Запрос.УстановитьПараметр("парамПустаяДата"  , Дата('00010101'));
	Запрос.УстановитьПараметр("пустаяСтатьяНалоговойдекларации", Справочники.СтатьиНалоговыхДеклараций.ПустаяСсылка());
	Запрос.Текст = ТекстЗапроса;
	ВыборкаСотрудник = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Сотрудник");
	
	Код01 = Справочники.ВидыДоходовНДФЛ.Код01;
	ВидСтавкиОсновная = Перечисления.ВидыСтавокНДФЛ.Основная;
	
	Пока ВыборкаСотрудник.Следующий() Цикл
		
		// Начисления
		НоваяСтрока = Начисления.Добавить();
		НоваяСтрока.Сотрудник			= ВыборкаСотрудник.Сотрудник;
		НоваяСтрока.БазовыйПериодНачало	= ПериодРегистрации;
		НоваяСтрока.Счет				= ПланыСчетов.Хозрасчетный.РасчетыПоЗаработнойПлате;
		
		// НФДЛ         
		НоваяСтрока = НДФЛ.Добавить();
		НоваяСтрока.Сотрудник			= ВыборкаСотрудник.Сотрудник;
		НоваяСтрока.ВидСтавки           = ВидСтавкиОсновная;
		НоваяСтрока.ДоходНДФЛ           = Код01;
		НоваяСтрока.БазовыйПериодНачало	= ПериодРегистрации;
		НоваяСтрока.Счет				= ПланыСчетов.Хозрасчетный.РасчетыПоНДФЛ;
		
	КонецЦикла;
	
	ВыборкаВзносы = Запрос.Выполнить().Выгрузить();
	ВыборкаВзносы.Свернуть("Налог,СчетУчета,СтатьяНалоговойДекларации");
	ВыборкаВзносы.Сортировать("СчетУчета");
	Для Каждого Взнос из ВыборкаВзносы Цикл
		Если Взнос.Налог = NULL Тогда
			Продолжить;
		КонецЕсли;
		НоваяСтрока = Взносы.Добавить();
		НоваяСтрока.Налог						= Взнос.Налог;
		НоваяСтрока.СтатьяНалоговойДекларации	= Взнос.СтатьяНалоговойДекларации;
		НоваяСтрока.Счет						= Взнос.СчетУчета;
		НоваяСтрока.БазовыйПериодНачало			= ПериодРегистрации;

	КонецЦикла;	
	
КонецПроцедуры // АвтозаполнениеВзносы



///////////////////////////////////////////////////////////////////////////
// общие функции для всех Автозаполнений

Функция ДобавитьСтрокуВПроводкиНачисления(ДанныеУчета)
	
	СтрокаДанных = ОтражениеВУчете.Добавить();
	
	// ресурсы
	СтрокаДанных.Сумма			= ДанныеУчета.Сумма;
	
	// реквизиты
	СтрокаДанных.СчетДт      = ПланыСчетов.Хозрасчетный.Вспомогательный;
	
	СтрокаДанных.СчетКт      = ДанныеУчета.Счет;
	СтрокаДанных.СубконтоКт1 = ДанныеУчета.Сотрудник.ФизЛицо;
	
	Возврат СтрокаДанных;
	
КонецФункции     // ДобавитьСтрокуВПроводкиНачисления()

Функция ДобавитьСтрокуВПроводкиВзносы(ДанныеУчета)
	
	СтрокаДанных = ОтражениеВУчете.Добавить();
	
	// ресурсы
	СтрокаДанных.Сумма			= ДанныеУчета.Сумма;
	
	// реквизиты
	СтрокаДанных.СчетДт      = ПланыСчетов.Хозрасчетный.Вспомогательный;
	
	СтрокаДанных.СчетКт      = ДанныеУчета.СчетКт;
	СтрокаДанных.СубконтоКт1 = ДанныеУчета.СубконтоКт1;
	СтрокаДанных.СубконтоКт2 = ДанныеУчета.СубконтоКт2;
	
	Возврат СтрокаДанных;
	
КонецФункции     // ДобавитьСтрокуВПроводкиНачисления()

Функция ДобавитьСтрокуВПроводкиНДФЛ(ДанныеУчета)
	
	СтрокаДанных = ОтражениеВУчете.Добавить();
	
	// ресурсы
	СтрокаДанных.Сумма			= ДанныеУчета.Сумма;
	
	// реквизиты
	СтрокаДанных.СчетДт      = ПланыСчетов.Хозрасчетный.Вспомогательный;
	
	СтрокаДанных.СчетКт      = ДанныеУчета.СчетКт;
	
	Возврат СтрокаДанных;
	
КонецФункции     // ДобавитьСтрокуВПроводкиНачисления()


