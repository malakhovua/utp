					ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, 2, СтрокаАкцизногоНалога.СхемаРеализации.СубконтоВычетовИзДоходов2);
					ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, 3, СтрокаАкцизногоНалога.СхемаРеализации.СубконтоВычетовИзДоходов3);
					ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "НоменклатурныеГруппы", СтрокаАкцизногоНалога.НоменклатурнаяГруппа);
						
				Иначе
					Проводка.Содержание  = НСтр("ru='Акцизный налог розничной выручки';uk='Акцизний податок роздрібного виторгу'",Локализация.КодЯзыкаИнформационнойБазы());
