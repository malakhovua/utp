							Проводка.СуммаНУКт = Проводка.Сумма;
						КонецЕсли;
					КонецЕсли;
					
				КонецЕсли; 
				
			КонецЦикла;
			
		КонецЕсли; 

		Если Дата >= глЗначениеПеременной("ДатаНачалаИспользованияСчетаРозничнаяВыручкаВКассахККМ") Тогда
			
