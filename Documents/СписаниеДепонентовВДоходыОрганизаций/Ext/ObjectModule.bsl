// Выполняет автоматическое заполнение документа 
// 
// Параметры: 
//  нет
//
// Возвращаемое значение:
//  нет
//
Процедура Автозаполнение() Экспорт

	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("ЧерезКассу",Перечисления.СпособыВыплатыЗарплаты.ЧерезКассу);
	Запрос.УстановитьПараметр("НеВыплачено",Перечисления.ВыплаченностьЗарплаты.НеВыплачено);
	Запрос.УстановитьПараметр("Задепонировано",Перечисления.ВыплаченностьЗарплаты.Задепонировано);
	Запрос.УстановитьПараметр("Организация",Организация);
	Запрос.УстановитьПараметр("Регистратор", Ссылка);
	Запрос.УстановитьПараметр("Дата",?(ЭтоНовый(),КонецДня(Дата),Дата));
	Запрос.УстановитьПараметр("ВидвыплатыДепонент", Справочники.ВидыВыплат.Депоненты);
	
	Запрос.Текст = "
	|ВЫБРАТЬ 
	|	Зарплата.Ссылка КАК Ведомость,
	|	Зарплата.ВидВзаиморасчетов КАК ВидВзаиморасчетов,
	|	Зарплата.СчетУчета КАК СчетУчета,
	|	СУММА(Зарплата.Выплата) КАК СуммаКВыплате
	|ИЗ	Документ.ЗарплатаКВыплатеОрганизаций.Зарплата КАК Зарплата
	|
	|ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗарплатаКВыплатеОрганизаций.РаботникиОрганизации КАК ПараметрыВедомости
	|ПО	Зарплата.Ссылка = ПараметрыВедомости.Ссылка
	|И	Зарплата.Физлицо = ПараметрыВедомости.Физлицо
	|И	ПараметрыВедомости.СпособВыплаты = &ЧерезКассу 
	|И	ПараметрыВедомости.ВыплаченностьЗарплаты = &Задепонировано  
	|
	|ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОВыплатахРаботникамОрганизацийПоПлатежнымВедомостям КАК РанееВыплаченныеСуммы
	|ПО Зарплата.Ссылка = РанееВыплаченныеСуммы.Ведомость
	|И Зарплата.Физлицо = РанееВыплаченныеСуммы.Физлицо
	|И РанееВыплаченныеСуммы.Регистратор <> &Регистратор
	|
	|ГДЕ Зарплата.Ссылка.Организация = &Организация
	|И	Зарплата.Ссылка.ВидВыплаты <> &ВидвыплатыДепонент
	|И	Зарплата.Ссылка.Дата <= &Дата
	|И	Зарплата.Выплата > 0
	|И	РанееВыплаченныеСуммы.Физлицо ЕСТЬ NULL 
 	|
	|
	|СГРУППИРОВАТЬ ПО 
	|	Зарплата.Ссылка,
	|	Зарплата.ВидВзаиморасчетов,
	|	Зарплата.СчетУчета
	|";
	
	ВыплатаЗаработнойПлаты.Загрузить(Запрос.Выполнить().Выгрузить());
	
КонецПроцедуры //  Автозаполнение

Процедура АвтозаполнениеСписаниеДепонента() Экспорт 
	
	// Заполнение ТЧ Зарплата и Работники
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("парамДата",	Дата);
	Запрос.УстановитьПараметр("парамНачало", СписаниеДепонентаНаДату);
	Запрос.УстановитьПараметр("парамОрганизация", Организация);
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	Взаиморасчеты.Сотрудник			КАК Сотрудник,
	|	Взаиморасчеты.Ведомость			КАК Ведомость,
	|	Взаиморасчеты.СуммаОстаток		КАК Сумма
	|ИЗ
	|	РегистрНакопления.ВзаиморасчетыСДепонентамиОрганизаций.Остатки( &парамДата,
	|			Организация = &парамОрганизация	И	Ведомость.ПериодРегистрации <= &парамНачало
	|    ) КАК Взаиморасчеты
	|";
	
	Запрос.Текст = ТекстЗапроса;
	Работники.Загрузить( Запрос.Выполнить().Выгрузить() );
	
КонецПроцедуры // Автозаполнение_ОсновнаяВыплата()

