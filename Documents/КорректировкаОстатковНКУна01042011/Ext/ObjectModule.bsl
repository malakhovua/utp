		ИначеЕсли РазделУчета = Перечисления.РазделыУчетаДляКорректировкиОстатковНКУна01042011.ЗапасыСебестоимость 
		      ИЛИ РазделУчета = Перечисления.РазделыУчетаДляКорректировкиОстатковНКУна01042011.ЗапасыПереданные Тогда
			  			
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "Номенклатура",          СтрокаЗапасы.Номенклатура);
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "Партии",                СтрокаЗапасы.Партия);
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "Склады",                СтрокаЗапасы.Склад);      // ЗапасыСебестоимость
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "Контрагенты",           СтрокаЗапасы.Контрагент); // ЗапасыПереданные
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "НоменклатурныеПозиции", СтрокаЗапасы.НоменклатурнаяПозиция);
			
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "Номенклатура",          СтрокаЗапасы.Номенклатура);
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "Партии",                СтрокаЗапасы.Партия);
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "Склады",                СтрокаЗапасы.Склад);      // ЗапасыСебестоимость
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "Контрагенты",           СтрокаЗапасы.Контрагент); // ЗапасыПереданные
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "НоменклатурныеПозиции", СтрокаЗапасы.НоменклатурнаяПозиция);
			
			// Счет исключение 286
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "ОсновныеСредства", СтрокаЗапасы.Номенклатура);
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "ОсновныеСредства", СтрокаЗапасы.Номенклатура);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ФормированиеПроводокБух_ТоварыПоПродажнойЦене(ТоварыПоПродажнойЦене, АТТ)
	
	Операция = Движения.Хозрасчетный;
	
	Для Каждого СтрокаЗапасы Из ТоварыПоПродажнойЦене Цикл
						
		// Товары на розничном складе
		Проводка = СформироватьПроводкуБух(Операция, СтрокаЗапасы);				
		Проводка.Сумма     = СтрокаЗапасы.СуммаПродажи;
		Проводка.СуммаНУДт = СтрокаЗапасы.СуммаПродажи;
				
		Если АТТ Тогда
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "Номенклатура",          СтрокаЗапасы.Номенклатура);
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "Номенклатура",          СтрокаЗапасы.Номенклатура);
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "Партии",                СтрокаЗапасы.Партия);			
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "Партии",                СтрокаЗапасы.Партия);
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "НоменклатурныеПозиции", СтрокаЗапасы.НоменклатурнаяПозиция);
		Иначе			
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "СтавкиНДС", СтрокаЗапасы.СтавкаНДС);
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "СтавкиНДС", СтрокаЗапасы.СтавкаНДС);
		КонецЕсли;
		ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "Склады", СтрокаЗапасы.Склад);
		ОбщегоНазначения.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "Склады", СтрокаЗапасы.Склад);
							
		// Торговая наценка
		ТорговаяНаценка   = СтрокаЗапасы.СуммаПродажи - СтрокаЗапасы.Сумма;	
		ТорговаяНаценкаНУ = СтрокаЗапасы.СуммаПродажи - ПолучитьСуммуНУСтроки(СтрокаЗапасы);	
		
		Если ТорговаяНаценка = 0 И ТорговаяНаценкаНУ = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Проводка = Операция.Добавить();
		Проводка.Период      = СтруктураШапкиДокумента.Дата;
		Проводка.Организация = СтруктураШапкиДокумента.Организация;
		Проводка.Содержание  = мСодержаниеПроводки;
		
		Проводка.Сумма       = ТорговаяНаценка;
		
		Если АТТ Тогда
			Проводка.СчетДт = ПланыСчетов.Хозрасчетный.ТорговаяНаценкаАТТ;
			Проводка.СчетКт = ПланыСчетов.Хозрасчетный.ТорговаяНаценкаАТТ;
			
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "Номенклатура",          СтрокаЗапасы.Номенклатура);
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "Номенклатура",          СтрокаЗапасы.Номенклатура);
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "Партии",                СтрокаЗапасы.Партия);			
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "Партии",                СтрокаЗапасы.Партия);
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "НоменклатурныеПозиции", СтрокаЗапасы.НоменклатурнаяПозиция);
		Иначе			
			Проводка.СчетДт = ПланыСчетов.Хозрасчетный.ТорговаяНаценкаНТТ;
			Проводка.СчетКт = ПланыСчетов.Хозрасчетный.ТорговаяНаценкаНТТ;
			
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "СтавкиНДС", СтрокаЗапасы.СтавкаНДС);
			ОбщегоНазначения.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "СтавкиНДС", СтрокаЗапасы.СтавкаНДС);
		КонецЕсли;
		ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "Склады", СтрокаЗапасы.Склад);
		ОбщегоНазначения.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "Склады", СтрокаЗапасы.Склад);
		
		Проводка.СуммаНУКт   = ТорговаяНаценкаНУ;		
		Проводка.НалоговоеНазначениеКт  = ПолучитьНалоговоеНазначениеСтроки(СтрокаЗапасы);
			
	КонецЦикла;
	
КонецПроцедуры

