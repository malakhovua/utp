					СуммаНаценкиНУ = СтрокаТаблицыНаценок[0].ТН_НУ * Сумма / (СтрокаТаблицыНаценок[0].ПС_НУ);
					ПокупнаяЦенаНУ = Сумма - СуммаНаценкиНУ;
