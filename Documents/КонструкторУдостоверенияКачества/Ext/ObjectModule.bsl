// Процедура вызывается перед записью документа 
//
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)

	мУдалятьДвижения = НЕ ЭтоНовый();
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
КонецПроцедуры // ПередЗаписью

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	Если мУдалятьДвижения Тогда
		ОбщегоНазначения.УдалитьДвиженияРегистратора(ЭтотОбъект, Отказ);
	КонецЕсли;
	
	// регистр НастройкиУдостоверенияКачества
	Движения.umk_НастройкиУдостоверенияКачества.Записывать = Истина;
	Движения.umk_НастройкиУдостоверенияКачества.Очистить();
	Для Каждого ТекСтрокаТовары Из Товары Цикл
		Движение = Движения.umk_НастройкиУдостоверенияКачества.Добавить();
		Движение.Период = Дата;
		Движение.Организация = Организация;
		Движение.ФормаУдостоверенияКачества = ФормаУдостоверенияКачества;
		Движение.СрокГодности = ТекСтрокаТовары.СрокГодности;
		Движение.КатегорияПродукции = ТекСтрокаТовары.КатегорияПродукции;
		Движение.Номенклатура = ТекСтрокаТовары.Номенклатура;
		Движение.НаименованиеДляПечати = ТекСтрокаТовары.НаименованиеДляПечати;
		Движение.Сорт = ТекСтрокаТовары.Сорт;
		Движение.Оболочка = ТекСтрокаТовары.Оболочка;
		Движение.НомерСтраницы = ТекСтрокаТовары.НомерСтраницы;
		ПорядокСортировки = ПолучитьПорядокСортировки(ТекСтрокаТовары);
		Движение.ПорядокСортировки = ПорядокСортировки;
		Движение.ПорядокСортировкиКатегории = ПолучитьПорядокСортировкиКатегории(ТекСтрокаТовары);
	КонецЦикла;
	
	//регистр  РеквизитыНоменклатурыУдостоверенияКачества
	
КонецПроцедуры // ОбработкаПроведения()

Функция ПолучитьПорядокСортировки(ТекСтрокаТовары)
	
	НомерСтраницы      = ТекСтрокаТовары.НомерСтраницы;
	КатегорияПродукции = ТекСтрокаТовары.КатегорияПродукции;
	СрокГодности       = ТекСтрокаТовары.СрокГодности;

	Параметр = Новый Структура("КатегорияПродукции",КатегорияПродукции);
	НайденнаяСтрокаКатегории = КатегорииПродукции.НайтиСтроки(Параметр);
	
	Если НайденнаяСтрокаКатегории.Количество() = 0 Тогда
		Сообщить(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Порядок сортировки не установлен: %1", КатегорияПродукции), СтатусСообщения.Важное);
		Возврат 0
	КонецЕсли;
		
	ПорядокКатегории = НайденнаяСтрокаКатегории[0].НомерСтроки;
	
	Параметр = Новый Структура("СрокГодности",СрокГодности);
	НайденнаяСтрокаКатегории = СрокиГодности.НайтиСтроки(Параметр);
	ПорядокСрокиГодности = НайденнаяСтрокаКатегории[0].НомерСтроки;
	
	ПорядокСрокиТовары  = ТекСтрокаТовары.НомерСтроки;
	
	Порядок =  Строка(НомерСтраницы) +  Строка(ПорядокКатегории) + Строка(ПорядокСрокиГодности)
	 + Строка(ПорядокСрокиТовары);
	
	Возврат Порядок 
		
КонецФункции

Функция ПолучитьПорядокСортировкиКатегории(ТекСтрокаТовары)
	
	
	КатегорияПродукции = ТекСтрокаТовары.КатегорияПродукции;
	

	Параметр = Новый Структура("КатегорияПродукции",КатегорияПродукции);
	НайденнаяСтрокаКатегории = КатегорииПродукции.НайтиСтроки(Параметр);
	
	Если НайденнаяСтрокаКатегории.Количество() = 0 Тогда
		Сообщить(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Порядок сортировки категории не установлен: %1", КатегорияПродукции), СтатусСообщения.Важное);
		Возврат 0
	КонецЕсли;
	
	ПорядокКатегории = НайденнаяСтрокаКатегории[0].НомерСтроки;
		
	Возврат ПорядокКатегории 
		
КонецФункции


Процедура ОбработкаУдаленияПроведения(Отказ)
	
