// Проверка заполнения шапки документа
Функция ПроверитьШапку(ОбъектДок, Отказ)

	Если НЕ ЗначениеЗаполнено(ОбъектДок.Технолог) Тогда
		СообщениеОбОшибке = Новый СообщениеПользователю;
		СообщениеОбОшибке.Текст = "Не заполнен Технолог!";
		СообщениеОбОшибке.Поле = "Технолог";
		СообщениеОбОшибке.УстановитьДанные(ОбъектДок);
		СообщениеОбОшибке.Сообщить();
		Отказ = Истина;
	КонецЕсли; // Если НЕ ЗначениеЗаполнено Технолог // + claude

	Если НЕ ЗначениеЗаполнено(ОбъектДок.Кладовщик) Тогда
		СообщениеОбОшибке = Новый СообщениеПользователю;
		СообщениеОбОшибке.Текст = "Не заполнен Кладовщик!";
		СообщениеОбОшибке.Поле = "Кладовщик";
		СообщениеОбОшибке.УстановитьДанные(ОбъектДок);
		СообщениеОбОшибке.Сообщить();
		Отказ = Истина;
	КонецЕсли; // Если НЕ ЗначениеЗаполнено Кладовщик // + claude

	Если НЕ ЗначениеЗаполнено(ОбъектДок.ВетВрач) Тогда
		СообщениеОбОшибке = Новый СообщениеПользователю;
		СообщениеОбОшибке.Текст = "Не заполнен Вет. врач!";
		СообщениеОбОшибке.Поле = "ВетВрач";
		СообщениеОбОшибке.УстановитьДанные(ОбъектДок);
		СообщениеОбОшибке.Сообщить();
		Отказ = Истина;
	КонецЕсли; // Если НЕ ЗначениеЗаполнено ВетВрач // + claude

КонецФункции // ПроверитьШапку // + claude

// Проверка заполнения строк ТЧ
Функция ПроверитьСтроки(ОбъектДок, Отказ)

	Для Каждого Строка Из ОбъектДок.ТМЦ Цикл
		Если НЕ ЗначениеЗаполнено(Строка.ТМЦ) Тогда
			СообщениеОбОшибке = Новый СообщениеПользователю;
			СообщениеОбОшибке.Текст = "Не заполнено поле ТМЦ в строке " + Строка.НомерСтроки + "!";
			СообщениеОбОшибке.Поле = "ТМЦ[" + (Строка.НомерСтроки - 1) + "].ТМЦ";
			СообщениеОбОшибке.УстановитьДанные(ОбъектДок);
			СообщениеОбОшибке.Сообщить();
			Отказ = Истина;
			Возврат Ложь;
		КонецЕсли; // Если НЕ ЗначениеЗаполнено ТМЦ // + claude
	КонецЦикла; // Для Каждого Строка // + claude

	Возврат Истина;

КонецФункции // ПроверитьСтроки // + claude

// Обработка проведения документа
Процедура ОбработкаПроведения(Отказ, РежимПроведения)

	// Проверка шапки
	ПроверитьШапку(ЭтотОбъект, Отказ);
	Если Отказ Тогда
		Возврат;
	КонецЕсли; // Если Отказ // + claude

	// Проверка строк ТЧ
	ПроверитьСтроки(ЭтотОбъект, Отказ);

КонецПроцедуры // ОбработкаПроведения // + claude

// Заполнение на основании Отчета производства за смену
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)

	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ОтчетПроизводстваЗаСмену") Тогда

		СтандартнаяОбработка = Ложь;
		ДокОснование = ДанныеЗаполнения.ПолучитьОбъект();

		ОтчетПроизводства = ДанныеЗаполнения;
		Дата              = ДокОснование.Дата;

		Для Каждого СтрокаОснования Из ДокОснование.Продукция Цикл
			НоваяСтрока = ТМЦ.Добавить();
			НоваяСтрока.ТМЦ          = СтрокаОснования.Номенклатура;
			НоваяСтрока.Кво          = СтрокаОснования.Количество;
			НоваяСтрока.Ед           = СтрокаОснования.ЕдиницаИзмерения;
			НоваяСтрока.Коэффициент  = 1;
			// Установить оценки 5 по умолчанию
			НоваяСтрока.ВН  = 5; НоваяСтрока.ВНВ = 5; НоваяСтрока.ВНК = 5;
			НоваяСтрока.Ц   = 5; НоваяСтрока.ЦВ  = 5; НоваяСтрока.ЦК  = 5;
			НоваяСтрока.З   = 5; НоваяСтрока.ЗВ  = 5; НоваяСтрока.ЗК  = 5;
			НоваяСтрока.К   = 5; НоваяСтрока.КВ  = 5; НоваяСтрока.КК  = 5;
			НоваяСтрока.В   = 5; НоваяСтрока.ВВ  = 5; НоваяСтрока.ВК  = 5;
			НоваяСтрока.С   = 5; НоваяСтрока.СВ  = 5; НоваяСтрока.СК  = 5;
			// Расчет средних
			НоваяСтрока.СредТ = 5; НоваяСтрока.СредВ = 5;
			НоваяСтрока.СредК = 5; НоваяСтрока.СредО = 5;
		КонецЦикла; // Для Каждого СтрокаОснования // + claude

	КонецЕсли; // Если ТипЗнч ОтчетПроизводстваЗаСмену // + claude

КонецПроцедуры // ОбработкаЗаполнения // + claude
