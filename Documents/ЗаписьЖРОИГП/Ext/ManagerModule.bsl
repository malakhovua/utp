
// Подготовка реквизитов организации через стандартный механизм УТП
Функция РеквизитыОрганизации(Орг, Дата)

	СведОрг = УправлениеКонтактнойИнформацией.СведенияОЮрФизЛице(Орг, Дата);

	Рез = Новый Структура;
	Рез.Вставить("НазваОрг",       Орг.НаименованиеПолное);
	Рез.Вставить("АдресОрг",       СведОрг.ЮридическийАдрес);
	Рез.Вставить("ЄДРПОУ",         СведОрг.КодПоЕДРПОУ);
	Рез.Вставить("ІПНОрг",         "ІПН " + СведОрг.ИНН);
	Рез.Вставить("ТелефониОрг",    "тел. " + СведОрг.Телефоны);
	Рез.Вставить("НомерСвідоцтва", СведОрг.НомерСвидетельства);
	Рез.Вставить("РеквизитыРС",    ФормированиеПечатныхФорм.ОписаниеОрганизации(СведОрг, "НомерСчета,Банк,МФО,"));
	Возврат Рез;

КонецФункции // РеквизитыОрганизации // + claude

// Заполнение параметров шапки макета реквизитами организации
Процедура ЗаполнитьШапкуОрг(Область, РеквОрг)

	Область.Параметры.ДатаУкр        = РеквОрг.ДатаУкр; // заполняется снаружи
	Область.Параметры.НазваОрг       = РеквОрг.НазваОрг;
	Область.Параметры.АдресОрг       = РеквОрг.АдресОрг;
	Область.Параметры.ЄДРПОУ         = РеквОрг.ЄДРПОУ;
	Область.Параметры.ІПНОрг         = РеквОрг.ІПНОрг;
	Область.Параметры.ТелефониОрг    = РеквОрг.ТелефониОрг;
	Область.Параметры.НомерСвідоцтва = РеквОрг.НомерСвідоцтва;
	Область.Параметры.РеквизитыРС    = РеквОрг.РеквизитыРС;

КонецПроцедуры // ЗаполнитьШапкуОрг // + claude

// Дегустационный лист
// ХвостПодписанта: "" = Технолог, "В" = ВетВрач, "К" = Кладовщик
Функция СформироватьДекЛист(СсылкаДокумента, Знач ХвостПодписанта = "") Экспорт

	ДокОбъект = СсылкаДокумента.ПолучитьОбъект();
	Макет = ПолучитьМакет("ДекЛист");
	
	СоотвПодписей = Новый Соответствие();
	СоотвПодписей.Вставить("","технолога");
	СоотвПодписей.Вставить("К","комірника");
	СоотвПодписей.Вставить("В","рабітника сан-вет. служби");

	ТабДок = Новый ТабличныйДокумент;
	ТабДок.ИмяПараметровПечати = "ПЕЧАТЬ_ДекЛист";

	Орг     = глЗначениеПеременной("ОсновнаяОрганизация");
	РеквОрг = РеквизитыОрганизации(Орг, ДокОбъект.Дата);
	РеквОрг.Вставить("ДатаУкр", Формат(ДокОбъект.Дата,"Л=uk; ДЛФ=DD"));

	// Шапка
	Область = Макет.ПолучитьОбласть("Шапка");
	ЗаполнитьШапкуОрг(Область, РеквОрг);
	Область.Параметры.ТекстПодписи =  СоотвПодписей.Получить(ХвостПодписанта);
	ТабДок.Вывести(Область);

	// Суффикс средней оценки: "" → "Т", "В" → "В", "К" → "К"
	СуффСред = ?(ХвостПодписанта = "", "Т", ?(ХвостПодписанта = "В", "В", "К"));

	// Строки ТЧ
	ОбластьСтр = Макет.ПолучитьОбласть("Строка");
	Для Каждого Строка Из ДокОбъект.ТМЦ Цикл
		ОбластьСтр.Параметры.ДатаРядок      = ДокОбъект.Дата;
		ОбластьСтр.Параметры.НазваПродукту  = Строка.ТМЦ.Наименование;
		ОбластьСтр.Параметры.Оц1            = Строка["ВН" + ХвостПодписанта];
		ОбластьСтр.Параметры.Оц2            = Строка["Ц"  + ХвостПодписанта];
		ОбластьСтр.Параметры.Оц3            = Строка["З"  + ХвостПодписанта];
		ОбластьСтр.Параметры.Оц4            = Строка["К"  + ХвостПодписанта];
		ОбластьСтр.Параметры.Оц5            = Строка["В"  + ХвостПодписанта];
		ОбластьСтр.Параметры.Оц6            = Строка["С"  + ХвостПодписанта];
		ОбластьСтр.Параметры.СредОц         = Строка["Сред" + СуффСред];
		ТабДок.Вывести(ОбластьСтр);
	КонецЦикла; // Для Каждого Строка // + claude

	// Дно
	ОбластьДно = Макет.ПолучитьОбласть("Дно");
	ТабДок.Вывести(ОбластьДно);

	Возврат ТабДок;

КонецФункции // СформироватьДекЛист // + claude

// Общий журнал регистрации ОИГП
Функция СформироватьОбщую(СсылкаДокумента) Экспорт

	ДокОбъект = СсылкаДокумента.ПолучитьОбъект();
	Макет = ПолучитьМакет("Общая");

	ТабДок = Новый ТабличныйДокумент;
	ТабДок.ИмяПараметровПечати = "ПЕЧАТЬ_ЖурналОИГП";

	Орг     = глЗначениеПеременной("ОсновнаяОрганизация");
	РеквОрг = РеквизитыОрганизации(Орг, ДокОбъект.Дата);
	РеквОрг.Вставить("ДатаУкр", Формат(ДокОбъект.Дата,"Л=uk; ДЛФ=DD"));

	// Шапка
	Область = Макет.ПолучитьОбласть("Шапка");
	ЗаполнитьШапкуОрг(Область, РеквОрг);
	Область.Параметры.ФІОТехнолог = ДокОбъект.Технолог.Наименование;
	Область.Параметры.ФІОВетЛікар = ДокОбъект.ВетВрач.Наименование;
	Область.Параметры.ФІОКомірник = ДокОбъект.Кладовщик.Наименование;
	ТабДок.Вывести(Область);

	// Строки ТЧ
	ОбластьСтр = Макет.ПолучитьОбласть("Строка");
	Для Каждого Строка Из ДокОбъект.ТМЦ Цикл
		ОбластьСтр.Параметры.НазваПродукту = Строка.ТМЦ.Наименование;
		ОбластьСтр.Параметры.СредО         = Строка.СредО;
		ТабДок.Вывести(ОбластьСтр);
	КонецЦикла; // Для Каждого Строка // + claude

	// Дно
	ОбластьДно = Макет.ПолучитьОбласть("Дно");
	ТабДок.Вывести(ОбластьДно);

	Возврат ТабДок;

КонецФункции // СформироватьОбщую // + claude
