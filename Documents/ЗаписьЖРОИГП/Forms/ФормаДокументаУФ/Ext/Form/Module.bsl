// Массив имен органолептических показателей ТЧ
// Используется для расчета средних и установки оценок // + claude
Перем МассивОценок Экспорт;

#Область ОбработчикиСобытийФормы

// При создании формы на сервере - инициализация
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	МассивОценок = Новый Массив;
	МассивОценок.Добавить("ВН");
	МассивОценок.Добавить("Ц");
	МассивОценок.Добавить("З");
	МассивОценок.Добавить("К");
	МассивОценок.Добавить("В");
	МассивОценок.Добавить("С");

	// Заполнение значений по умолчанию для нового документа
	Если Объект.Ссылка.Пустая() Тогда
		ЗаполнитьПоУмолчаниюШапку();
	КонецЕсли; // Если новый документ // + claude

КонецПроцедуры // ПриСозданииНаСервере // + claude

// После записи документа - сохранить последние значения шапки
&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)

	ХранилищеОбщихНастроек.Сохранить("ЖРОИГПНастройки", "Технолог",  ТекущийОбъект.Технолог);
	ХранилищеОбщихНастроек.Сохранить("ЖРОИГПНастройки", "Кладовщик", ТекущийОбъект.Кладовщик);
	ХранилищеОбщихНастроек.Сохранить("ЖРОИГПНастройки", "ВетВрач",   ТекущийОбъект.ВетВрач);

КонецПроцедуры // ПослеЗаписиНаСервере // + claude

#КонецОбласти // ОбработчикиСобытийФормы // + claude

#Область СлужебныеПроцедурыИФункции

// Заполнение шапки документа сохраненными значениями по умолчанию
&НаСервере
Процедура ЗаполнитьПоУмолчаниюШапку()

	Объект.Технолог  = ХранилищеОбщихНастроек.Загрузить("ЖРОИГПНастройки", "Технолог");
	Объект.Кладовщик = ХранилищеОбщихНастроек.Загрузить("ЖРОИГПНастройки", "Кладовщик");
	Объект.ВетВрач   = ХранилищеОбщихНастроек.Загрузить("ЖРОИГПНастройки", "ВетВрач");

КонецПроцедуры // ЗаполнитьПоУмолчаниюШапку // + claude

// Расчет средних оценок по строке ТЧ
&НаКлиенте
Процедура РассчитатьСредниеПоСтроке(СтрокаТЧ)

	Если СтрокаТЧ = Неопределено Тогда
		Возврат;
	КонецЕсли; // Если нет строки // + claude

	СуммаТ = 0; СуммаВ = 0; СуммаК = 0;
	КвоОценок = МассивОценок.Количество();

	Для Каждого ИмяРекв Из МассивОценок Цикл
		СуммаТ = СуммаТ + СтрокаТЧ[ИмяРекв];
		СуммаВ = СуммаВ + СтрокаТЧ[ИмяРекв + "В"];
		СуммаК = СуммаК + СтрокаТЧ[ИмяРекв + "К"];
	КонецЦикла; // Для Каждого ИмяРекв // + claude

	СтрокаТЧ.СредТ = Окр(СуммаТ / КвоОценок, 1);
	СтрокаТЧ.СредВ = Окр(СуммаВ / КвоОценок, 1);
	СтрокаТЧ.СредК = Окр(СуммаК / КвоОценок, 1);
	СтрокаТЧ.СредО = Окр((СтрокаТЧ.СредТ + СтрокаТЧ.СредВ + СтрокаТЧ.СредК) / 3, 1);

КонецПроцедуры // РассчитатьСредниеПоСтроке // + claude

// Установка оценок по строке ТЧ
&НаКлиенте
Процедура УстановитьОценкиПоСтроке(СтрокаТЧ, Тех = Истина, ВетВ = Истина, Клад = Истина)

	Для Каждого ИмяРекв Из МассивОценок Цикл
		Если Тех Тогда
			СтрокаТЧ[ИмяРекв]         = 5;
		КонецЕсли; // Если Тех // + claude
		Если ВетВ Тогда
			СтрокаТЧ[ИмяРекв + "В"]   = 5;
		КонецЕсли; // Если ВетВ // + claude
		Если Клад Тогда
			СтрокаТЧ[ИмяРекв + "К"]   = 5;
		КонецЕсли; // Если Клад // + claude
	КонецЦикла; // Для Каждого ИмяРекв // + claude

	РассчитатьСредниеПоСтроке(СтрокаТЧ);

КонецПроцедуры // УстановитьОценкиПоСтроке // + claude

#КонецОбласти // СлужебныеПроцедурыИФункции // + claude

#Область ОбработчикиЭлементовФормы

// Изменение ТМЦ в строке - установить базовую единицу измерения
&НаКлиенте
Процедура ТМЦТМЦПриИзменении(Элемент)

	ТекДанные = Элементы.ТМЦ.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли; // Если нет текущей строки // + claude

	Если ЗначениеЗаполнено(ТекДанные.ТМЦ) Тогда
		ТекДанные.Ед          = ТекДанные.ТМЦ.БазоваяЕдиницаИзмерения;
		ТекДанные.Коэффициент = 1;
	КонецЕсли; // Если ЗначениеЗаполнено ТМЦ // + claude

КонецПроцедуры // ТМЦТМЦПриИзменении // + claude

// Изменение единицы измерения - установить коэффициент
&НаКлиенте
Процедура ТМЦЕдПриИзменении(Элемент)

	ТекДанные = Элементы.ТМЦ.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли; // Если нет текущей строки // + claude

	Если ЗначениеЗаполнено(ТекДанные.Ед) Тогда
		ТекДанные.Коэффициент = ТекДанные.Ед.Коэффициент;
	КонецЕсли; // Если ЗначениеЗаполнено Ед // + claude

КонецПроцедуры // ТМЦЕдПриИзменении // + claude

// При окончании редактирования строки ТЧ - пересчитать средние
&НаКлиенте
Процедура ТМЦПослеОкончанияРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)

	Если ОтменаРедактирования Тогда
		Возврат;
	КонецЕсли; // Если отмена // + claude

	РассчитатьСредниеПоСтроке(Элементы.ТМЦ.ТекущиеДанные);

КонецПроцедуры // ТМЦПослеОкончанияРедактирования // + claude

#КонецОбласти // ОбработчикиЭлементовФормы // + claude

#Область КомандыФормы

// Заполнить оценки для всех строк ТЧ
&НаКлиенте
Процедура КомандаЗаполнить(Команда)

	СписокВариантов = Новый СписокЗначений;
	СписокВариантов.Добавить(1, "Все по 5");
	СписокВариантов.Добавить(2, "Все по 5 технолог");
	СписокВариантов.Добавить(3, "Все по 5 ветврач");
	СписокВариантов.Добавить(4, "Все по 5 кладовщик");

	ПоказатьВыборИзМеню(
		Новый ОписаниеОповещения("КомандаЗаполнитьЗавершение", ЭтотОбъект),
		СписокВариантов,
		Элементы.КомандаЗаполнить);

КонецПроцедуры // КомандаЗаполнить // + claude

// Завершение выбора варианта заполнения
&НаКлиенте
Процедура КомандаЗаполнитьЗавершение(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт

	Если ВыбранныйЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли; // Если отмена выбора // + claude

	Зн    = ВыбранныйЭлемент.Значение;
	Тех   = (Зн = 1 Или Зн = 2);
	ВетВ  = (Зн = 1 Или Зн = 3);
	Клад  = (Зн = 1 Или Зн = 4);

	Для Каждого Строка Из Объект.ТМЦ Цикл
		УстановитьОценкиПоСтроке(Строка, Тех, ВетВ, Клад);
	КонецЦикла; // Для Каждого Строка // + claude

КонецПроцедуры // КомандаЗаполнитьЗавершение // + claude

// Печать дегустационного листа
&НаКлиенте
Процедура КомандаПечать(Команда)

	СписокПодписей = Новый СписокЗначений;
	СписокПодписей.Добавить("Технолог",  "технолога Т");
	СписокПодписей.Добавить("ВетВрач",   "рабітника сан-вет. служби ВВ");
	СписокПодписей.Добавить("Кладовщик", "комірника КК");

	ПоказатьВыборИзМеню(
		Новый ОписаниеОповещения("КомандаПечатьЗавершение", ЭтотОбъект),
		СписокПодписей,
		Элементы.КомандаПечать);

КонецПроцедуры // КомандаПечать // + claude

// Завершение выбора подписи для печати дегустационного листа
&НаКлиенте
Процедура КомандаПечатьЗавершение(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт

	Если ВыбранныйЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли; // Если отмена // + claude

	ИмяПодписанта    = ВыбранныйЭлемент.Значение;
	ТекстПодписанта  = ВыбранныйЭлемент.Представление;

	ТабДок = СформироватьДегустационныйЛист(Объект.Ссылка, ИмяПодписанта, ТекстПодписанта);
	ТабДок.Показать("Дегустационный лист");

КонецПроцедуры // КомандаПечатьЗавершение // + claude

// Печать общего журнала ОИГП
&НаКлиенте
Процедура КомандаПечатьОбщая(Команда)

	ТабДок = СформироватьЖурналОИГП(Объект.Ссылка);
	ТабДок.Показать("Журнал регистрации ОИГП");

КонецПроцедуры // КомандаПечатьОбщая // + claude

#КонецОбласти // КомандыФормы // + claude

#Область ПечатьФормирование

// Формирование дегустационного листа
&НаСервере
Функция СформироватьДегустационныйЛист(СсылкаДокумента, ИмяПодписанта, ТекстПодписанта)

	ДокОбъект = СсылкаДокумента.ПолучитьОбъект();

	Таб = Новый ТабличныйДокумент;
	Таб.ИмяПараметровПечати = "ПЕЧАТЬ_ДегустационныйЛист";

	// Шапка документа
	Область = Таб.ПолучитьОбласть("Шапка");
	Если Область = Неопределено Тогда
		// Формирование без шаблона
		Таб.Вывести(СформироватьШапкуДегустационногоЛиста(ДокОбъект));
	КонецЕсли; // Если нет шаблона // + claude

	Ном = 0;
	Для Каждого Строка Из ДокОбъект.ТМЦ Цикл
		Ном = Ном + 1;
		СтрТаб = Новый ТабличныйДокумент;

		Макет = ПолучитьМакетСтрокиДегустации(
			Ном, Строка, ДокОбъект, ИмяПодписанта, ТекстПодписанта);
		Таб.Вывести(Макет);
	КонецЦикла; // Для Каждого Строка ТМЦ // + claude

	Возврат Таб;

КонецФункции // СформироватьДегустационныйЛист // + claude

// Формирование шапки дегустационного листа
&НаСервере
Функция СформироватьШапкуДегустационногоЛиста(ДокОбъект)

	Таб = Новый ТабличныйДокумент;

	ОбластьШапки = Таб.ПолучитьОбласть("R1");
	Таб.НачатьАвтогруппировкуСтрок();

	// Заголовок
	Ячейка = Таб.Область(1, 1, 1, 20);
	Ячейка.Текст = "ДЕГУСТАЦІЙНИЙ ЛИСТ";
	Ячейка.Шрифт = Новый Шрифт(, 14, Истина);
	Таб.ВывестиГоризонтальныйРазделитель();

	// Дата и номер
	Ячейка = Таб.Область(2, 1, 2, 10);
	Ячейка.Текст = "Дата: " + Формат(ДокОбъект.Дата, "ДФ=dd.MM.yyyy") +
	               "    № " + ДокОбъект.Номер;

	// Підписанти
	Ячейка = Таб.Область(3, 1, 3, 10);
	Ячейка.Текст = "Технолог: " + ДокОбъект.Технолог;
	Ячейка = Таб.Область(4, 1, 4, 10);
	Ячейка.Текст = "Вет. врач: " + ДокОбъект.ВетВрач;
	Ячейка = Таб.Область(5, 1, 5, 10);
	Ячейка.Текст = "Кладовщик: " + ДокОбъект.Кладовщик;

	Возврат Таб;

КонецФункции // СформироватьШапкуДегустационногоЛиста // + claude

// Формирование строки дегустационного листа
&НаСервере
Функция ПолучитьМакетСтрокиДегустации(Ном, Строка, ДокОбъект, ИмяПодписанта, ТекстПодписанта)

	Таб = Новый ТабличныйДокумент;

	Ячейка = Таб.Область(1, 1); Ячейка.Текст = Ном;
	Ячейка = Таб.Область(1, 2); Ячейка.Текст = Строка.ТМЦ.Наименование;
	Ячейка = Таб.Область(1, 3); Ячейка.Текст = Строка.Кво;
	Ячейка = Таб.Область(1, 4); Ячейка.Текст = Строка.Ед;
	// Оценки технолога
	Ячейка = Таб.Область(1, 5);  Ячейка.Текст = Строка.ВН;
	Ячейка = Таб.Область(1, 6);  Ячейка.Текст = Строка.Ц;
	Ячейка = Таб.Область(1, 7);  Ячейка.Текст = Строка.З;
	Ячейка = Таб.Область(1, 8);  Ячейка.Текст = Строка.К;
	Ячейка = Таб.Область(1, 9);  Ячейка.Текст = Строка.В;
	Ячейка = Таб.Область(1, 10); Ячейка.Текст = Строка.С;
	Ячейка = Таб.Область(1, 11); Ячейка.Текст = Строка.СредТ;
	// Оценки ветврача
	Ячейка = Таб.Область(1, 12); Ячейка.Текст = Строка.ВНВ;
	Ячейка = Таб.Область(1, 13); Ячейка.Текст = Строка.ЦВ;
	Ячейка = Таб.Область(1, 14); Ячейка.Текст = Строка.ЗВ;
	Ячейка = Таб.Область(1, 15); Ячейка.Текст = Строка.КВ;
	Ячейка = Таб.Область(1, 16); Ячейка.Текст = Строка.ВВ;
	Ячейка = Таб.Область(1, 17); Ячейка.Текст = Строка.СВ;
	Ячейка = Таб.Область(1, 18); Ячейка.Текст = Строка.СредВ;
	// Оценки кладовщика
	Ячейка = Таб.Область(1, 19); Ячейка.Текст = Строка.ВНК;
	Ячейка = Таб.Область(1, 20); Ячейка.Текст = Строка.ЦК;
	Ячейка = Таб.Область(1, 21); Ячейка.Текст = Строка.ЗК;
	Ячейка = Таб.Область(1, 22); Ячейка.Текст = Строка.КК;
	Ячейка = Таб.Область(1, 23); Ячейка.Текст = Строка.ВК;
	Ячейка = Таб.Область(1, 24); Ячейка.Текст = Строка.СК;
	Ячейка = Таб.Область(1, 25); Ячейка.Текст = Строка.СредК;
	// Средняя оценка
	Ячейка = Таб.Область(1, 26); Ячейка.Текст = Строка.СредО;

	Возврат Таб;

КонецФункции // ПолучитьМакетСтрокиДегустации // + claude

// Формирование журнала ОИГП
&НаСервере
Функция СформироватьЖурналОИГП(СсылкаДокумента)

	ДокОбъект = СсылкаДокумента.ПолучитьОбъект();

	Таб = Новый ТабличныйДокумент;
	Таб.ИмяПараметровПечати = "ПЕЧАТЬ_ЖурналОИГП";

	// Заголовок
	Ячейка = Таб.Область(1, 1, 1, 26);
	Ячейка.Текст = "ЖУРНАЛ РЕЄСТРАЦІЇ ОІГП від " + Формат(ДокОбъект.Дата, "ДФ=dd.MM.yyyy");
	Ячейка.Шрифт = Новый Шрифт(, 12, Истина);
	Таб.ВывестиГоризонтальныйРазделитель();

	// Строки ТЧ
	Ном = 0;
	Для Каждого Строка Из ДокОбъект.ТМЦ Цикл
		Ном = Ном + 1;
		МакетСтроки = ПолучитьМакетСтрокиДегустации(Ном, Строка, ДокОбъект, "", "");
		Таб.Вывести(МакетСтроки);
	КонецЦикла; // Для Каждого Строка ТМЦ // + claude

	Возврат Таб;

КонецФункции // СформироватьЖурналОИГП // + claude

#КонецОбласти // ПечатьФормирование // + claude
