	КонецЕсли;	
	
	ТаблицаДвижений.ЗаполнитьЗначения(Организация       , "Организация");
	ТаблицаДвижений.ЗаполнитьЗначения(ДоговорКонтрагента, "ДоговорКонтрагента");
	
	
	Если НЕ Отказ И ТаблицаДвижений.Количество() > 0 Тогда
		
		НаборДвижений.мПериод          = СтруктураШапкиДокумента.ПериодДвижений;
		НаборДвижений.мТаблицаДвижений = ТаблицаДвижений;
		
		Движения.НДСНалоговыеОбязательства.ДобавитьДвижение();
	
	КонецЕсли;
	
КонецПроцедуры


////////////////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ СОБЫТИЙ


// Процедура - обработчик события "ОбработкаЗаполнения".
//
Процедура ОбработкаЗаполнения(Основание)
	
	Если Не Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(Основание)) ИЛИ Основание = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ТипОснования = ТипЗнч(Основание);
	ДокументВводаНаОсновании = Основание;
	
	Если ТипОснования = Тип("ДокументСсылка.ЧекККМ") Тогда
		
		ДокументВводаНаОсновании =  "Чек ККМ";
		// Заполним реквизиты из стандартного набора по документу основанию.
		ЗаполнениеДокументов.ЗаполнитьШапкуДокументаПоОснованию(ЭтотОбъект, Основание);
		
		ТаблицаВидовОпераций = ОпределитьВозможныеВидыОперацийПоОснованию(Основание);
		
		Если ТаблицаВидовОпераций.Количество() > 1 Тогда
			ВыбранныйВидОперации = ТаблицаВидовОпераций.ВыбратьСтроку(НСтр("ru='Выберите операцию для формирования налоговой накладной';uk='Виберіть операцію для формування податкової накладної'"));
		ИначеЕсли ТаблицаВидовОпераций.Количество() = 1 Тогда
			ВыбранныйВидОперации = ТаблицаВидовОпераций[0];
		Иначе
			//в документе-основании нет строк с заполненной СтавкойНДС
			ВыбранныйВидОперации = Неопределено;
		КонецЕсли;
			
		Если ВыбранныйВидОперации = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		ВидОперации = ВыбранныйВидОперации[0];
		
		// Этот документ всегда имеет установленный флаг УчитыватьНДС
		УчитыватьНДС = Истина;
		
		ЗаполнитьУсловиеПродажи(Основание);
		ЗаполнитьВидДоговора();
		
		УстановитьТипПричиныНевыдачиПокупателюПоУмолчанию();
		
		// в документе Чек нет некоторых реквизитов...  установим вручную
		Организация = Основание.КассаККМ.Владелец;
		ОбособленноеПодразделение = Основание.КассаККМ.ОбособленноеПодразделение;
		ВалютаДокумента = мВалютаРегламентированногоУчета;
		КурсВзаиморасчетов = 1;
		КратностьВзаиморасчетов = 1;
		СуммаВключаетНДС = Истина;
		АвторасчетНДС = Истина;
		
		ФормаРасчетов = "";
		
		СуммаБезналичнойОплаты = 0;
		Для каждого СтрокаОплаты Из Основание.Оплата Цикл
			
			Если НЕ СтрокаОплаты.ВидОплаты.ТипОплаты = Перечисления.ТипыОплатЧекаККМ.Наличные Тогда
				СуммаБезналичнойОплаты = СуммаБезналичнойОплаты + СтрокаОплаты.Сумма;
			КонецЕсли;
		
		КонецЦикла;
		
		
		Если СуммаБезналичнойОплаты > 0 Тогда
			
			ФормаРасчетов = "Безготівковий розрахунок";
			
		КонецЕсли;
		Если Основание.СуммаДокумента - СуммаБезналичнойОплаты > 0 Тогда
			
			Если ФормаРасчетов = "" Тогда
				ФормаРасчетов = "Готівка";
			Иначе
				ФормаРасчетов = ФормаРасчетов + ", готівка";
			КонецЕсли; 
			
		КонецЕсли;
		
		// В качестве документа-основания не имеет смысл выбирать документ ЧекККМ
		// с видом операции "Чек на возврат"
		Если   Основание.ВидОперации = Перечисления.ВидыОперацийЧекККМ.Возврат Тогда
	    	Сообщить(НСтр("ru='Нельзя вводить документ Налоговая накладная на основании Чека на возврат! ';uk='Не можна вводити документ Податкова накладна на підставі Чека на повернення! '"), СтатусСообщения.Внимание);
			Возврат;
		КонецЕсли;
		
		СкопироватьТовары(Основание);
		СкопироватьУслуги(Основание);

		Возврат;
		
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.СписаниеТоваров")  Тогда
		// Заполним реквизиты из стандартного набора по документу основанию.
		ЗаполнениеДокументов.ЗаполнитьШапкуДокументаПоОснованию(ЭтотОбъект, Основание);
		ВидОперации = Перечисления.ВидыОперацийНалоговаяНакладная.УсловнаяПродажа;
		ДокументОснование = Основание;
		
		// Заполняется только количество, т.к. бухгалтерской себестоимости у нас нет
		
		Для каждого СтрокаТЧ Из Основание.Товары Цикл
			
		 	НоваяСтрока = Товары.Добавить();
			НоваяСтрока.Номенклатура				=	СтрокаТЧ.Номенклатура;
			НоваяСтрока.ХарактеристикаНоменклатуры	=	СтрокаТЧ.ХарактеристикаНоменклатуры;
			НоваяСтрока.Количество					=	СтрокаТЧ.Количество;
			НоваяСтрока.ЕдиницаИзмерения			=	СтрокаТЧ.ЕдиницаИзмерения;
			НоваяСтрока.Коэффициент					=	СтрокаТЧ.Коэффициент;
			
			ОбработкаТабличныхЧастей.ЗаполнитьСтавкуНДСТабЧасти(НоваяСтрока, ЭтотОбъект, "Реализация");
			ЗаполнитьСчетаУчетаВСтрокеТабЧасти(НоваяСтрока, "Товары");
			
		КонецЦикла; 
		
		УстановитьТипПричиныНевыдачиПокупателюПоУмолчанию();
	
		Возврат;
		
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ОтчетКомиссионераОПродажах") 
		    И Основание.ДоговорКонтрагента.Внешнеэкономический Тогда
#Если Клиент Тогда			
	
			
			// имеет смысл вводить налоговую только на услуги нерезидента. 
			// с 2011 года налоговые выписываются при передаче товаров комиссионеру (поставке)
			Выбор = Новый Структура("Значение", 2);
			
			Если Выбор = Неопределено Тогда
				//отказались от выбора
				мНеОткрыватьФормуДокумента = Истина;
				Возврат;
			ИначеЕсли Выбор.Значение = 2 Тогда
			
				// Заполним реквизиты из стандартного набора по документу основанию.
				ЗаполнениеДокументов.ЗаполнитьШапкуДокументаПоОснованию(ЭтотОбъект, Основание);
				
				ВидОперации = Перечисления.ВидыОперацийНалоговаяНакладная.РаботыОтНерезидента;
				
				// Этот документ всегда имеет установленный флаг УчитыватьНДС
				УчитыватьНДС = Истина;
				
				СчетНДС = ПланыСчетов.Хозрасчетный.РасчетыПоНДС;	
				
				//Заполним ТЧ
				СкопироватьУслугиКомиссииОтНерезидента(Основание);
		
				УстановитьТипПричиныНевыдачиПокупателюПоУмолчанию();
				
				Возврат;
			
			Иначе// Выбор = 1;
				//Стандартное заполнение с помощью обработки
			КонецЕсли;
#КонецЕсли		

	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ИзменениеНалоговогоНазначенияЗапасов")
		  ИЛИ ТипОснования = Тип("ДокументСсылка.ИзменениеНалоговогоНазначенияТЗР") Тогда	
		
		// Заполним реквизиты из стандартного набора по документу основанию.
		ЗаполнениеДокументов.ЗаполнитьШапкуДокументаПоОснованию(ЭтотОбъект, Основание);
		
		Сводная = Истина;
		КодПризнакаСводной =  1;
		ВидОперации = Перечисления.ВидыОперацийНалоговаяНакладная.УсловнаяПродажа;
		
		// Этот документ всегда имеет установленный флаг УчитыватьНДС
		УчитыватьНДС = Истина;
		
		СчетНДС = ПланыСчетов.Хозрасчетный.РасчетыПоНДС;	
		
		ВалютаДокумента = мВалютаРегламентированногоУчета;
		КурсВзаиморасчетов = 1;
		КратностьВзаиморасчетов = 1;
		
		//Заполним ТЧ
		Если ТипОснования = Тип("ДокументСсылка.ИзменениеНалоговогоНазначенияЗапасов") Тогда
			СкопироватьТоварыИзИзмененияНалоговогоНазначенияЗапасов(Основание);
		Иначе	
			СкопироватьТоварыИзИзменениеНалоговогоНазначенияТЗР(Основание);
		КонецЕсли; 

		УстановитьТипПричиныНевыдачиПокупателюПоУмолчанию();
		
		НоваяНакладная = ВыделитьСтавкуНДС7ВОтдельныйДокумент(Ложь);
		Если НЕ НоваяНакладная = Неопределено Тогда
			Форма7 = НоваяНакладная.ПолучитьФорму("ФормаДокумента",, Новый УникальныйИдентификатор);	
			Форма7.Открыть();
		КонецЕсли;
		
		Возврат;
		
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ИзменениеНалоговогоНазначенияОС") Тогда	
		
		// Заполним реквизиты из стандартного набора по документу основанию.
		ЗаполнениеДокументов.ЗаполнитьШапкуДокументаПоОснованию(ЭтотОбъект, Основание);
		
		Сводная = Истина;
		КодПризнакаСводной =  1;
		ВидОперации = Перечисления.ВидыОперацийНалоговаяНакладная.УсловнаяПродажа;

		// Этот документ всегда имеет установленный флаг УчитыватьНДС
		УчитыватьНДС = Истина;
		СуммаВключаетНДС = Ложь;

		ДокументОснование = Основание;
		СчетНДС = ПланыСчетов.Хозрасчетный.РасчетыПоНДС;	
		
		ВалютаДокумента = мВалютаРегламентированногоУчета;
		КурсВзаиморасчетов = 1;
		КратностьВзаиморасчетов = 1;
		
		//Заполним ТЧ
		СкопироватьТоварыИзИзмененияНалоговогоНазначенияОС(Основание);
		
		ТипПричиныНевыдачиПокупателю = 6;
		
		НоваяНакладная = ВыделитьСтавкуНДС7ВОтдельныйДокумент(Ложь);
		Если НЕ НоваяНакладная = Неопределено Тогда
			Форма7 = НоваяНакладная.ПолучитьФорму("ФормаДокумента",, Новый УникальныйИдентификатор);	
			Форма7.Открыть();
		КонецЕсли;
		
		Возврат;
	
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.СписаниеОС") 
		  ИЛИ ТипОснования = Тип("ДокументСсылка.СписаниеМалоценкиИзЭксплуатации") 
		  ИЛИ ТипОснования = Тип("ДокументСсылка.СписаниеНМА") Тогда	
		  
		// Заполним реквизиты из стандартного набора по документу основанию.
		ЗаполнениеДокументов.ЗаполнитьШапкуДокументаПоОснованию(ЭтотОбъект, Основание);
		
		ВидОперации = Перечисления.ВидыОперацийНалоговаяНакладная.УсловнаяПродажаСписаниеОС;
		
		// Этот документ всегда имеет установленный флаг УчитыватьНДС
		УчитыватьНДС = Истина;
		СуммаВключаетНДС = Ложь;
		
		ДокументОснование = Основание;
		СчетНДС = ПланыСчетов.Хозрасчетный.РасчетыПоНДС;	
		
		ВалютаДокумента = мВалютаРегламентированногоУчета;
		КурсВзаиморасчетов = 1;
		КратностьВзаиморасчетов = 1;
		
		//Заполним в ТЧ номенклатуру
		Если ТипОснования = Тип("ДокументСсылка.СписаниеОС") Тогда
			ЗаполнитьОСПоСписаниюОС(Основание);
		ИначеЕсли ТипОснования = Тип("ДокументСсылка.СписаниеНМА") Тогда
			ЗаполнитьНМАПоСписаниюНМА(Основание);
		Иначе
			ЗаполнитьТоварыПоСписаниюМалоценкиИзЭксплуатации(Основание);
		КонецЕсли;
		
		УстановитьТипПричиныНевыдачиПокупателюПоУмолчанию();
		
		Возврат;

	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ПоступлениеТоваровУслуг") 
		  ИЛИ ТипОснования = Тип("ДокументСсылка.ПоступлениеТоваровУслугВНТТ") Тогда	
		
		Если НЕ Основание.ДоговорКонтрагента.Внешнеэкономический Тогда
			
			Сообщить(НСтр("ru='На основании документа ""Поступление товаров и услуг"" можно вводить ""Налоговую накладную"" только при поставке от нерезидента!';uk='На підставі документа ""Надходження товарів і послуг"" можна вводити ""Податкову накладну"" тільки при постачанні від нерезидента!'"));
			
			мНеОткрыватьФормуДокумента = Истина;
			Возврат;
			
		КонецЕсли;	
			       
		// Заполним реквизиты из стандартного набора по документу основанию.
		ЗаполнениеДокументов.ЗаполнитьШапкуДокументаПоОснованию(ЭтотОбъект, Основание);
		
		ДокументОснование = Основание;
		
		ВидОперации = Перечисления.ВидыОперацийНалоговаяНакладная.РаботыОтНерезидента;
		
		ДокументОснование = Основание;
		
		// Этот документ всегда имеет установленный флаг УчитыватьНДС
		УчитыватьНДС = Истина;
		
		СчетНДС = ПланыСчетов.Хозрасчетный.РасчетыПоНДС;	
		
		//Заполним ТЧ
		СкопироватьУслуги(Основание);
		
		УстановитьТипПричиныНевыдачиПокупателюПоУмолчанию();

		Возврат;
		
	ИначеЕсли (ТипОснования = Тип("ДокументСсылка.ПриходныйКассовыйОрдер") И Основание.ВидОперации = Перечисления.ВидыОперацийПКО.ПриходДенежныхСредствРозничнаяВыручка)
	       ИЛИ ТипОснования = Тип("ДокументСсылка.ОтчетОРозничныхПродажах") Тогда	
			
		мНеОткрыватьФормуДокумента = Истина;
		
		ОбработкаФормированияНН = Обработки.ФормированиеНалоговыхНакладныхПоРознице.ПолучитьФорму();
		ОбработкаФормированияНН.Открыть();
		
		ОбработкаФормированияНН.ЭтотОбъект.Организация = Основание.Организация;
		ОбработкаФормированияНН.ЭтотОбъект.ДатаНачала 	 = Основание.Дата;
		ОбработкаФормированияНН.ЭтотОбъект.ДатаОкончания = Основание.Дата;
		
		Возврат;
		
	ИначеЕсли  ТипОснования = Тип("ДокументСсылка.КорректировкаДолгаПоВозвратнойТаре") Тогда
		Если Основание.ВидОперации = Перечисления.ВидыОперацийКорректировкаДолгаПоВозвратнойТаре.УПокупателя Тогда
			Сообщить(НСтр("ru='Нельзя вводить Налоговую накладную на основании документа Корректировка долга по возвратной таре с видом операции ""списание тары покупателя"" ';uk='Не можна вводити Податкову накладну на підставі документа Коригування боргу по зворотній тарі з видом операції ""списання тари покупця"" '"), СтатусСообщения.Внимание);
			мНеОткрыватьФормуДокумента = Истина;
			Возврат;
		КонецЕсли;
		
		// списание тары поставщика влечет появление налоговых обязательст (условная продажа)
		ЗаполнениеДокументов.ЗаполнитьШапкуДокументаПоОснованию(ЭтотОбъект, Основание);
		ВидОперации = Перечисления.ВидыОперацийНалоговаяНакладная.УсловнаяПродажа;
		
		ДокументОснование = Основание;
		СкопироватьТаруВТовары();
	      
		Возврат;
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.РеализацияТоваровУслуг")
			  И Основание.ДоговорКонтрагента.ВидДоговора = Перечисления.ВидыДоговоровКонтрагентов.СКомиссионером Тогда
		// налоговые обязательства возникают по поставке.
		// заполним документ на основании.
		
		// возможно, в документе указаны облагаемые и не облагаемые НДС товары
		ЕстьОблагаемыеОперации = Истина;
		ЕстьНеОблагаемыеОперации = Истина;
		ЕстьНеНДСперации = Истина;
		СтавкиНДС = Основание.Товары.ВыгрузитьКолонку("СтавкаНДС");
		Если  СтавкиНДС.Найти(Перечисления.СтавкиНДС.НДС20) = Неопределено
			И СтавкиНДС.Найти(Перечисления.СтавкиНДС.НДС14) = Неопределено
			И СтавкиНДС.Найти(Перечисления.СтавкиНДС.НДС7) = Неопределено
			И СтавкиНДС.Найти(Перечисления.СтавкиНДС.НДС0) = Неопределено Тогда
			ЕстьОблагаемыеОперации = Ложь;	
		КонецЕсли;
		Если  СтавкиНДС.Найти(Перечисления.СтавкиНДС.БезНДС) = Неопределено Тогда
