	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	Макет.КодЯзыкаМакета = "ru";
	
	ПодготовитьТаблицы(СтруктураШапкиДокумента, ТаблицаНоменклатуры, ТаблицаПоТаре, ТаблицаПоУслугам, ТаблицаПоОС, ТаблицаПоНМА);

	Для каждого СтрокаТоваров Из ТаблицаНоменклатуры Цикл
		Если ЗначениеЗаполнено(СтрокаТоваров.Вес) И СтрокаТоваров.РежимЭкспортногоОбеспечения Тогда
