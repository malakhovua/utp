//// ПРОЦЕДУРЫ И ФУНКЦИИ ДЛЯ ОБЕСПЕЧЕНИЯ ПРОВЕДЕНИЯ ДОКУМЕНТА

// Проверяет правильность заполнения шапки документа.
// Если какой-то из реквизтов шапки, влияющий на проведение не заполнен или
// заполнен не корректно, то выставляется флаг отказа в проведении.
// Проверяется также правильность заполнения реквизитов ссылочных полей документа.
// Проверка выполняется по объекту и по выборке из результата запроса по шапке.
//
// Параметры: 
//  СтруктураШапкиДокумента - выборка из результата запроса по шапке документа,
//  Отказ                   - флаг отказа в проведении,
//  Заголовок               - строка, заголовок сообщения об ошибке проведения.
//
Процедура ПроверитьЗаполнениеШапки(СтруктураШапкиДокумента, Отказ, Заголовок)
	
	// Документ должен принадлежать хотя бы к одному виду учета (управленческий, бухгалтерский, налоговый)
	ОбщегоНазначения.ПроверитьПринадлежностьКВидамУчета(СтруктураШапкиДокумента, Отказ, Заголовок);
	
	ЗаполнитьСписокРеквизитовЗависимыхОтТиповУчета();

	// Укажем, что надо проверить:
	РеквизитыШапки     = "Организация, Подразделение, ПодразделениеОрганизации, СчетЗатрат";
	
	ПроверятьСклад = Ложь;
	Если Продукция.Количество() > 0 ИЛИ ВозвратныеОтходы.Количество() > 0 ИЛИ Материалы.Количество() > 0 Тогда
		РеквизитыШапки = РеквизитыШапки + ", Склад";
		ПроверятьСклад = Истина;
	КонецЕсли;
	
	УправлениеПроизводством.НепроверятьРеквизитыПоТипуУчета(ЭтотОбъект, РеквизитыШапки,  мСтрокаРеквизитыУпрУчета, мСтрокаРеквизитыБухУчета, мСтрокаРеквизитыНалУчета,,СтруктураШапкиДокумента);
	
	РеквизитыШапки = Новый Структура(РеквизитыШапки);
	// Теперь позовем общую процедуру проверки.
	ЗаполнениеДокументов.ПроверитьЗаполнениеШапкиДокумента(ЭтотОбъект, РеквизитыШапки, Отказ, Заголовок);
	
	Если ПроверятьСклад И НЕ СтруктураШапкиДокумента.ВидСклада = Перечисления.ВидыСкладов.Оптовый Тогда
		ОбщегоНазначения.ОшибкаПриПроведении(НСтр("ru='В качестве склада может быть выбран только оптовый склад!';uk='В якості складу може бути обраний тільки оптовий склад!'"), Отказ, Заголовок);
	КонецЕсли;

КонецПроцедуры // ПроверитьЗаполнениеШапки()

// Процедура проверяет правильность заполнения реквизитов документа
//
Процедура ПроверкаРеквизитовТЧ(СтруктураШапкиДокумента, Отказ, Заголовок) Экспорт

	РеквизитыТабПродукция = "Номенклатура, Количество, Счет, СуммаПлановая, СуммаПлановаяУпр, Качество, НоменклатурнаяГруппа";
	РеквизитыТабУслуги    = "Номенклатура, Счет, СуммаПлановая, СуммаПлановаяУпр, ПодразделениеПолучатель, СтатьяЗатратПолучатель, НоменклатурнаяГруппа";
	РеквизитыТабОтходы    = "Номенклатура, Количество, Счет, Сумма, СтатьяЗатрат, НоменклатурнаяГруппа";
	РеквизитыТабМатериалы = "Номенклатура, Количество, ЕдиницаИзмерения, Счет, НоменклатурнаяГруппа, СтатьяЗатрат, Качество, СпособСписанияОстаткаТоваров";
	
	Если ВариантВыраженияВнутреннихУслуг <> Перечисления.ВариантВыраженияВнутреннихУслуг.ВПлановыхЦенах Тогда
		РеквизитыТабУслуги = СтрЗаменить(РеквизитыТабУслуги, "СуммаПлановая, СуммаПлановаяУпр,", "Количество,");
	КонецЕсли; 
	
	УправлениеПроизводством.НепроверятьРеквизитыПоТипуУчета(ЭтотОбъект, РеквизитыТабПродукция, мСтрокаРеквизитыУпрУчета, мСтрокаРеквизитыБухУчета, мСтрокаРеквизитыНалУчета, "Продукция", СтруктураШапкиДокумента);
	УправлениеПроизводством.НепроверятьРеквизитыПоТипуУчета(ЭтотОбъект, РеквизитыТабУслуги,    мСтрокаРеквизитыУпрУчета, мСтрокаРеквизитыБухУчета, мСтрокаРеквизитыНалУчета, "Услуги",    СтруктураШапкиДокумента);
	УправлениеПроизводством.НепроверятьРеквизитыПоТипуУчета(ЭтотОбъект, РеквизитыТабОтходы,    мСтрокаРеквизитыУпрУчета, мСтрокаРеквизитыБухУчета, мСтрокаРеквизитыНалУчета, "ВозвратныеОтходы", СтруктураШапкиДокумента);
	УправлениеПроизводством.НепроверятьРеквизитыПоТипуУчета(ЭтотОбъект, РеквизитыТабМатериалы,    мСтрокаРеквизитыУпрУчета, мСтрокаРеквизитыБухУчета, мСтрокаРеквизитыНалУчета, "Материалы", СтруктураШапкиДокумента);
	
	ЗаполнениеДокументов.ПроверитьЗаполнениеТабличнойЧасти(ЭтотОбъект, "Продукция", Новый Структура(РеквизитыТабПродукция), Отказ, Заголовок);
	ЗаполнениеДокументов.ПроверитьЗаполнениеТабличнойЧасти(ЭтотОбъект, "Услуги", Новый Структура(РеквизитыТабУслуги), Отказ, Заголовок);
	ЗаполнениеДокументов.ПроверитьЗаполнениеТабличнойЧасти(ЭтотОбъект, "ВозвратныеОтходы", Новый Структура(РеквизитыТабОтходы), Отказ, Заголовок);
	ЗаполнениеДокументов.ПроверитьЗаполнениеТабличнойЧасти(ЭтотОбъект, "Материалы", Новый Структура(РеквизитыТабМатериалы), Отказ, Заголовок);
	
КонецПроцедуры // ПроверкаРеквизитовТЧ()

// Проверяет, что в табличной части нет счетов учета МПЗ.
//
// Параметры:
//  ДокументОбъект    - объект проводимого документа, 
//  ИмяТабличнойЧасти - табличная часть документа,
//  ТаблицаЗначений   - таблица значений, содержащая данные табличной части и признак услуги
//  Отказ                      - флаг отказа в проведении.
//  Заголовок                  - строка, заголовок сообщения об ошибке проведения.
//
Процедура ПроверитьЧтоНетСчетаСКоличественнымУчетом(ДокументОбъект, ИмяТабличнойЧасти, ТаблицаЗначений, 
                                                    Отказ, Заголовок) 

	ПредставлениеТабличнойЧасти = ДокументОбъект.Метаданные().ТабличныеЧасти[ИмяТабличнойЧасти].Представление();

	// Цикл по строкам таблицы значений.
	Для каждого СтрокаТаблицы Из ТаблицаЗначений Цикл
                                               
		Если ЗначениеЗаполнено(СтрокаТаблицы.Счет)
		   И  СтрокаТаблицы.Счет.Количественный Тогда

				ОбщегоНазначения.ОшибкаПриПроведении(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='В строке номер ""%1"" табличной части ""%2"": содержится счет (БУ)%3. Укажите счет затрат!';uk='У рядку номер ""%1"" табличної частини ""%2"": міститься рахунок (БО)%3. Вкажіть рахунок витрат!'"), СокрЛП(СтрокаТаблицы.НомерСтроки), ПредставлениеТабличнойЧасти, СтрокаТаблицы.Счет), Отказ, Заголовок);

		КонецЕсли;
								
	КонецЦикла;

КонецПроцедуры // УправлениеЗапасами.ПроверитьЧтоНетУслуг()

// Проверяет правильность заполнения строк табличной части "Услуги".
//
// Параметры:
// Параметры: 
//  РезультатЗапросаПоУслугам - результат запроса, содержащий данные для проведения и проверки ТЧ Услуги
//  СтруктураШапкиДокумента   - структура, содержащая рексвизиты шапки документа и результаты запроса по шапке
//  Отказ                     - флаг отказа в проведении.
//  Заголовок                 - строка, заголовок сообщения об ошибке проведения.
//
Процедура ПроверитьЗаполнениеТабличнойЧастиУслуги(ТаблицаПоУслугам, СтруктураШапкиДокумента, Отказ, Заголовок)

	ИмяТабличнойЧасти = "Услуги";

	// Здесь товаров быть не должно.
	УправлениеЗапасами.ПроверитьЧтоНетТоваров(ЭтотОбъект, "Услуги", ТаблицаПоУслугам, Отказ, Заголовок);
	
	Если СтруктураШапкиДокумента.ЕстьНДС Тогда
		//Проверяем соответствует ли аналитика затрат налоговым назначениям в ТЧ Услуги                                           
		ОбщегоНазначения.ПроверитьСоответствиеАналитикиЗатратНалоговомуНазначению(ЭтотОбъект, "Услуги", Отказ, Заголовок, "Счет",,Дата);
	КонецЕсли;	
	
	
	Если НЕ Отказ  
		 И  СтруктураШапкиДокумента.ЕстьНалогНаПрибыльДо2015 Тогда
		 
		Для каждого СтрокаТаблицы Из ТаблицаПоУслугам Цикл
			
			ХарактерЗатрат = СтрокаТаблицы.ХарактерЗатрат;
			
			Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.НалоговоеНазначениеДоходовИЗатрат) Тогда
				
				Если ХарактерЗатрат = "Затраты" Тогда
					СтрокаСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Для услуги в строке ""%1"" не указано налоговое назначение затрат!';uk='Для послуги в рядку ""%1"" не зазначено податкове призначення витрат!'"), СтрокаТаблицы.НомерСтроки);
					ОбщегоНазначения.ОшибкаПриПроведении(СтрокаСообщения, Отказ, Заголовок);			
				ИначеЕсли ХарактерЗатрат = "Строительство" Тогда
					СтрокаСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Для услуги в строке ""%1"" не указано налоговое назначение для объекта строительства или НМА!';uk='Для послуги в рядку ""%1"" не зазначено податкове призначення для об''єкта будівництва або НМА!'"), СтрокаТаблицы.НомерСтроки);
					ОбщегоНазначения.ОшибкаПриПроведении(СтрокаСообщения, Отказ, Заголовок);			
				ИначеЕсли ХарактерЗатрат = "Производство" Тогда
					СтрокаСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Для услуги в строке ""%1"" не указано налоговое назначение в производстве для номенклатурной группы!';uk='Для послуги в рядку ""%1"" не зазначено податкове призначення у виробрництві для номенклатурної групи!'"), СтрокаТаблицы.НомерСтроки);
					ОбщегоНазначения.ОшибкаПриПроведении(СтрокаСообщения, Отказ, Заголовок);			
				ИначеЕсли ХарактерЗатрат = "РБП" Тогда
					СтрокаСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Для услуги в строке ""%1"" не указано налоговое назначение для расходов будущих периодов!';uk='Для послуги в рядку ""%1"" не зазначено податкове призначення для витрат майбутніх періодів!'"), СтрокаТаблицы.НомерСтроки);
					ОбщегоНазначения.ОшибкаПриПроведении(СтрокаСообщения, Отказ, Заголовок);			
				Иначе
					СтрокаСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Для услуги в строке ""%1"" невозможно определить налоговое назначение затрат для указанного счета затрат!';uk='Для послуги в рядку ""%1"" неможливо визначити податкове призначення витрат для вказанного рахунку витрат!'"), СтрокаТаблицы.НомерСтроки);
					Сообщить(СтрокаСообщения);			
				КонецЕсли;
				
			КонецЕсли;
			
			// нельзя по НДС указывать нехоз. деятельность, а по НП - хоз. деятельность
			Если НЕ Отказ  
				И  СтруктураШапкиДокумента.ЕстьНДС Тогда
				
				НехозДеятельностьНДС = (СтрокаТаблицы.НалоговоеНазначение = Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_НеоблагаемаяНеХозДеятельность);
				НехозДеятельностьНКУ = (СтрокаТаблицы.НалоговоеНазначениеДоходовИЗатрат = Справочники.НалоговыеНазначенияАктивовИЗатрат.НКУ_НеХозДеятельность);
				
				Если НЕ СтрокаТаблицы.НалоговоеНазначение = СтрокаТаблицы.НалоговоеНазначениеДоходовИЗатрат  
					  И НехозДеятельностьНДС <> НехозДеятельностьНКУ Тогда 
					СтрокаСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Для услуги в строке ""%1"" нельзя указывать нехозяйственное налоговое назначение и одновременно хозяйственную деятельность по затратам (и наоборот)!';uk='Для послуги в рядку ""%1"" не можна зазначати негосподарське податкове призначення по НДВ і одночасно господарську діяльність по витратам (та навпаки)!'"), СтрокаТаблицы.НомерСтроки);
					ОбщегоНазначения.ОшибкаПриПроведении(СтрокаСообщения, Отказ, Заголовок);			
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;	
	КонецЕсли;
	
КонецПроцедуры // ПроверитьЗаполнениеТабличнойЧастиУслуги()

// Процедура формирует движения регистров по табличной части Продукция
////
Процедура ДвиженияПоТабличнойЧастиПродукция(ТаблицаПоПродукции, СтруктураШапкиДокумента)
	
	Если Продукция.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ДвиженияПоТабличнойЧастиПродукцияУпр(ТаблицаПоПродукции, СтруктураШапкиДокумента);
	ДвиженияПоТабличнойЧастиПродукцияБух(ТаблицаПоПродукции, СтруктураШапкиДокумента);
	
КонецПроцедуры // ДвиженияПоТабличнойЧастиПродукция()

// Процедура формирует движения регистров по табличной части Продукция по управленческому учету
Процедура ДвиженияПоТабличнойЧастиПродукцияУпр(ТаблицаПоПродукции, СтруктураШапкиДокумента)

	Если Не ОтражатьВУправленческомУчете Тогда
		Возврат;
	КонецЕсли;
	
	НаборДвиженийТоварыНаСкладах  = Движения["ТоварыНаСкладах"];
	ТаблицаДвиженийТоварыНаСкладах = НаборДвиженийТоварыНаСкладах.ВыгрузитьКолонки();
	
	НаборДвиженийВП   = Движения["ВыпускПродукцииУслуг"];
	ТаблицаДвиженийВП = НаборДвиженийВП.ВыгрузитьКолонки();
	
	НаборДвиженийПартии   = Движения["ПартииТоваровНаСкладах"];
	ТаблицаДвиженийПартии = НаборДвиженийПартии.ВыгрузитьКолонки();
	
	НаборДвиженийРезерв   = Движения["ТоварыВРезервеНаСкладах"];
	ТаблицаДвиженийРезерв = НаборДвиженийРезерв.ВыгрузитьКолонки();
	
	НаборДвиженийНЗП   = Движения["НезавершенноеПроизводство"];
	ТаблицаДвиженийНЗП = НаборДвиженийНЗП.ВыгрузитьКолонки();
	
	НаборДвиженийВнутренниеЗаказы   = Движения["ВнутренниеЗаказы"];
	ТаблицаДвиженийВнутренниеЗаказы = НаборДвиженийВнутренниеЗаказы.ВыгрузитьКолонки();
	
	
	Для Каждого Строка Из ТаблицаПоПродукции Цикл
		
		ДвиженияПоВыпускуПродукцииОтходовУпр(СтруктураШапкиДокумента, Строка, "Продукция", ТаблицаДвиженийВП, ТаблицаДвиженийРезерв, ТаблицаДвиженийТоварыНаСкладах, ТаблицаДвиженийПартии, ТаблицаДвиженийВнутренниеЗаказы);
		
		// спишем из НЗП плановую стоимость и плановый НДС
		НоваяСтрокаНЗП = ТаблицаДвиженийНЗП.Добавить();
		
		НоваяСтрокаНЗП.Подразделение 					= СтруктураШапкиДокумента.Подразделение;
		НоваяСтрокаНЗП.НоменклатурнаяГруппа 			= Строка.НоменклатурнаяГруппа;
		
		НоваяСтрокаНЗП.Стоимость 						= Строка.СуммаПлановаяУпрБезНДС;
		НоваяСтрокаНЗП.НДС       						= Строка.ПлановыйНДСУпр;
		
		НоваяСтрокаНЗП.Продукция 						= Строка.Номенклатура;
		НоваяСтрокаНЗП.ПродукцияКоличество				= Строка.Количество;
		НоваяСтрокаНЗП.ХарактеристикаПродукции    		= Строка.ХарактеристикаНоменклатуры;
		НоваяСтрокаНЗП.СерияПродукции    				= Строка.СерияНоменклатуры;
		НоваяСтрокаНЗП.Заказ							= Строка.Заказ;
		НоваяСтрокаНЗП.Качество    						= Строка.Качество;
		
		НоваяСтрокаНЗП.КодОперации  = Перечисления.КодыОперацийНезавершенноеПроизводство.СписаниеНЗПРегламент;

	КонецЦикла;
	
	НаборДвиженийТоварыНаСкладах.мПериод = Дата;
	НаборДвиженийТоварыНаСкладах.мТаблицаДвижений = ТаблицаДвиженийТоварыНаСкладах;
	НаборДвиженийТоварыНаСкладах.ВыполнитьПриход();

	НаборДвиженийВП.мПериод = Дата;
	НаборДвиженийВП.мТаблицаДвижений = ТаблицаДвиженийВП;
	НаборДвиженийВП.ДобавитьДвижение();

	НаборДвиженийПартии.мПериод = Дата;
	НаборДвиженийПартии.мТаблицаДвижений = ТаблицаДвиженийПартии;
	НаборДвиженийПартии.ВыполнитьПриход();
	НаборДвиженийПартии.Записать(Ложь);
	
	НаборДвиженийРезерв.мПериод = Дата;
	НаборДвиженийРезерв.мТаблицаДвижений = ТаблицаДвиженийРезерв;
	НаборДвиженийРезерв.ВыполнитьПриход();
		
	НаборДвиженийНЗП.мПериод = Дата;
	НаборДвиженийНЗП.мТаблицаДвижений = ТаблицаДвиженийНЗП;
	НаборДвиженийНЗП.ВыполнитьРасход();
	НаборДвиженийНЗП.Записать(Ложь);
	
	НаборДвиженийВнутренниеЗаказы.мПериод          = Дата;
	НаборДвиженийВнутренниеЗаказы.мТаблицаДвижений = ТаблицаДвиженийВнутренниеЗаказы;
	НаборДвиженийВнутренниеЗаказы.ВыполнитьРасход();
	

КонецПроцедуры // ДвиженияПоТабличнойЧастиПродукцияУпр()

// Процедура формирует движения по складскому и партионному учету, и выпуску продукции по упр. учету
Процедура ДвиженияПоВыпускуПродукцииОтходовУпр(СтруктураШапкиДокумента, Строка, ИмяТабличнойЧасти, ТаблицаДвиженийВП, ТаблицаДвиженийРезерв, ТаблицаДвиженийТовары, ТаблицаДвиженийПартии, ТаблицаДвиженийВнутренниеЗаказы = Неопределено)
	
	Если Не ОтражатьВУправленческомУчете Тогда
		Возврат;
	КонецЕсли;
	
	ВыпускПродукцииИзДавальческогоСырья = Ложь;
	ОбособленныйУчетТоваровПоЗаказамПокупателей = Ложь;
	
	Если ИмяТабличнойЧасти = "Продукция" И ТипЗнч(Строка.Заказ) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда
	  	Если Строка.Заказ.ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.Переработка Тогда
	  		ВыпускПродукцииИзДавальческогоСырья = Истина;
	  		ОбособленныйУчетТоваровПоЗаказамПокупателей = Истина;
	  	Иначе
	  		ОбособленныйУчетТоваровПоЗаказамПокупателей = Строка.Заказ.ДоговорКонтрагента.ОбособленныйУчетТоваровПоЗаказамПокупателей;
	  	КонецЕсли;
	  КонецЕсли;
	
	Если ИмяТабличнойЧасти = "Продукция" Тогда
		// Отражаем факт изготовления продукции в регистре ВыпускПродукции
		НоваяСтрокаВП = ТаблицаДвиженийВП.Добавить();
		НоваяСтрокаВП.Подразделение           = СтруктураШапкиДокумента.Подразделение;
		НоваяСтрокаВП.НоменклатурнаяГруппа    = Строка.НоменклатурнаяГруппа;
		НоваяСтрокаВП.Продукция               = Строка.Номенклатура;
		НоваяСтрокаВП.ХарактеристикаПродукции = Строка.ХарактеристикаНоменклатуры;
		НоваяСтрокаВП.СерияПродукции          = Строка.СерияНоменклатуры;
		НоваяСтрокаВП.Спецификация            = Строка.Спецификация;
		НоваяСтрокаВП.ДокументВыпуска         = Ссылка;
		НоваяСтрокаВП.Заказ              	  = Строка.Заказ;
		НоваяСтрокаВП.Количество              = Строка.Количество;
		НоваяСтрокаВП.ПлановаяСтоимость       = Строка.СуммаПлановаяУпрБезНДС;
		НоваяСтрокаВП.ПлановыйНДС		      = Строка.ПлановыйНДСУпр;
		
		Если ИмяТабличнойЧасти = "Продукция" Тогда
			НоваяСтрокаВП.Качество            = Строка.Качество;
		Иначе
			НоваяСтрокаВП.Качество            = Справочники.Качество.Новый;
		КонецЕсли;
		
		Если ИмяТабличнойЧасти = "Продукция" Тогда
			НоваяСтрокаВП.КодОперации = Перечисления.КодыОперацийВыпускПродукции.ВыпускПродукцииФиксНаСклад;
		Иначе
			НоваяСтрокаВП.КодОперации = Перечисления.КодыОперацийВыпускПродукции.ВыпускПродукцииПоФиксированнойСтоимости;
		КонецЕсли;
		
		НоваяСтрокаВП.СкладПолучатель = СтруктураШапкиДокумента.Склад;
		
	КонецЕсли;
	
	// Приход продукции на склад.
		
	// Если был выпуск по заказу, зарезервируем выпущенную продукцию
	Если ИмяТабличнойЧасти = "Продукция" И ЗначениеЗаполнено(Строка.Заказ) Тогда
	  	Если НЕ (ТипЗнч(Строка.Заказ) = Тип("ДокументСсылка.ВнутреннийЗаказ")
	  		И (Строка.Заказ.ВидЗаказа = Перечисления.ВидыВнутреннегоЗаказа.НаСклад // Считается исполнением внутреннего заказа.
	  		И Склад = Строка.Заказ.Заказчик)) Тогда                                // Резерв в это случае делать не надо.
	   		НоваяСтрокаРезерв = ТаблицаДвиженийРезерв.Добавить();
	  		НоваяСтрокаРезерв.Склад                      = Склад;
	  		НоваяСтрокаРезерв.Номенклатура               = Строка.Номенклатура;
	  		НоваяСтрокаРезерв.ХарактеристикаНоменклатуры = Строка.ХарактеристикаНоменклатуры;
	  		НоваяСтрокаРезерв.ДокументРезерва            = Строка.Заказ;
	  		НоваяСтрокаРезерв.Количество                 = Строка.Количество;
		Иначе
			// Считается исполнением внутреннего заказа.
			// Остаток по внутреннему заказу
			КоличествоОстаток = УправлениеЗаказами.ПолучитьОстатокПоВнутреннемуЗаказу(Строка.Заказ, 
																   Строка.Количество, 
																   Строка.Номенклатура, 
																   Строка.ХарактеристикаНоменклатуры,
																   Строка.ЕдиницаИзмерения, 
																   Перечисления.СтатусыПартийТоваров.Купленный);
			// исполнение внутреннего заказа													   
			КоличествоИсполнение = Мин(Строка.Количество, КоличествоОстаток);
			
			Если КоличествоИсполнение > 0 Тогда
				
				НоваяСтрока = ТаблицаДвиженийВнутренниеЗаказы.Добавить();
				
				НоваяСтрока.ВнутреннийЗаказ            = Строка.Заказ;
				НоваяСтрока.Заказчик                   = Строка.Заказ.Заказчик;
				НоваяСтрока.СтатусПартии               = Перечисления.СтатусыПартийТоваров.Купленный;
				НоваяСтрока.Номенклатура               = Строка.Номенклатура;
				НоваяСтрока.Количество                 = КоличествоИсполнение;
				НоваяСтрока.ХарактеристикаНоменклатуры = Строка.ХарактеристикаНоменклатуры;
				НоваяСтрока.ЕдиницаИзмерения           = Строка.ЕдиницаИзмерения;
				
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
	

	НоваяСтрокаТовары = ТаблицаДвиженийТовары.Добавить();
	НоваяСтрокаТовары.Склад                      = СтруктураШапкиДокумента.Склад;
	НоваяСтрокаТовары.Номенклатура               = Строка.Номенклатура;
	НоваяСтрокаТовары.ХарактеристикаНоменклатуры = Строка.ХарактеристикаНоменклатуры;
	НоваяСтрокаТовары.СерияНоменклатуры          = Строка.СерияНоменклатуры;
	НоваяСтрокаТовары.Количество                 = Строка.Количество;
	Если ИмяТабличнойЧасти = "Продукция" Тогда
		НоваяСтрокаТовары.Качество      = Строка.Качество;
	Иначе
		НоваяСтрокаТовары.Качество      = Справочники.Качество.Новый;
	КонецЕсли;
		
	// Формируем поступление продукции в регистре ПартииТоваров
	НоваяСтрокаПартии = ТаблицаДвиженийПартии.Добавить();
	Если мУчетнаяПолитикаУпр["ВестиПартионныйУчетПоСкладам"] И Не ВыпускПродукцииИзДавальческогоСырья Тогда
		НоваяСтрокаПартии.Склад = СтруктураШапкиДокумента.Склад;
	КонецЕсли;
		
	НоваяСтрокаПартии.Номенклатура               = Строка.Номенклатура;
	НоваяСтрокаПартии.ХарактеристикаНоменклатуры = Строка.ХарактеристикаНоменклатуры;
	НоваяСтрокаПартии.СерияНоменклатуры          = ?(Строка.ВестиПартионныйУчетПоСериям, Строка.СерияНоменклатуры, Неопределено);
		
	Если Не мУчетнаяПолитикаУпр["СпособОценкиМПЗ"] = Перечисления.СпособыОценки.ПоСредней Тогда
		НоваяСтрокаПартии.ДокументОприходования  = Ссылка;
	КонецЕсли;
		
	Если ВыпускПродукцииИзДавальческогоСырья Тогда
		НоваяСтрокаПартии.СтатусПартии = Перечисления.СтатусыПартийТоваров.ВПереработку;
	Иначе
		НоваяСтрокаПартии.СтатусПартии = Перечисления.СтатусыПартийТоваров.Продукция;
	КонецЕсли;
		
	НоваяСтрокаПартии.Количество   = Строка.Количество;
	НоваяСтрокаПартии.Стоимость    = Строка.СуммаПлановаяУпрБезНДС;
	НоваяСтрокаПартии.НДС		   = Строка.ПлановыйНДСУпр;
	
	Если ИмяТабличнойЧасти = "Продукция" Тогда
		Если ОбособленныйУчетТоваровПоЗаказамПокупателей Тогда
			НоваяСтрокаПартии.Заказ   = Строка.Заказ;
		КонецЕсли;
		НоваяСтрокаПартии.Качество    = Строка.Качество;
		НоваяСтрокаПартии.КодОперации = Перечисления.КодыОперацийПартииТоваров.ВыпускПоОперацииСтоимость;
	Иначе
		НоваяСтрокаПартии.Качество    = Справочники.Качество.Новый;
		НоваяСтрокаПартии.КодОперации = Перечисления.КодыОперацийПартииТоваров.ВыпускПродукцииФиксНаСклад;
	КонецЕсли;
	
КонецПроцедуры // ДвиженияПоВыпускуПродукцииОтходовУпр()

// Процедура формирует движения регистров по табличной части Продукция по бухгалтерскому учету
Процедура ДвиженияПоТабличнойЧастиПродукцияБух(ТаблицаПоПродукции, СтруктураШапкиДокумента)

	Если НЕ СтруктураШапкиДокумента.ОтражатьВБухгалтерскомУчете Тогда
		Возврат;
	КонецЕсли; 
	
	Для Каждого Строка Из ТаблицаПоПродукции Цикл
		// проводка выпуска и отражение в регистре ВыпускПродукцииУслугБухгалтерскийУчет
		ДвиженияПоВыпускуПродукцииБух(Строка, СтруктураШапкиДокумента, ОперацияБУ, ТаблицаДвиженийВыпускБУ, Истина);
	КонецЦикла;

	ДвиженияВыпускПродукцииУслугБУ.мПериод = Дата;
	ДвиженияВыпускПродукцииУслугБУ.мТаблицаДвижений = ТаблицаДвиженийВыпускБУ;
	
КонецПроцедуры // ДвиженияПоТабличнойЧастиПродукция()

// Процедура формирует движения по выпуску продукции по бухгалтерскому учету
Процедура ДвиженияПоВыпускуПродукцииБух(Строка, СтруктураШапкиДокумента, Операция, ТаблицаДвиженийВыпуск, БухгалтерскийУчет)

	Счет                = Строка.СчетУчетаБУ;
	СчетЗатратТекущий   = СчетЗатрат;
	УчетнаяПолитика     = мУчетнаяПолитикаБух;
	
	// Сформируем проводку.
	Если НЕ ЗначениеЗаполнено(Счет)
	 ИЛИ НЕ ЗначениеЗаполнено(СчетЗатратТекущий) Тогда
		Возврат;
	КонецЕсли;

	НоваяПроводка = Операция.Добавить();

	НоваяПроводка.Организация = Организация;
	НоваяПроводка.Период      = Дата;

	НоваяПроводка.СчетДт = Счет;
	ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетДт, НоваяПроводка.СубконтоДт, "Номенклатура", 			Строка.Номенклатура);
	ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетДт, НоваяПроводка.СубконтоДт, "НоменклатурныеПозиции",    Строка.НоменклатурнаяПозиция);
	ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетДт, НоваяПроводка.СубконтоДт, "Склады",       			Склад);
	
	// Если способ оценки ФИФО или ЛИФО и на счете ведется партионный учет,
	// то в проводке указываем в качестве партии текущий документ.
	Если ПартионныйУчетБУ Тогда
		ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетДт, НоваяПроводка.СубконтоДт, "Партии",       Ссылка);
	КонецЕсли; 
	
	НоваяПроводка.Содержание = НСтр("ru='Выпуск продукции';uk='Випуск продукції'",Локализация.КодЯзыкаИнформационнойБазы());
	
	НоваяПроводка.СчетКт = СчетЗатратТекущий;
	
	ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетКт, НоваяПроводка.СубконтоКт, "Подразделения",        ПодразделениеОрганизации);
	ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетКт, НоваяПроводка.СубконтоКт, "НоменклатурныеГруппы", Строка.НоменклатурнаяГруппа);
	
	НоваяПроводка.КоличествоДт = ?(НоваяПроводка.СчетДТ.Количественный, Строка.Количество, 0);
	НоваяПроводка.Сумма        = Строка.СуммаПлановая;
	
	НоваяПроводка.НалоговоеНазначениеДт = Строка.НалоговоеНазначение;
	НоваяПроводка.НалоговоеНазначениеКт = Строка.НалоговоеНазначение;
	
	Если СтруктураШапкиДокумента.ЕстьНалогНаПрибыльДо2015
	   И Строка.НалоговоеНазначение <> Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_НеоблагаемаяНеХозДеятельность Тогда
		СуммаНУ = Строка.СуммаПлановая;
		НоваяПроводка.СуммаНУДт = СуммаНУ;
		НоваяПроводка.СуммаНУКт = СуммаНУ;
	КонецЕсли;
	
	// Отражения выпуска в регистре накопления ВыпускПродукцииУслугБухгалтерскийУчет
	СтрокаДвижения = ТаблицаДвиженийВыпуск.Добавить();
	СтрокаДвижения.Организация           = Организация;
	СтрокаДвижения.Продукция             = Строка.Номенклатура;
	СтрокаДвижения.НоменклатурнаяПозиция = Строка.НоменклатурнаяПозиция;
	СтрокаДвижения.СчетЗатрат            = СчетЗатратТекущий;
	СтрокаДвижения.Подразделение         = ПодразделениеОрганизации;
	СтрокаДвижения.НоменклатурнаяГруппа  = Строка.НоменклатурнаяГруппа;
	СтрокаДвижения.СчетСписания          = Счет;
	
	СтрокаДвижения.НалоговоеНазначениеДоходовИЗатрат  = Строка.НалоговоеНазначение;
	
	Если Счет.ВидыСубконто.Количество() > 0 Тогда
		СтрокаДвижения.СубконтоСписания1 = НоваяПроводка.СубконтоДт[НоваяПроводка.СчетДт.ВидыСубконто[0].ВидСубконто];
	КонецЕсли; 
	
	Если Счет.ВидыСубконто.Количество() > 1 Тогда
		СтрокаДвижения.СубконтоСписания2 = НоваяПроводка.СубконтоДт[НоваяПроводка.СчетДт.ВидыСубконто[1].ВидСубконто];
	КонецЕсли;
	
	Если Счет.ВидыСубконто.Количество() > 2 Тогда
		СтрокаДвижения.СубконтоСписания3 = НоваяПроводка.СубконтоДт[НоваяПроводка.СчетДт.ВидыСубконто[2].ВидСубконто];
	КонецЕсли;
	
	Если Счет.ВидыСубконто.Количество() > 3 Тогда
		СтрокаДвижения.СубконтоСписания4 = НоваяПроводка.СубконтоДт[НоваяПроводка.СчетДт.ВидыСубконто[3].ВидСубконто];
	КонецЕсли;
	
	СтрокаДвижения.Количество = Строка.Количество;
	СтрокаДвижения.ПлановаяСтоимость = Строка.СуммаПлановая;
	
КонецПроцедуры // ДвиженияПоВыпускуПродукцииОтходовБух()

// Процедура формирует движения регистров по табличной части Услуги
Процедура ДвиженияПоТабличнойЧастиУслуги(ТаблицаПоУслугам, СтруктураШапкиДокумента)

	Если Услуги.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ДвиженияПоТабличнойЧастиУслугиУпр(ТаблицаПоУслугам, СтруктураШапкиДокумента);
	ДвиженияПоТабличнойЧастиУслугиБух(ТаблицаПоУслугам, СтруктураШапкиДокумента);
	
КонецПроцедуры // ДвиженияПоТабличнойЧастиУслуги()

// Процедура формирует движения регистров по табличной части Услуги по управленческому учету
Процедура ДвиженияПоТабличнойЧастиУслугиУпр(ТаблицаПоУслугам, СтруктураШапкиДокумента)

	Если Не ОтражатьВУправленческомУчете Тогда
		Возврат;
	КонецЕсли;
	
	НаборДвиженийВП   = Движения["ВыпускПродукцииУслуг"];
	ТаблицаДвиженийВП = НаборДвиженийВП.ВыгрузитьКолонки();
	
	НаборДвиженийНЗП   = Движения["НезавершенноеПроизводство"];
	ТаблицаДвиженийНЗП = НаборДвиженийНЗП.ВыгрузитьКолонки();
	
	ТаблицаЗатрат = Новый ТаблицаЗначений;
	ТаблицаЗатрат.Колонки.Добавить("СтатьяЗатрат"              , Новый ОписаниеТипов("СправочникСсылка.СтатьиЗатрат"));
	ТаблицаЗатрат.Колонки.Добавить("Подразделение"             , Новый ОписаниеТипов("СправочникСсылка.Подразделения"));
	ТаблицаЗатрат.Колонки.Добавить("НоменклатурнаяГруппа"      , Новый ОписаниеТипов("СправочникСсылка.НоменклатурныеГруппы"));
	ТаблицаЗатрат.Колонки.Добавить("Номенклатура"              , Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТаблицаЗатрат.Колонки.Добавить("ХарактеристикаНоменклатуры", Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	ТаблицаЗатрат.Колонки.Добавить("СерияНоменклатуры"         , Новый ОписаниеТипов("СправочникСсылка.СерииНоменклатуры"));
	ТаблицаЗатрат.Колонки.Добавить("Продукция"                 , Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТаблицаЗатрат.Колонки.Добавить("ХарактеристикаПродукции"   , Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	ТаблицаЗатрат.Колонки.Добавить("СерияПродукции"            , Новый ОписаниеТипов("СправочникСсылка.СерииНоменклатуры"));
	ТаблицаЗатрат.Колонки.Добавить("ОбъектСтроительства");
	ТаблицаЗатрат.Колонки.Добавить("Заказ");
	ТаблицаЗатрат.Колонки.Добавить("Количество"                , ОбщегоНазначения.ПолучитьОписаниеТиповЧисла(15, 3));
	ТаблицаЗатрат.Колонки.Добавить("СуммаУпр"                  , ОбщегоНазначения.ПолучитьОписаниеТиповЧисла(15, 2));
	ТаблицаЗатрат.Колонки.Добавить("НДСУпр"                    , ОбщегоНазначения.ПолучитьОписаниеТиповЧисла(15, 2));
	
	ТаблицаЗатрат.Колонки.Добавить("ПодразделениеНЗП"             , Новый ОписаниеТипов("СправочникСсылка.Подразделения"));
	ТаблицаЗатрат.Колонки.Добавить("НоменклатурнаяГруппаНЗП"      , Новый ОписаниеТипов("СправочникСсылка.НоменклатурныеГруппы"));
	
	
	Для Каждого Строка Из ТаблицаПоУслугам Цикл
		
		ХарактерЗатрат = Строка.ХарактерЗатрат;
		
		// отражение выпуска - движение по регистру ВыпускПродукцииУслуг
		ДвиженияПоВыпускуВнутрУслугУпр(СтруктураШапкиДокумента, Строка, ХарактерЗатрат, ТаблицаДвиженийВП);
		
		// добавление строки в таблицу затрат
			
		НоваяСтрока = ТаблицаЗатрат.Добавить();
		НоваяСтрока.СтатьяЗатрат               = Строка.СтатьяЗатратПолучатель;
		НоваяСтрока.Подразделение              = Строка.ПодразделениеПолучатель;
		НоваяСтрока.НоменклатурнаяГруппа       = Строка.НоменклатурнаяГруппаПолучатель;
		// НоваяСтрока.Заказ                      = Строка.ЗаказПолучатель;
		// НоваяСтрока.Номенклатура               = Строка.Номенклатура;
		// НоваяСтрока.ХарактеристикаНоменклатуры = Строка.ХарактеристикаНоменклатуры;
		// НоваяСтрока.СерияНоменклатуры          = ?(Строка.Номенклатура.ВестиУчетПоСериямВНЗП, Строка.СерияНоменклатуры, Неопределено);
		// НоваяСтрока.Продукция                  = Строка.Продукция;
		// НоваяСтрока.ХарактеристикаПродукции    = Строка.ХарактеристикаПродукции;
		// НоваяСтрока.СерияПродукции             = Строка.СерияПродукции;
		НоваяСтрока.ОбъектСтроительства        = Строка.ОбъектСтроительства;
		НоваяСтрока.СуммаУпр                   = Строка.СуммаПлановаяУпр;
		НоваяСтрока.НДСУпр                     = Строка.ПлановыйНДСУпр;
		НоваяСтрока.Количество                 = 0;
		
		НоваяСтрока.ПодразделениеНЗП           = СтруктураШапкиДокумента.Подразделение;
		НоваяСтрока.НоменклатурнаяГруппаНЗП    = Строка.НоменклатурнаяГруппа;
		
		// спишем из НЗП плановую стоимость
		НоваяСтрокаНЗП = ТаблицаДвиженийНЗП.Добавить();
		НоваяСтрокаНЗП.Подразделение = СтруктураШапкиДокумента.Подразделение;
		НоваяСтрокаНЗП.НоменклатурнаяГруппа = Строка.НоменклатурнаяГруппа;
			
		НоваяСтрокаНЗП.Стоимость = Строка.СуммаПлановаяУпрБезНДС;
		НоваяСтрокаНЗП.НДС       = Строка.ПлановыйНДСУпр;
			
		НоваяСтрокаНЗП.Продукция = Строка.Номенклатура;
		
		НоваяСтрокаНЗП.КодОперации  = Перечисления.КодыОперацийНезавершенноеПроизводство.СписаниеНЗПРегламент;
		
	КонецЦикла;
	
	НаборДвиженийНЗП.мПериод = Дата;
	НаборДвиженийНЗП.мТаблицаДвижений = ТаблицаДвиженийНЗП;
	НаборДвиженийНЗП.ВыполнитьРасход();
	НаборДвиженийНЗП.Записать(Ложь);
	
	// движения по затратам - НезавершенноеПроизводство, Затраты, БракВПроизводстве, СтроительствоОбъектовОсновныхСредств
	Если ТаблицаЗатрат.Количество() > 0 Тогда
		СтруктДопПараметры = Новый Структура;
		СтруктДопПараметры.Вставить("КодОперацииНЗП" , Перечисления.КодыОперацийНезавершенноеПроизводство.ВнутренниеУслугиНаПроизводство);
		СтруктДопПараметры.Вставить("ЕстьНДС"        , Ложь);
		СтруктДопПараметры.Вставить("ЕстьКоличество" , Ложь);
			
		УправлениеЗатратами.ДвиженияПоПрочимЗатратамУпр(ЭтотОбъект, ТаблицаЗатрат, СтруктураШапкиДокумента, мВалютаРегламентированногоУчета, СтруктДопПараметры);
	КонецЕсли;
	
	
	НаборДвиженийВП.мПериод = Дата;
	НаборДвиженийВП.мТаблицаДвижений = ТаблицаДвиженийВП;
	НаборДвиженийВП.ДобавитьДвижение();
	
КонецПроцедуры // ДвиженияПоТабличнойЧастиУслугиУпр()

// Процедура формирует движения по выпуску внутренних услуг производственных подразделений по управленческому учету
Процедура ДвиженияПоВыпускуВнутрУслугУпр(СтруктураШапкиДокумента, Строка, ХарактерЗатрат, ТаблицаДвиженийВП)
	
	Если Не ОтражатьВУправленческомУчете Тогда
		Возврат;
	КонецЕсли;
	
	// Отражаем факт изготовления продукции в регистре ВыпускПродукцииУслуг
	НоваяСтрокаВП = ТаблицаДвиженийВП.Добавить();
	НоваяСтрокаВП.Подразделение           = СтруктураШапкиДокумента.Подразделение;
	НоваяСтрокаВП.НоменклатурнаяГруппа    = Строка.НоменклатурнаяГруппа;
	НоваяСтрокаВП.Продукция               = Строка.Номенклатура;
	// НоваяСтрокаВП.ХарактеристикаПродукции = Строка.ХарактеристикаНоменклатуры;
	// НоваяСтрокаВП.СерияПродукции          = Строка.СерияНоменклатуры;
	// НоваяСтрокаВП.Спецификация            = Строка.Спецификация;
	НоваяСтрокаВП.ДокументВыпуска         = Ссылка;
	
	НоваяСтрокаВП.ПрямыеРасходыРаспределятьПоКоличеству = Не УслугиВСуммовомВыражении;
	НоваяСтрокаВП.Количество = ?(УслугиВСуммовомВыражении, 1, Строка.Количество);
	НоваяСтрокаВП.ПлановаяСтоимость = ?(УслугиВСуммовомВыражении, Строка.СуммаПлановая, 0);
	НоваяСтрокаВП.ПлановыйНДС       = ?(УслугиВСуммовомВыражении, Строка.ПлановыйНДСУпр, 0);
	
	
	Если ХарактерЗатрат = Перечисления.ХарактерЗатрат.Прочие Тогда
		НоваяСтрокаВП.КодОперации = Перечисления.КодыОперацийВыпускПродукции.ВыпускПродукцииФиксВнутрУслугиНаСчет;
	ИначеЕсли Строка.СтатьяЗатратПолучатель.ХарактерЗатрат = Перечисления.ХарактерЗатрат.ПроизводственныеРасходы Тогда
		НоваяСтрокаВП.КодОперации = Перечисления.КодыОперацийВыпускПродукции.ВыпускПродукцииФиксВнутрУслугиНаПроизводство;
	Иначе
		НоваяСтрокаВП.КодОперации = Перечисления.КодыОперацийВыпускПродукции.ВыпускПродукцииФиксВнутрУслугиНаПостЗатраты;
	КонецЕсли;
	
			
		НоваяСтрокаВП.ПодразделениеПолучатель        = Строка.ПодразделениеПолучатель;
		НоваяСтрокаВП.СтатьяЗатратПолучатель         = Строка.СтатьяЗатратПолучатель;
		НоваяСтрокаВП.НоменклатурнаяГруппаПолучатель = Строка.НоменклатурнаяГруппаПолучатель;
	
КонецПроцедуры // ДвиженияПоВыпускуВнутрУслугУпр()

// Процедура формирует движения регистров по табличной части Услуги по бухгалтерскому учету
Процедура ДвиженияПоТабличнойЧастиУслугиБух(ТаблицаПоУслугам, СтруктураШапкиДокумента)

	Если НЕ СтруктураШапкиДокумента.ОтражатьВБухгалтерскомУчете Тогда
		Возврат;
	КонецЕсли; 
	
	Для Каждого Строка Из ТаблицаПоУслугам Цикл
		// отражение выпуска - проводка и движение по регистру ВыпускПродукцииУслугБухгалтерскийУчет
		 ДвиженияПоВыпускуВнутрУслугБух(Строка, СтруктураШапкиДокумента, ОперацияБУ, ТаблицаДвиженийВыпускБУ);
	КонецЦикла;

	ДвиженияВыпускПродукцииУслугБУ.мПериод = Дата;
	ДвиженияВыпускПродукцииУслугБУ.мТаблицаДвижений = ТаблицаДвиженийВыпускБУ;

КонецПроцедуры // ДвиженияПоТабличнойЧастиУслуги()

// Процедура формирует движения по выпуску внутренних услуг производственных подразделений по бухгалтерскому учету
Процедура ДвиженияПоВыпускуВнутрУслугБух(Строка, СтруктураШапкиДокумента, Операция, ТаблицаДвиженийВыпуск)

	Счет                      = Строка.Счет;
	СчетЗатратТекущий         = СчетЗатрат;
	УчетнаяПолитика           = мУчетнаяПолитикаБух;

	// Сформируем проводку.
	Если НЕ ЗначениеЗаполнено(Счет)
	 ИЛИ НЕ ЗначениеЗаполнено(СчетЗатратТекущий) Тогда
		Возврат;
	КонецЕсли;

	НоваяПроводка = Операция.Добавить();

	НоваяПроводка.Организация = Организация;
	НоваяПроводка.Период      = Дата;

	НоваяПроводка.СчетДт = Счет;
	
	Если ЗначениеЗаполнено(Строка.ХарактерЗатрат) И НЕ (Строка.ХарактерЗатрат = Перечисления.ХарактерЗатрат.Прочие ИЛИ Строка.ХарактерЗатрат = Перечисления.ХарактерЗатрат.ПрочиеОперационныеРасходы) Тогда
		ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетДт, НоваяПроводка.СубконтоДт, "Подразделения"       , Строка.ПодразделениеОрганизацииПолучатель);
		ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетДт, НоваяПроводка.СубконтоДт, "НоменклатурныеГруппы", Строка.НоменклатурнаяГруппаПолучатель);
		ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетДт, НоваяПроводка.СубконтоДт, "СтатьиЗатрат"        , Строка.СтатьяЗатратПолучатель);
		ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетДт, НоваяПроводка.СубконтоДт, "ОбъектыСтроительства", Строка.ОбъектСтроительства);
		ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетДт, НоваяПроводка.СубконтоДт, "НалоговыеНазначения" , Строка.НалоговоеНазначение);
	Иначе
		ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетДт, НоваяПроводка.СубконтоДт, 1, Строка.Субконто1);
		ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетДт, НоваяПроводка.СубконтоДт, 2, Строка.Субконто2);
		ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетДт, НоваяПроводка.СубконтоДт, 3, Строка.Субконто3);
	КонецЕсли; 
	
	НоваяПроводка.Содержание = НСтр("ru='Выпуск внутр.услуг';uk='Випуск внутр.послуг'",Локализация.КодЯзыкаИнформационнойБазы());

	НоваяПроводка.СчетКт = СчетЗатратТекущий;
	ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетКт, НоваяПроводка.СубконтоКт, "НоменклатурныеГруппы", Строка.НоменклатурнаяГруппа);
	ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетКт, НоваяПроводка.СубконтоКт, "Подразделения", ПодразделениеОрганизации);
	
	//ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетКт, НоваяПроводка.СубконтоКт, "СтатьиЗатрат", );
	
	НоваяПроводка.КоличествоДт = ?(НоваяПроводка.СчетДТ.Количественный, Строка.Количество, 0);
	НоваяПроводка.Сумма        = Строка.СуммаПлановая;
	
	НоваяПроводка.НалоговоеНазначениеДт = Строка.НалоговоеНазначениеДоходовИЗатрат;
	НоваяПроводка.НалоговоеНазначениеКт = Строка.НалоговоеНазначение;
	
	Если СтруктураШапкиДокумента.ЕстьНалогНаПрибыльДо2015
		И Строка.НалоговоеНазначение <> Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_НеоблагаемаяНеХозДеятельность Тогда
		СуммаНУ = Строка.СуммаПлановая;
		НоваяПроводка.СуммаНУДт = СуммаНУ;
		НоваяПроводка.СуммаНУКт = СуммаНУ;
	КонецЕсли;
	
	// Отражения выпуска в регистре накопления ВыпускПродукцииУслугБухгалтерскийУчет
	СтрокаДвижения = ТаблицаДвиженийВыпуск.Добавить();
	СтрокаДвижения.Организация           = Организация;
	СтрокаДвижения.Продукция             = Строка.Номенклатура;
	СтрокаДвижения.СчетЗатрат            = СчетЗатратТекущий;
	СтрокаДвижения.Подразделение         = ПодразделениеОрганизации;
	СтрокаДвижения.НоменклатурнаяГруппа  = Строка.НоменклатурнаяГруппа;
	СтрокаДвижения.СчетСписания          = Счет;
	
	СтрокаДвижения.НалоговоеНазначениеДоходовИЗатрат   = Строка.НалоговоеНазначениеДоходовИЗатрат;
 
	Если Счет.ВидыСубконто.Количество() > 0 Тогда
		СтрокаДвижения.СубконтоСписания1 = НоваяПроводка.СубконтоДт[НоваяПроводка.СчетДт.ВидыСубконто[0].ВидСубконто];
	КонецЕсли; 
	
	Если Счет.ВидыСубконто.Количество() > 1 Тогда
		СтрокаДвижения.СубконтоСписания2 = НоваяПроводка.СубконтоДт[НоваяПроводка.СчетДт.ВидыСубконто[1].ВидСубконто];
	КонецЕсли;
	
	Если Счет.ВидыСубконто.Количество() > 2 Тогда
		СтрокаДвижения.СубконтоСписания3 = НоваяПроводка.СубконтоДт[НоваяПроводка.СчетДт.ВидыСубконто[2].ВидСубконто];
	КонецЕсли;
	
	Если Счет.ВидыСубконто.Количество() > 3 Тогда
		СтрокаДвижения.СубконтоСписания4 = НоваяПроводка.СубконтоДт[НоваяПроводка.СчетДт.ВидыСубконто[3].ВидСубконто];
	КонецЕсли;
	
	СтрокаДвижения.ПрямыеРасходыРаспределятьПоКоличеству = Не УслугиВСуммовомВыражении;
	СтрокаДвижения.Количество = ?(УслугиВСуммовомВыражении, 1, Строка.Количество);
	СтрокаДвижения.ПлановаяСтоимость = ?(УслугиВСуммовомВыражении, Строка.СуммаПлановая, 0);
	
КонецПроцедуры // ДвиженияПоВыпускуВнутрУслуг()

// Процедура формирует движения регистров по табличной части ВозвратныеОтходы
////
Процедура ДвиженияПоТабличнойЧастиОтходы(ТаблицаПоОтходам, СтруктураШапкиДокумента)

	Если ВозвратныеОтходы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ДвиженияПоТабличнойЧастиОтходыУпр(ТаблицаПоОтходам, СтруктураШапкиДокумента);
	ДвиженияПоТабличнойЧастиОтходыБух(ТаблицаПоОтходам, СтруктураШапкиДокумента);

КонецПроцедуры // ДвиженияПоТабличнойЧастиОтходы()

// Процедура формирует движения регистров по табличной части ВозвратныеОтходы по управленческому учету
Процедура ДвиженияПоТабличнойЧастиОтходыУпр(ТаблицаПоОтходам, СтруктураШапкиДокумента)

	Если Не ОтражатьВУправленческомУчете Тогда
		Возврат;
	КонецЕсли;
	
	НаборДвиженийТоварыНаСкладах  = Движения["ТоварыНаСкладах"];
	ТаблицаДвиженийТоварыНаСкладах = НаборДвиженийТоварыНаСкладах.ВыгрузитьКолонки();
	
	НаборДвиженийВП   = Движения["ВыпускПродукцииУслуг"];
	ТаблицаДвиженийВП = НаборДвиженийВП.ВыгрузитьКолонки();
	
	НаборДвиженийПартии   = Движения["ПартииТоваровНаСкладах"];
	ТаблицаДвиженийПартии = НаборДвиженийПартии.ВыгрузитьКолонки();
	
	НаборДвиженийРезерв   = Движения["ТоварыВРезервеНаСкладах"];
	ТаблицаДвиженийРезерв = НаборДвиженийРезерв.ВыгрузитьКолонки();
	
	НаборДвиженийНЗП   = Движения["НезавершенноеПроизводство"];
	ТаблицаДвиженийНЗП = НаборДвиженийНЗП.ВыгрузитьКолонки();
	
	Для Каждого Строка Из ТаблицаПоОтходам Цикл
		
		ДвиженияПоВыпускуПродукцииОтходовУпр(СтруктураШапкиДокумента, Строка, "ВозвратныеОтходы", ТаблицаДвиженийВП, ТаблицаДвиженийРезерв, ТаблицаДвиженийТоварыНаСкладах, ТаблицаДвиженийПартии);
		
		// добавим в НЗП плановую стоимость и плановый НДС с -
		НоваяСтрокаНЗП = ТаблицаДвиженийНЗП.Добавить();
		
		НоваяСтрокаНЗП.Подразделение 				= СтруктураШапкиДокумента.Подразделение;
		НоваяСтрокаНЗП.НоменклатурнаяГруппа 		= Строка.НоменклатурнаяГруппа;
		
		НоваяСтрокаНЗП.Стоимость 					= -Строка.СуммаПлановаяУпрБезНДС;
		НоваяСтрокаНЗП.НДС       					= -Строка.ПлановыйНДСУпр;
		
		НоваяСтрокаНЗП.КодОперации 					= Перечисления.КодыОперацийНезавершенноеПроизводство.ОтрицательныеЗатраты; 
		НоваяСтрокаНЗП.СтатьяЗатрат 				= Строка.СтатьяЗатрат;
		НоваяСтрокаНЗП.НоменклатураЗатрат           = Строка.Номенклатура;
		НоваяСтрокаНЗП.НоменклатураЗатратКоличество = Строка.Количество;

	КонецЦикла;
	
	НаборДвиженийТоварыНаСкладах.мПериод = Дата;
	НаборДвиженийТоварыНаСкладах.мТаблицаДвижений = ТаблицаДвиженийТоварыНаСкладах;
	НаборДвиженийТоварыНаСкладах.ВыполнитьПриход();

	//НаборДвиженийВП.мПериод = Дата;
	//НаборДвиженийВП.мТаблицаДвижений = ТаблицаДвиженийВП;
	//НаборДвиженийВП.ДобавитьДвижение();

	НаборДвиженийПартии.мПериод = Дата;
	НаборДвиженийПартии.мТаблицаДвижений = ТаблицаДвиженийПартии;
	НаборДвиженийПартии.ВыполнитьПриход();
	НаборДвиженийПартии.Записать(Ложь);
			
	//НаборДвиженийРезерв.мПериод = Дата;
	//НаборДвиженийРезерв.мТаблицаДвижений = ТаблицаДвиженийРезерв;
	//НаборДвиженийРезерв.ВыполнитьПриход();
		
	НаборДвиженийНЗП.мПериод = Дата;
	НаборДвиженийНЗП.мТаблицаДвижений = ТаблицаДвиженийНЗП;
	НаборДвиженийНЗП.ВыполнитьПриход();
	НаборДвиженийНЗП.Записать(Ложь);

КонецПроцедуры // ДвиженияПоТабличнойЧастиОтходыУпр()


// Процедура формирует движения регистров по табличной части ВозвратныеОтходы
////
Процедура ДвиженияПоТабличнойЧастиОтходыБух(ТаблицаПоОтходам, СтруктураШапкиДокумента)
	
	Если НЕ СтруктураШапкиДокумента.ОтражатьВБухгалтерскомУчете Тогда
		Возврат;
	КонецЕсли; 
	
	Для Каждого Строка Из ТаблицаПоОтходам Цикл
		ДвиженияПоВыпускуОтходовБух(Строка, СтруктураШапкиДокумента, ОперацияБУ, ТаблицаДвиженийВыпускБУ, Истина);
	КонецЦикла;

	ДвиженияВыпускПродукцииУслугБУ.мПериод = Дата;
	ДвиженияВыпускПродукцииУслугБУ.мТаблицаДвижений = ТаблицаДвиженийВыпускБУ;

КонецПроцедуры // ДвиженияПоТабличнойЧастиОтходыБух()


// Процедура формирует движения по выпуску отходов.
//
Процедура ДвиженияПоВыпускуОтходовБух(Строка, СтруктураШапкиДокумента, Операция, ТаблицаДвиженийВыпуск, БухгалтерскийУчет)

	Счет                = Строка.Счет;
	СчетЗатратТекущий   = СчетЗатрат;
	СтатьяЗатрат        = Строка.СтатьяЗатрат;
	УчетнаяПолитика     = мУчетнаяПолитикаБух;
	

	// Сформируем проводку.
	Если НЕ ЗначениеЗаполнено(Счет)
	 ИЛИ НЕ ЗначениеЗаполнено(СчетЗатратТекущий) Тогда
		Возврат;
	КонецЕсли;

	НоваяПроводка = Операция.Добавить();

	НоваяПроводка.Организация = Организация;
	НоваяПроводка.Период      = Дата;

	НоваяПроводка.СчетКт = Счет;
	ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетКт, НоваяПроводка.СубконтоКт, "Номенклатура", Строка.Номенклатура);
	ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетКт, НоваяПроводка.СубконтоКт, "Склады",       Склад);
	
	ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетКт, НоваяПроводка.СубконтоКт, "НоменклатурныеПозиции", Строка.НоменклатурнаяПозиция);
	
	// Если способ оценки ФИФО или ЛИФО и на счете ведется партионный учет,
	// то в проводке указываем в качестве партии текущий документ.
	Если УправлениеЗапасами.ВедетсяПартионныйУчет(УчетнаяПолитика) Тогда
		ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетКт, НоваяПроводка.СубконтоКт, "Партии",       Ссылка);
	КонецЕсли; 

	НоваяПроводка.Содержание = НСтр("ru='Выпуск возвратных отходов';uk='Випуск зворотних відходів'",Локализация.КодЯзыкаИнформационнойБазы());

	НоваяПроводка.СчетДт = СчетЗатратТекущий;
	ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетДт, НоваяПроводка.СубконтоДт, "Подразделения",        ПодразделениеОрганизации);
	ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетДт, НоваяПроводка.СубконтоДт, "НоменклатурныеГруппы", Строка.НоменклатурнаяГруппа);
	ОбщегоНазначения.УстановитьСубконто(НоваяПроводка.СчетДт, НоваяПроводка.СубконтоДт, "СтатьиЗатрат",         СтатьяЗатрат);
	
	НоваяПроводка.КоличествоКт = ?(НоваяПроводка.СчетКТ.Количественный, - Строка.Количество, 0);
	НоваяПроводка.Сумма        = - Строка.Сумма;
	
	НоваяПроводка.НалоговоеНазначениеДт = Строка.НалоговоеНазначение;
	НоваяПроводка.НалоговоеНазначениеКт = Строка.НалоговоеНазначение;
	
	Если СтруктураШапкиДокумента.ЕстьНалогНаПрибыльДо2015
	   И Строка.НалоговоеНазначение <> Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_НеоблагаемаяНеХозДеятельность Тогда
		СуммаНУ = - Строка.Сумма;
		НоваяПроводка.СуммаНУДт = СуммаНУ;
		НоваяПроводка.СуммаНУКт = СуммаНУ;
	КонецЕсли;
				
КонецПроцедуры // ДвиженияПоВыпускуОтходовБух()


// Процедура формирует движения регистров по табличной части Материалы
Процедура ДвиженияПоТабличнойЧастиМатериалы(ТаблицаПоМатериалам, СтруктураШапкиДокумента, РежимПроведения, Отказ, Заголовок)

	Если НЕ ИспользоватьМатериалы Тогда
		Возврат;
	КонецЕсли; 
	
	Если Материалы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ДвиженияПоТабличнойЧастиМатериалыУпр(ТаблицаПоМатериалам, СтруктураШапкиДокумента, РежимПроведения, Отказ, Заголовок);
	ДвиженияПоТабличнойЧастиМатериалыБух(ТаблицаПоМатериалам, СтруктураШапкиДокумента, РежимПроведения, Отказ, Заголовок);
	
	// Списание по партиям в УУ
	Если ОтражатьВУправленческомУчете Тогда
	
		// Проводить по партиям сразу нужно если установлен параметр
		// учетной политики СписыватьПартииПриПроведенииДокументов.
		ПроводитьПоПартиям = РегистрыСведений.УчетнаяПолитика.ПолучитьПоследнее(Дата).СписыватьПартииПриПроведенииДокументов;
			
		Если ПроводитьПоПартиям Тогда
			
			УправлениеЗапасамиПартионныйУчет.ДвижениеПартийТоваров(Ссылка, Движения.СписанныеТовары.Выгрузить());
			
			ЗаписьРегистрации = ПринадлежностьПоследовательностям.ПартионныйУчет.Добавить();
			ЗаписьРегистрации.Период = Дата;
			ЗаписьРегистрации.Регистратор = Ссылка;
			
		Иначе
			// В неоперативном режиме границы последовательностей сдвигаются назад, если они позже документа.
			Если РежимПроведения = РежимПроведенияДокумента.Неоперативный Тогда
				УправлениеЗапасамиПартионныйУчет.СдвигГраницыПоследовательностиПартионногоУчетаНазад(Дата, Ссылка, Организация);
			КонецЕсли;
			
		КонецЕсли;
	
	КонецЕсли;
	

КонецПроцедуры // ДвиженияПоТабличнойЧастиМатериалы()

// Процедура формирует движения регистров по табличной части Материалы по упр. учету 
Процедура ДвиженияПоТабличнойЧастиМатериалыУпр(ТаблицаПоМатериалам, СтруктураШапкиДокумента, РежимПроведения, Отказ, Заголовок)

	Если Не ОтражатьВУправленческомУчете Тогда
		Возврат;
	КонецЕсли;
	
	// МАТЕРИАЛЫ ПО РЕГИСТРУ ТоварыНаСкладах.
	НаборДвижений = Движения.ТоварыНаСкладах;

	// Получим таблицу значений, совпадающую со струкутрой набора записей регистра.
	ТаблицаДвижений = НаборДвижений.ВыгрузитьКолонки();

	// Заполним таблицу движений.
	ОбщегоНазначения.ЗагрузитьВТаблицуЗначений(ТаблицаПоМатериалам, ТаблицаДвижений);
	
	ТаблицаДвижений.ЗаполнитьЗначения(Склад,						"Склад");
	
	НаборДвижений.мПериод            = Дата;
	НаборДвижений.мТаблицаДвижений   = ТаблицаДвижений;

	// Проверка остатков при оперативном проведении.
	Если РежимПроведения = РежимПроведенияДокумента.Оперативный Тогда
		НаборДвижений.КонтрольОстатков(ЭтотОбъект, "Материалы", СтруктураШапкиДокумента, Отказ, Заголовок);
	КонецЕсли;
		
	Если Не Отказ Тогда
		Движения.ТоварыНаСкладах.ВыполнитьРасход();
	КонецЕсли;
	
	// Если есть списание из резерва, то надо списать резерв
	ТаблицаПоТоварамИзРезерва = ТаблицаПоМатериалам.Скопировать();
	
	Сч = 0;
	Пока Сч < ТаблицаПоТоварамИзРезерва.Количество() Цикл
		СтрокаТаблицы = ТаблицаПоТоварамИзРезерва.Получить(Сч);
		Если СтрокаТаблицы.СпособСписанияОстаткаТоваров <> Перечисления.СпособыСписанияОстаткаТоваров.ИзРезерва Тогда
			 ТаблицаПоТоварамИзРезерва.Удалить(СтрокаТаблицы);
		Иначе 
			Сч = Сч + 1;
		КонецЕсли; 
	КонецЦикла;

	Если ТаблицаПоТоварамИзРезерва.Количество() > 0 Тогда
		
		НаборДвижений = Движения.ТоварыВРезервеНаСкладах;

		// Получим таблицу значений, совпадающую со структурой набора записей регистра.
		ТаблицаДвижений = НаборДвижений.ВыгрузитьКолонки();

		// Заполним таблицу движений.
		ОбщегоНазначения.ЗагрузитьВТаблицуЗначений(ТаблицаПоТоварамИзРезерва, ТаблицаДвижений);

		// Недостающие поля.
		ТаблицаДвижений.ЗаполнитьЗначения(Склад, "Склад");

		НаборДвижений.мПериод            = Дата;
		НаборДвижений.мТаблицаДвижений   = ТаблицаДвижений;

		Если РежимПроведения = РежимПроведенияДокумента.Оперативный Тогда
			НаборДвижений.КонтрольОстатков(ЭтотОбъект, "Материалы", 		 СтруктураШапкиДокумента, Отказ, Заголовок);
		КонецЕсли;
		
		Если Не Отказ Тогда
			Движения.ТоварыВРезервеНаСкладах.ВыполнитьРасход();
		КонецЕсли;
		
	КонецЕсли;
	
	ДвиженияПоРегиструСписанныеТовары(СтруктураШапкиДокумента, ТаблицаПоМатериалам, Отказ, Заголовок);
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("ИмяТабЧасти",     "Материалы");
	ДопПараметры.Вставить("СтатусПартии",    Перечисления.СтатусыПартийТоваров.Купленный);
	ДопПараметры.Вставить("РежимПроведения", РежимПроведения);
	ДопПараметры.Вставить("ИмяРеквизитаЗаказ", "Заказ");
	ДопПараметры.Вставить("ЗаказВШапке",       Ложь);
	
	УправлениеЗаказами.ДвижениеПоВнутреннимЗаказам(ЭтотОбъект, ТаблицаПоМатериалам, ДопПараметры, Отказ, Заголовок);
	

КонецПроцедуры // ДвиженияПоТабличнойЧастиМатериалыУпр()

// Формирование движений по регистру СписанныеТовары.
Процедура ДвиженияПоРегиструСписанныеТовары(СтруктураШапкиДокумента, ТаблицаПоМатериалам, Отказ, Заголовок)

	// МАТЕРИАЛЫ ПО РЕГИСТРУ СписанныеТовары.
	НаборДвижений = Движения.СписанныеТовары;

	// Получим таблицу значений, совпадающую со структурой набора записей регистра.
	ТаблицаДвижений = НаборДвижений.ВыгрузитьКолонки();

	// Заполним таблицу движений.

	ОбщегоНазначения.ЗагрузитьВТаблицуЗначений(ТаблицаПоМатериалам, ТаблицаДвижений);

	// Недостающие поля.
	Инд = 0;
	Для каждого Строка Из ТаблицаДвижений Цикл
		Инд = Инд+1;
		Строка.НомерСтрокиДокумента = Инд;
		
		СтатьяЗатрат = Строка.СтатьяЗатрат;
				
		Если СтатьяЗатрат.ХарактерЗатрат = Перечисления.ХарактерЗатрат.ПроизводственныеРасходы Тогда
			Строка.КодОперацииПартииТоваров = Перечисления.КодыОперацийПартииТоваров.СписаниеПартийВПроизводствоОперативно;
		ИначеЕсли СтатьяЗатрат.ХарактерЗатрат = Перечисления.ХарактерЗатрат.БракВПроизводстве Тогда
			Строка.КодОперацииПартииТоваров = Перечисления.КодыОперацийПартииТоваров.СписаниеНаБрак;
		ИначеЕсли СтатьяЗатрат.ХарактерЗатрат = Перечисления.ХарактерЗатрат.ВложенияВоВнеоборотныеАктивы Тогда
			Строка.КодОперацииПартииТоваров = Перечисления.КодыОперацийПартииТоваров.СписаниеНаВложенияВоВнеоборотныеАктивы;
		Иначе
			Строка.КодОперацииПартииТоваров = Перечисления.КодыОперацийПартииТоваров.СписаниеНаЗатраты;
		КонецЕсли;
		
		Строка.ВидТабличнойЧасти = Перечисления.ВидыТабличныхЧастей.Материалы;		
		
		СтрокаТЧ = ТаблицаПоМатериалам.Получить(ТаблицаДвижений.Индекс(Строка));
		
		Если (ТипЗнч(СтрокаТЧ.Заказ) = Тип("ДокументСсылка.ЗаказПокупателя")) И (СтрокаТЧ.Заказ.ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.Переработка) Тогда
			// давальческие материалы
			Строка.ДопустимыйСтатус1 = Перечисления.СтатусыПартийТоваров.ВПереработку;
			Строка.ВидТабличнойЧасти = Перечисления.ВидыТабличныхЧастей.МатериалыЗаказчика;		
			Строка.КодОперацииПартииТоваров = Перечисления.КодыОперацийПартииТоваров.СписаниеМатериаловЗаказчикаВПроизводствоОперативно;		
		Иначе
			Строка.ДопустимыйСтатус1 = Перечисления.СтатусыПартийТоваров.Купленный;
			Строка.ВидТабличнойЧасти = Перечисления.ВидыТабличныхЧастей.Материалы;	
			// КодОперацииПартииТоваров заполнен ранее
		КонецЕсли;
		
	КонецЦикла;
	
	ТаблицаДвижений.ЗаполнитьЗначения(Перечисления.СтатусыПартийТоваров.Продукция, "ДопустимыйСтатус2");
	
	// Если ПУ по складам
	Если мУчетнаяПолитикаУпр.ВестиПартионныйУчетПоСкладам Тогда
		ТаблицаДвижений.ЗаполнитьЗначения(Склад, "Склад");
	КонецЕсли;

	ТаблицаДвижений.ЗаполнитьЗначения(Дата,   "Период");
	ТаблицаДвижений.ЗаполнитьЗначения(Ссылка, "Регистратор");
	ТаблицаДвижений.ЗаполнитьЗначения(Истина, "Активность");
	
	ТаблицаДвижений.ЗаполнитьЗначения(СтруктураШапкиДокумента.Подразделение, "Подразделение");
    ТаблицаДвижений.ЗаполнитьЗначения(ОтражатьВУправленческомУчете, "ОтражатьВУправленческомУчете");

	НаборДвижений.мПериод          = Дата;
	НаборДвижений.мТаблицаДвижений = ТаблицаДвижений;

	Если Не Отказ Тогда
		Движения.СписанныеТовары.ВыполнитьДвижения();
	КонецЕсли;
	
	Если Движения.СписанныеТовары.Модифицированность() Тогда
		Движения.СписанныеТовары.Записать(Истина);
	КонецЕсли;

КонецПроцедуры // ДвиженияПоРегиструСписанныеТовары()

// Процедура формирует движения регистров по табличной части Материалы по регл. учету 
Процедура ДвиженияПоТабличнойЧастиМатериалыБух(ТаблицаПоМатериалам, СтруктураШапкиДокумента, РежимПроведения, Отказ, Заголовок)

	Если НЕ СтруктураШапкиДокумента.ОтражатьВБухгалтерскомУчете Тогда
		Возврат;	
	КонецЕсли;
	
	// МАТЕРИАЛЫ ПО РЕГИСТРУ ТоварыОрганизаций.
	НаборДвижений = Движения.ТоварыОрганизаций;

	// Получим таблицу значений, совпадающую со структурой набора записей регистра.
	ТаблицаДвижений = НаборДвижений.ВыгрузитьКолонки();

	// Заполним таблицу движений.
	ОбщегоНазначения.ЗагрузитьВТаблицуЗначений(ТаблицаПоМатериалам, ТаблицаДвижений);

	ТаблицаДвижений.ЗаполнитьЗначения(Организация, "Организация");
	ТаблицаДвижений.ЗаполнитьЗначения(Неопределено,"Комиссионер");
	ТаблицаДвижений.ЗаполнитьЗначения(СтруктураШапкиДокумента.Склад, "Склад");

	Если Не ВестиУчетПоДопРазрезамРегл Тогда
		ТаблицаДвижений.ЗаполнитьЗначения(Неопределено, "ХарактеристикаНоменклатуры");
		ТаблицаДвижений.ЗаполнитьЗначения(Неопределено, "СерияНоменклатуры");
		ТаблицаДвижений.ЗаполнитьЗначения(Неопределено, "Качество");
	КонецЕсли;
		
	Если Не ВестиСкладскойУчетБУ Тогда
		ТаблицаДвижений.ЗаполнитьЗначения(Неопределено, "Склад");
	КонецЕсли;
	
	НаборДвижений.мПериод            = Дата;
	НаборДвижений.мТаблицаДвижений   = ТаблицаДвижений;

	// Проверка остатков при оперативном проведении.
	Если РежимПроведения = РежимПроведенияДокумента.Оперативный Тогда
		НаборДвижений.КонтрольОстатков(ЭтотОбъект, "Материалы", СтруктураШапкиДокумента, Отказ, Заголовок);
	КонецЕсли;

	Если Не Отказ Тогда
		Движения.ТоварыОрганизаций.ВыполнитьРасход();
	КонецЕсли;
	
	// Списание по партиям по БУ
	ЕстьНалоговыйУчетПартий = (СтруктураШапкиДокумента.ЕстьНДС ИЛИ СтруктураШапкиДокумента.ЕстьНалогНаПрибыльДо2015);
	
	УправлениеЗапасамиПартионныйУчет.ДвижениеПартийТоваров(Ссылка, ТаблицаПоМатериалам, , Ложь, СтруктураШапкиДокумента.ОтражатьВБухгалтерскомУчете, , , Отказ);
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
КонецПроцедуры // ДвиженияПоТабличнойЧастиМатериалыБух()

Процедура ДвиженияПоРегиструТоварыОрганизаций(РежимПроведения, ТаблицаПоПродукции, ТаблицаПоОтходам, Отказ, Заголовок, СтруктураШапкиДокумента)

	Если Не СтруктураШапкиДокумента.ОтражатьВБухгалтерскомУчете Тогда
		Возврат;
	КонецЕсли;
	
	// ПРОДУКЦИЯ И ВОЗВРАТНЫЕ ОТХОДЫ ПО РЕГИСТРУ ТоварыОрганизаций.
	НаборДвижений = Движения.ТоварыОрганизаций;

	// Получим таблицу значений, совпадающую со структурой набора записей регистра.
	ТаблицаДвижений = НаборДвижений.ВыгрузитьКолонки();

	// Заполним таблицу движений.
	ТаблицаПоОтходам.Колонки.Счет.Имя = "СчетучетаБУ";
	ОбщегоНазначения.ЗагрузитьВТаблицуЗначений(ТаблицаПоОтходам,   ТаблицаДвижений);
	ТаблицаПоОтходам.Колонки.СчетУчетаБУ.Имя = "Счет"; 
		
	// Недостающие поля.
	ТаблицаДвижений.ЗаполнитьЗначения(Справочники.Качество.Новый, "Качество");
	// В Продукции качество есть, в возвратных отходах - всегда Новый 
	ОбщегоНазначения.ЗагрузитьВТаблицуЗначений(ТаблицаПоПродукции, ТаблицаДвижений);
	
	// Недостающие поля.
	ТаблицаДвижений.ЗаполнитьЗначения(Организация, 	"Организация");
	ТаблицаДвижений.ЗаполнитьЗначения(Склад, 		"Склад");
	ТаблицаДвижений.ЗаполнитьЗначения(Неопределено,	"Комиссионер");

	Если Не ВестиУчетПоДопРазрезамРегл Тогда
		ТаблицаДвижений.ЗаполнитьЗначения(Неопределено, "ХарактеристикаНоменклатуры");
		ТаблицаДвижений.ЗаполнитьЗначения(Неопределено, "СерияНоменклатуры");
		ТаблицаДвижений.ЗаполнитьЗначения(Неопределено, "Качество");
	КонецЕсли;
		
	Если Не ВестиСкладскойУчетБУ Тогда
		ТаблицаДвижений.ЗаполнитьЗначения(Неопределено, "Склад");
	КонецЕсли;
		
	НаборДвижений.мПериод            = Дата;
	НаборДвижений.мТаблицаДвижений   = ТаблицаДвижений;

	Если Не Отказ Тогда
		Движения.ТоварыОрганизаций.ВыполнитьПриход();
	КонецЕсли;

КонецПроцедуры // ДвиженияПоРегиструТоварыОрганизацийРегл()

Процедура ПодготовитьТаблицуПродукцииУпр(ТаблицаПоПродукции, СтруктураШапкиДокумента)
	
	Если Не СтруктураШапкиДокумента.ОтражатьВУправленческомУчете Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаПоПродукции.Колонки.Добавить("ПлановыйНДСУпр", ОбщегоНазначения.ПолучитьОписаниеТиповЧисла(15,2));
	ТаблицаПоПродукции.Колонки.Добавить("СуммаПлановаяУпрБезНДС", ОбщегоНазначения.ПолучитьОписаниеТиповЧисла(15,2));
	
	Для Каждого СтрокаТаблицы Из ТаблицаПоПродукции Цикл
		// ставку НДС берем из номенклатурной группы
		СтавкаНДС = УчетНДС.ПолучитьСтавкуНДС(СтрокаТаблицы.НоменклатурнаяГруппа.СтавкаНДС);
		ПлановыйНДСУпр = УчетНДС.РассчитатьСуммуНДС(СтрокаТаблицы.СуммаПлановаяУпр, Истина, Истина, СтавкаНДС);
		СтрокаТаблицы.ПлановыйНДСУпр = ПлановыйНДСУпр;
		СтрокаТаблицы.СуммаПлановаяУпрБезНДС = СтрокаТаблицы.СуммаПлановаяУпр - СтрокаТаблицы.ПлановыйНДСУпр;
	КонецЦикла;

КонецПроцедуры

Процедура ПодготовитьТаблицуУслугУпр(ТаблицаПоУслугам, СтруктураШапкиДокумента)
	
	Если Не СтруктураШапкиДокумента.ОтражатьВУправленческомУчете Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаПоУслугам.Колонки.Добавить("ПлановыйНДСУпр", ОбщегоНазначения.ПолучитьОписаниеТиповЧисла(15,2));
	ТаблицаПоУслугам.Колонки.Добавить("СуммаПлановаяУпрБезНДС", ОбщегоНазначения.ПолучитьОписаниеТиповЧисла(15,2));
	
	Для Каждого СтрокаТаблицы Из ТаблицаПоУслугам Цикл
		// ставку НДС берем из номенклатурной группы
		СтавкаНДС = УчетНДС.ПолучитьСтавкуНДС(СтрокаТаблицы.НоменклатурнаяГруппа.СтавкаНДС);
		ПлановыйНДСУпр = УчетНДС.РассчитатьСуммуНДС(СтрокаТаблицы.СуммаПлановаяУпр, Истина, Истина, СтавкаНДС);
		СтрокаТаблицы.ПлановыйНДСУпр = ПлановыйНДСУпр;
		СтрокаТаблицы.СуммаПлановаяУпрБезНДС = СтрокаТаблицы.СуммаПлановаяУпр - СтрокаТаблицы.ПлановыйНДСУпр;
	КонецЦикла;

КонецПроцедуры

Процедура ПодготовитьТаблицуОтходовУпр(ТаблицаПоОтходам, СтруктураШапкиДокумента)
	
	Если Не СтруктураШапкиДокумента.ОтражатьВУправленческомУчете Тогда
		Возврат;
	КонецЕсли;
	
	// добавим сумму без НДС, НДС в валюте управленческого учета
	
	ТаблицаПоОтходам.Колонки.Добавить("ПлановыйНДСУпр", ОбщегоНазначения.ПолучитьОписаниеТиповЧисла(15,2));
	ТаблицаПоОтходам.Колонки.Добавить("СуммаПлановаяУпрБезНДС", ОбщегоНазначения.ПолучитьОписаниеТиповЧисла(15,2));
	
	Для Каждого СтрокаТаблицы Из ТаблицаПоОтходам Цикл
		
		// ставку НДС берем из номенклатурной группы
		СтавкаНДС = УчетНДС.ПолучитьСтавкуНДС(СтрокаТаблицы.НоменклатурнаяГруппа.СтавкаНДС);
		
		
		СтрокаТаблицы.СуммаПлановаяУпрБезНДС = МодульВалютногоУчета.ПересчитатьИзВалютыВВалюту(СтрокаТаблицы.Сумма, мВалютаРегламентированногоУчета,
		                                 СтруктураШапкиДокумента.ВалютаУправленческогоУчета, 1, 
		                                 СтруктураШапкиДокумента.КурсВалютыУправленческогоУчета,
		                                 1, 
		                                 СтруктураШапкиДокумента.КратностьВалютыУправленческогоУчета);
		
		СтрокаТаблицы.ПлановыйНДСУпр = УчетНДС.РассчитатьСуммуНДС(СтрокаТаблицы.СуммаПлановаяУпрБезНДС, Истина, Ложь, СтавкаНДС);
		
	КонецЦикла;

КонецПроцедуры

// Выгружает результат запроса в табличную часть, добавляет ей необходимые колонки для проведения.
//
// Параметры: 
//  РезультатЗапросаПоМатериалам - результат запроса по табличной части "Материалы",
//  СтруктураШапкиДокумента   - выборка по результату запроса по шапке документа.
//
// Возвращаемое значение:
//  Сформированная таблица значений.
//
Функция ПодготовитьТаблицуМатериалов(РезультатЗапросаПоМатериалам, СтруктураШапкиДокумента)

	ТаблицаМатериалов = РезультатЗапросаПоМатериалам.Выгрузить();

	ТаблицаМатериалов.Колонки.Добавить("ДокументОприходования");
	ТаблицаМатериалов.Колонки.Добавить("Регистратор");
	ТаблицаМатериалов.Колонки.Добавить("Склад");
	ТаблицаМатериалов.Колонки.Добавить("Организация");
	ТаблицаМатериалов.Колонки.Добавить("ДоговорКонтрагента");
	ТаблицаМатериалов.Колонки.Добавить("Валюта");
	ТаблицаМатериалов.Колонки.Добавить("ВходящийНДС");
	ТаблицаМатериалов.Колонки.Добавить("КоэффОплаты");
	
	ТаблицаМатериалов.Колонки.Добавить("КорСчетСписанияБУ");
	ТаблицаМатериалов.Колонки.Добавить("КорСубконтоСписанияБУ1");
	ТаблицаМатериалов.Колонки.Добавить("КорСубконтоСписанияБУ2");
	ТаблицаМатериалов.Колонки.Добавить("КорСубконтоСписанияБУ3");
	
	КоэффОплаты      = 1;
	
	ТаблицаМатериалов.ЗаполнитьЗначения(КоэффОплаты,   							"КоэффОплаты");
	ТаблицаМатериалов.ЗаполнитьЗначения(ЭтотОбъект,    							"Регистратор");
	ТаблицаМатериалов.ЗаполнитьЗначения(СтруктураШапкиДокумента.Склад,      	"Склад");
	ТаблицаМатериалов.ЗаполнитьЗначения(СтруктураШапкиДокумента.Организация,	"Организация");
	ТаблицаМатериалов.ЗаполнитьЗначения(СчетЗатрат,    							"КорСчетСписанияБУ");
	
	ТаблицаМатериалов.ЗаполнитьЗначения(СтруктураШапкиДокумента.ПодразделениеОрганизации,	"КорСубконтоСписанияБУ1");
	
	ТаблицаМатериалов.Колонки.Добавить("ХарактерЗатрат");
	
	Для Каждого СтрокаМатериалов ИЗ ТаблицаМатериалов Цикл
		СтрокаМатериалов.КорСубконтоСписанияБУ2 = СтрокаМатериалов.НоменклатурнаяГруппа;	
		СтрокаМатериалов.КорСубконтоСписанияБУ3 = СтрокаМатериалов.СтатьяЗатрат;
		// заполним ХарактерЗатрат, НалоговоеНазначениеНовое
		НалоговыйУчет.ОпределениеАналитикиНалоговогоУчетаВПроводкахДляЗатрат(СтрокаМатериалов, СтрокаМатериалов.КорСчетСписанияБУ, СтрокаМатериалов.ХарактерЗатрат,
														       	СтрокаМатериалов.НалоговоеНазначениеНовое, ,                                                                   
																СтрокаМатериалов.НалоговоеНазначение, СтрокаМатериалов.НалоговоеНазначениеНовое, "КорСубконтоСписанияБУ",,Ложь,Дата
																,,СтруктураШапкиДокумента.ЕстьНДС
																);
	КонецЦикла;

	Возврат ТаблицаМатериалов;

КонецФункции // ПодготовитьТаблицуМатериалов()

Процедура ПроверитьТабЧастьМатериалыПострочно(ТаблицаМатериалов, СтруктураШапкиДокумента, Отказ, Заголовок)
	
	НеоблагаемыйВНД = Справочники.ВидыНалоговойДеятельности.НеОблагаемая;
	
	Для каждого СтрокаТЧ Из ТаблицаМатериалов Цикл

		СтрокаНачалаСообщенияОбОшибке = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='В строке номер ""%1"" табличной части ""Материалы"": ';uk='У рядку номер ""%1"" табличної частини ""Матеріали"": '"), СокрЛП(СтрокаТЧ.НомерСтроки));
		
		Если НЕ Отказ  
			 И  СтруктураШапкиДокумента.ЕстьНалогНаПрибыльДо2015 Тогда
		
			ХарактерЗатрат = СтрокаТЧ.ХарактерЗатрат;
			Если НЕ ЗначениеЗаполнено(СтрокаТЧ.НалоговоеНазначениеНовое) Тогда
				Если ХарактерЗатрат = "Затраты" Тогда
					СтрокаСообщения = СтрокаНачалаСообщенияОбОшибке + НСтр("ru='не указано ""Налоговое назначение затрат""!';uk='не зазначено ""Податкове призначення витрат""!'");
					ОбщегоНазначения.ОшибкаПриПроведении(СтрокаСообщения, Отказ, Заголовок);
				ИначеЕсли ХарактерЗатрат = "Строительство" Тогда
					СтрокаСообщения = СтрокаНачалаСообщенияОбОшибке + НСтр("ru='не указано налоговое назначение для объекта строительства или НМА!';uk=""не зазначено податкове призначення для об'єкта будівництва або НМА!""");
					ОбщегоНазначения.ОшибкаПриПроведении(СтрокаСообщения, Отказ, Заголовок);
				ИначеЕсли ХарактерЗатрат = "Производство" Тогда
					СтрокаСообщения = СтрокаНачалаСообщенияОбОшибке + НСтр("ru='не указано налоговое назначение для номенклатурной группы!';uk='не зазначено податкове призначення для номенклатурної групи!'");
					ОбщегоНазначения.ОшибкаПриПроведении(СтрокаСообщения, Отказ, Заголовок);			
				ИначеЕсли ХарактерЗатрат = "РБП" Тогда
					СтрокаСообщения = СтрокаНачалаСообщенияОбОшибке + НСтр("ru='не указано налоговое назначение для расходов будущих периодов!';uk='не зазначено податкове призначення для витрат майбутніх періодів!'");
					ОбщегоНазначения.ОшибкаПриПроведении(СтрокаСообщения, Отказ, Заголовок);			
				Иначе
					//Для ТЗР определить НалоговоеНазначение можно только в строке, даже если счет затрат в указывается шапке
					СтрокаСообщения = НСтр("ru='невозможно определить налоговое назначение затрат для указанного счета затрат!';uk='неможливо визначити податкое призначення витрат для вказанного рахунку витрат!'");
					ОбщегоНазначения.СообщитьОбОшибке(СтрокаСообщения);			
				КонецЕсли;
			КонецЕсли;
			 
			// нельзя по НДС указывать нехоз. деятельность, а по НП - хоз. деятельность
			Если НЕ Отказ  
				И  СтруктураШапкиДокумента.ЕстьНДС Тогда
				
				НехозДеятельностьНДС = (СтрокаТЧ.НалоговоеНазначение = Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_НеоблагаемаяНеХозДеятельность);
				НехозДеятельностьНКУ = (СтрокаТЧ.НалоговоеНазначениеНовое = Справочники.НалоговыеНазначенияАктивовИЗатрат.НКУ_НеХозДеятельность);
				
				Если НЕ СтрокаТЧ.НалоговоеНазначение = СтрокаТЧ.НалоговоеНазначениеНовое
					  И НехозДеятельностьНДС <> НехозДеятельностьНКУ Тогда 
					СтрокаСообщения = СтрокаНачалаСообщенияОбОшибке + НСтр("ru='ошибочно указано нехозяйственное налоговое назначение (НДС) и одновременно хозяйственную деятельность по затратам (и наоборот)!';uk='помилково зазначено господарське податкове призначення (ПДВ) і одночасно господарську діяльність за витратами (і навпаки)!'");
					ОбщегоНазначения.СообщитьОбОшибке(СтрокаСообщения);
				КонецЕсли;
				
			КонецЕсли;
		КонецЕсли;
 		
	КонецЦикла;
	
КонецПроцедуры

Функция ПодготовитьТаблицуУслуг(РезультатЗапросаПоТаблицеУслуги, СтруктураШапкиДокумента)
	
	ТаблицаУслуг = РезультатЗапросаПоТаблицеУслуги.Выгрузить();
	
	УслугиВСуммовомВыражении = (ВариантВыраженияВнутреннихУслуг = Перечисления.ВариантВыраженияВнутреннихУслуг.ВПлановыхЦенах);
	
	Для каждого СтрокаТаблицы Из ТаблицаУслуг Цикл
		
		Если УслугиВСуммовомВыражении Тогда
			СтрокаТаблицы.Количество = 0;
		Иначе
			СтрокаТаблицы.СуммаПлановая = 0;
			СтрокаТаблицы.СуммаПлановаяУпр = 0;
		КонецЕсли;
		
	КонецЦикла;
	
	ТаблицаУслуг.Колонки.Добавить("ХарактерЗатратНУ");
	
	Для каждого Строка Из ТаблицаУслуг Цикл
		
		// заполним характер затрат, признак Амортизируется и НалоговоеНазначениеДоходовИЗатрат
		НалоговыйУчет.ОпределениеАналитикиНалоговогоУчетаВПроводкахДляЗатрат(Строка, Строка.Счет, Строка.ХарактерЗатратНУ,
														       	Строка.НалоговоеНазначениеДоходовИЗатрат, Строка.Амортизируется,               
																Строка.НалоговоеНазначение, Строка.НалоговоеНазначениеДоходовИЗатрат, , Истина,,Дата
																,,СтруктураШапкиДокумента.ЕстьНДС
																);
		
	КонецЦикла;
	
	Возврат ТаблицаУслуг;
	
КонецФункции


