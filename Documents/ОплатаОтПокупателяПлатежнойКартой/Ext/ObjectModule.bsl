// ОБРАБОТЧИКИ СОБЫТИЙ

// Процедура - обработчик события "ОбработкаЗаполнения".
//
Процедура ОбработкаЗаполнения(Основание)
	
	Если Не Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(Основание)) ИЛИ Основание = Неопределено Тогда
		Возврат;
	КонецЕсли;

	// Заполним реквизиты из стандартного набора по документу основанию.
	ЗаполнениеДокументов.ЗаполнитьШапкуДокументаПоОснованию(ЭтотОбъект, Основание);

	ВалютаДокумента         = мВалютаРегламентированногоУчета;

	СтруктураКурсаДокумента = МодульВалютногоУчета.ПолучитьКурсВалюты(ВалютаДокумента, Дата);
	КурсДокумента           = СтруктураКурсаДокумента.Курс;
	КратностьДокумента      = СтруктураКурсаДокумента.Кратность;

	ДокументОснование = Основание.Ссылка;
	СпособЗаполнения  = "Не заполнять";

	Если ТипЗнч(Основание) = Тип("ДокументСсылка.ЗаказПокупателя") 
	 ИЛИ ТипЗнч(Основание) = Тип("ДокументСсылка.СчетНаОплатуПокупателю") Тогда

		ВидОперации  = Перечисления.ВидыОперацийОплатаОтПокупателяПлатежнойКартой.ОплатаПокупателя;
		Контрагент   = Основание.Контрагент;
		
		ТаблицаПлатежей = РасшифровкаПлатежа.Выгрузить();

        СуммаДокументаОснования = Ценообразование.ПолучитьСуммуДокументаСНДСВРазрезеСтавокНДС(Основание);
        СуммаДокументаОснования.Колонки.Сумма.Имя = "СуммаПлатежа";
        ОбщегоНазначения.ЗагрузитьВТаблицуЗначений(СуммаДокументаОснования, ТаблицаПлатежей);
        
 		Если ТаблицаПлатежей.Количество() = 0 тогда
 			ТаблицаПлатежей.Добавить();
		КонецЕсли;
		
		ДоговорКонтрагента      	= Основание.ДоговорКонтрагента;
		СтруктураКурсаВзаиморасчетов= МодульВалютногоУчета.ПолучитьКурсВалюты(ДоговорКонтрагента.ВалютаВзаиморасчетов, );
		
 		ТаблицаПлатежей.ЗаполнитьЗначения(ДоговорКонтрагента,"ДоговорКонтрагента");
 		ТаблицаПлатежей.ЗаполнитьЗначения(СтруктураКурсаВзаиморасчетов.Курс,"КурсВзаиморасчетов");
 		ТаблицаПлатежей.ЗаполнитьЗначения(СтруктураКурсаВзаиморасчетов.Кратность,"КратностьВзаиморасчетов");

        Если ОтражатьВБухгалтерскомУчете Тогда
    		// Заполним счету бух.учета
     		СчетаУчета = УправлениеВзаиморасчетами.ПолучитьСчетаРасчетовСКонтрагентом(Основание.Организация, 
     		                                                Основание.Контрагент, Основание.ДоговорКонтрагента);
    		ТаблицаПлатежей.ЗаполнитьЗначения(СчетаУчета.СчетРасчетовПокупателя,   "СчетУчетаРасчетовСКонтрагентом"); 
    		ТаблицаПлатежей.ЗаполнитьЗначения(СчетаУчета.СчетАвансовПокупателя,    "СчетУчетаРасчетовПоАвансам") ;
        КонецЕсли;    
		
		Если ТипЗнч(Основание) = Тип("ДокументСсылка.ЗаказПокупателя") И Основание.Проведен  Тогда
			СпособЗаполнения = "По заказу";
		Иначе
			СпособЗаполнения = "По сумме документа";
		КонецЕсли;
		
		Сделка = Неопределено;
		
		Если (ТипЗнч(Основание) = Тип("ДокументСсылка.ЗаказПокупателя") ИЛИ ТипЗнч(Основание) = Тип("ДокументСсылка.СчетНаОплатуПокупателю"))
			И (ТаблицаПлатежей[0].ДоговорКонтрагента.ВедениеВзаиморасчетов=Перечисления.ВедениеВзаиморасчетовПоДоговорам.ПоДоговоруВЦелом
			ИЛИ ТаблицаПлатежей[0].ДоговорКонтрагента.ВедениеВзаиморасчетов=Перечисления.ВедениеВзаиморасчетовПоДоговорам.ПоЗаказам) Тогда
			
			Если ТипЗнч(Основание) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда
				Сделка=Основание;
			Иначе
				Сделка=Основание.ЗаказПокупателя;
			КонецЕсли;
			
		ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.СчетНаОплатуПокупателю") И ТаблицаПлатежей[0].ДоговорКонтрагента.ВедениеВзаиморасчетов=Перечисления.ВедениеВзаиморасчетовПоДоговорам.ПоСчетам Тогда
			
			Сделка=Основание;
			
		ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.СчетНаОплатуПокупателю") Тогда
			Сделка=Основание.ЗаказПокупателя;
						
			//заполняем заказ покупателя из табличной части
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	СчетНаОплатуПокупателюТовары.ЗаказПокупателя,
			|	СчетНаОплатуПокупателюТовары.СтавкаНДС,
			|	СУММА(ВЫБОР
			|			КОГДА СчетНаОплатуПокупателюТовары.Ссылка.УчитыватьНДС
			|					И (НЕ СчетНаОплатуПокупателюТовары.Ссылка.СуммаВключаетНДС)
			|				ТОГДА СчетНаОплатуПокупателюТовары.Сумма + СчетНаОплатуПокупателюТовары.СуммаНДС
			|			ИНАЧЕ СчетНаОплатуПокупателюТовары.Сумма
			|		КОНЕЦ) КАК Сумма,
			|	СУММА(СчетНаОплатуПокупателюТовары.СуммаНДС) КАК СуммаНДС
			|ПОМЕСТИТЬ СУММЫ
			|ИЗ
			|	Документ.СчетНаОплатуПокупателю.Товары КАК СчетНаОплатуПокупателюТовары
			|ГДЕ
			|	СчетНаОплатуПокупателюТовары.Ссылка = &СчетНаОплату
			|
			|СГРУППИРОВАТЬ ПО
			|	СчетНаОплатуПокупателюТовары.ЗаказПокупателя,
			|	СчетНаОплатуПокупателюТовары.СтавкаНДС
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	СчетНаОплатуПокупателУслуги.ЗаказПокупателя,
			|	СчетНаОплатуПокупателУслуги.СтавкаНДС,
			|	СУММА(ВЫБОР
			|			КОГДА СчетНаОплатуПокупателУслуги.Ссылка.УчитыватьНДС
			|					И (НЕ СчетНаОплатуПокупателУслуги.Ссылка.СуммаВключаетНДС)
			|				ТОГДА СчетНаОплатуПокупателУслуги.Сумма + СчетНаОплатуПокупателУслуги.СуммаНДС
			|			ИНАЧЕ СчетНаОплатуПокупателУслуги.Сумма
			|		КОНЕЦ),
			|	СУММА(СчетНаОплатуПокупателУслуги.СуммаНДС)
			|ИЗ
			|	Документ.СчетНаОплатуПокупателю.Услуги КАК СчетНаОплатуПокупателУслуги
			|ГДЕ
			|	СчетНаОплатуПокупателУслуги.Ссылка = &СчетНаОплату
			|
			|СГРУППИРОВАТЬ ПО
			|	СчетНаОплатуПокупателУслуги.ЗаказПокупателя,
			|	СчетНаОплатуПокупателУслуги.СтавкаНДС
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	СУММЫ.ЗаказПокупателя,
			|	СУММЫ.СтавкаНДС КАК СтавкаНДС,
			|	СУММА(СУММЫ.Сумма) КАК Сумма,
			|	СУММА(СУММЫ.СуммаНДС) КАК СуммаНДС
			|ИЗ
			|	СУММЫ КАК СУММЫ
			|
			|СГРУППИРОВАТЬ ПО
			|	СУММЫ.ЗаказПокупателя,
			|	СУММЫ.СтавкаНДС
			|ИТОГИ ПО
			|	СтавкаНДС";
			
			Запрос.УстановитьПараметр("СчетНаОплату",Основание.Ссылка);
			
			Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока Выборка.Следующий() Цикл
				
				СтрокаТЧ = ТаблицаПлатежей.Найти(Выборка.СтавкаНДС, "СтавкаНДС");
				СтрокаТЧ.Сделка = Сделка;
				
				ВыборкаСделка = Выборка.Выбрать();
				Пока ВыборкаСделка.Следующий() Цикл
					
					Если НЕ ЗначениеЗаполнено(ВыборкаСделка.ЗаказПокупателя) Тогда
						Продолжить;
					КонецЕсли;
					НоваяСтрока = ТаблицаПлатежей.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ); 
					
					НоваяСтрока.Сделка       = ВыборкаСделка.ЗаказПокупателя;
					НоваяСтрока.СуммаПлатежа = ВыборкаСделка.Сумма;
					НоваяСтрока.СуммаНДС     = ВыборкаСделка.СуммаНДС;
					
					СтрокаТЧ.СуммаПлатежа = СтрокаТЧ.СуммаПлатежа - НоваяСтрока.СуммаПлатежа;
					СтрокаТЧ.СуммаНДС 	  = СтрокаТЧ.СуммаНДС 	  - НоваяСтрока.СуммаНДС;
				
				КонецЦикла;
				
				Если СтрокаТЧ.СуммаПлатежа <= 0 Тогда
					ТаблицаПлатежей.Удалить(СтрокаТЧ);
				КонецЕсли;
				
			КонецЦикла;
			
			СпособЗаполнения = "Не заполнять";
			
		КонецЕсли;

		Если НЕ СпособЗаполнения = "Не заполнять" Тогда
		
			ТаблицаПлатежей.ЗаполнитьЗначения(Сделка,"Сделка");	
		
		КонецЕсли; 
		
		ТаблицаПлатежей.ЗагрузитьКолонку(ТаблицаПлатежей.ВыгрузитьКолонку("СуммаПлатежа"),"СуммаВзаиморасчетов");

 		РасшифровкаПлатежа.Загрузить(ТаблицаПлатежей);
 		СуммаДокумента = РасшифровкаПлатежа.Итог("СуммаПлатежа");
		
		СтруктураКурсаДокумента = МодульВалютногоУчета.ПолучитьКурсВалюты(ВалютаДокумента,);
		КурсДокумента           = СтруктураКурсаДокумента.Курс;
		КратностьДокумента      = СтруктураКурсаДокумента.Кратность;
		
	ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.РеализацияТоваровУслуг")
		или ТипЗнч(Основание) = Тип("ДокументСсылка.ОтчетКомиссионераОПродажах") Тогда
		
		ВидОперации  = Перечисления.ВидыОперацийОплатаОтПокупателяПлатежнойКартой.ОплатаПокупателя;
		Контрагент   = Основание.Контрагент;

	 	// Сформируем таблицу платежей с разбивкой по ставкам НДС
   		ТаблицаПлатежей = РасшифровкаПлатежа.Выгрузить();

        СуммаДокументаОснования = Ценообразование.ПолучитьСуммуДокументаСНДСВРазрезеСтавокНДС(Основание);
        СуммаДокументаОснования.Колонки.Сумма.Имя = "СуммаПлатежа";
        Если ТипЗнч(Основание) = Тип("ДокументСсылка.ОтчетКомиссионераОПродажах") Тогда
            Если Основание.УдержатьКомиссионноеВознаграждение тогда
                СуммаКоррПлатежа= СуммаДокументаОснования.Итог("СуммаПлатежа") - Основание.СуммаВознаграждения;
                СуммаКоррНДС	= СуммаДокументаОснования.Итог("СуммаНДС") - Основание.Товары.Итог("СуммаНДСВознаграждения");
                НоваяКолонкаСумм = ОбщегоНазначения.РаспределитьПропорционально(СуммаКоррПлатежа,СуммаДокументаОснования.ВыгрузитьКолонку("СуммаПлатежа"));
                Если не НоваяКолонкаСумм = Неопределено Тогда
                    СуммаДокументаОснования.ЗагрузитьКолонку(НоваяКолонкаСумм,"СуммаПлатежа");
                КонецЕсли; 
                НоваяКолонкаНДС = ОбщегоНазначения.РаспределитьПропорционально(СуммаКоррНДС,СуммаДокументаОснования.ВыгрузитьКолонку("СуммаНДС"));
                Если не НоваяКолонкаНДС = Неопределено Тогда
                    СуммаДокументаОснования.ЗагрузитьКолонку(НоваяКолонкаНДС,"СуммаНДС");
                КонецЕсли; 
            КонецЕсли;
        КонецЕсли;
        
        ОбщегоНазначения.ЗагрузитьВТаблицуЗначений(СуммаДокументаОснования, ТаблицаПлатежей);
 		Если ТаблицаПлатежей.Количество() = 0 тогда
 			ТаблицаПлатежей.Добавить();
		КонецЕсли;
		 
		ДоговорКонтрагента      	= Основание.ДоговорКонтрагента;
		СтруктураКурсаВзаиморасчетов= МодульВалютногоУчета.ПолучитьКурсВалюты(ДоговорКонтрагента.ВалютаВзаиморасчетов, );
		
 		ТаблицаПлатежей.ЗаполнитьЗначения(ДоговорКонтрагента,"ДоговорКонтрагента");
 		ТаблицаПлатежей.ЗаполнитьЗначения(СтруктураКурсаВзаиморасчетов.Курс,"КурсВзаиморасчетов");
 		ТаблицаПлатежей.ЗаполнитьЗначения(СтруктураКурсаВзаиморасчетов.Кратность,"КратностьВзаиморасчетов");
		ТаблицаПлатежей.ЗаполнитьЗначения(Основание.Проект, "Проект");
		
        Если ОтражатьВБухгалтерскомУчете Тогда
     		Если ТипЗнч(Основание) = Тип("ДокументСсылка.ОтчетКомиссионераОПродажах") тогда
     			ТаблицаПлатежей.ЗаполнитьЗначения(Основание.СчетУчетаРасчетовСКонтрагентом,          "СчетУчетаРасчетовСКонтрагентом"); 
     			ТаблицаПлатежей.ЗаполнитьЗначения(Основание.СчетУчетаРасчетовПоАвансамПолученным,    "СчетУчетаРасчетовПоАвансам") ;
     		Иначе
     			ТаблицаПлатежей.ЗаполнитьЗначения(Основание.СчетУчетаРасчетовСКонтрагентом,"СчетУчетаРасчетовСКонтрагентом") ;
     			ТаблицаПлатежей.ЗаполнитьЗначения(Основание.СчетУчетаРасчетовПоАвансам,    "СчетУчетаРасчетовПоАвансам") ;
            КонецЕсли;
        КонецЕсли;    
		
		Если ТипЗнч(Основание) = Тип("ДокументСсылка.ОтчетКомиссионераОПродажах") Тогда
			Сделка = ?(ЗначениеЗаполнено(Основание.СделкаПоРеализации), Основание.СделкаПоРеализации, Неопределено);
		Иначе
			Сделка = ?(ЗначениеЗаполнено(Основание.Сделка), Основание.Сделка, Неопределено);
		КонецЕсли;
		
		Если ТаблицаПлатежей[0].ДоговорКонтрагента.ВестиПоДокументамРасчетовСКонтрагентом Тогда
			ДокументРасчетовСКонтрагентом = Основание;
		КонецЕсли;
		Если Основание.Проведен Тогда
			СпособЗаполнения = "По взаиморасчетам";
		Иначе
			СпособЗаполнения = "По сумме документа";
		КонецЕсли;
		
		ТаблицаПлатежей.ЗаполнитьЗначения(Сделка,"Сделка");
		ТаблицаПлатежей.ЗаполнитьЗначения(ДокументРасчетовСКонтрагентом,"ДокументРасчетовСКонтрагентом");
		
 		РасшифровкаПлатежа.Загрузить(ТаблицаПлатежей);
 		СуммаДокумента = РасшифровкаПлатежа.Итог("СуммаПлатежа");
		
		СтруктураКурсаДокумента = МодульВалютногоУчета.ПолучитьКурсВалюты(ВалютаДокумента,);
		КурсДокумента           = СтруктураКурсаДокумента.Курс;
		КратностьДокумента      = СтруктураКурсаДокумента.Кратность;

	ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.ВозвратТоваровОтПокупателя") Тогда
		ВидОперации  = Перечисления.ВидыОперацийОплатаОтПокупателяПлатежнойКартой.ВозвратДенежныхСредствПокупателю;
		Контрагент   = Основание.Контрагент;


		СтруктураКурсаДокумента = МодульВалютногоУчета.ПолучитьКурсВалюты(ВалютаДокумента,Дата);
		КурсДокумента      = СтруктураКурсаДокумента.Курс;
		КратностьДокумента = СтруктураКурсаДокумента.Кратность;	

		// Подготовка таблицы платежей
		ТаблицаПлатежей = РасшифровкаПлатежа.Выгрузить();
		
		СуммаДокументаОснования = Ценообразование.ПолучитьСуммуДокументаСНДСВРазрезеСтавокНДС(Основание);
		СуммаДокументаОснования.Колонки.Сумма.Имя = "СуммаПлатежа";
		
		ОбщегоНазначения.ЗагрузитьВТаблицуЗначений(СуммаДокументаОснования, ТаблицаПлатежей);
		Если ТаблицаПлатежей.Количество() = 0 тогда
			ТаблицаПлатежей.Добавить();
		КонецЕсли;
		
		// Заполонение общих параметров,для всех строк таблицы платежей
		ДоговорКонтрагента      	= Основание.ДоговорКонтрагента;
		СтруктураКурсаВзаиморасчетов= МодульВалютногоУчета.ПолучитьКурсВалюты(ДоговорКонтрагента.ВалютаВзаиморасчетов, );
		
		ТаблицаПлатежей.ЗаполнитьЗначения(ДоговорКонтрагента,"ДоговорКонтрагента");
		ТаблицаПлатежей.ЗаполнитьЗначения(СтруктураКурсаВзаиморасчетов.Курс,"КурсВзаиморасчетов");
		ТаблицаПлатежей.ЗаполнитьЗначения(СтруктураКурсаВзаиморасчетов.Кратность,"КратностьВзаиморасчетов");
		
		ТаблицаПлатежей.ЗагрузитьКолонку(ТаблицаПлатежей.ВыгрузитьКолонку("СуммаПлатежа"),"СуммаВзаиморасчетов");
		
		ТаблицаПлатежей.ЗаполнитьЗначения(Основание.СчетУчетаРасчетовСКонтрагентом, "СчетУчетаРасчетовСКонтрагентом") ;
		ТаблицаПлатежей.ЗаполнитьЗначения(Основание.СчетУчетаРасчетовПоАвансам, "СчетУчетаРасчетовПоАвансам") ;
		
		Сделка = Основание.Сделка;
		
		Если ДоговорКонтрагента.ВестиПоДокументамРасчетовСКонтрагентом Тогда
			ДокументРасчетовСКонтрагентом = Основание;
		КонецЕсли;
		
		Если Основание.Проведен Тогда
			СпособЗаполнения = "По взаиморасчетам";
		Иначе
			СпособЗаполнения = "По сумме документа";
		КонецЕсли;

		ТаблицаПлатежей.ЗаполнитьЗначения(Сделка,"Сделка");
		ТаблицаПлатежей.ЗаполнитьЗначения(ДокументРасчетовСКонтрагентом,"ДокументРасчетовСКонтрагентом");
		
		ТаблицаПлатежей.ЗагрузитьКолонку(ТаблицаПлатежей.ВыгрузитьКолонку("СуммаПлатежа"),"СуммаВзаиморасчетов");
		
		РасшифровкаПлатежа.Загрузить(ТаблицаПлатежей);
 		СуммаДокумента = РасшифровкаПлатежа.Итог("СуммаПлатежа");
		
	ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.ОплатаОтПокупателяПлатежнойКартой") Тогда
		
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, Основание, 
			"ВидОплаты, ВалютаДокумента, ДоговорВзаиморасчетовЭквайрера, ДоговорЭквайринга, Контрагент, Подразделение, 
			|ПроцентТорговойУступки, СуммаДокумента, СуммаТорговойУступки, Эквайрер");
		ВидОперации  = Перечисления.ВидыОперацийОплатаОтПокупателяПлатежнойКартой.ВозвратДенежныхСредствПокупателю;
		
		СтруктураКурсаДокумента = МодульВалютногоУчета.ПолучитьКурсВалюты(ВалютаДокумента, Дата);
		КурсДокумента           = СтруктураКурсаДокумента.Курс;
		КратностьДокумента      = СтруктураКурсаДокумента.Кратность;
		
		РасшифровкаПлатежа.Загрузить(Основание.РасшифровкаПлатежа.Выгрузить());
		
		Для каждого СтрокаПлатеж Из РасшифровкаПлатежа Цикл
			ТекВалютаВзаиморасчетов = СтрокаПлатеж.ДоговорКонтрагента.ВалютаВзаиморасчетов;
			СтруктураКурсаВзаиморасчетов = МодульВалютногоУчета.ПолучитьКурсВалюты(ТекВалютаВзаиморасчетов, Дата);
			СтрокаПлатеж.СуммаВзаиморасчетов = МодульВалютногоУчета.ПересчитатьИзВалютыВВалюту(СтрокаПлатеж.СуммаВзаиморасчетов, 
				ТекВалютаВзаиморасчетов, ТекВалютаВзаиморасчетов,
				СтрокаПлатеж.КурсВзаиморасчетов, СтруктураКурсаВзаиморасчетов.Курс,
				СтрокаПлатеж.КратностьВзаиморасчетов, СтруктураКурсаВзаиморасчетов.Кратность);
			СтрокаПлатеж.КурсВзаиморасчетов      = СтруктураКурсаВзаиморасчетов.Курс;
			СтрокаПлатеж.КратностьВзаиморасчетов = СтруктураКурсаВзаиморасчетов.Кратность;
		КонецЦикла;
		
	КонецЕсли;
		
	Для каждого СтрокаПлатеж Из РасшифровкаПлатежа Цикл
		ПроверкаКурсовВалют(СтрокаПлатеж);
	КонецЦикла; 

	Если СпособЗаполнения = "По взаиморасчетам" 
	   И ОтражатьВБухгалтерскомУчете Тогда
	   
	   СпособЗаполнения = "По сумме документа";
	
	КонецЕсли;
	
	ТаблицаПлатежей = РасшифровкаПлатежа.Выгрузить();
	
	Если СпособЗаполнения = "По заказу" Тогда
		
		ОписаниеТиповЧ = Новый ОписаниеТипов("Число");
		ТаблицаПлатежей.Колонки.Добавить("Коэф",ОписаниеТиповЧ);
		
		Если ТаблицаПлатежей.Количество()>1 Тогда
			Если ТаблицаПлатежей.Итог("СуммаПлатежа") <> 0 Тогда
				Для каждого СтрокаПлатеж Из ТаблицаПлатежей Цикл
					СтрокаПлатеж.Коэф = СтрокаПлатеж.СуммаПлатежа/ТаблицаПлатежей.Итог("СуммаПлатежа");
				КонецЦикла;	
			КонецЕсли;
		Иначе
			ТаблицаПлатежей.ЗаполнитьЗначения(1, "Коэф");
		КонецЕсли; 
		
		Для каждого СтрокаПлатеж Из ТаблицаПлатежей Цикл
			ЗаполнитьПоЗаказуУпр(СтрокаПлатеж);
			СтрокаПлатеж.СуммаВзаиморасчетов = СтрокаПлатеж.СуммаВзаиморасчетов *  СтрокаПлатеж.Коэф;
			СтрокаПлатеж.СуммаПлатежа 		 = СтрокаПлатеж.СуммаПлатежа 	    *  СтрокаПлатеж.Коэф;
			УправлениеДенежнымиСредствами.ПересчитатьСуммуНДС(СтрокаПлатеж);
		КонецЦикла;    

		РасшифровкаПлатежа.Загрузить(ТаблицаПлатежей);
		СуммаДокумента=РасшифровкаПлатежа.Итог("СуммаПлатежа");

	ИначеЕсли СпособЗаполнения = "По взаиморасчетам" Тогда

		// Данный вид заполнения, для бухгалтерского учета невозможен.
        Если НЕ ОтражатьВБухгалтерскомУчете Тогда
    		Для каждого СтрокаПлатеж Из ТаблицаПлатежей Цикл
        		УправлениеДенежнымиСредствами.ЗаполнитьПоВзаиморасчетамУпр(ВалютаДокумента,КурсДокумента,КратностьДокумента,СтрокаПлатеж,1);
        		УправлениеДенежнымиСредствами.ПересчитатьСуммуНДС(СтрокаПлатеж);
    		КонецЦикла; 
        КонецЕсли; 

		РасшифровкаПлатежа.Загрузить(ТаблицаПлатежей);
		СуммаДокумента=РасшифровкаПлатежа.Итог("СуммаПлатежа");
		
	ИначеЕсли СпособЗаполнения = "По сумме документа" Тогда
		
		Для каждого СтрокаПлатеж Из ТаблицаПлатежей Цикл
			
			СтруктураКурсаОснования = МодульВалютногоУчета.ПолучитьКурсВалюты(ВалютаДокумента, Дата);
			КурсОснования=СтруктураКурсаОснования.Курс;
			КратностьОснования=СтруктураКурсаОснования.Кратность;

			ОснованиеСуммаДокумента  = Основание.СуммаДокумента;

			СтрокаПлатеж.СуммаВзаиморасчетов = МодульВалютногоУчета.ПересчитатьИзВалютыВВалюту(СтрокаПлатеж.СуммаПлатежа, Основание.ВалютаДокумента, Основание.ДоговорКонтрагента.ВалютаВзаиморасчетов,
			                                   КурсОснования, Основание.КурсВзаиморасчетов, КратностьОснования, Основание.КратностьВзаиморасчетов);
			СуммаДокумента = МодульВалютногоУчета.ПересчитатьИзВалютыВВалюту(СтрокаПлатеж.СуммаПлатежа, Основание.ВалютаДокумента, ВалютаДокумента, КурсОснования,
			                 КурсДокумента, КратностьОснования,КратностьДокумента);

			СтрокаПлатеж.СуммаПлатежа=СуммаДокумента;
			УправлениеДенежнымиСредствами.ПересчитатьСуммуНДС(СтрокаПлатеж);
			
		КонецЦикла; 
		
		РасшифровкаПлатежа.Загрузить(ТаблицаПлатежей);
		СуммаДокумента=РасшифровкаПлатежа.Итог("СуммаПлатежа");
		
	Иначе
		
		Если  НЕ(ТаблицаПлатежей=Неопределено) Тогда
    		РасшифровкаПлатежа.Загрузить(ТаблицаПлатежей);
        КонецЕсли; 
		СуммаДокумента=РасшифровкаПлатежа.Итог("СуммаПлатежа");
		
	КонецЕсли;
	
	Для каждого СтрокаПлатеж Из РасшифровкаПлатежа Цикл
		ОпределитьСчетаУчетаРасчетовСКонтрагентом(СтрокаПлатеж, НЕ ЗначениеЗаполнено(СтрокаПлатеж.СчетУчетаРасчетовСКонтрагентом));
	КонецЦикла; 
	
	Если ЗначениеЗаполнено(ДоговорВзаиморасчетовЭквайрера) И ОтражатьВБухгалтерскомУчете Тогда
		
		СчетаУчета = УправлениеВзаиморасчетами.ПолучитьСчетаРасчетовСКонтрагентом(Организация, Эквайрер, ДоговорВзаиморасчетовЭквайрера);
		СчетУчетаРасчетовСЭквайрером = СчетаУчета.СчетРасчетов;
		
	КонецЕсли;
	
	ЕстьРасчетыСКонтрагентами = Истина;
	ЕстьРасчетыПоКредитам     = Ложь;
	ОтраженоВОперУчете        = Истина;
	Оплачено                  = Истина;

КонецПроцедуры // ОбработкаЗаполнения()

Процедура ОбработкаПроведения(Отказ, Режим)
	
	Перем Заголовок, СтруктураШапкиДокумента;

	Если мУдалятьДвижения Тогда
		ОбщегоНазначения.УдалитьДвиженияРегистратора(ЭтотОбъект, Отказ);
	КонецЕсли;

	СтруктураШапкиДокумента   = ОбщегоНазначения.СформироватьСтруктуруШапкиДокумента(ЭтотОбъект);

	СтруктураШапкиДокумента.Вставить("ВалютаРегламентированногоУчета", мВалютаРегламентированногоУчета);

	// Заголовок для сообщений об ошибках проведения.
	Заголовок = ОбщегоНазначения.ПредставлениеДокументаПриПроведении(СтруктураШапкиДокумента);

	СтруктураКурсаДокумента   = МодульВалютногоУчета.ПолучитьКурсВалюты(ВалютаДокумента,Дата);
	КурсДокумента             = СтруктураКурсаДокумента.Курс;
	КратностьДокумента        = СтруктураКурсаДокумента.Кратность;

	ЕстьРасчетыСКонтрагентами = Истина;
	ЕстьРасчетыПоКредитам     = Ложь;

	// Документ должен принадлежать хотя бы к одному виду учета (управленческий, бухгалтерский, налоговый)
 	ОбщегоНазначения.ПроверитьПринадлежностьКВидамУчета(СтруктураШапкиДокумента, Отказ, Заголовок);

	Если СтруктураШапкиДокумента.ОтражатьВБухгалтерскомУчете Тогда		
		ПроверкаАктуальностиУчета(СтруктураШапкиДокумента, Заголовок);
	КонецЕсли;
	
 	СтруктураПолейУчетнойПолитикиНУ = Новый Структура("ЕстьНалогНаПрибыль,ЕстьНДС,ЕстьЕдиныйНалог");
 	ОбщегоНазначения.ДополнитьПоложениямиУчетнойПолитики(СтруктураШапкиДокумента, СтруктураШапкиДокумента.Дата, Отказ, СтруктураШапкиДокумента.Организация, "Нал",СтруктураПолейУчетнойПолитикиНУ);
	
	ТаблицаПлатежейУпр = ПолучитьТаблицуПлатежейУпрПоКартам(Дата,ВалютаДокумента,Ссылка, "ОплатаОтПокупателяПлатежнойКартой");
	
	ПроверитьЗаполнениеДокумента(СтруктураШапкиДокумента, Отказ, Режим, Заголовок);

	Если Не Отказ Тогда
		ДвиженияПоРегистрам(Режим, Отказ, Заголовок, СтруктураШапкиДокумента);
	КонецЕсли;
	
	Движения.Хозрасчетный.ВыполнитьДействияПередЗаписьюДвижений();
	
КонецПроцедуры // ОбработкаПроведения

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)

	мУдалятьДвижения = НЕ ЭтоНовый();

КонецПроцедуры // ПередЗаписью

Процедура ОбработкаУдаленияПроведения(Отказ)

	ОбщегоНазначения.УдалитьДвиженияРегистратора(ЭтотОбъект, Отказ);

КонецПроцедуры // ОбработкаУдаленияПроведения

Процедура ПриКопировании(ОбъектКопирования)
	
	ДокументОснование = Неопределено

КонецПроцедуры

мВалютаРегламентированногоУчета = глЗначениеПеременной("ВалютаРегламентированногоУчета");

