	ТекНомерНалоговой = Прав("       " + СокрЛП(ОбщегоНазначения.ПолучитьНомерНаПечать(Шапка.НалоговаяНакладная)), 7);
		
	// филиал/спецрежим налоговой
	ТекНомерФилиал = "";
