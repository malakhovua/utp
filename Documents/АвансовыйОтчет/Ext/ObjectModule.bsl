	ИспользуемыеКлассыСчетовРасходов = БухгалтерскийУчет.ПолучитьИспользуемыеКлассыСчетовРасходов(Дата, Организация);
	
	Счетчик = 0;
	Если ВариантДо01012011 Тогда
		
		Для каждого СтрокаВыборки Из ВыборкаПроводокКопияДт Цикл
			
