	КвоАвансов = ?(ВыданныеАвансы.Количество()>3, 3, ВыданныеАвансы.Количество());
	Для Инд = 1 По КвоАвансов Цикл
		
		ДокументАванса = ВыданныеАвансы[Инд-1].ДокументАванса;
		
