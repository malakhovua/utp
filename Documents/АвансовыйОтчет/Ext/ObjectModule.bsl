	|
	|СГРУППИРОВАТЬ ПО
	|	Хозрасчетный.СчетДт,
	|	Хозрасчетный.СчетКт
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	ВыборкаПроводок = ЗапросПоПроводкам.Выполнить().Выгрузить();
	ВыборкаПроводокКопияДт = ВыборкаПроводок.Скопировать();
