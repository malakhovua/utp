Функция ПроверкаПовторовВидовОперацийРегл(СтруктураШапкиДокумента)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НачалоМесяца", мНачМесяца);
	Запрос.УстановитьПараметр("КонецМесяца",  мКонМесяца);
	Запрос.УстановитьПараметр("НачалоКвартала", мНачКвартала);
	Запрос.УстановитьПараметр("КонецКвартала",  мКонКвартала);
	Запрос.УстановитьПараметр("Организация",  СтруктураШапкиДокумента.Организация);
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	СУММА(ВЫБОР
	               |			КОГДА ЗакрытиеМесяца_.КорректировкаСебестоимостиРеализованнойПродукцииПоКомплектамБУ = ИСТИНА
	               |				ТОГДА 1
	               |			ИНАЧЕ 0
	               |		КОНЕЦ) КАК КорректировкаСебестоимостиРеализованнойПродукцииПоКомплектамБУ,
	               |	СУММА(ВЫБОР
	               |			КОГДА ЗакрытиеМесяца_.КорректировкаЗатратОПРНаОсновноеПроизводство = ИСТИНА
	               |				ТОГДА 1
	               |			ИНАЧЕ 0
	               |		КОНЕЦ) КАК КорректировкаЗатратОПРНаОсновноеПроизводство
	               |ИЗ
	               |	Документ.ЗакрытиеМесяца_ КАК ЗакрытиеМесяца_
	               |ГДЕ
	               |	ЗакрытиеМесяца_.Организация = &Организация
	               |	И ЗакрытиеМесяца_.Дата >= &НачалоМесяца
	               |	И ЗакрытиеМесяца_.Дата <= &КонецМесяца
	               |	И ЗакрытиеМесяца_.Проведен
	               |	И НЕ ЗакрытиеМесяца_.ПометкаУдаления";
				   
	Результат = Запрос.Выполнить().Выгрузить();
	
	ТекстСообщения = "";
	
	Для Каждого Выборка Из Результат Цикл


        Если (Выборка.КорректировкаСебестоимостиРеализованнойПродукцииПоКомплектамБУ > 1) И КорректировкаСебестоимостиРеализованнойПродукцииПоКомплектамБУ Тогда
			ТекстСообщения = ТекстСообщения + "Повторение операции Корректировка себестоимости реализованной продукции по комплектам(БУ)"
"";
		КонецЕсли;
		
		 Если (Выборка.КорректировкаЗатратОПРНаОсновноеПроизводство > 1) И КорректировкаЗатратОПРНаОсновноеПроизводство Тогда
			ТекстСообщения = ТекстСообщения + "Повторение операции Корректировка затрат сч. БУ 91 на Основное производство"
"";
		КонецЕсли;


	КонецЦикла;

	Возврат ТекстСообщения;
	
Конецфункции

