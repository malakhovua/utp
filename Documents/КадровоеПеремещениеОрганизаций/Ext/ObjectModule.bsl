// ОБРАБОТЧИКИ СОБЫТИЙ

Процедура ОбработкаПроведения(Отказ, Режим)
	//структура, содержащая имена регистров сведений по которым надо проводить документ
	Перем СтруктураПроведенияПоРегистрамСведений;

	//структура, содержащая имена регистров накопления по которым надо проводить документ
	Перем СтруктураПроведенияПоРегистрамНакопления;
    	
	Если мУдалятьДвижения Тогда
    	ОбщегоНазначения.УдалитьДвиженияРегистратора(ЭтотОбъект, Отказ);
	КонецЕсли;
	
	РезультатЗапросаПоШапке = СформироватьЗапросПоШапке(Режим);

	ПрименяетсяФиксированнаяИндексация = (ПроведениеРасчетов.ДатаВвводаФиксированнойИндексации() <= Дата);

	// Получим реквизиты шапки из запроса
	ВыборкаПоШапкеДокумента = РезультатЗапросаПоШапке.Выбрать();

	Если ВыборкаПоШапкеДокумента.Следующий() Тогда

		//Надо позвать проверку заполнения реквизитов шапки
		ПроверитьЗаполнениеШапки(ВыборкаПоШапкеДокумента, Отказ);

		// Движения стоит добавлять, если в проведении еще не отказано (отказ = ложь)
		Если НЕ Отказ Тогда

			РезультатЗапросаПоРаботники	= 	СформироватьЗапросПоРаботникиОрганизаций(Режим);
			ВыборкаПоСтрокамДокумента 	= 	РезультатЗапросаПоРаботники.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			

			Пока ВыборкаПоСтрокамДокумента.Следующий() Цикл 

				// проверим очередную строку табличной части
				ПроверитьЗаполнениеСтрокиРаботникаОрганизации(ВыборкаПоШапкеДокумента,ВыборкаПоСтрокамДокумента, Отказ);

				Если НЕ Отказ Тогда

					// Заполним записи в наборах записей регистров
					ДобавитьСтрокуВДвиженияПоРаботникиОрганизации(ВыборкаПоШапкеДокумента, ВыборкаПоСтрокамДокумента);
					Если ИндексацияЗаработка И ПрименяетсяФиксированнаяИндексация Тогда
                    	ДобавитьСтрокуВДвиженияПоРегистрам(ВыборкаПоШапкеДокумента, ВыборкаПоСтрокамДокумента);
					КонецЕсли;	
				КонецЕсли;

			КонецЦикла;
			
			// надо закрыть способы расчета по сотрудникам, 
			// если не изменился	- движения не делаем, 
			// если новый пустой	- закрываем, 
			// если другой			- просто записываем новый
			ВыборкаПоСтрокамРаботники = СформироватьЗапросПоРаботникиОрганизацийСтарыеОтраженияЗП().Выбрать();
		
			// плановые начисления
			Если НЕ Отказ Тогда
				// выполним выборку по табличной части основных начислений  
				// ВыборкаПоСтрокамДокумента = СформироватьЗапросПоНачисления().Выбрать();
				ВыборкаПоСтрокамДокумента = СформироватьЗапросПроверкаНачисления().Выбрать();
				
				// обходим строки документа
				Пока ВыборкаПоСтрокамДокумента.Следующий() Цикл
					ПроверитьЗаполнениеСтрокиНачисления(ВыборкаПоШапкеДокумента, ВыборкаПоСтрокамДокумента, Отказ);
					Если не Отказ Тогда
						
						Если ВыборкаПоСтрокамДокумента.Действие = Перечисления.ВидыДействияСНачислением.НеИзменять Тогда
							Продолжить;
						КонецЕсли;
						
						Если ВыборкаПоСтрокамДокумента.Действие = Перечисления.ВидыДействияСНачислением.НеИзменять тогда
							// ничего не меняем
							Продолжить;
							
						ИначеЕсли ВыборкаПоСтрокамДокумента.Действие = Перечисления.ВидыДействияСНачислением.Изменить Тогда
							мПериод = ВыборкаПоСтрокамДокумента.ДатаНачала-1;
							мДействует	= Ложь;
							ДобавитьСтрокуВДвиженияПоНачислениям(ВыборкаПоШапкеДокумента, ВыборкаПоСтрокамДокумента,мПериод,мДействует);
							
							мПериод = ВыборкаПоСтрокамДокумента.ДатаНачала;
							мДействует	= Истина;
							ДобавитьСтрокуВДвиженияПоНачислениям(ВыборкаПоШапкеДокумента, ВыборкаПоСтрокамДокумента,мПериод,мДействует);
							
						ИначеЕсли ВыборкаПоСтрокамДокумента.Действие = Перечисления.ВидыДействияСНачислением.Начать Тогда
							мПериод = ВыборкаПоСтрокамДокумента.ДатаНачала;
							мДействует	= Истина;
							ДобавитьСтрокуВДвиженияПоНачислениям(ВыборкаПоШапкеДокумента, ВыборкаПоСтрокамДокумента,мПериод,мДействует);
							
						ИначеЕсли ВыборкаПоСтрокамДокумента.Действие = Перечисления.ВидыДействияСНачислением.Прекратить тогда
							// движеие на вечер предыдущих суток
							мПериод = ВыборкаПоСтрокамДокумента.ДатаНачала - 1;
							мДействует	= Ложь;
							ДобавитьСтрокуВДвиженияПоНачислениям(ВыборкаПоШапкеДокумента, ВыборкаПоСтрокамДокумента,мПериод,мДействует);
							
						КонецЕсли;

					КонецЕсли;
					
				КонецЦикла;
				
			КонецЕсли;
			
			// плановые удержания
			Если НЕ Отказ Тогда
				// выполним выборку по табличной части Удержания
				ВыборкаПоСтрокамДокумента = СформироватьЗапросПоУдержания().Выбрать();
				
				// обходим строки документа
				Пока ВыборкаПоСтрокамДокумента.Следующий() Цикл
					
					Если ВыборкаПоСтрокамДокумента.Действие = Перечисления.ВидыДействияСНачислением.НеИзменять Тогда
						Продолжить;
					КонецЕсли;
					
					Если ВыборкаПоСтрокамДокумента.Действие = Перечисления.ВидыДействияСНачислением.НеИзменять тогда
						// ничего не меняем
						Продолжить;
						
					ИначеЕсли ВыборкаПоСтрокамДокумента.Действие = Перечисления.ВидыДействияСНачислением.Изменить Тогда
						мПериод = ВыборкаПоСтрокамДокумента.ДатаНачала-1;
						мДействует	= Ложь;
						ДобавитьСтрокуВДвиженияПоУдержаниям(ВыборкаПоШапкеДокумента, ВыборкаПоСтрокамДокумента,мПериод,мДействует);
						
						мПериод = ВыборкаПоСтрокамДокумента.ДатаНачала;
						мДействует	= Истина;
						ДобавитьСтрокуВДвиженияПоУдержаниям(ВыборкаПоШапкеДокумента, ВыборкаПоСтрокамДокумента,мПериод,мДействует);
						
					ИначеЕсли ВыборкаПоСтрокамДокумента.Действие = Перечисления.ВидыДействияСНачислением.Начать Тогда
						мПериод = ВыборкаПоСтрокамДокумента.ДатаНачала;
						мДействует	= Истина;
						ДобавитьСтрокуВДвиженияПоУдержаниям(ВыборкаПоШапкеДокумента, ВыборкаПоСтрокамДокумента,мПериод,мДействует);
						
					ИначеЕсли ВыборкаПоСтрокамДокумента.Действие = Перечисления.ВидыДействияСНачислением.Прекратить тогда
						// движеие на вечер предыдущих суток
						мПериод = ВыборкаПоСтрокамДокумента.ДатаНачала - 1;
						мДействует	= Ложь;
						ДобавитьСтрокуВДвиженияПоУдержаниям(ВыборкаПоШапкеДокумента, ВыборкаПоСтрокамДокумента,мПериод,мДействует);
						
					КонецЕсли;
					
				КонецЦикла;
			КонецЕсли;
			
			РезультатЗапросаПоВзносам = СформироватьЗапросПоВзносамСотрудники(Режим);
			ВыборкаПоВзносам = РезультатЗапросаПоВзносам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			Пока ВыборкаПоВзносам.Следующий() Цикл 
				
				// Заполним записи в наборах записей регистров
				ДобавитьСтрокуВДвиженияПоВзносамВФонды(ВыборкаПоШапкеДокумента, ВыборкаПоВзносам);
				
			КонецЦикла;
	
		КонецЕсли; 

	КонецЕсли;

КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	ПроцедурыУправленияПерсоналом.ЗаполнитьФизЛицоПоТЧ(РаботникиОрганизации);
	КраткийСоставДокумента = ПроцедурыУправленияПерсоналом.ЗаполнитьКраткийСоставДокумента(РаботникиОрганизации);
	
	мУдалятьДвижения = НЕ ЭтоНовый();

КонецПроцедуры

Процедура ОбработкаЗаполнения(Основание)
	
	ТипОснования = ТипЗнч(Основание);
	Если ТипОснования = Тип("СправочникСсылка.СотрудникиОрганизаций") Тогда
		
		Если Основание.ВидДоговора <> Перечисления.ВидыДоговоровСФизЛицами.ТрудовойДоговор Тогда
			Возврат;
		КонецЕсли;
	
		Если Не Основание.ОбособленноеПодразделение.Пустая() Тогда
			Организация = Основание.ОбособленноеПодразделение;
		Иначе
			Организация = Основание.Организация;
		КонецЕсли;
		
		НоваяСтрока = РаботникиОрганизации.Добавить();
		ФормаДокумента = ПолучитьФорму();

		НаборДанных = ПроцедурыУправленияПерсоналом.ПодборДанныхПоСотруднику(ФормаДокумента, ФормаДокумента.ЭлементыФормы.РаботникиОрганизации,Основание, Организация,,глЗначениеПеременной("глУчетнаяПолитикаПоПерсоналуОрганизации"));
		НоваяСтрока.Сотрудник = Основание;
		
		НоваяСтрока.ДатаНачала = ТекущаяДата();
		Если НаборДанных <> Неопределено Тогда
			НоваяСтрока.ЗанимаемыхСтавок = НаборДанных.ЗанимаемыхСтавок;
			НоваяСтрока.ЗанимаемыхСтавокУпр = НаборДанных.ЗанимаемыхСтавокУпр;			
			НоваяСтрока.Должность = НаборДанных.Должность;
			НоваяСтрока.ДолжностьУпр = НаборДанных.ДолжностьУпр;
			НоваяСтрока.ГрафикРаботы = НаборДанных.ГрафикРаботы;
			НоваяСтрока.ПодразделениеОрганизации = НаборДанных.ПодразделениеОрганизации;
			НоваяСтрока.ПодразделениеУпр = НаборДанных.ПодразделениеУпр;
			НоваяСтрока.СпособОтраженияВБухУчете = НаборДанных.СпособОтраженияВБухУчете;
			НоваяСтрока.СпособОтраженияВУпрУчете = НаборДанных.СпособОтраженияВУпрУчете;
			НоваяСтрока.ФизЛицо = Основание.ФизЛицо;
		КонецЕсли;
			
		ДобавитьСтрокиНачисленийПоРаботнику(Основание);
		ФормаДокумента.ДобавитьВзносыПостроке(НоваяСтрока);
		ФормаДокумента.ДобавитьУдержанияПоСтроке(НоваяСтрока);

		
	КонецЕсли;

КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	
	ОбщегоНазначения.УдалитьДвиженияРегистратора(ЭтотОбъект, Отказ);
	
КонецПроцедуры

мДлинаСуток = 86400;

