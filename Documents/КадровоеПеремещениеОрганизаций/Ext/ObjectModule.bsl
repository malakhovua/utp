	|			ПО ДатыНачислений.Сотрудник = ПлановыеНачисленияРаботниковОрганизаций.Сотрудник И (ПлановыеНачисленияРаботниковОрганизаций.Организация = &ГоловнаяОрганизация)И ДатыНачислений.Период = ПлановыеНачисленияРаботниковОрганизаций.Период И ДатыНачислений.ВидРасчета = ПлановыеНачисленияРаботниковОрганизаций.ВидРасчета) КАК ТекущиеИПрежниеНачисления
	|		
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.КадровоеПеремещениеОрганизаций.Начисления КАК ДвойныеСтроки
	|		ПО ТекущиеИПрежниеНачисления.Ссылка = ДвойныеСтроки.Ссылка 
	|			И ТекущиеИПрежниеНачисления.Сотрудник = ДвойныеСтроки.Сотрудник 
	|			И ТекущиеИПрежниеНачисления.ВидРасчета = ДвойныеСтроки.ВидРасчета 
	|			И ТекущиеИПрежниеНачисления.НомерСтроки < ДвойныеСтроки.НомерСтроки
	|СГРУППИРОВАТЬ ПО
	|	ТекущиеИПрежниеНачисления.ДатаДвижения,
	|	ТекущиеИПрежниеНачисления.Регистратор,
	|	ТекущиеИПрежниеНачисления.ОрганизацияПодразделения,
	|	ТекущиеИПрежниеНачисления.ДатаНачала,
	|	ТекущиеИПрежниеНачисления.НомерСтроки,
	|	ТекущиеИПрежниеНачисления.Сотрудник,
	
	|	ТекущиеИПрежниеНачисления.ВидРасчета,
	|	ТекущиеИПрежниеНачисления.Действие,
	|	ТекущиеИПрежниеНачисления.ВидНачисления,
	|	ТекущиеИПрежниеНачисления.СпособОтраженияВБухучете,
	|	ТекущиеИПрежниеНачисления.СпособОтраженияВУпручете,
	|	ТекущиеИПрежниеНачисления.Показатель1,
	|	ТекущиеИПрежниеНачисления.Показатель2,
	|	ТекущиеИПрежниеНачисления.Показатель3,
	|	ТекущиеИПрежниеНачисления.Показатель4,
	|	ТекущиеИПрежниеНачисления.Показатель5,
	|	ТекущиеИПрежниеНачисления.Показатель6,
	|	ТекущиеИПрежниеНачисления.Валюта1,
	|	ТекущиеИПрежниеНачисления.Валюта2,
	|	ТекущиеИПрежниеНачисления.Валюта3,
	|	ТекущиеИПрежниеНачисления.Валюта4,
	|	ТекущиеИПрежниеНачисления.Валюта5,
	|	ТекущиеИПрежниеНачисления.Валюта6,
	|	ТекущиеИПрежниеНачисления.Ссылка,
	|	ТекущиеИПрежниеНачисления.Регистратор.Представление";
	
	Запрос.Текст = ТекстЗапроса;
	
	// Установим параметры запроса
	Запрос.УстановитьПараметр("ДокументСсылка", Ссылка);
	Запрос.УстановитьПараметр("ГоловнаяОрганизация", Организация);
	
	Возврат Запрос.Выполнить();

КонецФункции // СформироватьЗапросПоНачисления()

// Формирует запрос по таблице "Начисления" документа
//
// Параметры: 
//  нет
//
// Возвращаемое значение:
//  Результат запроса.
//
Функция СформироватьЗапросПоУдержания()
	Запрос = Новый Запрос;

	ТекстЗапроса = "
	|ВЫБРАТЬ
	|	Работники.Сотрудник			КАК Сотрудник,
	|	Работники.ДатаНачала		КАК ДатаНачала,
	|	Работники.ВидРасчета		КАК ВидРасчета,
	|	Работники.Период 			КАК Период,
	|	СтУдержания.ВидРасчета		КАК СтНачисления_ВидРасчета,
	|	НовыеУдержания.ВидРасчета 	КАК НовыеНачисления_ВидРасчета,
	|		
	|	ВЫБОР КОГДА НовыеУдержания.ВидРасчета ЕСТЬ NULL 
	|			ТОГДА &парамДейстсвиеПрекратить 
	|			ИНАЧЕ НовыеУдержания.Действие
	|		КОНЕЦ КАК Действие,
	|		
	|	ВЫБОР КОГДА НовыеУдержания.ВидРасчета ЕСТЬ NULL 
	|			ТОГДА СтУдержания.Показатель1 
	|			ИНАЧЕ НовыеУдержания.Показатель1
	|		КОНЕЦ КАК Показатель1,
	|		
	|	ВЫБОР КОГДА НовыеУдержания.ВидРасчета ЕСТЬ NULL 
	|			ТОГДА СтУдержания.Показатель2 
	|			ИНАЧЕ НовыеУдержания.Показатель2
	|		КОНЕЦ КАК Показатель2,
	|		
	|	ВЫБОР КОГДА НовыеУдержания.ВидРасчета ЕСТЬ NULL 
	|			ТОГДА СтУдержания.Показатель3 
	|			ИНАЧЕ НовыеУдержания.Показатель3
	|		КОНЕЦ КАК Показатель3,
	|		
	|	ВЫБОР КОГДА НовыеУдержания.ВидРасчета ЕСТЬ NULL 
	|			ТОГДА СтУдержания.Показатель4 
	|			ИНАЧЕ НовыеУдержания.Показатель4
	|		КОНЕЦ КАК Показатель4,
	|
	|	ВЫБОР КОГДА НовыеУдержания.ВидРасчета ЕСТЬ NULL 
	|			ТОГДА СтУдержания.Показатель5 
	|			ИНАЧЕ НовыеУдержания.Показатель5
	|		КОНЕЦ КАК Показатель5,
	|		
	|	ВЫБОР КОГДА НовыеУдержания.ВидРасчета ЕСТЬ NULL 
	|			ТОГДА СтУдержания.Показатель6 
	|			ИНАЧЕ НовыеУдержания.Показатель6
	|		КОНЕЦ КАК Показатель6,
	|			
	|	ВЫБОР КОГДА НовыеУдержания.ВидРасчета ЕСТЬ NULL 
	|			ТОГДА СтУдержания.Валюта1 
	|			ИНАЧЕ НовыеУдержания.Валюта1
	|		КОНЕЦ КАК Валюта1,
	|		
	|	ВЫБОР КОГДА НовыеУдержания.ВидРасчета ЕСТЬ NULL 
	|			ТОГДА СтУдержания.Валюта2 
	|			ИНАЧЕ НовыеУдержания.Валюта2
	|		КОНЕЦ КАК Валюта2,
	|		
	|	ВЫБОР КОГДА НовыеУдержания.ВидРасчета ЕСТЬ NULL 
	|			ТОГДА СтУдержания.Валюта3 
	|			ИНАЧЕ НовыеУдержания.Валюта3
	|		КОНЕЦ КАК Валюта3,
	|
	|	ВЫБОР КОГДА НовыеУдержания.ВидРасчета ЕСТЬ NULL 
	|			ТОГДА СтУдержания.Валюта4 
	|			ИНАЧЕ НовыеУдержания.Валюта4
	|		КОНЕЦ КАК Валюта4,
	|		
	|	ВЫБОР КОГДА НовыеУдержания.ВидРасчета ЕСТЬ NULL 
	|			ТОГДА СтУдержания.Валюта5 
	|			ИНАЧЕ НовыеУдержания.Валюта5
	|		КОНЕЦ КАК Валюта5,
	|
	|	ВЫБОР КОГДА НовыеУдержания.ВидРасчета ЕСТЬ NULL 
	|			ТОГДА СтУдержания.Валюта6 
	|			ИНАЧЕ НовыеУдержания.Валюта6
	|		КОНЕЦ КАК Валюта6,
	|		
	|	ВЫБОР КОГДА НовыеУдержания.ВидРасчета ЕСТЬ NULL 
	|			ТОГДА СтУдержания.СпособОтраженияВБухучете 
	|			ИНАЧЕ НовыеУдержания.СпособОтраженияВБухучете
	|		КОНЕЦ КАК СпособОтраженияВБухучете,
	|		
	|		
	|	ВЫБОР КОГДА НовыеУдержания.ВидРасчета ЕСТЬ NULL 
	|			ТОГДА СтУдержания.СпособОтраженияВУпручете 
	|			ИНАЧЕ НовыеУдержания.СпособОтраженияВУпручете
	|		КОНЕЦ КАК СпособОтраженияВУпручете
	|		
	|		
	|ИЗ (
	|	ВЫБРАТЬ
	|		РаботникиПериоды.Сотрудник					КАК Сотрудник,
	|		РаботникиПериоды.Организация				КАК Организация,
	|		РаботникиПериоды.ДатаНачала					КАК ДатаНачала,
	|		РаботникиПериоды.ВидРасчета					КАК ВидРасчета,
	|		МАКСИМУМ(РаботникиПериоды.Период) 			КАК Период
	|	
	|	ИЗ (
	|		ВЫБРАТЬ
	|			РаботникиОрганизации.Сотрудник					КАК Сотрудник,
	|			РаботникиОрганизации.Ссылка.Организация				КАК Организация,
	|			РаботникиОрганизации.ДатаНачала					КАК ДатаНачала,
	|			АктуальныеУдержания.ВидРасчета					КАК ВидРасчета,
	|			МАКСИМУМ(АктуальныеУдержания.Период) 			КАК Период
	|		ИЗ Документ.КадровоеПеремещениеОрганизаций.РаботникиОрганизации КАК РаботникиОрганизации
	|		
	|			
	|		ЛЕВОЕ СОЕДИНЕНИЕ(
	|			ВЫБРАТЬ
	|				ПлановыеУдержания.Сотрудник		КАК Сотрудник,
	|				ПлановыеУдержания.Организация	КАК Организация,
	|				ПлановыеУдержания.ВидРасчета	КАК ВидРасчета,
	|				ПлановыеУдержания.Период		КАК Период
	|				
	|			ИЗ РегистрСведений.ПлановыеУдержанияРаботниковОрганизаций КАК ПлановыеУдержания		
	|			ГДЕ ПлановыеУдержания.Организация = &ГоловнаяОрганизация
	|			
	|		)КАК АктуальныеУдержания
	|		ПО		АктуальныеУдержания.Сотрудник	= РаботникиОрганизации.Сотрудник 
	|			И	АктуальныеУдержания.Организация	= РаботникиОрганизации.Ссылка.Организация 
	|			И	АктуальныеУдержания.Период	< РаботникиОрганизации.ДатаНачала 
	|	
	|		ГДЕ	РаботникиОрганизации.Ссылка = &ДокументСсылка
 	|		И	АктуальныеУдержания.ВидРасчета <> &пустойВидРасчета
	| 			
	|		СГРУППИРОВАТЬ ПО
	|			РаботникиОрганизации.Сотрудник,
	|			РаботникиОрганизации.Ссылка.Организация,
	|			РаботникиОрганизации.ДатаНачала,
	|			АктуальныеУдержания.ВидРасчета
	| 
	|		ОБЪЕДИНИТЬ
	|	 	ВЫБРАТЬ
	|			РаботникиОрганизации.Сотрудник			КАК Сотрудник,
	|			РаботникиОрганизации.Ссылка.Организация	КАК Организация,
	|			РаботникиОрганизации.ДатаНачала		КАК ДатаНачала,
	|			НовыеУдержания.ВидРасчета			КАК ВидРасчета,
	|			РаботникиОрганизации.ДатаНачала		КАК Период
	|			 		
	|		ИЗ Документ.КадровоеПеремещениеОрганизаций.РаботникиОрганизации КАК РаботникиОрганизации
    |
	|		ЛЕВОЕ СОЕДИНЕНИЕ  Документ.КадровоеПеремещениеОрганизаций.Удержания КАК НовыеУдержания
	|		ПО		РаботникиОрганизации.Сотрудник = НовыеУдержания.Сотрудник
	|		   И	НовыеУдержания.Ссылка = &ДокументСсылка
    |
	|		ГДЕ	РаботникиОрганизации.Ссылка = &ДокументСсылка
 	|	 	И	НовыеУдержания.ВидРасчета <> &пустойВидРасчета
	|
	|   ) КАК РаботникиПериоды
	|		   
	|   СГРУППИРОВАТЬ ПО
	|		РаботникиПериоды.Сотрудник,
	|		РаботникиПериоды.Организация,
	|		РаботникиПериоды.ДатаНачала,
	|		РаботникиПериоды.ВидРасчета
	|) КАК Работники
	|				
	|ЛЕВОЕ СОЕДИНЕНИЕ  РегистрСведений.ПлановыеУдержанияРаботниковОрганизаций КАК СтУдержания
	|ПО		Работники.Сотрудник = СтУдержания.Сотрудник
	|	И	Работники.ВидРасчета = СтУдержания.ВидРасчета
	|	И	Работники.Период = СтУдержания.Период
	|			
	|ЛЕВОЕ СОЕДИНЕНИЕ  Документ.КадровоеПеремещениеОрганизаций.Удержания КАК НовыеУдержания
	|ПО		Работники.Сотрудник = НовыеУдержания.Сотрудник
	|	И	Работники.ВидРасчета = НовыеУдержания.ВидРасчета
	|	И   НовыеУдержания.Ссылка = &ДокументСсылка
	|";
	
	Запрос.Текст = ТекстЗапроса;
	
	// Установим параметры запроса
	Запрос.УстановитьПараметр("пустойВидРасчета", ПланыВидовРасчета.Удержания.ПустаяСсылка());	
	Запрос.УстановитьПараметр("парамДейстсвиеПрекратить", Перечисления.ВидыДействияСНачислением.Прекратить);	
	Запрос.УстановитьПараметр("ДокументСсылка", Ссылка);
	Запрос.УстановитьПараметр("ГоловнаяОрганизация", Организация);
	
	Возврат Запрос.Выполнить();

КонецФункции // СформироватьЗапросПоУдержания()

// Проверяет правильность заполнения шапки документа.
// Если какой-то из реквизтов шапки, влияющий на проведение не заполнен или
// заполнен не корректно, то выставляется флаг отказа в проведении.
// Проверка выполняется по выборке из результата запроса по шапке,
// все проверяемые реквизиты должны быть включены в выборку по шапке.
//
// Параметры: 
//  ВыборкаПоШапкеДокумента	- выборка из результата запроса по шапке документа,
//  Отказ 					- флаг отказа в проведении.
//
Процедура ПроверитьЗаполнениеШапки(ВыборкаПоШапкеДокумента, Отказ)

	Если ВыборкаПоШапкеДокумента.ОтражатьВРеглУчете Тогда
		Если НЕ ЗначениеЗаполнено(ВыборкаПоШапкеДокумента.Организация) Тогда
			ОбщегоНазначения.ОшибкаПриПроведении(НСтр("ru='Не указана организация!';uk='Не зазначена організація!'"), Отказ);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры // ПроверитьЗаполнениеШапки()

// Проверяет правильность заполнения реквизитов в строке ТЧ "РаботникиОрганизации" документа.
// Если какой-то из реквизтов, влияющий на проведение не заполнен или
// заполнен не корректно, то выставляется флаг отказа в проведении.
// Проверка выполняется по выборке из результата запроса по строке ТЧ документа,
// все проверяемые реквизиты должны быть включены в выборку.
//
// Параметры: 
//  ВыборкаПоШапкеДокумента		- выборка из результата запроса по шапке документа,
//  ВыборкаПоСтрокамДокумента	- спозиционированная на определеной строке выборка 
//  							  из результата запроса по товарам документа, 
//  Отказ 						- флаг отказа в проведении.
//
Процедура ПроверитьЗаполнениеСтрокиРаботникаОрганизации(ВыборкаПоШапкеДокумента, ВыборкаПоСтрокамДокумента, Отказ)
	
	СтрокаНачалаСообщенияОбОшибке = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='В строке номер ""%1"" табл. части ""Работники"": ';uk='У рядку номер ""%1"" табл. частини ""Працівники"": '"), СокрЛП(ВыборкаПоСтрокамДокумента.НомерСтроки));

	Если ВыборкаПоСтрокамДокумента.ВидСтрокиЗапроса = "ДанныеДляДвиженийКадров" Тогда

		// ФизЛицо
		НетСотрудника = НЕ ЗначениеЗаполнено(ВыборкаПоСтрокамДокумента.Сотрудник);
		Если НетСотрудника Тогда
			ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + НСтр("ru='не выбран работник!';uk='не обраний працівник!'"), Отказ);
		КонецЕсли;

		// ДатаНачала
		НетДатыНачала = НЕ ЗначениеЗаполнено(ВыборкаПоСтрокамДокумента.ДатаНачала);
		Если НетДатыНачала Тогда
			ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + НСтр("ru='не указазана дата перемещения!';uk='не вказана дата переміщення!'"), Отказ);
		КонецЕсли;

		
		Если ВыборкаПоШапкеДокумента.ОтражатьВРеглУчете Тогда			
			// Подразделение
			Если НЕ ЗначениеЗаполнено(ВыборкаПоСтрокамДокумента.ПодразделениеОрганизации) Тогда
				ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + НСтр("ru='не указано подразделение (регл), куда переводится работник!';uk='не вказаний підрозділ (регл), куди переводиться працівник!'"), Отказ);
			ИначеЕсли ВыборкаПоСтрокамДокумента.ОшибкаПодразделениеНеПринадлежитОрганизации Тогда
				ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + НСтр("ru='указано подразделение (регл), принадлежащее другой организации!';uk='зазначений підрозділ (регл), що належить іншій організації!'"), Отказ);
			ИначеЕсли ВыборкаПоСтрокамДокумента.ОшибкаПодразделениеНеПринадлежитОбособленномуПодразделению Тогда
				ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + НСтр("ru='указано подразделение (регл), принадлежащее другому обособленнму подразделению!';uk='зазначений підрозділ (регл), що належить іншому відокремленому підрозділу!'"), Отказ);
			КонецЕсли;

			// Должность
			Если НЕ ЗначениеЗаполнено(ВыборкаПоСтрокамДокумента.Должность) Тогда
				ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + НСтр("ru='не указана должность (регл), на которую переводится работник!';uk='не зазначена посада (регл), на яку переводиться працівник!'"), Отказ);
			КонецЕсли;

			
			Если НетСотрудника ИЛИ НетДатыНачала Тогда
				Возврат; // Дальше не проверяем
			КонецЕсли;
			
			// Приказ о приеме должен принадлежать организации
			Если ВыборкаПоСтрокамДокумента.ОшибкаНеСоответствиеОрганизацииПриказаОПриеме Тогда
				ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + НСтр("ru=' указанный приказ о приеме оформлен на другую организацию!';uk=' вказаний наказ про прийом оформлений на іншу організацію!'"), Отказ);
				
			КонецЕсли;
				
				
			//Если ЗначениеЗаполнено(ВыборкаПоСтрокамДокумента.Сотрудник1) Тогда
			//	Сообщить(СтрокаНачалаСообщенияОбОшибке + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("табельный номер (регл) уже используется для работника %1", ВыборкаПоСтрокамДокумента.Сотрудник1.Наименование), СтатусСообщения.Важное);
			//КонецЕсли;                    

			
		КонецЕсли;
		
		Если ВыборкаПоШапкеДокумента.ОтражатьВУпрУчете Тогда
						
			// Подразделение
			Если НЕ ЗначениеЗаполнено(ВыборкаПоСтрокамДокумента.ПодразделениеУпр) Тогда
				ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + НСтр("ru='не указано подразделение (упр), куда переводится работник!';uk='не вказаний підрозділ (упр), куди переводиться працівник!'"), Отказ);
			КонецЕсли;

			// Должность
			Если НЕ ЗначениеЗаполнено(ВыборкаПоСтрокамДокумента.ДолжностьУпр) Тогда
				ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + НСтр("ru='не указана должность (упр), на которую переводится работник!';uk='не зазначена посада (упр), на яку переводиться працівник!'"), Отказ);
			КонецЕсли;

			Если НетСотрудника
				ИЛИ НетДатыНачала Тогда
				Возврат; // Дальше не проверяем
			КонецЕсли;
			
			Уволен = Ложь;
			УжеРаботает = РегистрыСведений.Работники.СрезПоследних(ВыборкаПоСтрокамДокумента.ДатаНачала, Новый Структура("ФизЛицо",ВыборкаПоСтрокамДокумента.Сотрудник.ФизЛицо));
			Для каждого Место из УжеРаботает Цикл
				Если Место.ЗанимаемыхСтавок = 0 Тогда
					Уволен = Истина;
				КонецЕсли;
			КонецЦикла;
			Если УжеРаботает.Количество()=0 ИЛИ Уволен Тогда
				ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + НСтр("ru='работник не принят на работу на предприятие!';uk='працівник не прийнятий на роботу на підприємство!'"),Отказ);
			КонецЕсли;
			
		КонецЕсли;
		
		
		// Проверка: противоречие другой строке документа
		Если ВыборкаПоСтрокамДокумента.КонфликтнаяСтрокаНомер <> NULL Тогда
			СтрокаСообщениеОбОшибке = НСтр("ru='период действия назначения пересекается с периодом действия строки ';uk='період дії призначення перетинається з періодом дії рядка '") + ВыборкаПоСтрокамДокумента.КонфликтнаяСтрокаНомер + "!"; 
			ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + СтрокаСообщениеОбОшибке, Отказ);
		КонецЕсли;
		


	ИначеЕсли ВыборкаПоСтрокамДокумента.ВидСтрокиЗапроса = "КонфликтныйДокумент" Тогда	

		// противоречие другим кадровым приказам
		СтрокаСообщениеОбОшибке = НСтр("ru='период действия приказа противоречит кадровому приказу ';uk='період дії наказу суперечить кадровому наказу '") + Символы.ПС + Символы.Таб + ВыборкаПоСтрокамДокумента.КонфликтныйДокумент + "!"; 
		ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + СтрокаСообщениеОбОшибке, Отказ);
	КонецЕсли; 

КонецПроцедуры

// Проверяет правильность заполнения реквизитов в строке ТЧ "Начисления" документа.
//
// Параметры: 
//  ВыборкаПоШапкеДокумента		- выборка из результата запроса по шапке документа,
//  ВыборкаПоСтрокамДокумента	- спозиционированная на определеной строке выборка 
//  							  из результата запроса, 
//  Отказ 						- флаг отказа в проведении.
//	Заголовок					- Заголовок для сообщений об ошибках проведения
//
Процедура ПроверитьЗаполнениеСтрокиНачисления(ВыборкаПоШапкеДокумента, ВыборкаПоСтрокамДокумента, Отказ)

	СтрокаНачалаСообщенияОбОшибке = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='В строке номер ""%1"" табл. части ""Начисления"": ';uk='У рядку номер ""%1"" табл. частини ""Нарахування"": '"), СокрЛП(ВыборкаПоСтрокамДокумента.НомерСтроки));

	// ФизЛицо
 	НетСотрудника = НЕ ЗначениеЗаполнено(ВыборкаПоСтрокамДокумента.Сотрудник);
 	Если НетСотрудника Тогда
		ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + НСтр("ru='не выбран работник!';uk='не обраний працівник!'"), Отказ);
	КонецЕсли;
		
	// Вид начисления
	Если НЕ ЗначениеЗаполнено(ВыборкаПоСтрокамДокумента.ВидНачисления) Тогда
		ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + НСтр("ru='не указан вид начисления!';uk='не зазначений вид нарахування!'"));
	КонецЕсли;
    	
	// Вид расчета
 	НетВР = НЕ ЗначениеЗаполнено(ВыборкаПоСтрокамДокумента.ВидРасчета);
 	Если НетВР Тогда
		ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + НСтр("ru='не указано начисление!';uk='не зазначене нарахування!'"), Отказ);
	КонецЕсли;
	
	// Действие
	Если НЕ ЗначениеЗаполнено(ВыборкаПоСтрокамДокумента.Действие) Тогда
		ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + НСтр("ru='не указано действие!';uk='не зазначена дія!'"), Отказ);
	КонецЕсли;
	
	// проверка на существование работника в табличной части "РаботникиОрганизации"
	Если ВыборкаПоСтрокамДокумента.ДатаНачала = NULL Тогда
		ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + НСтр("ru='данный работник не введен в приказ - по нему не могут быть введены начисления!';uk='даний працівник не внесений у наказ - по ньому не можуть бути введені нарахування!'"), Отказ);
	КонецЕсли;
	
	// Проверка: противоречие другой строке документа
	Если Не НетВР и Не НетСотрудника и (ВыборкаПоСтрокамДокумента.ДвойнаяСтрока <> NULL) и (ВыборкаПоСтрокамДокумента.ВидНачисления = перечисления.ВидыНачисленийРаботникаОрганизации.Индивидуальное) Тогда
		СтрокаСообщениеОбОшибке = НСтр("ru='по работнику не может быть изменено одно и тоже начисление дважды (см. строку ';uk='по працівнику не може бути змінено одне й теж нарахування двічі (див. рядок '") + ВыборкаПоСтрокамДокумента.ДвойнаяСтрока + ")!"; 
		ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + СтрокаСообщениеОбОшибке, Отказ);
	КонецЕсли;	
	
	Если ВыборкаПоСтрокамДокумента.Действие = Перечисления.ВидыДействияСНачислением.Начать
		ИЛИ ВыборкаПоСтрокамДокумента.Действие = Перечисления.ВидыДействияСНачислением.Изменить Тогда
		
		
		Если ОтражатьВРеглУчете Тогда
			
			// Способ отражения в бухучете
			Если НЕ ЗначениеЗаполнено(ВыборкаПоСтрокамДокумента.СпособОтраженияВБухучете) Тогда
				ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + НСтр("ru='не заполнен ""Способ отражения в бух.учете""!';uk='не заповнений ""Спосіб відображення в бух.обліку""!'"), Отказ);
			КонецЕсли;
			
		КонецЕсли;
		
		Если ОтражатьВУпрУчете Тогда
			
			// Способ отражения в упручете
			Если НЕ ЗначениеЗаполнено(ВыборкаПоСтрокамДокумента.СпособОтраженияВУпручете) Тогда
				ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + НСтр("ru='не заполнен ""Способ отражения в упр.учете""!';uk='не заповнений ""Спосіб відображення в упр.обліку""!'"), Отказ);
			КонецЕсли;
			
		КонецЕсли;
		
		Если ВыборкаПоСтрокамДокумента.Действие = Перечисления.ВидыДействияСНачислением.Начать
		   И ВыборкаПоСтрокамДокумента.ВидНачисления = Перечисления.ВидыНачисленийРаботникаОрганизации.Основное Тогда	
			Конфликт = Ложь;
			Действующие = РегистрыСведений.ПлановыеНачисленияРаботниковОрганизаций.СрезПоследних(ВыборкаПоСтрокамДокумента.ДатаНачала, Новый Структура("Сотрудник,Организация",ВыборкаПоСтрокамДокумента.Сотрудник,ВыборкаПоШапкеДокумента.Организация));
			Для каждого ВР из Действующие Цикл
				Если ВР.ВидНачисления = Перечисления.ВидыНачисленийРаботникаОрганизации.Основное Тогда
					//Проверим, не отменяется ли оно в документе
					ПараметрыОтбора = Новый Структура;
					ПараметрыОтбора.Вставить("Сотрудник", ВыборкаПоСтрокамДокумента.Сотрудник);
					ПараметрыОтбора.Вставить("ВидРасчета", ВР.ВидРасчета);
					ПараметрыОтбора.Вставить("Действие", Перечисления.ВидыДействияСНачислением.Прекратить);
					НайденныеСтроки = Начисления.НайтиСтроки(ПараметрыОтбора);
					Если НайденныеСтроки.Количество() = 0 Тогда
						Конфликт = Истина;
						Прервать;
					КонецЕсли;	
				КонецЕсли;
			КонецЦикла;
			Если Конфликт Тогда
				ОбщегоНазначения.ОшибкаПриПроведении(СтрокаНачалаСообщенияОбОшибке + НСтр("ru='у работника уже действует основное начисление!';uk='у працівника вже діє основне нарахування!'"),Отказ);
			КонецЕсли;
        КонецЕсли;

		
	КонецЕсли;	
			
КонецПроцедуры		

// По строке выборки результата запроса по документу формируем движения по регистрам
//
// Параметры: 
//  ВыборкаПоШапкеДокумента                - выборка из результата запроса по шапке документа,
//	ВыборкаПоСтрокамДокумента
//
// Возвращаемое значение:
//  Нет.
//
Процедура ДобавитьСтрокуВДвиженияПоРаботникиОрганизации(ВыборкаПоШапкеДокумента, ВыборкаПоСтрокамДокумента)
	
	Если ВыборкаПоШапкеДокумента.ОтражатьВРеглУчете Тогда
		
		Если ВыборкаПоСтрокамДокумента.ВидСтрокиЗапроса = "ДанныеДляДвиженийКадров" Тогда
			
			// отразим новое место работы
			Движение = Движения.РаботникиОрганизаций.Добавить();
			
			// Свойства
			Движение.Период						= ВыборкаПоСтрокамДокумента.ДатаНачала;
			
			// Измерения
			Движение.Сотрудник					= ВыборкаПоСтрокамДокумента.Сотрудник;
						
			// Ресурсы
			Движение.ЗанимаемыхСтавок			= ВыборкаПоСтрокамДокумента.ЗанимаемыхСтавок;
			Движение.ПодразделениеОрганизации	= ВыборкаПоСтрокамДокумента.ПодразделениеОрганизации;
			Движение.Должность					= ВыборкаПоСтрокамДокумента.Должность;
			Движение.ГрафикРаботы				= ВыборкаПоСтрокамДокумента.ГрафикРаботы;
			Движение.СпособОтраженияВБухучете	= ВыборкаПоСтрокамДокумента.СпособОтраженияВБухучете;
			Движение.ПринятНаНовоеРабочееМесто	= ВыборкаПоСтрокамДокумента.ПринятНаНовоеРабочееМесто;
			Движение.РаботаСНефиксированнымРабочимВременем	= ВыборкаПоСтрокамДокумента.РаботаСНефиксированнымРабочимВременем;
				// Реквизиты
			//Движение.Организация				= ВыборкаПоСтрокамДокумента.ОрганизацияПодразделения;
			Движение.Организация				= ВыборкаПоШапкеДокумента.ГоловнаяОрганизация;
			Движение.ПричинаИзмененияСостояния  = Перечисления.ПричиныИзмененияСостояния.Перемещение;
		КонецЕсли;
		
		// Движения по регистру "КоэффициентыПовышенияОкладов" - отразим факт индексации заработка
		Если ВыборкаПоШапкеДокумента.ИндексацияЗаработка  Тогда //И СтруктураПроведенияПоРегистрамСведений.Свойство(ИмяРегистра)
			
			Движение = Движения.КоэффициентыПовышенияОкладов.Добавить();
			
			// Свойства
			Движение.Период                     = ВыборкаПоСтрокамДокумента.ДатаНачала;
			
			// Измерения
			Движение.Сотрудник                    = ВыборкаПоСтрокамДокумента.Сотрудник;
			Движение.Организация                = ВыборкаПоШапкеДокумента.Организация;
			
			Если ВыборкаПоШапкеДокумента.ИндексацияПоДожностям Тогда
				Движение.ПодразделениеОрганизации	= ВыборкаПоСтрокамДокумента.ПодразделениеОрганизации;
				Движение.Должность					= ВыборкаПоСтрокамДокумента.Должность;
			КонецЕсли;	
			
			// Ресурсы
			Движение.Коэффициент				= КоэффициентИндексацииЗаработка;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ВыборкаПоШапкеДокумента.ОтражатьВУпрУчете Тогда
		
		Если ВыборкаПоСтрокамДокумента.ВидСтрокиЗапроса = "ДанныеДляДвиженийКадров" Тогда
			
			// отразим новое место работы
			Движение = Движения.Работники.Добавить();
			
			// Свойства
			Движение.Период						= ВыборкаПоСтрокамДокумента.ДатаНачала;
			
			// Измерения
			Движение.ФизЛицо					= ВыборкаПоСтрокамДокумента.Сотрудник.ФизЛицо;
			
			// Ресурсы
			Движение.ЗанимаемыхСтавок			= ВыборкаПоСтрокамДокумента.ЗанимаемыхСтавокУпр;
			Движение.Подразделение				= ВыборкаПоСтрокамДокумента.ПодразделениеУпр;
			Движение.Должность					= ВыборкаПоСтрокамДокумента.ДолжностьУпр;
			Движение.ГрафикРаботы				= ВыборкаПоСтрокамДокумента.ГрафикРаботы;
			Движение.СпособОтраженияВУпрУчете	= ВыборкаПоСтрокамДокумента.СпособОтраженияВУпрУчете;
			
			// Реквизиты
			Движение.ПричинаИзмененияСостояния  = Перечисления.ПричиныИзмененияСостояния.Перемещение;
		КонецЕсли;
		
	КонецЕсли;	
	
КонецПроцедуры // ДобавитьСтрокуВДвиженияПоРегистрамСведений

// По строке выборки результата запроса по документу формируем движения по регистрам
//
// Параметры: 
//  ВыборкаПоШапкеДокумента                - выборка из результата запроса по шапке документа,
//	ВыборкаПоСтрокамДокумента
//
// Возвращаемое значение:
//  Нет.
//
Процедура ДобавитьСтрокуВДвиженияПоВзносамВФонды(ВыборкаПоШапкеДокумента, ВыборкаПоСтрокамДокумента)
	
	Если НЕ ВыборкаПоШапкеДокумента.ОтражатьВРеглУчете Тогда
		Возврат;
	КонецЕсли;
		
	Если ВыборкаПоСтрокамДокумента.Действие = Перечисления.ВидыДействияСНачислением.НеИзменять тогда
		// ничего не меняем
		Возврат;
		
	ИначеЕсли ВыборкаПоСтрокамДокумента.Действие = Перечисления.ВидыДействияСНачислением.Начать
		ИЛИ ВыборкаПоСтрокамДокумента.Действие = Перечисления.ВидыДействияСНачислением.Изменить Тогда
		мПериод = ВыборкаПоСтрокамДокумента.ДатаДействия;
		мДействует	= Истина;

	ИначеЕсли ВыборкаПоСтрокамДокумента.Действие = Перечисления.ВидыДействияСНачислением.Прекратить тогда
		// движеие на вечер предыдущих суток
		мПериод = ВыборкаПоСтрокамДокумента.ДатаДействия - 1;
		мДействует	= Ложь;

	КонецЕсли;
	
	Движение = Движения.ВзносыВФондыРаботниковОрганизаций.Добавить();
	
	// Свойства
	Движение.Период       = мПериод;
	Движение.Регистратор  = ВыборкаПоШапкеДокумента.Ссылка;
	
	// Измерения
	Движение.Организация	= ВыборкаПоШапкеДокумента.Организация;
	Движение.Сотрудник		= ВыборкаПоСтрокамДокумента.Сотрудник;
	Движение.Налог			= ВыборкаПоСтрокамДокумента.Налог;
	
	// Ресурсы
	Движение.Актуальность	= мДействует;
			
КонецПроцедуры // ДобавитьСтрокуВДвиженияПоРегистрамСведений

Процедура ДобавитьСтрокуВДвиженияПоНачислениям(ВыборкаПоШапкеДокумента, ВыборкаПоСтрокамДокумента, мПериод, мДействует)
	
	Движение = Движения.ПлановыеНачисленияРаботниковОрганизаций.Добавить();
	
	// Свойства
	Движение.Период						= мПериод;
	
	// Измерения
	Движение.Сотрудник					= ВыборкаПоСтрокамДокумента.Сотрудник;
	Движение.Организация				= ВыборкаПоШапкеДокумента.ГоловнаяОрганизация;

	Движение.ВидРасчета					= ВыборкаПоСтрокамДокумента.ВидРасчета;
	
	Если НЕ (ВыборкаПоСтрокамДокумента.ВидНачисления = Перечисления.ВидыНачисленийРаботникаОрганизации.Основное) Тогда
      Движение.ВидРасчетаИзмерение      = ВыборкаПоСтрокамДокумента.ВидРасчета;
	КонецЕсли;
	
	// Ресурсы
	Движение.Актуальность		= мДействует;
	Если мДействует Тогда
		Движение.Показатель1	= ВыборкаПоСтрокамДокумента.Показатель1;
		Движение.Показатель2	= ВыборкаПоСтрокамДокумента.Показатель2;
		Движение.Показатель3	= ВыборкаПоСтрокамДокумента.Показатель3;
		Движение.Показатель4	= ВыборкаПоСтрокамДокумента.Показатель4;
		Движение.Показатель5	= ВыборкаПоСтрокамДокумента.Показатель5;
		Движение.Показатель6	= ВыборкаПоСтрокамДокумента.Показатель6;
		Движение.Валюта1		= ВыборкаПоСтрокамДокумента.Валюта1;
		Движение.Валюта2		= ВыборкаПоСтрокамДокумента.Валюта2;
		Движение.Валюта3		= ВыборкаПоСтрокамДокумента.Валюта3;
		Движение.Валюта4		= ВыборкаПоСтрокамДокумента.Валюта4;
		Движение.Валюта5		= ВыборкаПоСтрокамДокумента.Валюта5;
		Движение.Валюта6		= ВыборкаПоСтрокамДокумента.Валюта6;
		Движение.ВидНачисления	= ВыборкаПоСтрокамДокумента.ВидНачисления;
		
		Движение.СпособОтраженияВБухучете	= ВыборкаПоСтрокамДокумента.СпособОтраженияВБухучете;
		Движение.СпособОтраженияВУпручете	= ВыборкаПоСтрокамДокумента.СпособОтраженияВУпручете;
	КонецЕсли;

КонецПроцедуры

Процедура ДобавитьСтрокуВДвиженияПоУдержаниям(ВыборкаПоШапкеДокумента, ВыборкаПоСтрокамДокумента, мПериод, мДействует)
	
	Движение = Движения.ПлановыеУдержанияРаботниковОрганизаций.Добавить();
	
	// Свойства
	Движение.Период			= мПериод;
	
	// Измерения
	Движение.Организация	= ВыборкаПоШапкеДокумента.ГоловнаяОрганизация;
	Движение.Сотрудник		= ВыборкаПоСтрокамДокумента.Сотрудник;
	Движение.ВидРасчета		= ВыборкаПоСтрокамДокумента.ВидРасчета;
	
	// Ресурсы
	Движение.Актуальность	= мДействует;
	Движение.Показатель1	= ВыборкаПоСтрокамДокумента.Показатель1;
	Движение.Показатель2	= ВыборкаПоСтрокамДокумента.Показатель2;
	Движение.Показатель3	= ВыборкаПоСтрокамДокумента.Показатель3;
	Движение.Показатель4    = ВыборкаПоСтрокамДокумента.Показатель4;
	Движение.Показатель5	= ВыборкаПоСтрокамДокумента.Показатель5;
	Движение.Показатель6	= ВыборкаПоСтрокамДокумента.Показатель6;
	Движение.Валюта1		= ВыборкаПоСтрокамДокумента.Валюта1;
	Движение.Валюта2		= ВыборкаПоСтрокамДокумента.Валюта2;
	Движение.Валюта3		= ВыборкаПоСтрокамДокумента.Валюта3;
	Движение.Валюта4		= ВыборкаПоСтрокамДокумента.Валюта4;
	Движение.Валюта5		= ВыборкаПоСтрокамДокумента.Валюта5;
	Движение.Валюта6		= ВыборкаПоСтрокамДокумента.Валюта6;
	
	Движение.СпособОтраженияВБухучете	= ВыборкаПоСтрокамДокумента.СпособОтраженияВБухучете;
	Движение.СпособОтраженияВУпручете	= ВыборкаПоСтрокамДокумента.СпособОтраженияВУпручете;

КонецПроцедуры

Процедура ДобавитьСтрокуВДвиженияПоРегистрам(ВыборкаПоШапкеДокумента, ВыборкаПоРаботникиОрганизации)
	
	Движение = Движения.ПараметрыФиксированнойИндексации.Добавить();
	Движение.Организация  	= ВыборкаПоШапкеДокумента.Организация;
	Движение.Сотрудник    	= ВыборкаПоРаботникиОрганизации.Сотрудник;
	Если ВыборкаПоШапкеДокумента.ИндексацияПоДожностям Тогда
		Движение.ПодразделениеОрганизации	= ВыборкаПоРаботникиОрганизации.ПодразделениеОрганизации;
		Движение.Должность					= ВыборкаПоРаботникиОрганизации.Должность;
	КонецЕсли;	
	Движение.Период       	= ВыборкаПоРаботникиОрганизации.ДатаНачала;
	Движение.Размер			= ВыборкаПоРаботникиОрганизации.ФиксированнаяИндексация;
	
КонецПроцедуры	

// Формирует запрос по таблице "Сотрудники" документа
//
// Параметры: 
//  Режим - режим проведения
//
// Возвращаемое значение:
//  Результат запроса. В запросе данные документа дополняются значениями
//  проверяемых параметров из связанного с
//
Функция СформироватьЗапросПоВзносамСотрудники(Режим)

	Запрос = Новый Запрос;
	
	// Установим параметры запроса
	Запрос.УстановитьПараметр("ДокументСсылка", Ссылка);

    // Описание текста запроса:
	//
    // 1. Выборка "Начисления": 
	//		Объединяются строки ТЧ Начисления. Сразу проверяем наличие строк-дублей.  

	ТекстЗапроса = "ВЫБРАТЬ
	               |	ТЧВзносы.НомерСтроки,
	               |	ТЧВзносы.Сотрудник,
	               |	ТЧВзносы.Налог,
	               |	ТЧВзносы.Действие,
				   |	ТЧРаботникиОрганизации.ДатаНачала КАК ДатаДействия
				   |ИЗ Документ.КадровоеПеремещениеОрганизаций.Взносы КАК ТЧВзносы
				   |	
				   |ЛЕВОЕ СОЕДИНЕНИЕ Документ.КадровоеПеремещениеОрганизаций.РаботникиОрганизации КАК ТЧРаботникиОрганизации
				   |ПО		ТЧРаботникиОрганизации.Сотрудник = ТЧВзносы.Сотрудник 
				   |	И	ТЧРаботникиОрганизации.Ссылка = ТЧВзносы.Ссылка
				   |	
				   |ГДЕ ТЧВзносы.Ссылка = &ДокументСсылка
				   |
				   |	
				   |ОБЪЕДИНИТЬ	
				   |ВЫБРАТЬ	
				   |	ТЧВзносыФОТ.НомерСтроки,
				   |	ТЧВзносыФОТ.Сотрудник,
				   |	ТЧВзносыФОТ.Налог,
				   |	ТЧВзносыФОТ.Действие,
				   |	ТЧРаботникиОрганизации.ДатаНачала
				   |ИЗ Документ.КадровоеПеремещениеОрганизаций.ВзносыФОТ КАК ТЧВзносыФОТ
				   |	
				   |ЛЕВОЕ СОЕДИНЕНИЕ Документ.КадровоеПеремещениеОрганизаций.РаботникиОрганизации КАК ТЧРаботникиОрганизации
				   |ПО		ТЧРаботникиОрганизации.Сотрудник = ТЧВзносыФОТ.Сотрудник 
				   |	И	ТЧРаботникиОрганизации.Ссылка = ТЧВзносыФОТ.Ссылка
				   |
				   |ГДЕ	ТЧВзносыФОТ.Ссылка = &ДокументСсылка
				   |";
			   
	
	Запрос.Текст = ТекстЗапроса;
	
	Возврат Запрос.Выполнить();

КонецФункции


