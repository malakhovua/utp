&НаСервере
Процедура ТоварыНоменклатураПриИзмененииНаСервере(СтруктрураСтрокиТЧ)
	
	ДопПараметры = Новый Структура("ДоговорКонтрагента",Объект.ДоговорКонтрагента);
	ИмяТабЧасти = "Товары";
	
	ОбработкаТабличныхЧастейСервер.ПриИзмененииНоменклатурыТабЧасти(СтруктрураСтрокиТЧ,"Товары");
	
	// Заполняем реквизиты табличной части.
	ОбработкаТабличныхЧастейСервер.ЗаполнитьСтавкуНДСТабЧасти(СтруктрураСтрокиТЧ,"Товары", ДопПараметры, "Реализация");
	ОбработкаТабличныхЧастейСЕрвер.ЗаполнитьСпособСписанияОстаткаТоваровТабЧасти(СтруктрураСтрокиТЧ);

	// Заполнение цены зависит от розничности операции.
	ОбработкаТабличныхЧастейСервер.ЗаполнитьЕдиницуЦенуПродажиТабЧасти(СтруктрураСтрокиТЧ,"Товары", ДопПараметры, мВалютаРегламентированногоУчета); 
	
	
	СчетаУчета     = БухгалтерскийУчет.ПолучитьСчетаУчетаНоменклатуры(Объект.Организация, СтруктрураСтрокиТЧ.Номенклатура, ?(мУказаниеСкладовВТЧ, СтруктрураСтрокиТЧ.Склад, Объект.Склад));
	ЭтоКомиссия    = (Объект.ВидОперации = Перечисления.ВидыОперацийРеализацияТоваров.ПродажаКомиссия
			   		И Объект.ДоговорКонтрагента.ВидДоговора = Перечисления.ВидыДоговоровКонтрагентов.СКомиссионером);
	
	ЗаполнитьСчетаБУ(СтруктрураСтрокиТЧ, ИмяТабЧасти, СчетаУчета, Истина, ЭтоКомиссия);
	ЗаполнитьСчетаНУ(СтруктрураСтрокиТЧ, ИмяТабЧасти, СчетаУчета, Истина, ЭтоКомиссия);
	
	//ОбновитьИтогиСервер();
	
КонецПроцедуры

