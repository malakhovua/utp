				СуммаНаценкиНУ = СтрокаТаблицыНаценок.ТН_НУ * СуммаНУ / (СтрокаТаблицыНаценок.ПС_НУ);
				ПокупнаяЦенаНУ = СуммаНУ - СуммаНаценкиНУ;
