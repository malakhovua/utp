		ОбщегоНазначения.СообщитьОбОшибке(СтрокаНачалаСообщенияОбОшибке + НСтр("ru='не указан СчетКт!';uk='не зазначений СчетКт!'"), Отказ, Заголовок);
	КонецЕсли;

