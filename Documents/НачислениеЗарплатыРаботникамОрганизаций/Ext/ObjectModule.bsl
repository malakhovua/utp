Функция		СформироватьЗапросОтражениеВУпрУчете()
	
	Запрос = Новый Запрос();
	
	ТекстЗапроса_ТабличныеЧасти  = "
	|ВЫБРАТЬ
	|	Основные.СтатьяЗатрат				КАК СтатьяЗатрат,
	|	Основные.НоменклатурнаяГруппа		КАК НоменклатурнаяГруппа,
	|	Основные.ОбъектСтроительства 		КАК ОбъектСтроительства,
	|	Основные.ПодразделениеУпр			КАК Подразделение,
	|	Основные.РезультатУпр				КАК Сумма
	|
	|ИЗ	Документ.НачислениеЗарплатыРаботникамОрганизаций.НачисленияПроводки КАК Основные
	|ГДЕ Основные.Ссылка = &парамРегистратор
	| И  Основные.ПодразделениеУпр <> &парамПустоеПодразделениеУпр
	| И  Основные.РезультатУпр <> 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|ВЫБРАТЬ
	|	Основные.СтатьяЗатрат				КАК СтатьяЗатрат,
	|	Основные.НоменклатурнаяГруппа		КАК НоменклатурнаяГруппа,
	|	Основные.ОбъектСтроительства 		КАК ОбъектСтроительства,
	|	Основные.ПодразделениеУпр			КАК Подразделение,
	|	Основные.РезультатУпр				КАК Сумма
	|
	|ИЗ	Документ.НачислениеЗарплатыРаботникамОрганизаций.ВзносыФОТПроводки КАК Основные
	|ГДЕ Основные.Ссылка = &парамРегистратор
	| И  Основные.ПодразделениеУпр <> &парамПустоеПодразделениеУпр
	| И  Основные.РезультатУпр <> 0
	|
	|";
	
	ТекстЗапроса  = "
	|ВЫБРАТЬ
	|	Основные.СтатьяЗатрат				КАК СтатьяЗатрат,
	|	Основные.НоменклатурнаяГруппа		КАК НоменклатурнаяГруппа,
	|	Основные.ОбъектСтроительства 		КАК ОбъектСтроительства,
	|	Основные.Подразделение				КАК Подразделение,
	|	СУММА(Основные.Сумма)				КАК Сумма
	|	
	|ИЗ	(" + ТекстЗапроса_ТабличныеЧасти + ") КАК Основные
	|
	|СГРУППИРОВАТЬ ПО
	|	Основные.СтатьяЗатрат,
	|	Основные.НоменклатурнаяГруппа,
	|	Основные.ОбъектСтроительства,
	|	Основные.Подразделение
	|";
	
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("парамРегистратор", Ссылка);
	Запрос.УстановитьПараметр("парамПериодРегистрации", ПериодРегистрации);
	Запрос.УстановитьПараметр("парамПустоеПодразделениеУпр", Справочники.Подразделения.ПолучитьСсылку());
	Запрос.УстановитьПараметр("парамОрганизация", Организация);
	спФизЛицо = РаботникиОрганизации.ВыгрузитьКолонку("ФизЛицо");
	Запрос.УстановитьПараметр("парамФизЛицо", спФизЛицо);
	
	Возврат Запрос.Выполнить();
	
КонецФункции // СформироватьЗапросОтражениеВУпрУчете()

Процедура СформироватьВзаиморасчетыСРаботниками( Сотрудники, НаборЗаписей )
	
	ИспользуетсяЕСВ = ПроведениеРасчетов.ИспользуетсяЕСВ(ПериодРегистрации);
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("парамПериодРегистрации",	ПериодРегистрации);
	Запрос.УстановитьПараметр("парамСсылка",			Ссылка);
	Запрос.УстановитьПараметр("парамОрганизация",		Организация);
	
	Если Сотрудники = Неопределено Тогда
