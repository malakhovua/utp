	СтруктураПолей.Вставить("ВидДеятельностиНДС"		     	, "НалоговоеНазначение.ВидДеятельностиНДС");
	СтруктураПолей.Вставить("СуммаСебестоимостиНУ"     			, "СуммаСебестоимостиНУ");
	
