	СтруктураПолей.Вставить("СхемаНалоговогоУчетаПоТаре"		, "ДоговорКонтрагента.СхемаНалоговогоУчетаПоТаре");
	СтруктураПолей.Вставить("НалоговоеНазначение"				, "НалоговоеНазначение");
