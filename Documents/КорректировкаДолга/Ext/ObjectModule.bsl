						    Проводка.СчетДт = СтруктураШапкиДокумента.СчетДт;	
						КонецЕсли;
					Иначе		
						Проводка.СчетДт = Строка.СчетУчетаНДС;		
					КонецЕсли;
					
					Если ЭтоПродажа Тогда
						Если ЭтоСписаниеЗадолженности Тогда
							ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт,Проводка.СубконтоДт,1,СтруктураШапкиДокумента.СубконтоКт1, Истина);
							ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт,Проводка.СубконтоДт,2,СтруктураШапкиДокумента.СубконтоКт2);
							ОбщегоНазначения.УстановитьСубконто(Проводка.СчетДт,Проводка.СубконтоДт,3,СтруктураШапкиДокумента.СубконтоКт3);
