			Строка.СчетУчета			= Выборка.СчетУчета;
			Строка.Сумма			= Выборка.Сумма - тСуммаОкругления;
			Строка.СуммаУпр			= Выборка.СуммаУпр;
			Строка.СуммаОкругления	= тСуммаОкругления;
			
		КонецЦикла;
		
	КонецЦикла;
	
