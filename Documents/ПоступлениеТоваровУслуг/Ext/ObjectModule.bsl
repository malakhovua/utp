	СтруктураПолей.Вставить("НалоговоеНазначение"     	, "НалоговоеНазначение");
	СтруктураПолей.Вставить("ОбъектСтроительстваНалоговоеНазначение", "ОбъектСтроительства.НалоговоеНазначение");
	
