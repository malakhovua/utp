Процедура ЗаполнитьАлгоритмомУМК(Основание) 
	
	// Проверим соответствие контрагента ФОПУ
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	umk_СоответствиеОрганизацияФОП.Организация
		|ИЗ
		|	РегистрСведений.umk_СоответствиеОрганизацияФОП КАК umk_СоответствиеОрганизацияФОП
		|ГДЕ
		|	umk_СоответствиеОрганизацияФОП.Контрагент = &Контрагент";
	
	Запрос.УстановитьПараметр("Контрагент", Основание.Контрагент);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		Организация = Выборка.Организация;
		Контрагент = Константы.umk_ОсновнаяОрганизацияКонтрагент.Получить();
		ОбновитьСтруктуруПараметровДляПолученияДоговора();
	    // Выполняем общие действия для всех документов при изменении Контрагент.
    	ЗаполнениеДокументов.ПриИзмененииЗначенияКонтрагента(ЭтотОбъект, мСтруктураПараметровДляПолученияДоговора);
		СуммаВключаетНДС = Истина;
		СчетУчетаРасчетовСКонтрагентом = ПланыСчетов.Хозрасчетный.РасчетыСОтечественнымиПоставщиками;
		СчетУчетаРасчетовПоАвансам = ПланыСчетов.Хозрасчетный.РасчетыПоВыданнымАвансамВНациональнойВалюте;
		
		Для Каждого СтрокаТовары Из Товары Цикл
			
			Если Не Основание.СуммаВключаетНДС Тогда
				
				 СтрокаТовары.Цена = СтрокаТовары.Цена + (СтрокаТовары.Цена * УчетНДС.ПолучитьСтавкуНДС(СтрокаТовары.СтавкаНДС)*0.01);
				 ОбработкаТабличныхЧастей.РассчитатьСуммуТабЧасти(СтрокаТовары, ЭтотОбъект);
				
			КонецЕсли;
			
		   СтрокаТовары.СтавкаНДС = Перечисления.СтавкиНДС.БезНДС;
		   // Рассчитать реквизиты табличной части.
	       ОбработкаТабличныхЧастей.РассчитатьСуммуНДСТабЧасти(СтрокаТовары, ЭтотОбъект);
			
	   КонецЦикла;
	   
			                             
	КонецЕсли;
		

КонецПроцедуры

мВалютаРегламентированногоУчета = глЗначениеПеременной("ВалютаРегламентированногоУчета");

