// ОБРАБОТЧИКИ СОБЫТИЙ

Процедура ОбработкаПроведения(Отказ)

	ДвиженияПоРегистрам();

КонецПроцедуры // ОбработкаПроведения

Процедура ОбработкаУдаленияПроведения()

	УдалитьДвижения();

КонецПроцедуры // ОбработкаУдаленияПроведения()

