								|Оборудование.НалоговоеНазначение
								|Оборудование.СчетУчетаБУ";

	мСтрокаРеквизитыНалУчета =  "";

КонецПроцедуры // ЗаполнитьСписокРеквизитовЗависимыхОтТиповУчетаРегл()

