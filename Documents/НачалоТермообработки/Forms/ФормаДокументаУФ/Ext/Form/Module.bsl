// Модуль формы документа НачалоТермообработки

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ОбновитьНаименованиеПрограммы();
КонецПроцедуры // ПриСозданииНаСервере // + claude

&НаСервере
Процедура ОбновитьНаименованиеПрограммы()
	Если ЗначениеЗаполнено(Объект.ПодПрограмма) Тогда
		Программа = Объект.ПодПрограмма.Программа;
		Если ЗначениеЗаполнено(Программа) Тогда
			Элементы.НаименованиеПрограммы.Заголовок = "Программа: " + Строка(Программа);
		Иначе
			Элементы.НаименованиеПрограммы.Заголовок = "";
		КонецЕсли;
	Иначе
		Элементы.НаименованиеПрограммы.Заголовок = "";
	КонецЕсли;
КонецПроцедуры // ОбновитьНаименованиеПрограммы // + claude

&НаКлиенте
Процедура ПодПрограммаПриИзменении(Элемент)
	ПодПрограммаПриИзменении_НаСервере();
КонецПроцедуры // ПодПрограммаПриИзменении // + claude

&НаСервере
Процедура ПодПрограммаПриИзменении_НаСервере()
	ОбновитьНаименованиеПрограммы();
КонецПроцедуры // ПодПрограммаПриИзменении_НаСервере // + claude

&НаКлиенте
Процедура НачалоЧасыПриИзменении(Элемент)
	Если Объект.НачалоЧасы > 23 Тогда
		Объект.НачалоЧасы = 23;
	КонецЕсли;
КонецПроцедуры // НачалоЧасыПриИзменении // + claude

&НаКлиенте
Процедура НачалоМинутыПриИзменении(Элемент)
	Если Объект.НачалоМинуты > 59 Тогда
		Объект.НачалоМинуты = 59;
	КонецЕсли;
КонецПроцедуры // НачалоМинутыПриИзменении // + claude

&НаКлиенте
Процедура ТМЦКвоПриИзменении(Элемент)
	ТМЦКвоПриИзменении_НаСервере(Элементы.ТМЦ.ТекущиеДанные.ПолучитьИдентификатор());
КонецПроцедуры // ТМЦКвоПриИзменении // + claude

&НаСервере
Процедура ТМЦКвоПриИзменении_НаСервере(НомерСтроки)
	Строка = Объект.ТМЦ.НайтиПоИдентификатору(НомерСтроки);
	Если Строка = Неопределено Тогда
		Возврат;
	КонецЕсли;

	КвоПродукцииНаРаме = Строка.ТМЦ.КвоПродукцииНаРаме;
	Если КвоПродукцииНаРаме > 0 Тогда
		КвоРам = Цел(Строка.Кво / КвоПродукцииНаРаме);
		Если КвоРам * КвоПродукцииНаРаме < Строка.Кво Тогда
			КвоРам = КвоРам + 1; // округление вверх
		КонецЕсли;
		Строка.КвоРам = КвоРам;
	КонецЕсли;

КонецПроцедуры // ТМЦКвоПриИзменении_НаСервере // + claude

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	// Формируем ИтогПоВидамРам: группировка ТЧ по ВидРамы + сумма КвоРам, формат "Б2,К3,"
	ТЗ = ТекущийОбъект.ТМЦ.Выгрузить();
	ТЗ.Свернуть("ВидРамы", "КвоРам");
	ТекстИтог = "";
	Для Каждого Строка Из ТЗ Цикл
		Если ЗначениеЗаполнено(Строка.ВидРамы) Тогда
			ТекстИтог = ТекстИтог + Лев(Строка.ВидРамы.Наименование, 1) + СокрЛП(Формат(Строка.КвоРам, "ЧДц=0")) + ",";
		КонецЕсли;
	КонецЦикла;
	ТекстИтог = СокрП(ТекстИтог);
	Если Прав(ТекстИтог, 1) = "," Тогда
		ТекстИтог = Лев(ТекстИтог, СтрДлина(ТекстИтог) - 1);
	КонецЕсли;
	ТекущийОбъект.ИтогПоВидамРам = ТекстИтог;
КонецПроцедуры // ПередЗаписьюНаСервере // + claude
