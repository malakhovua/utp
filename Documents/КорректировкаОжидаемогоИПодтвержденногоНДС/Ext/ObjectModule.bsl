			ТекстСообщенияОшибка = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='   В табличной части ""Подтвержденный"" база НДС:%1, НДС :%2"
"   А в табличной части ""Ожидаемый"" база НДС:%3, НДС :%4!';uk='   У табличній частині ""Підтверджений"" база ПДВ:%1, ПДВ :%2"
"   А в табличній частині ""Очікуваний"" база ПДВ:%3, ПДВ :%4!'"), 
			(-СтрокаТаблицыПодтвержденный.БазаНДС), 
