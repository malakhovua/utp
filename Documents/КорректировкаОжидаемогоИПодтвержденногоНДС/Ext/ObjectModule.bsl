			ПодтвержденныйБазаНДС 					= 0;
			ПодтвержденныйНДС		 				= 0;
		КонецЕсли;
		
		Если НЕ (СтрокаТаблицыОжидаемый.БазаНДС 				 = ПодтвержденныйБазаНДС И
			 	 СтрокаТаблицыОжидаемый.СуммаНДС				 = ПодтвержденныйНДС) Тогда

ТекстСообщенияИзмерения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Не совпадают итоги в табличных частях по приобретениям !"
"По измерениям контрагент: %1, договор: %2, расчетный документ: %6,  возвратная тара: %3, событие: %4 ставка НДС: %5:';uk='Не збігаються підсумки в табличних частинах по придбаннях !"
