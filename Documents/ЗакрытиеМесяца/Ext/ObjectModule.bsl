				Выборка = ВыборкаРаздел.Выбрать();
				Пока Выборка.Следующий() Цикл
					
					НоваяСтрока = ТаблицаОстатков.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
					
				КонецЦикла;
				
			Иначе
				
				Выборка = ВыборкаРаздел.Выбрать();
				Пока Выборка.Следующий() Цикл
					
					СуммаКРаспределению = Выборка.СуммаВзаиморасчетов;
					КоэфРИ = Выборка.СуммаВзаиморасчетовРИ / Выборка.СуммаВзаиморасчетов;
					
					Для каждого СтрокаОстатков Из ТаблицаОстатков Цикл
						
						Если СуммаКРаспределению = 0 Тогда
							Прервать;
						КонецЕсли;
						
						СуммаПоСтроке = Мин(СуммаКРаспределению, СтрокаОстатков.СуммаВзаиморасчетов);
						
						Если ЗначениеЗаполнено(СуммаПоСтроке) Тогда
							
							НоваяСтрока = ТаблицаОжидаемыхРазниц.Добавить();
							ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
							ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаОстатков, "ПериодДвижения, ДокументДвижения");
							НоваяСтрока.Организация = СтруктураШапкиДокумента.Организация;
							НоваяСтрока.ДокументВторогоСобытия = Выборка.ДокументДвижения;
							НоваяСтрока.СуммаВзаиморасчетов = СуммаПоСтроке;
							
							Если Выборка.Аванс И КоэфРИ <> 0 Тогда
								
								//закрываем аванс реализацией текущего периода, финансовые показатели влияют только на сумму РИ
								ФинансовыеПоказателиДокумента = КэшФинансовыхПоказателей[Выборка.ДокументДвижения];
								Если ФинансовыеПоказателиДокумента = Неопределено Тогда
									
									ФинансовыеПоказателиДокумента = ПолучитьФинансовыеПоказателиДокумента(Выборка.ДокументДвижения, ГруппыСчетовУчета);
									КэшФинансовыхПоказателей.Вставить(Выборка.ДокументДвижения, ФинансовыеПоказателиДокумента);
									
								КонецЕсли;
								
								Если ФинансовыеПоказателиДокумента.СуммаВзаиморасчетов <> 0 Тогда
									
									Коэф = СуммаПоСтроке / ФинансовыеПоказателиДокумента.СуммаВзаиморасчетов;
									СуммаДоходов = ФинансовыеПоказателиДокумента.СуммаДоходов * Коэф;
									Себестоимость = ФинансовыеПоказателиДокумента.Себестоимость * Коэф;
									
									НоваяСтрока.СуммаДоходовВтороеСобытие = СуммаДоходов;
									НоваяСтрока.СебестоимостьВтороеСобытие = Себестоимость;
									
									Если РедакцияНКУ > 1 Тогда
										НоваяСтрока.СуммаРИПлюс = Себестоимость*КоэфРИ;
										НоваяСтрока.СуммаРИМинус = СуммаДоходов*КоэфРИ;
										СуммыРИПоСтатьям.Оплата1.Сумма = СуммыРИПоСтатьям.Оплата1.Сумма + НоваяСтрока.СуммаРИМинус;
										СуммыРИПоСтатьям.Продажа2.Сумма = СуммыРИПоСтатьям.Продажа2.Сумма + НоваяСтрока.СуммаРИПлюс;
									КонецЕсли;
								
								КонецЕсли;
								
							Иначе
								
								//реализация закрывается оплатой, финансовые показатели сохранены в остатках
								Коэф = СуммаПоСтроке / СтрокаОстатков.СуммаВзаиморасчетов;
								НоваяСтрока.СуммаДоходов = СтрокаОстатков.СуммаДоходов * Коэф;
								НоваяСтрока.Себестоимость = СтрокаОстатков.Себестоимость * Коэф;
								
								СтрокаОстатков.СуммаДоходов = СтрокаОстатков.СуммаДоходов - НоваяСтрока.СуммаДоходов;
								СтрокаОстатков.Себестоимость = СтрокаОстатков.Себестоимость - НоваяСтрока.Себестоимость;
								
								НоваяСтрока.СуммаРИПлюс = НоваяСтрока.СуммаДоходов * КоэфРИ;
								СуммыРИПоСтатьям.Оплата2.Сумма = СуммыРИПоСтатьям.Оплата2.Сумма + НоваяСтрока.СуммаРИПлюс;
								Если РедакцияНКУ > 1 Тогда
									НоваяСтрока.СуммаРИМинус = НоваяСтрока.Себестоимость * КоэфРИ;
									СуммыРИПоСтатьям.Продажа1.Сумма = СуммыРИПоСтатьям.Продажа1.Сумма + НоваяСтрока.СуммаРИМинус;
								КонецЕсли;
								
							КонецЕсли;
							
							СуммаКРаспределению = СуммаКРаспределению - СуммаПоСтроке;
							СтрокаОстатков.СуммаВзаиморасчетов = СтрокаОстатков.СуммаВзаиморасчетов - СуммаПоСтроке;
							
						КонецЕсли;
						
					КонецЦикла;
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла; 
	
	Если ТаблицаОжидаемыхРазниц.Количество() > 0 Тогда
		
		НаборЗаписей.мТаблицаДвижений = ТаблицаОжидаемыхРазниц;
		НаборЗаписей.мПериод = СтруктураШапкиДокумента.Дата;
		НаборЗаписей.ВыполнитьРасход();         
		НаборЗаписей.Записать(Ложь);
		
	КонецЕсли;
	
	СчетРИ = ПланыСчетов.Хозрасчетный.РазницыПоНалогуНаПрибыльРучныеКорректировки;
	
	Для каждого КЗ ИЗ СуммыРИПоСтатьям Цикл
		
		СуммаПоСтатье = КЗ.Значение;
		
		Если ЗначениеЗаполнено(СуммаПоСтатье.Сумма) Тогда	
			
			ПроводкаБУ                                 = мПроводкиБУ.Добавить();
			ПроводкаБУ.Период                          = СтруктураШапкиДокумента.Дата;
			ПроводкаБУ.Организация                     = СтруктураШапкиДокумента.Организация;
			
			ПроводкаБУ.СчетДт                          = СчетРИ;
			ПроводкаБУ.СубконтоДт.СтатьиНалоговыхДеклараций = СуммаПоСтатье.Статья;
			
			ПроводкаБУ.Сумма                           = СуммаПоСтатье.Сумма;
			
		КонецЕсли;			
		
	КонецЦикла;
	
	Если мПроводкиБУ.Количество() > 0 Тогда
		мПроводкиБУ.Записать(Ложь); 	
	КонецЕсли;
	
КонецПроцедуры   

Функция ПолучитьФинансовыеПоказателиДокумента(ДокументСсылка, ГруппыСчетовУчета = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СУММА(ВЗ.СуммаВзаиморасчетов) КАК СуммаВзаиморасчетов,
	|	СУММА(ВЗ.СуммаДоходов) КАК СуммаДоходов,
	|	СУММА(ВЗ.Себестоимость) КАК Себестоимость
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВЫБОР
	|			КОГДА Хозрасчетный.СчетДт В (&СчетаРасчетов)
	|				ТОГДА ВЫБОР КОГДА Хозрасчетный.ВалютаДт IS NULL ТОГДА Хозрасчетный.Сумма ИНАЧЕ Хозрасчетный.ВалютнаяСуммаДт КОНЕЦ
	|			ИНАЧЕ 0
	|		КОНЕЦ - ВЫБОР
	|			КОГДА Хозрасчетный.СчетКт В (&СчетаРасчетов)
	|				ТОГДА ВЫБОР КОГДА Хозрасчетный.ВалютаКт IS NULL ТОГДА Хозрасчетный.Сумма ИНАЧЕ Хозрасчетный.ВалютнаяСуммаКт КОНЕЦ
	|			ИНАЧЕ 0
	|		КОНЕЦ КАК СуммаВзаиморасчетов,
	|		ВЫБОР
	|			КОГДА Хозрасчетный.СчетДт В (&СчетаДоходов)
	|				ТОГДА -Хозрасчетный.Сумма
	|			ИНАЧЕ 0
	|		КОНЕЦ + ВЫБОР
	|			КОГДА Хозрасчетный.СчетКт В (&СчетаДоходов)
	|				ТОГДА Хозрасчетный.Сумма
	|			ИНАЧЕ 0
	|		КОНЕЦ КАК СуммаДоходов,
	|		ВЫБОР
	|			КОГДА Хозрасчетный.СчетДт В (&СчетаСебестоимости)
	|				ТОГДА Хозрасчетный.Сумма
	|			ИНАЧЕ 0
	|		КОНЕЦ - ВЫБОР
	|			КОГДА Хозрасчетный.СчетКт В (&СчетаСебестоимости)
	|				ТОГДА Хозрасчетный.Сумма
	|			ИНАЧЕ 0
	|		КОНЕЦ КАК Себестоимость
	|	ИЗ
	|		РегистрБухгалтерии.Хозрасчетный КАК Хозрасчетный
	|	ГДЕ
	|		Хозрасчетный.Регистратор = &Регистратор) КАК ВЗ";
	Запрос.УстановитьПараметр("Регистратор", ДокументСсылка);
	
	Если ГруппыСчетовУчета = Неопределено Тогда
		ГруппыСчетовУчета = ПолучитьДетальныеСпискиСчетовУчета();
	КонецЕсли;
	
	Для каждого ГруппаСчетов ИЗ ГруппыСчетовУчета Цикл
		Запрос.УстановитьПараметр(ГруппаСчетов.Ключ, ГруппаСчетов.Значение);
	КонецЦикла;
	
	СтруктураВозврата = Новый Структура("СуммаВзаиморасчетов, СуммаДоходов, Себестоимость", 0, 0, 0);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(СтруктураВозврата, Выборка);
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции 

Функция ПолучитьДетальныеСпискиСчетовУчета()
	
	ГруппыСчетовУчета = Новый Структура;
	
	МассивСчетовРасчетов = Новый Массив;
	МассивСчетовРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПокупателямиИЗаказчиками);
	МассивСчетовРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыПоАвансамПолученным);
	МассивСчетовРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСДругимиДебиторами);
	МассивСчетовРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСДругимиКредиторами);
	ГруппыСчетовУчета.Вставить("СчетаРасчетов", МассивСчетовРасчетов);
	
	МассивСчетовДенежныхСредств = Новый Массив;
	МассивСчетовДенежныхСредств.Добавить(ПланыСчетов.Хозрасчетный.Касса);
	МассивСчетовДенежныхСредств.Добавить(ПланыСчетов.Хозрасчетный.СчетаВБанках);
	ГруппыСчетовУчета.Вставить("СчетаДС", МассивСчетовДенежныхСредств);
	
	МассивСчетовДоходов = Новый Массив;
	МассивСчетовДоходов.Добавить(ПланыСчетов.Хозрасчетный.ДоходыОтРеализации);
	МассивСчетовДоходов.Добавить(ПланыСчетов.Хозрасчетный.ДоходОтРеализацииДругихОборотныхАктивов);
	ГруппыСчетовУчета.Вставить("СчетаДоходов", МассивСчетовДоходов);
	
	МассивСчетовСебестоимости = Новый Массив;
	МассивСчетовСебестоимости.Добавить(ПланыСчетов.Хозрасчетный.СебестоимостьРеализации);
	МассивСчетовСебестоимости.Добавить(ПланыСчетов.Хозрасчетный.СебестоимостьРеализованныхПроизводственныхЗапасов);
	ГруппыСчетовУчета.Вставить("СчетаСебестоимости", МассивСчетовСебестоимости);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Хозрасчетный.Ссылка КАК Ссылка
	|ИЗ
	|	ПланСчетов.Хозрасчетный КАК Хозрасчетный
	|ГДЕ
	|	Хозрасчетный.Ссылка В ИЕРАРХИИ(&МассивСчетов)";
	
	Для каждого ГруппаСчетов ИЗ ГруппыСчетовУчета Цикл
		
		Запрос.УстановитьПараметр("МассивСчетов", ГруппаСчетов.Значение);
		ГруппыСчетовУчета.Вставить(ГруппаСчетов.Ключ, Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку(0));
		
	КонецЦикла; 
	
	Возврат ГруппыСчетовУчета;
	
КонецФункции

// Выполняет движения по регистрам 
//
Процедура ДвиженияПоРегистрам(СтруктураШапкиДокумента, Отказ, Заголовок)
	
	Если СтруктураШапкиДокумента.ЭтоДокументЗакрытияМесяцаУпр Тогда
	
		ДвиженияПоРегистрамУпр(СтруктураШапкиДокумента, Отказ, Заголовок);	
		
	Иначе	
		
		ДвиженияПоРегистрамРегл(СтруктураШапкиДокумента, Отказ, Заголовок)
	
	КонецЕсли;
	
КонецПроцедуры

Процедура ДвиженияПоРегистрамУпр(СтруктураШапкиДокумента, Отказ, Заголовок)
	
	СтруктураДопПараметров = Новый Структура;
	СтруктураДопПараметров.Вставить("СпособРасчетаСебестоимостиПроизводства", "");
	СтруктураДопПараметров.Вставить("РасчетПрямыхЗатратНомер", "");
	
	ЗаписьРасчетаСебестоимости = Движения.РасчетСебестоимостиПродукцииУправленческийУчет.ВыгрузитьКолонки();
	ЗаписьРасчетаСебестоимости.Колонки.Добавить("ДокументВыпуска"); 
	СтруктураДопПараметров.Вставить("ЗаписьРасчетаСебестоимости", ЗаписьРасчетаСебестоимости);
	ЗаписьРасчетаРаспределенияКосвенныхРасходов = Движения.РасчетРаспределенияКосвенныхРасходовУправленческийУчет.ВыгрузитьКолонки();
	СтруктураДопПараметров.Вставить("ЗаписьРасчетаКосвенныхРасходов", ЗаписьРасчетаРаспределенияКосвенныхРасходов);
	
	//РАСПРЕДЕЛЕНИЕ ТЗР УУ
	РаспределениеТЗРУпр(СтруктураШапкиДокумента);   
	
	// КОРРЕКТИРОВКА СТОИМОСТИ НОМЕНКЛАТУРЫ
	КорректировкаСтоимостиНоменклатурыУпр(СтруктураШапкиДокумента, Отказ, Заголовок);
	
	// АМОРТИЗАЦИЯ
	// Начисление амортизации ОС
	НачислениеАмортизацииОСУпр(СтруктураШапкиДокумента, Отказ, Заголовок);
	
	// Начисление амортизации НМА
	НачислениеАмортизацииНМАУпр(СтруктураШапкиДокумента, Отказ, Заголовок);
	
	// ПЕРЕОЦЕНКА
	ПереоценкаВалютныхСредствУпр(СтруктураШапкиДокумента, Отказ, Заголовок);
	
	// ПРОИЗВОДСТВО УУ
	РасчетСебестоимостиПродукцииУпр(СтруктураШапкиДокумента, СтруктураДопПараметров, Отказ, Заголовок);

	// Списание торговой наценки из СНТТ
	РасчетТорговойНаценкиПоПроданнымТоварамУУ(СтруктураШапкиДокумента, Отказ, Заголовок);
	
КонецПроцедуры

Процедура ДвиженияПоРегистрамРегл(СтруктураШапкиДокумента, Отказ, Заголовок)
	
	СтруктураДопПараметров = Новый Структура;
	СтруктураДопПараметров.Вставить("СпособРасчетаСебестоимостиПроизводства", "");
	СтруктураДопПараметров.Вставить("РасчетПрямыхЗатратНомер", "");
	
	ЗаписьРасчетаСебестоимости = Движения.РасчетСебестоимостиПродукцици.ВыгрузитьКолонки();
	ЗаписьРасчетаСебестоимости.Колонки.Добавить("ДокументВыпуска"); 
	СтруктураДопПараметров.Вставить("ЗаписьРасчетаСебестоимости", ЗаписьРасчетаСебестоимости);
	ЗаписьРасчетаРаспределенияКосвенныхРасходов = Движения.РасчетРаспределенияКосвенныхРасходов.ВыгрузитьКолонки();
	СтруктураДопПараметров.Вставить("ЗаписьРасчетаКосвенныхРасходов", ЗаписьРасчетаРаспределенияКосвенныхРасходов);
	
	РаспределениеТЗР(СтруктураШапкиДокумента, Отказ, Заголовок); 
	
	// АМОРТИЗАЦИЯ
	// Начисление амортизации ОС
	НачислениеАмортизацииОСРегл(СтруктураШапкиДокумента, Отказ, Заголовок);
	// Начисление амортизации НМА
	НачислениеАмортизацииНМАРегл(СтруктураШапкиДокумента, Отказ, Заголовок);
	
	// ПЕРЕОЦЕНКА
	ПереоценкаВалютныхСредствРегл(СтруктураШапкиДокумента, Отказ, Заголовок);
	
	//// КОРРЕКТИРОВКА СТОИМОСТИ НОМЕНКЛАТУРЫ
	КорректировкаСтоимостиНоменклатурыРегл(СтруктураШапкиДокумента, СтруктураДопПараметров, Отказ, Заголовок);
	
	// СПИСАНИЕ РАСХОДОВ БУДУЩИХ ПЕРИОДОВ
	СписаниеРБП(СтруктураШапкиДокумента, Отказ, Заголовок);
	
	// ПРОИЗВОДСТВО БУ
	РасчетСебестоимостиПродукции(СтруктураШапкиДокумента, СтруктураДопПараметров, Отказ, Заголовок);
	
	// ПЕРЕОЦЕНКА ЗАПАСОВ БУ
	ПереоценкаСтоимостиЗапасовБУ(СтруктураШапкиДокумента, Отказ, Заголовок);
	
	// ТОРГОВЛЯ
	РасчетТорговойНаценкиПоПроданнымТоварамБУ(СтруктураШапкиДокумента, Отказ, Заголовок);
	
	// Закрытие регистров налогового учета (Продажи/ПриобретенияНалоговыйУчет)
	ЗакрытиеРегистровНалоговогоУчета(СтруктураШапкиДокумента, Отказ, Заголовок);
	
	// Расчет налоговых разниц после перехода с ЕН
	ФормированиеНалоговыхРазниц(СтруктураШапкиДокумента, Отказ, Заголовок);
	
КонецПроцедуры

// ПРОЦЕДУРЫ И ФУНКЦИИ ПО РАСПРЕДЕЛЕНИЮ ТЗР 

// Распределение ТЗР Управленческий учет

Процедура ДосписатьТЗРПоНаправлениюИспользования(СтруктураШапкиДокумента, НаправлениеИспользования, СтрокаВыборкиЗатраты, СтрокаВыборкиПартии, Сумма, Сумма_НДС)    	
	
	Если НаправлениеИспользования = "" Тогда
		Возврат;
	КонецЕсли; 
	
	НаборЗаписейЗатраты = Движения.Затраты;
	
	НоваяСтрока = НаборЗаписейЗатраты.Добавить();
	НоваяСтрока.Активность = Истина;
	НоваяСтрока.ВидДвижения = ВидДвиженияНакопления.Расход;
	НоваяСтрока.Период = Дата;
	
	НоваяСтрока.Подразделение = СтрокаВыборкиЗатраты.Подразделение;
	НоваяСтрока.СтатьяЗатрат = СтрокаВыборкиЗатраты.СтатьяЗатрат;
    НоваяСтрока.НоменклатурнаяГруппа = СтрокаВыборкиЗатраты.НоменклатурнаяГруппа; 	 		
		
	НоваяСтрока.Сумма = Сумма;  
	НоваяСтрока.НДС = Сумма_НДС;
		
	// Если в наборе записей 1000 строк, запишем набор.
	Если НаборЗаписейЗатраты.Количество() = 1000 Тогда
		НаборЗаписейЗатраты.Записать(Ложь);
	КонецЕсли;   	
	
	// движения по регистрам в зависимости от направления использования
	Если НаправлениеИспользования = "НЗП" Тогда 		
		НаборЗаписейНезавершенноеПроизводство = Движения.НезавершенноеПроизводство;
		
		НоваяСтрока = НаборЗаписейНезавершенноеПроизводство.Добавить();
		НоваяСтрока.Активность = Истина;
		НоваяСтрока.ВидДвижения = ВидДвиженияНакопления.Приход;
		НоваяСтрока.Период = Дата;   	
		
		НоваяСтрока.Подразделение        = СтрокаВыборкиПартии.Подразделение;
		НоваяСтрока.НоменклатурнаяГруппа = СтрокаВыборкиПартии.НоменклатурнаяГруппаЗатрат;
		
		НоваяСтрока.Стоимость = Сумма;
		НоваяСтрока.НДС = Сумма_НДС;
		
		НоваяСтрока.КодОперации = Перечисления.КодыОперацийНезавершенноеПроизводство.СписаниеПартийВПроизводствоОперативно; 
		НоваяСтрока.СтатьяЗатрат         = СтрокаВыборкиПартии.СтатьяЗатрат;
		НоваяСтрока.Заказ                = СтрокаВыборкиПартии.Заказ;
		
		НоваяСтрока.НоменклатураЗатрат   = СтрокаВыборкиПартии.Номенклатура;
		НоваяСтрока.НоменклатураЗатратКоличество = 0;
				
		// Если в наборе записей 1000 строк, запишем набор.
		Если НаборЗаписейНезавершенноеПроизводство.Количество() = 1000 Тогда
			НаборЗаписейНезавершенноеПроизводство.Записать(Ложь);
		КонецЕсли; 
		
	ИначеЕсли НаправлениеИспользования = "Затраты" Тогда
		
		НоваяСтрока = НаборЗаписейЗатраты.Добавить();
		НоваяСтрока.Активность = Истина;
		НоваяСтрока.ВидДвижения = ВидДвиженияНакопления.Приход;
		НоваяСтрока.Период = Дата;
		
		НоваяСтрока.Подразделение        = СтрокаВыборкиПартии.Подразделение;
		НоваяСтрока.НоменклатурнаяГруппа = СтрокаВыборкиПартии.НоменклатурнаяГруппаЗатрат;
		НоваяСтрока.СтатьяЗатрат         = СтрокаВыборкиПартии.СтатьяЗатрат;   
		
		НоваяСтрока.Сумма = Сумма;
		НоваяСтрока.НДС = Сумма_НДС;
		
		//Если в наборе записей 1000 строк, запишем набор.
		Если НаборЗаписейЗатраты.Количество() = 1000 Тогда
			НаборЗаписейЗатраты.Записать(Ложь);
		КонецЕсли;     	
		
	ИначеЕсли НаправлениеИспользования = "ЗатратыОС" Тогда 	
		
		НоваяСтрока = Движения.СтроительствоОбъектовОсновныхСредств.Добавить();
		НоваяСтрока.Активность = Истина;
		НоваяСтрока.ВидДвижения = ВидДвиженияНакопления.Приход;
		НоваяСтрока.Период = Дата;
		
		НоваяСтрока.ОбъектСтроительства = СтрокаВыборкиПартии.ОбъектСтроительства;
		НоваяСтрока.Сумма = Сумма;				
			
		// Если в наборе записей 1000 строк, запишем набор.
		Если Движения.СтроительствоОбъектовОсновныхСредств.Количество() = 1000 Тогда
			Движения.СтроительствоОбъектовОсновныхСредств.Записать(Ложь);
		КонецЕсли;		
			
	ИначеЕсли НаправлениеИспользования = "Брак" Тогда
		
		НаборЗаписейБракВПроизводстве = Движения.БракВПроизводстве;
		
		НоваяСтрока = НаборЗаписейБракВПроизводстве.Добавить();
		НоваяСтрока.Активность = Истина;
		НоваяСтрока.ВидДвижения = ВидДвиженияНакопления.Приход;
		НоваяСтрока.Период = Дата;
		
		НоваяСтрока.Подразделение        = СтрокаВыборкиПартии.Подразделение;
		НоваяСтрока.НоменклатурнаяГруппа = СтрокаВыборкиПартии.НоменклатурнаяГруппаЗатрат;
		НоваяСтрока.СтатьяЗатрат         = СтрокаВыборкиПартии.СтатьяЗатрат;
			
		НоваяСтрока.КодОперации = Перечисления.КодыОперацийБракВПроизводстве.СписаниеПартийВПроизводствоОперативно;
		
		НоваяСтрока.Сумма = Сумма;
		НоваяСтрока.НДС   = Сумма_НДС;

		
		// Если в наборе записей 1000 строк, запишем набор.
		Если Движения.БракВПроизводстве.Количество() = 1000 Тогда
			Движения.БракВПроизводстве.Записать(Ложь);
		КонецЕсли;
		
	ИначеЕсли НаправлениеИспользования = "Себестоимость" Тогда  					
		
		НоваяСтрока = Движения.ПродажиСебестоимость.Добавить();
		НоваяСтрока.Активность = Истина;
		НоваяСтрока.Период = Дата;
		
		НоваяСтрока.Номенклатура = СтрокаВыборкиПартии.Номенклатура;
		НоваяСтрока.ХарактеристикаНоменклатуры = СтрокаВыборкиПартии.ХарактеристикаНоменклатуры;
		НоваяСтрока.ЗаказПокупателя = СтрокаВыборкиПартии.Заказ;
		НоваяСтрока.ДокументОприходования = СтрокаВыборкиПартии.ДокументОприходования;
		НоваяСтрока.Подразделение = СтрокаВыборкиПартии.Подразделение;
		
		НоваяСтрока.Стоимость = Сумма;
		НоваяСтрока.НДС = Сумма_НДС; 
		
	 	НоваяСтрока.ДокументДвижения = СтрокаВыборкиПартии.Регистратор;
		НоваяСтрока.ДокументДвиженияПериод = СтрокаВыборкиПартии.РегистраторДата;
		НоваяСтрока.СписаниеПартий = Истина;
						
		// Если в наборе записей 1000 строк, запишем набор.
		Если Движения.ПродажиСебестоимость.Количество() = 1000 Тогда
			Движения.ПродажиСебестоимость.Записать(Ложь);
		КонецЕсли;  
		
	КонецЕсли;  
	
КонецПроцедуры // ДосписатьТЗРПоНаправлениюИспользования()
 
// Процедура распределения транспортно-заготовительных расходов 
//
//  СтруктураШапкиДокумента – Структура – Реквизиты документа "Закрытие месяца"
Процедура РаспределениеТЗРУпр(СтруктураШапкиДокумента) 
	
	Если СтруктураШапкиДокумента.РаспределениеТЗРУУ Тогда
		
		ЗапросПоЗатратам = СформироватьЗапросПоТЗР(СтруктураШапкиДокумента);
			
		ЗапросПоПартиям = СформироватьЗапросПоПартиямТоваров(СтруктураШапкиДокумента);
			
		ЗапросПоНачальнымОстаткам = СформироватьЗапросПоНачальнымОстаткамПартийТоваров(СтруктураШапкиДокумента);
			
		
		Если глЗначениеПеременной("ИспользоватьУправляемыеБлокировки") Тогда
			СтруктураПараметров = Новый Структура("ТипТаблицы, ИмяТаблицы", "РегистрНакопления", "Затраты");
			
			ЗначенияБлокировки = Новый Соответствие;
			ЗначенияБлокировки.Вставить("Период",      Новый Диапазон(, мКонМесяца)); 
			ОбщегоНазначения.УстановитьУправляемуюБлокировку(СтруктураПараметров, ЗначенияБлокировки);
		КонецЕсли;
		
		РезультатЗапросаПоЗатратам = ЗапросПоЗатратам.Выполнить();
		
		// ограничиваем запросы по партиям и нач. остаткам теми группами, для которых существуют ТЗР к распределению
		МассивНоменклатурныеГруппы = РезультатЗапросаПоЗатратам.Выгрузить().ВыгрузитьКолонку("НоменклатурнаяГруппа");
		ЗапросПоПартиям.УстановитьПараметр("НоменклатурныеГруппыЗатрат", МассивНоменклатурныеГруппы);
		ЗапросПоНачальнымОстаткам.УстановитьПараметр("НоменклатурныеГруппыЗатрат", МассивНоменклатурныеГруппы);

		РезультатЗапросаПоПартиям = ЗапросПоПартиям.Выполнить();
		
		РезультатЗапросаПоНачальнымОстаткам = ЗапросПоНачальнымОстаткам.Выполнить();
		
		
		Если РезультатЗапросаПоЗатратам.Пустой() // ТЗР не было
			ИЛИ РезультатЗапросаПоПартиям.Пустой() Тогда // списания партий не было
			Возврат;  
		КонецЕсли;     	
			
		// Получим построитель запроса по партиям товаров
		ПостроительЗапроса = ПолучитьПостроительЗапроса(СтруктураШапкиДокумента, РезультатЗапросаПоПартиям);
			
		// Получим построитель запроса по начальным остаткам 
		ПостроительЗапросаНачОст = ПолучитьПостроительЗапроса(СтруктураШапкиДокумента, РезультатЗапросаПоНачальнымОстаткам);
			
				
		МассивКоэфСуммаНЗП        = Новый Массив;	
		МассивКоэфСуммаЗатраты    = Новый Массив;	
		МассивКоэфСуммаБрак       = Новый Массив;	
		МассивКоэфСуммаЗатратыОС  = Новый Массив;	
		МассивКоэфСуммаРеализация = Новый Массив;  
		
		МассивКоэфСуммаНЗП_НДС        = Новый Массив;	
		МассивКоэфСуммаЗатраты_НДС    = Новый Массив;	
		МассивКоэфСуммаБрак_НДС       = Новый Массив;	
		МассивКоэфСуммаЗатратыОС_НДС  = Новый Массив;	
		МассивКоэфСуммаРеализация_НДС = Новый Массив;  
		
		ВыборкаПоЗатратам = РезультатЗапросаПоЗатратам.Выбрать();
		Пока ВыборкаПоЗатратам.Следующий() Цикл
			// Отберем строки партий товаров 
			УстановленНовыйОтбор = ПроверитьИУстановитьОтборПостроителяЗапроса(
				ВыборкаПоЗатратам.НоменклатурнаяГруппа, 	
				ПостроительЗапроса); 

			Если УстановленНовыйОтбор Тогда	
				ПостроительЗапроса.Выполнить();
			КонецЕсли;	
			
			РезультатЗапросаПоПартиямТоваров = ПостроительЗапроса.Результат;
						
			МассивКоэфСуммаНЗП.Очистить();
			МассивКоэфСуммаЗатраты.Очистить();
			МассивКоэфСуммаЗатратыОС.Очистить();
			МассивКоэфСуммаБрак.Очистить();
			МассивКоэфСуммаРеализация.Очистить(); 	
			
			МассивКоэфСуммаНЗП_НДС.Очистить();
			МассивКоэфСуммаЗатраты_НДС.Очистить();
			МассивКоэфСуммаЗатратыОС_НДС.Очистить();
			МассивКоэфСуммаБрак_НДС.Очистить();
			МассивКоэфСуммаРеализация_НДС.Очистить(); 
			
			ОбщаяСуммаПоступление = 0;
			ОбщаяСуммаНЗП = 0;
			ОбщаяСуммаЗатраты = 0;
			ОбщаяСуммаБрак = 0;
			ОбщаяСуммаЗатратыОС = 0;
			ОбщаяСуммаРеализация = 0;
			СуммаНачальныйОстаток = 0; 		
			
			ОбщаяСуммаПоступление_НДС = 0;
			ОбщаяСуммаНЗП_НДС = 0;
			ОбщаяСуммаЗатраты_НДС = 0;
			ОбщаяСуммаБрак_НДС = 0;
			ОбщаяСуммаЗатратыОС_НДС = 0;
			ОбщаяСуммаРеализация_НДС = 0;
			СуммаНачальныйОстаток_НДС = 0;   
			
			ВыборкаПартии = РезультатЗапросаПоПартиямТоваров.Выбрать();
			Пока ВыборкаПартии.Следующий() Цикл
				
				МассивКоэфСуммаНЗП.Добавить(ВыборкаПартии.СуммаНЗП);
				МассивКоэфСуммаЗатраты.Добавить(ВыборкаПартии.СуммаЗатраты);
				МассивКоэфСуммаБрак.Добавить(ВыборкаПартии.СуммаБрак);
				МассивКоэфСуммаЗатратыОС.Добавить(ВыборкаПартии.СуммаЗатратыОС);
				МассивКоэфСуммаРеализация.Добавить(ВыборкаПартии.СуммаРеализация - ВыборкаПартии.СуммаВозвратЭтогоМесяца);
				
				МассивКоэфСуммаНЗП_НДС.Добавить(ВыборкаПартии.СуммаНЗП_НДС);
				МассивКоэфСуммаЗатраты_НДС.Добавить(ВыборкаПартии.СуммаЗатраты_НДС);
				МассивКоэфСуммаБрак_НДС.Добавить(ВыборкаПартии.СуммаБрак_НДС);
				МассивКоэфСуммаЗатратыОС_НДС.Добавить(ВыборкаПартии.СуммаЗатратыОС_НДС);
				МассивКоэфСуммаРеализация_НДС.Добавить(ВыборкаПартии.СуммаРеализация_НДС - ВыборкаПартии.СуммаВозвратЭтогоМесяца_НДС);
				
				ОбщаяСуммаНЗП        = ОбщаяСуммаНЗП + ВыборкаПартии.СуммаНЗП;
				ОбщаяСуммаЗатраты    = ОбщаяСуммаЗатраты + ВыборкаПартии.СуммаЗатраты;
				ОбщаяСуммаБрак       = ОбщаяСуммаБрак + ВыборкаПартии.СуммаБрак;
				ОбщаяСуммаЗатратыОС  = ОбщаяСуммаЗатратыОС + ВыборкаПартии.СуммаЗатратыОС;
				ОбщаяСуммаРеализация = ОбщаяСуммаРеализация + ВыборкаПартии.СуммаРеализация - ВыборкаПартии.СуммаВозвратЭтогоМесяца;
				
	            ОбщаяСуммаПоступление = ОбщаяСуммаПоступление + ВыборкаПартии.СуммаПоступление - ВыборкаПартии.СуммаВозвратЭтогоМесяца - ВыборкаПартии.СуммаВозвратПоставщику;
				
				ОбщаяСуммаНЗП_НДС        = ОбщаяСуммаНЗП_НДС + ВыборкаПартии.СуммаНЗП_НДС;
				ОбщаяСуммаЗатраты_НДС    = ОбщаяСуммаЗатраты_НДС + ВыборкаПартии.СуммаЗатраты_НДС;
				ОбщаяСуммаБрак_НДС       = ОбщаяСуммаБрак_НДС + ВыборкаПартии.СуммаБрак_НДС;
				ОбщаяСуммаЗатратыОС_НДС  = ОбщаяСуммаЗатратыОС_НДС + ВыборкаПартии.СуммаЗатратыОС_НДС;
				ОбщаяСуммаРеализация_НДС = ОбщаяСуммаРеализация_НДС + ВыборкаПартии.СуммаРеализация_НДС - ВыборкаПартии.СуммаВозвратЭтогоМесяца_НДС;
				
				ОбщаяСуммаПоступление_НДС = ОбщаяСуммаПоступление_НДС + ВыборкаПартии.СуммаПоступление_НДС - ВыборкаПартии.СуммаВозвратЭтогоМесяца_НДС  - ВыборкаПартии.СуммаВозвратПоставщику_НДС;
				
			КонецЦикла;
			
			// Отберем строку начальных остатков
	   		УстановленНовыйОтбор = ПроверитьИУстановитьОтборПостроителяЗапроса(ВыборкаПоЗатратам.НоменклатурнаяГруппа, ПостроительЗапросаНачОст);

			Если УстановленНовыйОтбор Тогда	
				ПостроительЗапросаНачОст.Выполнить();
			КонецЕсли;	
			
			РезультатЗапросаПоНачальнымОстаткам = ПостроительЗапросаНачОст.Результат;
			
			СуммаНачальныйОстаток  = 0;
			СуммаНачальныйОстаток_НДС  = 0;
		
			ВыборкаНачОст = РезультатЗапросаПоНачальнымОстаткам.Выбрать();
			Если ВыборкаНачОст.Следующий() Тогда // может быть только одна или 0 строк для ном. группы
				СуммаНачальныйОстаток  = ?(ВыборкаНачОст.СуммаНачальныйОстаток = NULL, 0, ВыборкаНачОст.СуммаНачальныйОстаток);
				СуммаНачальныйОстаток_НДС  = ?(ВыборкаНачОст.СуммаНачальныйОстаток_НДС = NULL, 0, ВыборкаНачОст.СуммаНачальныйОстаток_НДС);
	      	КонецЕсли;		
					
			СписаноВсегоСумма = ОбщаяСуммаНЗП + ОбщаяСуммаЗатраты + ОбщаяСуммаБрак + ОбщаяСуммаЗатратыОС + ОбщаяСуммаРеализация;
			СписаноВсегоСумма_НДС = ОбщаяСуммаНЗП_НДС + ОбщаяСуммаЗатраты_НДС + ОбщаяСуммаБрак_НДС + ОбщаяСуммаЗатратыОС_НДС + ОбщаяСуммаРеализация_НДС;
			
			КоэфТЗРСумма = ?(ОбщаяСуммаПоступление + СуммаНачальныйОстаток = 0, 0, СписаноВсегоСумма/(ОбщаяСуммаПоступление + СуммаНачальныйОстаток));
			КоэфТЗРСумма_НДС = ?(ОбщаяСуммаПоступление_НДС + СуммаНачальныйОстаток_НДС = 0, 0, СписаноВсегоСумма_НДС/(ОбщаяСуммаПоступление_НДС + СуммаНачальныйОстаток_НДС));
	        					
			СуммаТЗР = Окр(ВыборкаПоЗатратам.СуммаОстаток * КоэфТЗРСумма, 2);
			СуммаТЗР_НДС = Окр(ВыборкаПоЗатратам.СуммаОстаток_НДС * КоэфТЗРСумма_НДС, 2);
			
			Если СуммаТЗР = 0 И СуммаТЗР_НДС = 0 Тогда
				// нечего распределять
				Продолжить;
			КонецЕсли; 
			
			СуммаНЗП = ?(СписаноВсегоСумма = 0, 0, Окр(СуммаТЗР * ОбщаяСуммаНЗП / СписаноВсегоСумма, 2));
			СуммаЗатраты = ?(СписаноВсегоСумма = 0, 0, Окр(СуммаТЗР * ОбщаяСуммаЗатраты / СписаноВсегоСумма, 2));
			СуммаБрак = ?(СписаноВсегоСумма = 0, 0, Окр(СуммаТЗР * ОбщаяСуммаБрак / СписаноВсегоСумма, 2));
			СуммаЗатратыОС = ?(СписаноВсегоСумма = 0, 0, Окр(СуммаТЗР * ОбщаяСуммаЗатратыОС / СписаноВсегоСумма, 2));
			СуммаРеализация = СуммаТЗР - СуммаНЗП - СуммаЗатраты - СуммаБрак - СуммаЗатратыОС;
			
			СуммаНЗП_НДС = ?(СписаноВсегоСумма_НДС = 0, 0, Окр(СуммаТЗР_НДС * ОбщаяСуммаНЗП_НДС / СписаноВсегоСумма_НДС, 2));
			СуммаЗатраты_НДС = ?(СписаноВсегоСумма_НДС = 0, 0, Окр(СуммаТЗР_НДС * ОбщаяСуммаЗатраты_НДС / СписаноВсегоСумма_НДС, 2));
			СуммаБрак_НДС = ?(СписаноВсегоСумма_НДС = 0, 0, Окр(СуммаТЗР_НДС * ОбщаяСуммаБрак_НДС / СписаноВсегоСумма_НДС, 2));
			СуммаЗатратыОС_НДС = ?(СписаноВсегоСумма_НДС = 0, 0, Окр(СуммаТЗР_НДС * ОбщаяСуммаЗатратыОС_НДС / СписаноВсегоСумма_НДС, 2));
			СуммаРеализация_НДС = СуммаТЗР_НДС - СуммаНЗП_НДС - СуммаЗатраты_НДС - СуммаБрак_НДС - СуммаЗатратыОС_НДС;
	        		
			МассивСуммаНЗП         = ПолучитьМассивРаспределеннойСуммы(СуммаНЗП, МассивКоэфСуммаНЗП, 2);
			МассивСуммаЗатраты     = ПолучитьМассивРаспределеннойСуммы(СуммаЗатраты, МассивКоэфСуммаЗатраты, 2);
			МассивСуммаБрак        = ПолучитьМассивРаспределеннойСуммы(СуммаБрак, МассивКоэфСуммаБрак, 2);
			МассивСуммаЗатратыОС   = ПолучитьМассивРаспределеннойСуммы(СуммаЗатратыОС, МассивКоэфСуммаЗатратыОС, 2);
			МассивСуммаРеализация  = ПолучитьМассивРаспределеннойСуммы(СуммаРеализация, МассивКоэфСуммаРеализация, 2);
			
			МассивСуммаНЗП_НДС         = ПолучитьМассивРаспределеннойСуммы(СуммаНЗП_НДС, МассивКоэфСуммаНЗП_НДС, 2);
			МассивСуммаЗатраты_НДС     = ПолучитьМассивРаспределеннойСуммы(СуммаЗатраты_НДС, МассивКоэфСуммаЗатраты_НДС, 2);
			МассивСуммаБрак_НДС        = ПолучитьМассивРаспределеннойСуммы(СуммаБрак_НДС, МассивКоэфСуммаБрак_НДС, 2);
			МассивСуммаЗатратыОС_НДС   = ПолучитьМассивРаспределеннойСуммы(СуммаЗатратыОС_НДС, МассивКоэфСуммаЗатратыОС_НДС, 2);
			МассивСуммаРеализация_НДС  = ПолучитьМассивРаспределеннойСуммы(СуммаРеализация_НДС, МассивКоэфСуммаРеализация_НДС, 2);
							
			Индекс = 0;
			ВыборкаПартии.Сбросить();
			Пока ВыборкаПартии.Следующий() Цикл
				
				ДосписаниеСуммаНЗП = МассивСуммаНЗП[Индекс];
				ДосписаниеСуммаЗатраты = МассивСуммаЗатраты[Индекс];
				ДосписаниеСуммаБрак = МассивСуммаБрак[Индекс];
				ДосписаниеСуммаЗатратыОС = МассивСуммаЗатратыОС[Индекс];
				ДосписаниеСуммаРеализация = МассивСуммаРеализация[Индекс];
				
				ДосписаниеСуммаНЗП_НДС = МассивСуммаНЗП_НДС[Индекс];
				ДосписаниеСуммаЗатраты_НДС = МассивСуммаЗатраты_НДС[Индекс];
				ДосписаниеСуммаБрак_НДС = МассивСуммаБрак_НДС[Индекс];
				ДосписаниеСуммаЗатратыОС_НДС = МассивСуммаЗатратыОС_НДС[Индекс];
				ДосписаниеСуммаРеализация_НДС = МассивСуммаРеализация_НДС[Индекс]; 
				
				НаправлениеИспользования = "";
				Сумма = 0;
				Сумма_НДС = 0;
				
				Если ДосписаниеСуммаНЗП <> 0 Тогда
					НаправлениеИспользования = "НЗП";
					Сумма = ДосписаниеСуммаНЗП;
					Сумма_НДС = ДосписаниеСуммаНЗП_НДС; 
				ИначеЕсли ДосписаниеСуммаЗатраты <> 0 Тогда
					НаправлениеИспользования = "Затраты";
					Сумма = ДосписаниеСуммаЗатраты;
					Сумма_НДС = ДосписаниеСуммаЗатраты_НДС;
				ИначеЕсли ДосписаниеСуммаБрак <> 0 Тогда
					НаправлениеИспользования = "Брак";
					Сумма = ДосписаниеСуммаБрак;
					Сумма_НДС = ДосписаниеСуммаБрак_НДС;
				ИначеЕсли ДосписаниеСуммаЗатратыОС <> 0 Тогда
					НаправлениеИспользования = "ЗатратыОС";
					Сумма = ДосписаниеСуммаЗатратыОС;
					Сумма_НДС = ДосписаниеСуммаЗатратыОС_НДС;
				ИначеЕсли ДосписаниеСуммаРеализация <> 0 Тогда
					НаправлениеИспользования = "Себестоимость";
					Сумма = ДосписаниеСуммаРеализация;
					Сумма_НДС = ДосписаниеСуммаРеализация_НДС;
				КонецЕсли; 
				
				ДосписатьТЗРПоНаправлениюИспользования(
					СтруктураШапкиДокумента,
					НаправлениеИспользования,
					ВыборкаПоЗатратам,
					ВыборкаПартии,
					Сумма, 
					Сумма_НДС);
				
				Индекс = Индекс + 1;        			
			КонецЦикла; 		
		КонецЦикла;	
		
		Если Движения.Затраты.Модифицированность() Тогда
			Движения.Затраты.Записать(Ложь);
		КонецЕсли;
		
		Если Движения.НезавершенноеПроизводство.Модифицированность() Тогда
			Движения.НезавершенноеПроизводство.Записать(Ложь);
		КонецЕсли;
		
		Если Движения.БракВПроизводстве.Модифицированность() Тогда
			Движения.БракВПроизводстве.Записать(Ложь);
		КонецЕсли;     
		
		Если Движения.ПродажиСебестоимость.Модифицированность() Тогда
			Движения.ПродажиСебестоимость.Записать(Ложь);
		КонецЕсли;
		
		Если Движения.СтроительствоОбъектовОсновныхСредств.Модифицированность() Тогда
			Движения.СтроительствоОбъектовОсновныхСредств.Записать(Ложь);
		КонецЕсли;   
		
	КонецЕсли;
	
КонецПроцедуры // РаспределениеТранспортноЗаготовительныхРасходов()

// Функция выполняет пропорциональное распределение суммы в соответствии
// с заданными коэффициентами распределения
//
// Параметры:
//		ИсхСумма - распределяемая сумма
//		МассивКоэф - массив коэффициентов распределения
//		Точность - точность округления при распределении. Необязателен.
//
//	Возврат:
//		МассивСумм - массив размерностью равный массиву коэффициентов, содержит
//			суммы в соответствии с весом коэффициента (из массива коэффициентов)
//          В случае если распределить не удалось (сумма = 0, кол-во коэф. = 0,
//          или суммарный вес коэф. = 0), тогда возвращается значение Неопределено
//
Функция ПолучитьМассивРаспределеннойСуммы(Сумма, МассивКоэф, Знач Точность = 2)
	
	ИсходнаяСумма = Сумма;

	СуммаКоэф = 0;
	Для Каждого Коэффициент Из МассивКоэф Цикл
		СуммаКоэф = СуммаКоэф + Коэффициент;
	КонецЦикла;
	
	МассивСумм = Новый Массив();
	
	Для Каждого Коэффициент Из МассивКоэф Цикл
		СуммаПоКоэффициенту = ?(СуммаКоэф <> 0, Окр(ИсходнаяСумма * Коэффициент / СуммаКоэф, Точность, 1), 0);
		МассивСумм.Добавить(СуммаПоКоэффициенту);
		
		ИсходнаяСумма = ИсходнаяСумма - СуммаПоКоэффициенту;
		СуммаКоэф = СуммаКоэф - Коэффициент;
	КонецЦикла;

	Возврат МассивСумм;

КонецФункции // ПолучитьМассивРаспределеннойСуммы()

Функция ПолучитьПостроительЗапроса(СтруктураШапкиДокумента,	РезультатЗапроса)
	
	ПостроительЗапроса = Новый ПостроительЗапроса();
	ПостроительЗапроса.ИсточникДанных = Новый ОписаниеИсточникаДанных(РезультатЗапроса);
	ПостроительЗапроса.Отбор.Добавить("НоменклатурнаяГруппа");
	
	ПостроительЗапроса.Отбор.НоменклатурнаяГруппа.Использование = Истина;
	ПостроительЗапроса.Отбор.НоменклатурнаяГруппа.ВидСравнения = ВидСравнения.Равно;  
	
	Возврат ПостроительЗапроса;   
	
КонецФункции // ПолучитьПостроительЗапросаПоПартиямТоваров()

Функция ПроверитьИУстановитьОтборПостроителяЗапроса(НоменклатурнаяГруппа, ПостроительЗапроса)
	
	ОтборСоответствуетАналитике = Ложь;
	Если ПостроительЗапроса.Отбор.НоменклатурнаяГруппа.Значение = НоменклатурнаяГруппа
	Тогда
		ОтборСоответствуетАналитике = Истина;
	КонецЕсли;
			
	Если Не ОтборСоответствуетАналитике Тогда
		ПостроительЗапроса.Отбор.НоменклатурнаяГруппа.Значение = НоменклатурнаяГруппа;
	КонецЕсли;
	
	Возврат Не ОтборСоответствуетАналитике;

КонецФункции // ПроверитьИУстановитьОтборПостроителяЗапросаПоНачальнымОстаткам()

Функция СформироватьЗапросПоТЗР(СтруктураШапкиДокумента)
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Затраты.Подразделение КАК Подразделение,
	|	Затраты.СтатьяЗатрат КАК СтатьяЗатрат,
	|	Затраты.НоменклатурнаяГруппа КАК НоменклатурнаяГруппа,
	|	СУММА(Затраты.СуммаОстаток) КАК СуммаОстаток,
	|	СУММА(Затраты.НДСОстаток) КАК СуммаОстаток_НДС
	|ИЗ
	|	РегистрНакопления.Затраты.Остатки(&КонГраница, СтатьяЗатрат.ХарактерЗатрат = ЗНАЧЕНИЕ(Перечисление.ХарактерЗатрат.ТранспортноЗаготовительныеРасходы)) КАК Затраты
	|
	|СГРУППИРОВАТЬ ПО
	|	Затраты.НоменклатурнаяГруппа,
	|	Затраты.Подразделение,
	|	Затраты.СтатьяЗатрат
	|
	|УПОРЯДОЧИТЬ ПО
	|	НоменклатурнаяГруппа,
	|	Подразделение,
	|	СтатьяЗатрат"; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("КонГраница", мКонГраница);  			
	Возврат Запрос;

КонецФункции // СформироватьЗапросПоТЗР()

Функция СформироватьЗапросПоПартиямТоваров(СтруктураШапкиДокумента)

	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ПартииТоваровНаСкладах.Номенклатура.НоменклатурнаяГруппа КАК НоменклатурнаяГруппа,
	|	ПартииТоваровНаСкладах.Номенклатура КАК Номенклатура,
	|	ПартииТоваровНаСкладах.КодОперации КАК КодОперации,
	|	ПартииТоваровНаСкладах.ДокументОприходования КАК ДокументОприходования,
	|	ПартииТоваровНаСкладах.ДокументДвижения КАК ДокументДвижения,
	|	ПартииТоваровНаСкладах.ДокументДвиженияПериод КАК ДокументДвиженияПериод,
	|	ПартииТоваровНаСкладах.Качество КАК Качество,
	|	ВЫБОР
	|		КОГДА ПартииТоваровНаСкладах.КодОперации В (&КодыРеализация)
	|				ИЛИ ПартииТоваровНаСкладах.Регистратор ССЫЛКА Документ.ВозвратТоваровОтПокупателя
	|					И (СписанныеТовары.ДокументПартии.Дата МЕЖДУ &НачМесяца И &КонМесяца)
	|					И ПартииТоваровНаСкладах.ВидДвижения = &ВидДвиженияПриход
	|			ТОГДА ПартииТоваровНаСкладах.Регистратор
	|		ИНАЧЕ NULL
	|	КОНЕЦ КАК Регистратор,
	|	ВЫБОР
	|		КОГДА ПартииТоваровНаСкладах.КодОперации В (&КодыРеализация)
	|				ИЛИ ПартииТоваровНаСкладах.Регистратор ССЫЛКА Документ.ВозвратТоваровОтПокупателя
	|					И (СписанныеТовары.ДокументПартии.Дата МЕЖДУ &НачМесяца И &КонМесяца)
	|					И ПартииТоваровНаСкладах.ВидДвижения = &ВидДвиженияПриход
	|			ТОГДА ПартииТоваровНаСкладах.Регистратор.Дата
	|		ИНАЧЕ NULL
	|	КОНЕЦ КАК РегистраторДата,
	|	СписанныеТовары.СкладПолучатель КАК СкладПолучатель,
	|	СписанныеТовары.Подразделение КАК Подразделение,
	|	СписанныеТовары.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
	|	СписанныеТовары.СерияНоменклатуры КАК СерияНоменклатуры,
	|	СписанныеТовары.СтатьяЗатрат КАК СтатьяЗатрат,
	|	СписанныеТовары.ОбъектСтроительства КАК ОбъектСтроительства,
	|	СписанныеТовары.НоменклатурнаяГруппа КАК НоменклатурнаяГруппаЗатрат,
	|	СписанныеТовары.ЗаказСписания КАК Заказ,
	|	СУММА(ВЫБОР
	|			КОГДА ПартииТоваровНаСкладах.КодОперации В (&КодыПоступление)
	|					И ПартииТоваровНаСкладах.ВидДвижения = &ВидДвиженияПриход
	|				ТОГДА ПартииТоваровНаСкладах.Стоимость
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаПоступление,
	|	СУММА(ВЫБОР
	|			КОГДА ПартииТоваровНаСкладах.КодОперации В (&КодыПоступление)
	|					И ПартииТоваровНаСкладах.ВидДвижения = &ВидДвиженияПриход
	|				ТОГДА ПартииТоваровНаСкладах.НДС
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаПоступление_НДС,
	|	СУММА(ВЫБОР
	|			КОГДА ПартииТоваровНаСкладах.КодОперации В (&КодыНЗП)
	|					И ПартииТоваровНаСкладах.ВидДвижения = &ВидДвиженияРасход
	|				ТОГДА ПартииТоваровНаСкладах.Стоимость
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаНЗП,
	|	СУММА(ВЫБОР
	|			КОГДА ПартииТоваровНаСкладах.КодОперации В (&КодыНЗП)
	|					И ПартииТоваровНаСкладах.ВидДвижения = &ВидДвиженияРасход
	|				ТОГДА ПартииТоваровНаСкладах.НДС
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаНЗП_НДС,
	|	СУММА(ВЫБОР
	|			КОГДА ПартииТоваровНаСкладах.КодОперации В (&КодыЗатраты)
	|					И ПартииТоваровНаСкладах.ВидДвижения = &ВидДвиженияРасход
	|				ТОГДА ПартииТоваровНаСкладах.Стоимость
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаЗатраты,
	|	СУММА(ВЫБОР
	|			КОГДА ПартииТоваровНаСкладах.КодОперации В (&КодыЗатраты)
	|					И ПартииТоваровНаСкладах.ВидДвижения = &ВидДвиженияРасход
	|				ТОГДА ПартииТоваровНаСкладах.НДС
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаЗатраты_НДС,
	|	СУММА(ВЫБОР
	|			КОГДА ПартииТоваровНаСкладах.КодОперации В (&КодыБрак)
	|					И ПартииТоваровНаСкладах.ВидДвижения = &ВидДвиженияРасход
	|				ТОГДА ПартииТоваровНаСкладах.Стоимость
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаБрак,
	|	СУММА(ВЫБОР
	|			КОГДА ПартииТоваровНаСкладах.КодОперации В (&КодыБрак)
	|					И ПартииТоваровНаСкладах.ВидДвижения = &ВидДвиженияРасход
	|				ТОГДА ПартииТоваровНаСкладах.НДС
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаБрак_НДС,
	|	СУММА(ВЫБОР
	|			КОГДА ПартииТоваровНаСкладах.КодОперации В (&КодыЗатратыОС)
	|					И ПартииТоваровНаСкладах.ВидДвижения = &ВидДвиженияРасход
	|				ТОГДА ПартииТоваровНаСкладах.Стоимость
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаЗатратыОС,
	|	СУММА(ВЫБОР
	|			КОГДА ПартииТоваровНаСкладах.КодОперации В (&КодыЗатратыОС)
	|					И ПартииТоваровНаСкладах.ВидДвижения = &ВидДвиженияРасход
	|				ТОГДА ПартииТоваровНаСкладах.НДС
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаЗатратыОС_НДС,
	|	СУММА(ВЫБОР
	|			КОГДА ПартииТоваровНаСкладах.КодОперации В (&КодыРеализация)
	|					И ПартииТоваровНаСкладах.ВидДвижения = &ВидДвиженияРасход
	|				ТОГДА ПартииТоваровНаСкладах.Стоимость
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаРеализация,
	|	СУММА(ВЫБОР
	|			КОГДА ПартииТоваровНаСкладах.КодОперации В (&КодыРеализация)
	|					И ПартииТоваровНаСкладах.ВидДвижения = &ВидДвиженияРасход
	|				ТОГДА ПартииТоваровНаСкладах.НДС
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаРеализация_НДС,
	|	СУММА(ВЫБОР
	|			КОГДА ПартииТоваровНаСкладах.Регистратор ССЫЛКА Документ.ВозвратТоваровОтПокупателя
	|					И (СписанныеТовары.ДокументПартии.Дата МЕЖДУ &НачМесяца И &КонМесяца)
	|					И ПартииТоваровНаСкладах.ВидДвижения = &ВидДвиженияПриход
	|				ТОГДА ПартииТоваровНаСкладах.Стоимость
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаВозвратЭтогоМесяца,
	|	СУММА(ВЫБОР
	|			КОГДА ПартииТоваровНаСкладах.Регистратор ССЫЛКА Документ.ВозвратТоваровОтПокупателя
	|					И (СписанныеТовары.ДокументПартии.Дата МЕЖДУ &НачМесяца И &КонМесяца)
	|					И ПартииТоваровНаСкладах.ВидДвижения = &ВидДвиженияПриход
	|				ТОГДА ПартииТоваровНаСкладах.НДС
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаВозвратЭтогоМесяца_НДС,
	|	СУММА(ВЫБОР
	|			КОГДА ПартииТоваровНаСкладах.КодОперации = ЗНАЧЕНИЕ(Перечисление.КодыОперацийПартииТоваров.ВозвратПоставщику)
	|					И ПартииТоваровНаСкладах.ВидДвижения = &ВидДвиженияРасход
	|				ТОГДА ПартииТоваровНаСкладах.Стоимость
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаВозвратПоставщику,
	|	СУММА(ВЫБОР
	|			КОГДА ПартииТоваровНаСкладах.КодОперации = ЗНАЧЕНИЕ(Перечисление.КодыОперацийПартииТоваров.ВозвратПоставщику)
	|					И ПартииТоваровНаСкладах.ВидДвижения = &ВидДвиженияРасход
	|				ТОГДА ПартииТоваровНаСкладах.НДС
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаВозвратПоставщику_НДС
	|ИЗ
	|	РегистрНакопления.ПартииТоваровНаСкладах КАК ПартииТоваровНаСкладах
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СписанныеТовары КАК СписанныеТовары
	|		ПО ПартииТоваровНаСкладах.Регистратор = СписанныеТовары.Регистратор
	|			И ПартииТоваровНаСкладах.НомерСтрокиСписанныхТоваров = СписанныеТовары.НомерСтроки
	|ГДЕ
	|	ПартииТоваровНаСкладах.Период МЕЖДУ &НачМесяца И &КонМесяца
	|	И ПартииТоваровНаСкладах.Номенклатура.НоменклатурнаяГруппа В(&НоменклатурныеГруппыЗатрат)
	|
	|СГРУППИРОВАТЬ ПО
	|	ПартииТоваровНаСкладах.Номенклатура.НоменклатурнаяГруппа,
	|	ПартииТоваровНаСкладах.Номенклатура,
	|	ПартииТоваровНаСкладах.КодОперации,
	|	ПартииТоваровНаСкладах.ДокументОприходования,
	|	ПартииТоваровНаСкладах.ДокументДвижения,
	|	ПартииТоваровНаСкладах.ДокументДвиженияПериод,
	|	ПартииТоваровНаСкладах.Качество,
	|	ВЫБОР
	|		КОГДА ПартииТоваровНаСкладах.КодОперации В (&КодыРеализация)
	|				ИЛИ ПартииТоваровНаСкладах.Регистратор ССЫЛКА Документ.ВозвратТоваровОтПокупателя
	|					И (СписанныеТовары.ДокументПартии.Дата МЕЖДУ &НачМесяца И &КонМесяца)
	|					И ПартииТоваровНаСкладах.ВидДвижения = &ВидДвиженияПриход
	|			ТОГДА ПартииТоваровНаСкладах.Регистратор
	|		ИНАЧЕ NULL
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ПартииТоваровНаСкладах.КодОперации В (&КодыРеализация)
	|				ИЛИ ПартииТоваровНаСкладах.Регистратор ССЫЛКА Документ.ВозвратТоваровОтПокупателя
	|					И (СписанныеТовары.ДокументПартии.Дата МЕЖДУ &НачМесяца И &КонМесяца)
	|					И ПартииТоваровНаСкладах.ВидДвижения = &ВидДвиженияПриход
	|			ТОГДА ПартииТоваровНаСкладах.Регистратор.Дата
	|		ИНАЧЕ NULL
	|	КОНЕЦ,
	|	СписанныеТовары.СкладПолучатель,
	|	СписанныеТовары.Подразделение,
	|	СписанныеТовары.ХарактеристикаНоменклатуры,
	|	СписанныеТовары.СерияНоменклатуры,
	|	СписанныеТовары.СтатьяЗатрат,
	|	СписанныеТовары.ОбъектСтроительства,
	|	СписанныеТовары.НоменклатурнаяГруппа,
	|	СписанныеТовары.ЗаказСписания
	|
	|УПОРЯДОЧИТЬ ПО
	|	НоменклатурнаяГруппа,
	|	Номенклатура,
	|	ДокументОприходования,
	|	ДокументДвижения,
	|	ДокументДвиженияПериод,
	|	Качество,
	|	РегистраторДата,
	|	КодОперации,
	|	СкладПолучатель,
	|	Подразделение,
	|	ХарактеристикаНоменклатуры,
	|	СерияНоменклатуры,
	|	СтатьяЗатрат,
	|	ОбъектСтроительства,
	|	НоменклатурнаяГруппаЗатрат,
	|	Заказ";    				   
	
	Запрос = Новый Запрос;  	
	Запрос.Текст = ТекстЗапроса;
	
	Запрос.УстановитьПараметр("НачМесяца",    мНачМесяца);
	Запрос.УстановитьПараметр("КонМесяца",    мКонМесяца);

	Запрос.УстановитьПараметр("ВидДвиженияРасход", ВидДвиженияНакопления.Расход);
	Запрос.УстановитьПараметр("ВидДвиженияПриход", ВидДвиженияНакопления.Приход);
	
	КодыПоступление = Новый Массив;
	КодыПоступление.Добавить(Перечисления.КодыОперацийПартииТоваров.Поступление);
	КодыПоступление.Добавить(Перечисления.КодыОперацийПартииТоваров.ПоступлениеДопРасходов);
    КодыПоступление.Добавить(Перечисления.КодыОперацийПартииТоваров.Оприходование);
    КодыПоступление.Добавить(Перечисления.КодыОперацийПартииТоваров.ВозвратОтПокупателя); 
	Запрос.УстановитьПараметр("КодыПоступление", КодыПоступление);
	
	КодыПеремещение = Новый Массив;
	КодыПеремещение.Добавить(Перечисления.КодыОперацийПартииТоваров.ПеремещениеМеждуСкладами);
	Запрос.УстановитьПараметр("КодыПеремещение", КодыПеремещение);
	
	КодыРеализация = Новый Массив;
	КодыРеализация.Добавить(Перечисления.КодыОперацийПартииТоваров.Реализация);
	КодыРеализация.Добавить(Перечисления.КодыОперацийПартииТоваров.РеализацияРозница);
	Запрос.УстановитьПараметр("КодыРеализация", КодыРеализация);
	
	КодыНЗП = Новый Массив;
	КодыНЗП.Добавить(Перечисления.КодыОперацийПартииТоваров.СписаниеПартийВПроизводствоОперативно);
	Запрос.УстановитьПараметр("КодыНЗП", КодыНЗП);
	
	КодыЗатраты = Новый Массив;
	КодыЗатраты.Добавить(Перечисления.КодыОперацийПартииТоваров.СписаниеНаЗатраты);
	Запрос.УстановитьПараметр("КодыЗатраты", КодыЗатраты);
	
	КодыБрак = Новый Массив;
	КодыБрак.Добавить(Перечисления.КодыОперацийПартииТоваров.СписаниеНаБрак);
	Запрос.УстановитьПараметр("КодыБрак", КодыБрак);
	
	КодыЗатратыОС = Новый Массив;
	КодыЗатратыОС.Добавить(Перечисления.КодыОперацийПартииТоваров.СписаниеНаСтроительствоОбъектовОС);
	КодыЗатратыОС.Добавить(Перечисления.КодыОперацийПартииТоваров.СписаниеНаВложенияВоВнеоборотныеАктивы);
	Запрос.УстановитьПараметр("КодыЗатратыОС", КодыЗатратыОС); 														 
															 
	Возврат Запрос;
															   
КонецФункции // СформироватьЗапросПоПартиямТоваров()

Функция СформироватьЗапросПоНачальнымОстаткамПартийТоваров(СтруктураШапкиДокумента)
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ПартииТоваровНаСкладах.Номенклатура.НоменклатурнаяГруппа КАК НоменклатурнаяГруппа,
	|	СУММА(ПартииТоваровНаСкладах.СтоимостьОстаток) КАК СуммаНачальныйОстаток,
	|	СУММА(ПартииТоваровНаСкладах.НДСОстаток) КАК СуммаНачальныйОстаток_НДС
	|ИЗ
	|	РегистрНакопления.ПартииТоваровНаСкладах.Остатки(&НачМесяца, Номенклатура.НоменклатурнаяГруппа В (&НоменклатурныеГруппыЗатрат)) КАК ПартииТоваровНаСкладах
	|
	|СГРУППИРОВАТЬ ПО
	|	ПартииТоваровНаСкладах.Номенклатура.НоменклатурнаяГруппа
	|
	|УПОРЯДОЧИТЬ ПО
	|	НоменклатурнаяГруппа"; 
	
	Запрос = Новый Запрос;  	
	Запрос.Текст = ТекстЗапроса;
	
	Запрос.УстановитьПараметр("НачМесяца", мНачМесяца);
	
	Возврат Запрос;
	
КонецФункции // СформироватьЗапросПоНачальнымОстаткамПартийТоваров()

// Распределение ТЗР Регламентированный учет  

Процедура РаспределениеТЗР(СтруктураШапкиДокумента, Отказ, Заголовок)
	
	Если СтруктураШапкиДокумента.РаспределениеТЗРБУ Тогда 
		РаспределениеТЗРБУ("Товары",    СтруктураШапкиДокумента);
		РаспределениеТЗРБУ("Материалы", СтруктураШапкиДокумента);
		РаспределениеТЗРБУ("РозницаСуммовойУчет", СтруктураШапкиДокумента);
	КонецЕсли;
		
КонецПроцедуры  

Процедура РаспределениеТЗРБУ(ВидТЗР, СтруктураШапкиДокумента)
	
	СуммовойУчет                    = Истина;

	МассивСчетовЗатратТЗР           = Новый Массив;
	МассивСчетовЗапасов             = Новый Массив;
	МассивСчетовЗапасовТаЖеГруппа   = Новый Массив; 
	МассивСчетовЗапасовДругаяГруппа = Новый Массив;  	
	
	Если ВидТЗР = "Материалы" Тогда
		
		МассивСчетовЗатратТЗР.Добавить(ПланыСчетов.Хозрасчетный.ТранспортноЗаготовительныеРасходыМатериалы);
		МассивСчетовЗапасов             = СформироватьМассивСчетовВИерархии(ПланыСчетов.Хозрасчетный.ПроизводственныеЗапасы);
		
		СчетТЗРМатериалы = МассивСчетовЗапасов.Найти(ПланыСчетов.Хозрасчетный.ТранспортноЗаготовительныеРасходыМатериалы);
		Если СчетТЗРМатериалы <> Неопределено Тогда  
			 МассивСчетовЗапасов.Удалить(СчетТЗРМатериалы);		
		 КонецЕсли; 
		МассивСчетовЗапасовТаЖеГруппа   = СформироватьМассивСчетовВИерархии(ПланыСчетов.Хозрасчетный.ПроизводственныеЗапасы);
       	МассивСчетовЗапасовДругаяГруппа = СформироватьМассивСчетовВИерархии(ПланыСчетов.Хозрасчетный.Товары);
		
	ИначеЕсли ВидТЗР = "Товары" Тогда
		
		МассивСчетовЗатратТЗР.Добавить(ПланыСчетов.Хозрасчетный.ТранспортноЗаготовительныеРасходыТовары);
		МассивСчетовЗапасов            = СформироватьМассивСчетовВИерархии(ПланыСчетов.Хозрасчетный.Товары);
		МассивСчетовЗапасовТаЖеГруппа  = СформироватьМассивСчетовВИерархии(ПланыСчетов.Хозрасчетный.Товары);
		
		СчетТЗРТовары = МассивСчетовЗапасов.Найти(ПланыСчетов.Хозрасчетный.ТранспортноЗаготовительныеРасходыТовары);
		Если СчетТЗРТовары <> Неопределено Тогда  
			 МассивСчетовЗапасов.Удалить(СчетТЗРТовары);		
		КонецЕсли;
		
    	МассивСчетовЗапасовДругаяГруппа = СформироватьМассивСчетовВИерархии(ПланыСчетов.Хозрасчетный.ПроизводственныеЗапасы);
		
		Если СуммовойУчет Тогда
			СчетТорговаяНаценка = МассивСчетовЗапасов.Найти(ПланыСчетов.Хозрасчетный.ТорговаяНаценкаНТТ);
			Если СчетТорговаяНаценка <> Неопределено Тогда 	
				МассивСчетовЗапасов.Удалить(СчетТорговаяНаценка);				
			КонецЕсли;
			
			СчетТорговаяНаценкаТажеГруппа = МассивСчетовЗапасовТаЖеГруппа.Найти(ПланыСчетов.Хозрасчетный.ТорговаяНаценкаНТТ);
            Если СчетТорговаяНаценкаТажеГруппа <> Неопределено Тогда 	
				МассивСчетовЗапасовТаЖеГруппа.Удалить(СчетТорговаяНаценкаТажеГруппа);
			КонецЕсли;   			

			СчетНТТ = МассивСчетовЗапасов.Найти(ПланыСчетов.Хозрасчетный.ТоварыВРозничнойТорговлеВПродажныхЦенахНТТ);
			Если СчетНТТ <> Неопределено Тогда 			
				МассивСчетовЗапасов.Удалить(СчетНТТ);
          		МассивСчетовЗапасовТаЖеГруппа.Удалить(МассивСчетовЗапасовТаЖеГруппа.Найти(ПланыСчетов.Хозрасчетный.ТоварыВРозничнойТорговлеВПродажныхЦенахНТТ));
			КонецЕсли;
			
			СчетНТТтажеГруппа = МассивСчетовЗапасовТаЖеГруппа.Найти(ПланыСчетов.Хозрасчетный.ТоварыВРозничнойТорговлеВПродажныхЦенахНТТ);
			Если СчетНТТтажеГруппа <> Неопределено Тогда 			
				МассивСчетовЗапасовТаЖеГруппа.Удалить(СчетНТТтажеГруппа);
			КонецЕсли;
			
			СчетТорговаяНаценкаАТТ = МассивСчетовЗапасов.Найти(ПланыСчетов.Хозрасчетный.ТорговаяНаценкаАТТ);
			Если СчетТорговаяНаценкаАТТ <> Неопределено Тогда 	
