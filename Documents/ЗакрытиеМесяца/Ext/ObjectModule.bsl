Процедура ФормированиеНалоговыхРазниц(СтруктураШапкиДокумента, Отказ, Заголовок)
	
	Если НЕ СтруктураШапкиДокумента.РасчетНалоговыхРазниц Тогда
		Возврат;
	КонецЕсли;
	
	ВестиРасчетыПоДокументам = ?(ПланыСчетов.Хозрасчетный.РасчетыСПокупателямиИЗаказчиками.ВидыСубконто.Найти(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ДокументыРасчетовСКонтрагентами, "ВидСубконто") = Неопределено, Ложь, Истина);	
	НаборЗаписей = Движения.ОжидаемыеНалоговыеРазницы;
	
	//общие параметры запросов
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("НачалоМесяца", НачалоМесяца(СтруктураШапкиДокумента.Дата));
	Запрос.УстановитьПараметр("КонецМесяца", КонецМесяца(СтруктураШапкиДокумента.Дата));
	Запрос.УстановитьПараметр("ПериодОстатков", МоментВремени());
	
	Запрос.УстановитьПараметр("Организация", СтруктураШапкиДокумента.Организация);
	Запрос.УстановитьПараметр("ГРН", Константы.ВалютаРегламентированногоУчета.Получить());
	
	ГруппыСчетовУчета = ПолучитьДетальныеСпискиСчетовУчета();
	Для каждого ГруппаСчетов ИЗ ГруппыСчетовУчета Цикл
		Запрос.УстановитьПараметр(ГруппаСчетов.Ключ, ГруппаСчетов.Значение);
	КонецЦикла;
	
	МассивВидовСубконто = Новый Массив;
	МассивВидовСубконто.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	МассивВидовСубконто.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Договоры);                     
	Если ВестиРасчетыПоДокументам Тогда
		МассивВидовСубконто.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ДокументыРасчетовСКонтрагентами);
	КонецЕсли;
	Запрос.УстановитьПараметр("ВидыСубконто", МассивВидовСубконто);
	
	// 1. Формирование разниц в первом месяце после переходана прибыль
	Если СтруктураШапкиДокумента.ЕстьНалогНаПрибыль И 	
		ОбщегоНазначения.ПолучитьСхемуНалогообложения(НачалоМесяца(СтруктураШапкиДокумента.Дата) - 1, СтруктураШапкиДокумента.Организация).ЕдиныйНалог Тогда
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СтатусыПлательщиковЕдиногоНалога.Период КАК Период,
		|	СтатусыПлательщиковЕдиногоНалога.ПлательщикЕдиногоНалога КАК ПлательщикЕдиногоНалога
		|ИЗ
		|	РегистрСведений.СтатусыПлательщиковЕдиногоНалога КАК СтатусыПлательщиковЕдиногоНалога
		|ГДЕ
		|	СтатусыПлательщиковЕдиногоНалога.Организация = &Организация
		|	И СтатусыПлательщиковЕдиногоНалога.Период < &КонецМесяца
		|
		|УПОРЯДОЧИТЬ ПО
		|	Период УБЫВ";
		
		НачалоПериодаЕН = Неопределено;
		КонецПериодаЕН = Неопределено;
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			
			Если НЕ Выборка.ПлательщикЕдиногоНалога Тогда
				Если НачалоПериодаЕН = Неопределено Тогда
					КонецПериодаЕН = Выборка.Период - 1;
				Иначе
					Прервать;
				КонецЕсли;
			ИначеЕсли КонецПериодаЕН <> Неопределено Тогда 
				НачалоПериодаЕН = Выборка.Период;
			КонецЕсли;
			
		КонецЦикла;
		
		Если НачалоПериодаЕН <> Неопределено И КонецПериодаЕН <> Неопределено Тогда
			
			Запрос.УстановитьПараметр("НачалоПериодаЕН", НачалоПериодаЕН);
			Запрос.УстановитьПараметр("КонецПериодаЕН", КонецПериодаЕН);
			Запрос.УстановитьПараметр("КонецПериодаЕНВключая", Новый Граница(КонецПериодаЕН, ВидГраницы.Включая));
			
			//распределение остатков расчетов на конец периода ЕН по образовавшим их регистраторам
			Если ВестиРасчетыПоДокументам Тогда
				Запрос.Текст = 
				"ВЫБРАТЬ
				|	ХозрасчетныйОстатки.Счет КАК Счет,
				|	ХозрасчетныйОстатки.Субконто1 КАК Субконто1,
				|	ХозрасчетныйОстатки.Субконто2 КАК Субконто2,
				|	ХозрасчетныйОстатки.Субконто3 КАК Субконто3,
				|	ЕСТЬNULL(ХозрасчетныйОстатки.Валюта, &ГРН) КАК Валюта,
				|	ВЫБОР
				|		КОГДА ХозрасчетныйОстатки.Валюта ЕСТЬ NULL
				|			ТОГДА ХозрасчетныйОстатки.СуммаОстатокДт
				|		ИНАЧЕ ХозрасчетныйОстатки.ВалютнаяСуммаОстатокДт
				|	КОНЕЦ КАК СуммаОстатокДт,
				|	ВЫБОР
				|		КОГДА ХозрасчетныйОстатки.Валюта ЕСТЬ NULL
				|			ТОГДА ХозрасчетныйОстатки.СуммаОстатокКт
				|		ИНАЧЕ ХозрасчетныйОстатки.ВалютнаяСуммаОстатокКт
				|	КОНЕЦ КАК СуммаОстатокКт,
				|	АВТОНОМЕРЗАПИСИ() КАК НомерАналитики
				|ПОМЕСТИТЬ Остатки
				|ИЗ
				|	РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериодаЕНВключая, Счет В (&СчетаРасчетов), &ВидыСубконто, Организация = &Организация) КАК ХозрасчетныйОстатки
				|ГДЕ
				|	(ВЫБОР
				|				КОГДА ХозрасчетныйОстатки.Валюта ЕСТЬ NULL
				|					ТОГДА ХозрасчетныйОстатки.СуммаОстатокДт
				|				ИНАЧЕ ХозрасчетныйОстатки.ВалютнаяСуммаОстатокДт
				|			КОНЕЦ <> 0
				|			ИЛИ ВЫБОР
				|				КОГДА ХозрасчетныйОстатки.Валюта ЕСТЬ NULL
				|					ТОГДА ХозрасчетныйОстатки.СуммаОстатокКт
				|				ИНАЧЕ ХозрасчетныйОстатки.ВалютнаяСуммаОстатокКт
				|			КОНЕЦ <> 0)
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	ХозрасчетныйОбороты.Регистратор КАК ДокументДвижения,
				|	ХозрасчетныйОбороты.Период КАК ПериодДвижения,
				|	ХозрасчетныйОбороты.Счет КАК Счет,
				|	ХозрасчетныйОбороты.Субконто1 КАК Контрагент,
				|	ХозрасчетныйОбороты.Субконто2 КАК Договор,
