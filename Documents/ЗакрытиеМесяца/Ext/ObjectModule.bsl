			|		ЕстьNULL(СУММА(Данные.ПриобретенияВозвратОтгрузкаВДВР)	, 0) 	КАК ПриобретенияВозвратОтгрузкаВДВР,
			|		ЕстьNULL(СУММА(Данные.ПриобретенияВозвратОплатаВДВР) 	, 0)	КАК ПриобретенияВозвратОплатаВДВР
			
			|	ИЗ
