#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
КонецПроцедуры // ПриСозданииНаСервере // + claude

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ДобавитьПроцесс(Команда)
	// добавить строку в ТЧ Процессы // + claude
	Объект.Процессы.Добавить();
КонецПроцедуры // ДобавитьПроцесс

&НаКлиенте
Процедура УдалитьПроцесс(Команда)
	// удалить текущую строку из ТЧ Процессы // + claude
	ТекущиеДанные = Элементы.Процессы.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли; // Если ТекущиеДанные
	Объект.Процессы.Удалить(ТекущиеДанные);
КонецПроцедуры // УдалитьПроцесс

&НаКлиенте
Процедура ВверхПроцесс(Команда)
	// сдвиг строки процесса вверх // + claude
	ТекущиеДанные = Элементы.Процессы.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли; // Если ТекущиеДанные
	Индекс = Объект.Процессы.Индекс(ТекущиеДанные);
	Если Индекс > 0 Тогда
		Объект.Процессы.Сдвинуть(ТекущиеДанные, -1);
	КонецЕсли; // Если Индекс > 0
КонецПроцедуры // ВверхПроцесс

&НаКлиенте
Процедура ВнизПроцесс(Команда)
	// сдвиг строки процесса вниз // + claude
	ТекущиеДанные = Элементы.Процессы.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли; // Если ТекущиеДанные
	Индекс = Объект.Процессы.Индекс(ТекущиеДанные);
	Если Индекс < Объект.Процессы.Количество() - 1 Тогда
		Объект.Процессы.Сдвинуть(ТекущиеДанные, 1);
	КонецЕсли; // Если Индекс < Количество
КонецПроцедуры // ВнизПроцесс

#КонецОбласти
