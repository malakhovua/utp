///////////////////////////////////////////////////////////////////////////////
//// ОБРАБОТЧИКИ СОБЫТИЙ

// Процедура - обработчик события "Перед записью".
//
// Параметры:
//  Отказ - <Булево>
//        - Признак отказа от записи элемента. Если в теле
//          процедуры-обработчика установить данному параметру
//          значение Истина, запись элемента выполнена не будет.
//          Значение по умолчанию: Ложь.
//
Процедура ПередЗаписью(Отказ)

	Если Не ОбменДанными.Загрузка Тогда

		Ошибки = "";
		Если ПустаяСтрока(Модель) Тогда
			Ошибки = НСтр("ru=' - Не указана модель торгового оборудования.';uk=' - Не зазначена модель торговельного обладнання.'");
		КонецЕсли;

		Если НЕ ЗначениеЗаполнено(ОбработкаОбслуживания) Тогда
			Ошибки = Ошибки + ?(ПустаяСтрока(Ошибки),
			                    "",
			                    "
			                    |")
			                + НСтр("ru=' - Не указана обработка обслуживания.';uk=' - Не зазначена обробка обслуговування.'");
		КонецЕсли;

		Если Не ПустаяСтрока(Ошибки) Тогда
			ОбщегоНазначения.СообщитьОбОшибке(НСтр("ru='При попытке записи элемента с кодом ""';uk='При спробі запису елемента з кодом ""'") + Код + НСтр("ru='"" были обнаружены ошибки:"
"';uk='"" були виявлені помилки:"
"'") + Ошибки);
			Отказ = Истина;
		КонецЕсли;

	КонецЕсли;

КонецПроцедуры
