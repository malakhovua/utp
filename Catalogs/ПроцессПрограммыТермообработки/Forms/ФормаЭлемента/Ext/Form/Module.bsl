// Модуль формы элемента ПроцессПрограммыТермообработки

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ОбновитьВнеКамеры();
КонецПроцедуры // ПриСозданииНаСервере // + claude

&НаСервере
Процедура ОбновитьВнеКамеры()
	Если ЗначениеЗаполнено(Объект.ВидПроцесса) И Объект.ВидПроцесса.ВнеКамеры Тогда
		Элементы.ВнеКамерыДекорация.Заголовок = "Вне камеры";
	Иначе
		Элементы.ВнеКамерыДекорация.Заголовок = "";
	КонецЕсли;
КонецПроцедуры // ОбновитьВнеКамеры // + claude

&НаКлиенте
Процедура ВидПроцессаПриИзменении(Элемент)
	ВидПроцессаПриИзменении_НаСервере();
КонецПроцедуры // ВидПроцессаПриИзменении // + claude

&НаСервере
Процедура ВидПроцессаПриИзменении_НаСервере()
	ОбновитьВнеКамеры();
КонецПроцедуры // ВидПроцессаПриИзменении_НаСервере // + claude
