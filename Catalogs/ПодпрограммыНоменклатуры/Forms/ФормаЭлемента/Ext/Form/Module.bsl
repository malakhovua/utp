// Модуль формы элемента ПодпрограммыНоменклатуры

&НаКлиенте
Процедура ВладелецПриИзменении(Элемент)
	ВладелецПриИзменении_НаСервере();
КонецПроцедуры // ВладелецПриИзменении // + claude

&НаСервере
Процедура ВладелецПриИзменении_НаСервере()
	// Сбрасываем Подпрограмму при смене Владельца
	Объект.Подпрограмма = Справочники.ПодПрограммыТермообработки.ПустаяСсылка();

	// Ищем ПодПрограмму с наименованием владельца
	Если НЕ ЗначениеЗаполнено(Объект.Owner) Тогда
		Возврат;
	КонецЕсли;

	НаимВладельца = Объект.Owner.Description;
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПодПрограммыТермообработки.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ПодПрограммыТермообработки КАК ПодПрограммыТермообработки
		|ГДЕ
		|	ПодПрограммыТермообработки.Наименование = &Наименование
		|	И НЕ ПодПрограммыТермообработки.ПометкаУдаления";
	Запрос.УстановитьПараметр("Наименование", НаимВладельца);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Объект.Подпрограмма = Выборка.Ссылка;
	КонецЕсли;

КонецПроцедуры // ВладелецПриИзменении_НаСервере // + claude
