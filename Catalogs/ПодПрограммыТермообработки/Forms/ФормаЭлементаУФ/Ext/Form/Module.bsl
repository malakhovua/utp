#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗаполнитьПоПрограмме(Команда)
	// заполнить ТЧ процессы из программы термообработки // + claude
	Если ПустаяСтрока(Объект.Программа) Тогда
		Предупреждение("Не выбрана программа термообработки!");
		Возврат;
	КонецЕсли; // Если ПустаяСтрока
	ЗаполнитьПоПрограммеНаСервере();
КонецПроцедуры // ЗаполнитьПоПрограмме

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьПоПрограммеНаСервере()
	// копируем виды процессов из ТЧ Процессы программы в ТЧ подпрограммы // + claude
	Объект.Процессы.Очистить();

	СпрПрограмма = Объект.Программа.ПолучитьОбъект();
	Если СпрПрограмма = Неопределено Тогда
		Возврат;
	КонецЕсли; // Если СпрПрограмма

	Для Каждого СтрПроцесс Из СпрПрограмма.Процессы Цикл
		НоваяСтрока = Объект.Процессы.Добавить();
		НоваяСтрока.ВидПроцесса = СтрПроцесс.ВидПроцесса;
	КонецЦикла; // Для Каждого СтрПроцесс
КонецПроцедуры // ЗаполнитьПоПрограммеНаСервере // + claude

// вычислить дни/часы/минуты из общего количества минут // + claude
&НаКлиенте
Процедура ПроцессыДлинаПроцессаПриИзменении(Элемент)
	ТекущиеДанные = Элементы.Процессы.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли; // Если ТекущиеДанные

	ВсегоМинут = ТекущиеДанные.ДлинаПроцесса;
	Дней  = 0;
	Часов = 0;
	Минут = 0;

	Если ВсегоМинут > 0 Тогда
		ТекЧасов = ВсегоМинут / 60;
		Часов = Цел(ТекЧасов);
		Минут = ВсегоМинут - Часов * 60;

		Если Часов > 23 Тогда
			ТекДней = Часов / 24;
			Дней  = Цел(ТекДней);
			Часов = Часов - Дней * 24;
		КонецЕсли; // Если Часов > 23
	КонецЕсли; // Если ВсегоМинут > 0

	ТекущиеДанные.ДлинаПроцессаДней  = Дней;
	ТекущиеДанные.ДлинаПроцессаЧасов = Часов;
	ТекущиеДанные.ДлинаПроцессаМинут = Минут;
КонецПроцедуры // ПроцессыДлинаПроцессаПриИзменении // + claude

#КонецОбласти
