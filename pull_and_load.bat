@echo off
chcp 65001 > nul
setlocal EnableDelayedExpansion

:: ============================================================
::  pull_and_load.bat
::  Стягує зміни з git-репозиторію та завантажує конфігурацію
::  з файлів у базу даних 1С (з наступним оновленням БД)
:: ============================================================

:: --- Налаштування -----------------------------------------------------------
set "V8=C:\Program Files\1cv8\8.3.18.1483\bin\1cv8.exe"

:: Сервер і ім'я бази
set "IB_SERVER=127.0.0.1"
set "IB_NAME=utp_dev"

:: Логін і пароль адміністратора конфігуратора (залиште порожніми якщо не потрібно)
set "IB_USER="
set "IB_PASS="

:: Шлях до локального репозиторію (каталог з файлами конфігурації)
set "REPO_PATH=C:\utp"

:: ---------------------------------------------------------------------------
echo.
echo ============================================================
echo  1C UTP -- git pull + завантаження конфігурації
echo ============================================================
echo  Репозиторій : !REPO_PATH!
echo  База        : !IB_SERVER!\!IB_NAME!
echo ============================================================
echo.

:: --- Перевірка наявності 1С -------------------------------------------------
if not exist "!V8!" (
    echo [ПОМИЛКА] Виконавчий файл 1С не знайдено: !V8!
    pause
    exit /b 1
)

:: --- Перевірка наявності репозиторію ----------------------------------------
if not exist "!REPO_PATH!\.git" (
    echo [ПОМИЛКА] Репозиторій не знайдено у: !REPO_PATH!
    echo Виконайте git clone спочатку.
    pause
    exit /b 1
)

:: --- Git pull ---------------------------------------------------------------
echo [1/2] Git pull...
echo.

cd /d "!REPO_PATH!"

git pull origin main
if errorlevel 1 (
    echo.
    echo [ПОМИЛКА] git pull завершився з помилкою.
    echo Перевірте SSH-ключ або мережеве з'єднання.
    pause
    exit /b 1
)

echo.
echo [OK] Репозиторій оновлено.

:: --- Завантаження конфігурації з файлів у 1С --------------------------------
echo.
echo [2/2] Завантаження конфігурації з файлів у базу...
echo       (може тривати кілька хвилин)
echo.

:: Формування параметрів авторизації
if "!IB_USER!"=="" (
    set "AUTH_PARAMS="
) else (
    if "!IB_PASS!"=="" (
        set "AUTH_PARAMS=/N"!IB_USER!""
    ) else (
        set "AUTH_PARAMS=/N"!IB_USER!" /P"!IB_PASS!""
    )
)

"!V8!" CONFIG /S"!IB_SERVER!\!IB_NAME!" !AUTH_PARAMS! /LoadConfigFromFiles "!REPO_PATH!" /UpdateDBCfg /Out "!REPO_PATH!\load_log.txt" 2>&1

if errorlevel 1 (
    echo.
    echo [ПОМИЛКА] Завантаження конфігурації завершилось з помилкою (код: %errorlevel%)
    echo Дивіться лог: !REPO_PATH!\load_log.txt
    pause
    exit /b 1
)

echo.
echo [OK] Конфігурація завантажена та база оновлена.

:: --- Показуємо лог якщо є ---------------------------------------------------
if exist "!REPO_PATH!\load_log.txt" (
    echo.
    echo --- Лог завантаження ---
    type "!REPO_PATH!\load_log.txt"
    echo ------------------------
)

echo.
echo ============================================================
echo  Готово! Конфігурацію оновлено в базі !IB_NAME!
echo ============================================================
echo.
pause
endlocal
