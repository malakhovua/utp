	Параметры.ПереходНКУ_УчетнаяПолитикаОрганизаций 		= РегистрыСведений.УчетнаяПолитикаБухгалтерскийУчет.ПолучитьФормуСписка();
	Параметры.ПереходНКУ_СчетаУчетаНоменклатуры 			= РегистрыСведений.СчетаУчетаНоменклатуры.ПолучитьФормуСписка();
	Параметры.ПереходНКУ_СчетаУчетаРасчетовСКонтрагентами	= РегистрыСведений.СчетаУчетаРасчетовСКонтрагентами.ПолучитьФормуСписка();
	Параметры.ПереходНКУ_ОтражениеВзносовФОТВРеглУчете		= РегистрыСведений.ОтражениеВзносовФОТВРеглУчете.ПолучитьФормуСписка();
	Параметры.ПереходНКУ_ПараметрыУчетаКурсовыхРазниц		= РегистрыСведений.ПараметрыУчетаКурсовыхРазниц.ПолучитьФормуСписка();
	Параметры.ПереходНКУ_СчетаУчетаПрочие					= РегистрыСведений.СчетаУчетаПрочие.ПолучитьФормуСписка();
	Параметры.ПереходНКУ_МетодыРаспределенияКосвенныхРасходовОрганизаций = РегистрыСведений.МетодыРаспределенияКосвенныхРасходовОрганизаций.ПолучитьФормуСписка();
	Параметры.ПереходНКУ_ПоказателиПриНормальнойМощности 	= РегистрыСведений.ПоказателиПриНормальнойМощности.ПолучитьФормуСписка();
	Параметры.ПерепроведениеДокументовОПЗ 	= ПолучитьФорму("ПерепроведениеДокументовПоСчетуОПЗ");
	
	Параметры.ЗаполнениеСинонимовОбъектов = Обработки.ЗаполнениеСинонимовОбъектов.ПолучитьФорму();
	
	Параметры.ПерепроведениеРВНДпоПропорциоанльнымОФ 	= ПолучитьФорму("ПерепроведениеРВНДпоПропорциоанльнымОФ");
	
	Параметры.ПерерасчетЕСВ126 	= ПолучитьФорму("ПерерасчетЕСВ126");
	Параметры.ВариантыАлгоритмов	= РегистрыСведений.ВариантыАлгоритмовРасчетаЗарплаты.ПолучитьФорму("ФормаСписка");
	
	Параметры.КакПодготовитьсяКУчетуРазницНКУ2015 		= ПолучитьФорму("КакПодготовитьсяКУчетуРазницНКУ2015");

	Параметры.ОчисткаНеиспользуемыхРеквизитовНКУ2015 	= ПолучитьФорму("ОчисткаНеиспользуемыхРеквизитовВПроводкахНКУ2015");
	
