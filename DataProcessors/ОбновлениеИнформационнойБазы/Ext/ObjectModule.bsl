	ОбрабатываемыеВидыОпераций.Добавить(Перечисления.ВидыОперацийРегистрацияВходящегоНалоговогоДокумента.РасчетКорректировкиКорректировка);
	
	Док = Документы.РегистрацияВходящегоНалоговогоДокумента.Выбрать('20111001');
	Пока Док.Следующий() Цикл
		Объект = Док.ПолучитьОбъект();
		Если НЕ ОбрабатываемыеВидыОпераций.НайтиПоЗначению(Объект.ВидОперации) = Неопределено			
			  И ЗначениеЗаполнено(Объект.Комментарий) Тогда
			  
			Объект.ОснованиеКорректировки = Объект.Комментарий;
			Объект.ОбменДанными.Загрузка = Истина;
			Попытка
			    Объект.Записать(РежимЗаписиДокумента.Запись);
			Исключение
				Сообщить(НСтр("ru='Не удалось обновить документ:  ';uk='Не вдалося оновити документ: '") + Док, СтатусСообщения.Важное);	
			КонецПопытки;
		
		КонецЕсли;
	КонецЦикла;
	
	СостояниеОбновления("");

КонецПроцедуры

Процедура ИсправитьНачальноеЗаполнениеСчетаУчетаРасчетовСКонтрагентами()
	
	МассивРесурсовНННДС = Новый Массив; 	
	МассивРесурсовНННДС.Добавить("НалоговоеНазначениеПриобретений");
	МассивРесурсовНННДС.Добавить("НалоговоеНазначениеПродаж");
	МассивРесурсовНННДС.Добавить("НалоговоеНазначениеПриобретенийПоТаре");
	МассивРесурсовНННДС.Добавить("НалоговоеНазначениеПродажПоТаре");
	
	СписокНалоговыхНазначенийНКУ_НДС = Новый СписокЗначений();
	СписокНалоговыхНазначенийНКУ_НДС.Добавить(Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_НеоблагаемаяНеХозДеятельность);
	СписокНалоговыхНазначенийНКУ_НДС.Добавить(Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_НеоблагаемаяХозДеятельность);
	СписокНалоговыхНазначенийНКУ_НДС.Добавить(Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_Облагаемая);
	СписокНалоговыхНазначенийНКУ_НДС.Добавить(Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_Пропорционально);
	
	НаборДвижений = РегистрыСведений.СчетаУчетаРасчетовСКонтрагентами.СоздатьНаборЗаписей();
	
	НаборДвижений.Прочитать();

	ИзмененыДвижения = Ложь;
	Для Каждого Движение Из НаборДвижений Цикл
		
		Для Каждого ИмяРесурсаНН Из МассивРесурсовНННДС Цикл
			
			ЗначениеРесурсаНН = Движение[ИмяРесурсаНН];
			
			// пустой ресурс - преобразовывать нечего
			Если НЕ ЗначениеЗаполнено(ЗначениеРесурсаНН) Тогда
				Продолжить;
			КонецЕсли;
			
			// ресурс заполнен нормально 
			Если НЕ СписокНалоговыхНазначенийНКУ_НДС.НайтиПоЗначению(ЗначениеРесурсаНН) = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			Если Прав(ИмяРесурсаНН,6) = "ПоТаре" Тогда
				Движение[ИмяРесурсаНН] = Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_НеоблагаемаяХозДеятельность;
			Иначе
				Движение[ИмяРесурсаНН] = Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_Облагаемая;
			КонецЕсли;
			ИзмененыДвижения = Истина;
		КонецЦикла; 
			
	КонецЦикла; 	
		
	Если ИзмененыДвижения Тогда
		НаборДвижений.ОбменДанными.Загрузка = Истина;
		НаборДвижений.Записать(Истина);
	КонецЕсли;
	
КонецПроцедуры //ИсправитьНачальноеЗаполнениеСчетаУчетаРасчетовСКонтрагентами()

Процедура ЗаполнениеДатыОплаты(ТипДокумента, ДатаНач) Экспорт
	
	НоваяДлинаНомера = Метаданные.Документы[ТипДокумента].ДлинаНомера;
	
	ЕстьДокументы = Истина;
	ДокументСсылка = Неопределено;
	
	Пока ЕстьДокументы Цикл
		
		Выборка = ПолучитьВыборкуДокументов(ТипДокумента, ДатаНач, ДокументСсылка);
		ЕстьДокументы = Выборка.Количество() > 0;
		
		Пока Выборка.Следующий() Цикл
			
			ДокументСсылка = Выборка.Ссылка;
			
			ДокументОбъект = ДокументСсылка.ПолучитьОбъект();
			
			ЗаписыватьОбъект = Ложь;
			
			Если НЕ ЗначениеЗаполнено(ДокументОбъект.ДатаОплаты) Тогда
				ДокументОбъект.ДатаОплаты = ДокументОбъект.НалоговаяНакладная.Дата;
				ЗаписыватьОбъект = Истина;
			КонецЕсли;
			
			Если ЗаписыватьОбъект = Истина Тогда
				ДокументОбъект.ОбменДанными.Загрузка = Истина;
				ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
			КонецЕсли;
			
		КонецЦикла;		
	КонецЦикла;
	
КонецПроцедуры

Процедура УдалитьСубконтоДокументыРасчетов(Счет)
	
	СчетОбъект = Счет.ПолучитьОбъект();
	
	ВидСубконтоДокументыРасчетов = ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ДокументыРасчетовСКонтрагентами;
	Субконто = СчетОбъект.ВидыСубконто.Найти(ВидСубконтоДокументыРасчетов, "ВидСубконто");	
	
	Если Субконто = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ХозрасчетныйОстатки.Счет
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(, Счет В ИЕРАРХИИ (&Счет), &ВидСубконто, Субконто1 <> &ПустСубконто) КАК ХозрасчетныйОстатки";
	
	Запрос.УстановитьПараметр("Счет", Счет); 
	Запрос.УстановитьПараметр("ВидСубконто", ВидСубконтоДокументыРасчетов);
	Запрос.УстановитьПараметр("ПустСубконто", Неопределено);
	
	Выборка = Запрос.Выполнить();
	
	Если Выборка.Пустой() Тогда
		СчетОбъект.ВидыСубконто.Удалить(Субконто);
		СчетОбъект.Записать();
		Сообщить(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='План счетов ""Хозрасчетный"", счет ""%1"" удалено субконто ""%2""';uk='План рахунків ""Госпрозрахунковий"", рахунок ""%1"" вилучене субконто ""%2""'"), Строка(СчетОбъект),ВидСубконтоДокументыРасчетов.Наименование));
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьФлагПризнаватьЗатратыВНУОприходованиеТоваров()
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаНач", глЗначениеПеременной("ДатаНачалаУчетаНКУ"));
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОприходованиеТоваров.Ссылка
	|ИЗ
	|	Документ.ОприходованиеТоваров КАК ОприходованиеТоваров
	|ГДЕ
	|	ОприходованиеТоваров.Дата >= &ДатаНач
	|	И ОприходованиеТоваров.ИнвентаризацияТоваровНаСкладе = ЗНАЧЕНИЕ(Документ.ИнвентаризацияТоваровНаСкладе.ПустаяСсылка)
	|	И (ОприходованиеТоваров.СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.Вспомогательный)
	|			ИЛИ ОприходованиеТоваров.СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.НеоплаченныйКапитал))
	|	И ОприходованиеТоваров.ПризнаватьЗатратыВНУ = ЛОЖЬ
	|	И ОприходованиеТоваров.ОтражатьВБухгалтерскомУчете = ИСТИНА";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Объект = Выборка.Ссылка.ПолучитьОбъект();
		Объект.ПризнаватьЗатратыВНУ = Истина;
		Объект.Записать(РежимЗаписиДокумента.Запись);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьНормыДляПятойИШестойГруппЕН()
	
