Процедура ЗаполнитьНастройкуПользователейОсновнойПредставительОрганизации()
	
	Настройки = РегистрыСведений.НастройкиПользователей.СоздатьНаборЗаписей();

	Пользователь = Справочники.Пользователи.Выбрать();
	
	Пока Пользователь.Следующий() Цикл
		
		Если Пользователь.ЭтоГруппа Тогда
			Продолжить;
		КонецЕсли;
		
		Если Пользователь.ФизЛицо.Пустая() Тогда
			Продолжить;
		КонецЕсли;
		
		// проверим, нет ли такой записи.
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	НастройкиПользователей.Значение
		               |ИЗ
		               |	РегистрСведений.НастройкиПользователей КАК НастройкиПользователей
		               |ГДЕ
		               |	НастройкиПользователей.Пользователь = &Пользователь
		               |	И НастройкиПользователей.Настройка = &Настройка";
		Запрос.УстановитьПараметр("Пользователь",Пользователь.Ссылка);
		Запрос.УстановитьПараметр("Настройка", ПланыВидовХарактеристик.НастройкиПользователей.ОсновнойПредставительОрганизации);
		
		Если Запрос.Выполнить().Пустой() Тогда
			Настройка = Настройки.Добавить();
			Настройка.Пользователь = Пользователь.Ссылка;
			Настройка.Настройка    = ПланыВидовХарактеристик.НастройкиПользователей.ОсновнойПредставительОрганизации;
			Настройка.Значение     = Пользователь.ФизЛицо;
		КонецЕсли;
		
	КонецЦикла;

	Настройки.Записать(Ложь);
	
КонецПроцедуры

Процедура УстановитьКоэффициентыДляЗаполнениПриложенияСВДекларацииПоПрибыли()
	
	ЗапросПоОрганизациямПлательщикамНП = Новый Запрос();
	ЗапросПоОрганизациямПлательщикамНП.УстановитьПараметр("Дата", '20110331');
	
	// все организации-плательщики, для которых на 01.04 не установлены коэффициенты
	ЗапросПоОрганизациямПлательщикамНП.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	                                           |	Организации.Ссылка  КАК Организация
	                                           |ИЗ
	                                           |	Справочник.Организации КАК Организации
	                                           |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УчетнаяПолитикаНалоговыйУчет.СрезПоследних(&Дата, ) КАК УчетнаяПолитикаОрганизацийСрезПоследних
	                                           |		ПО (УчетнаяПолитикаОрганизацийСрезПоследних.Организация = Организации.Ссылка)
	                                           |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КоэффициентыДляЗаполнениПриложенияСВДекларацииПоПрибыли.СрезПоследних(&Дата, ) КАК КоэффициентыДляЗаполнениПриложенияСВДекларацииПоПрибылиСрезПоследних
	                                           |		ПО (КоэффициентыДляЗаполнениПриложенияСВДекларацииПоПрибылиСрезПоследних.Организация = Организации.Ссылка)
	                                           |ГДЕ
	                                           |	УчетнаяПолитикаОрганизацийСрезПоследних.СхемаНалогообложения.НалогНаПрибыль
	                                           |	И КоэффициентыДляЗаполнениПриложенияСВДекларацииПоПрибылиСрезПоследних.Статья ЕСТЬ NULL ";
	
	Выборка = ЗапросПоОрганизациямПлательщикамНП.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
	
		Док = Документы.РасчетКоэффициентовДляЗаполненияПриложенияСВДекларацииПоПрибыли.СоздатьДокумент();	
		
		Док.Дата = '201103311200';
		
		Док.Организация = Выборка.Организация;
		Док.Ответственный = глЗначениеПеременной("глТекущийПользователь");
		Док.Комментарий = НСТР("ru='#Обновление на редакцию 1.2. Установка коэффициентов на 01.04.2011#';uk='#Оновлення на редакцію 1.2. Встановлення коеффіцієнтів на 01.04.2011#'");
		
		Строка = Док.Статьи.Добавить();
		
		Строка.Статья = Справочники.СтатьиНалоговыхДеклараций.НПНК_ПЗ_Материалы_;
		Строка.КоэффициентНаКонец = 1;
		
		Док.УстановитьНовыйНомер();
		
		Попытка
			Док.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбновитьВхожденияПредопределенныхЭлементов(ВидОбъекта, ТаблицаВхождений)
	
	МетаданныеСправочника = Метаданные.НайтиПоПолномуИмени(ВидОбъекта);
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ОсновнаяТаблица.Ссылка КАК ЗаменяемаяСсылка,
	|	ОсновнаяТаблица.СсылкаПредопределенный КАК ЗаменяющаяСсылка,
	|	ТаблицаВхождений.ИмяРеквизита КАК ИмяРеквизита,
	|	ТаблицаВхождений.Ссылка КАК Вхождение";
	
	ТекстЗапроса = ТекстЗапроса + "
	|ИЗ
	|	(ВЫБРАТЬ
	|		ТаблицаСправочника.Ссылка КАК Ссылка,
	|		ТаблицаСправочникаПредопределенные.Ссылка КАК СсылкаПредопределенный
	|	ИЗ
	|		" + ВидОбъекта + " КАК ТаблицаСправочника
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ " + ВидОбъекта + " КАК ТаблицаСправочникаПредопределенные
	|			ПО ТаблицаСправочника.Наименование = ТаблицаСправочникаПредопределенные.Наименование";
	
	Для каждого Реквизит из МетаданныеСправочника.Реквизиты Цикл
		Если ВРег(Лев(Реквизит.Имя, 7)) = "УДАЛИТЬ" Тогда
			Продолжить;
		КонецЕсли;
		ТекстЗапроса = ТекстЗапроса + "
		|			И ТаблицаСправочника." + Реквизит.Имя + " = ТаблицаСправочникаПредопределенные." + Реквизит.Имя;
	КонецЦикла;
	
	ТекстЗапроса = ТекстЗапроса + "
	|	ГДЕ
	|		ТаблицаСправочника.ПометкаУдаления
	|		И ТаблицаСправочникаПредопределенные.Предопределенный) КАК ОсновнаяТаблица
	|		ЛЕВОЕ СОЕДИНЕНИЕ(";
	
	НужноОбъединение = Ложь;
	Для каждого СтрокаВхождений из ТаблицаВхождений Цикл
		Если НужноОбъединение Тогда
			ТекстЗапроса = ТекстЗапроса + "
			|		
			|		ОБЪЕДИНИТЬ ВСЕ
			|";
		КонецЕсли;
		ТекстЗапроса = ТекстЗапроса + "
		|		ВЫБРАТЬ
		|			ТаблицаОбъектаПоиска.Ссылка КАК Ссылка,
		|			ТаблицаОбъектаПоиска." + СтрокаВхождений.ИмяРеквизита + " КАК Реквизит,
		|			""" + СтрокаВхождений.ИмяРеквизита + """ КАК ИмяРеквизита
		|		ИЗ
		|			" + СтрокаВхождений.ВидОбъекта + "  КАК ТаблицаОбъектаПоиска
		|		ГДЕ
		|			ТаблицаОбъектаПоиска." + СтрокаВхождений.ИмяРеквизита + ".ПометкаУдаления";
		Если НЕ НужноОбъединение Тогда
			НужноОбъединение = Истина;
		КонецЕсли;
	КонецЦикла;
	
	ТекстЗапроса = ТекстЗапроса + "
	|		) КАК ТаблицаВхождений
	|			ПО ОсновнаяТаблица.Ссылка = ТаблицаВхождений.Реквизит";	

	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	
	МассивЗаменяемыхСсылок = Новый Массив;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если МассивЗаменяемыхСсылок.Найти(Выборка.ЗаменяемаяСсылка) = Неопределено Тогда
			МассивЗаменяемыхСсылок.Добавить(Выборка.ЗаменяемаяСсылка);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Выборка.Вхождение) Тогда
			
			Объект = Выборка.Вхождение.ПолучитьОбъект();
			Объект[Выборка.ИмяРеквизита] = Выборка.ЗаменяющаяСсылка;
			Объект.ОбменДанными.Загрузка = Истина;
			Объект.Записать();
		
		КонецЕсли;
		
	КонецЦикла;
	
	Для каждого Ссылка из МассивЗаменяемыхСсылок Цикл
		Объект = Ссылка.ПолучитьОбъект();
		Объект.Удалить();
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбновитьВхожденияПредопределенныхЭлементовНаборыСтатейНалоговыхДеклараций()
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ОсновнаяТаблица.Ссылка КАК ЗаменяемаяСсылка,
	|	ОсновнаяТаблица.СсылкаПредопределенный КАК ЗаменяющаяСсылка,
	|	ТаблицаВхождений.Набор,
	|	ТаблицаВхождений.Статья
	|ИЗ
	|	(ВЫБРАТЬ
	|		ТаблицаСправочника.Ссылка КАК Ссылка,
	|		ТаблицаСправочникаПредопределенные.Ссылка КАК СсылкаПредопределенный
	|	ИЗ
	|		Справочник.НаборыСтатейНалоговыхДеклараций КАК ТаблицаСправочника
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.НаборыСтатейНалоговыхДеклараций КАК ТаблицаСправочникаПредопределенные
	|			ПО ТаблицаСправочника.Наименование = ТаблицаСправочникаПредопределенные.Наименование
	|	ГДЕ
	|		ТаблицаСправочника.ПометкаУдаления
	|		И ТаблицаСправочникаПредопределенные.Предопределенный) КАК ОсновнаяТаблица
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ТаблицаОбъектовПоиска.Набор КАК Набор,
	|			ТаблицаОбъектовПоиска.Статья КАК Статья
	|		ИЗ
	|			РегистрСведений.НаборыСтатейНалоговыхДеклараций КАК ТаблицаОбъектовПоиска
	|		ГДЕ
	|			ТаблицаОбъектовПоиска.Набор.ПометкаУдаления) КАК ТаблицаВхождений
	|		ПО ОсновнаяТаблица.Ссылка = ТаблицаВхождений.Набор";
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	
	МассивЗаменяемыхСсылок = Новый Массив;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если МассивЗаменяемыхСсылок.Найти(Выборка.ЗаменяемаяСсылка) = Неопределено Тогда
			МассивЗаменяемыхСсылок.Добавить(Выборка.ЗаменяемаяСсылка);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Выборка.Статья) Тогда
			
			НаборЗаписей = РегистрыСведений.НаборыСтатейНалоговыхДеклараций.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Набор.Установить(Выборка.ЗаменяемаяСсылка);
			НаборЗаписей.Отбор.Статья.Установить(Выборка.Статья);
			НаборЗаписей.Прочитать();
			Запись = НаборЗаписей[0];
			Запись.Набор = Выборка.ЗаменяющаяСсылка;
			НаборЗаписей.Отбор.Набор.Установить(Выборка.ЗаменяющаяСсылка);
			НаборЗаписей.Записать();
			
		КонецЕсли;
		
	КонецЦикла;
	
	Для каждого Ссылка из МассивЗаменяемыхСсылок Цикл
		Объект = Ссылка.ПолучитьОбъект();
		Объект.Удалить();
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбновитьВхожденияПредопределенныхЭлементовСправочников()
	
	ТаблицаВхождений = Новый ТаблицаЗначений;
	ТаблицаВхождений.Колонки.Добавить("ВидОбъекта");
	ТаблицаВхождений.Колонки.Добавить("ИмяРеквизита");
	
	НоваяСтрока = ТаблицаВхождений.Добавить();
	НоваяСтрока.ВидОбъекта = "Справочник.ДоговорыКонтрагентов";
	НоваяСтрока.ИмяРеквизита = "СхемаНалоговогоУчета";
	НоваяСтрока = ТаблицаВхождений.Добавить();
	НоваяСтрока.ВидОбъекта = "Справочник.ДоговорыКонтрагентов";
	НоваяСтрока.ИмяРеквизита = "СхемаНалоговогоУчетаПоТаре";
	ОбновитьВхожденияПредопределенныхЭлементов("Справочник.СхемыНалоговогоУчетаПоДоговорамКонтрагентов", ТаблицаВхождений);
	ОбновитьВхожденияПредопределенныхЭлементовНаборыСтатейНалоговыхДеклараций();
	
КонецПроцедуры

Процедура ПроверитьКонстантуЗапретИзмененияДанныхДо01042011()
	
	Если Константы.ЗапретИзмененияДанныхДо01042011.Получить() Тогда
		Набор = РегистрыСведений.ГраницыЗапретаИзмененияДанных.СоздатьНаборЗаписей();
		Набор.Прочитать();
		Если Набор.Количество() = 0 Тогда
			Набор.Отбор.Организация.Установить(Справочники.Организации.ПустаяСсылка());
			Запись = Набор.Добавить();
			Запись.Организация = Справочники.Организации.ПустаяСсылка();
   			Запись.Пользователь = Неопределено;
			Запись.ГраницаЗапретаИзменений = Дата('00010101');
			Набор.Записать();
			
		    Запрос = Новый Запрос;
		    Запрос.Текст  = 
				"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			    |	Организации.Ссылка КАК Организация
			    |ИЗ
			    |	Справочник.Организации КАК Организации";
		    
		    Выборка = Запрос.Выполнить().Выбрать();
		    Пока Выборка.Следующий() Цикл		
		        
		        Набор = РегистрыСведений.ГраницыЗапретаИзмененияДанных.СоздатьНаборЗаписей();
		        Набор.Отбор.Организация.Установить(Выборка.Организация);
		        
		        Запись = Набор.Добавить();
		        Запись.Организация = Выборка.Организация;
		        Запись.Пользователь = Неопределено;
		        
		        Запись.ГраницаЗапретаИзменений = Дата('00010101');
			    Набор.Записать();
				
		    КонецЦикла;
		КонецЕсли; 
		ПолныеПрава.УстановитьПараметрГраницыЗапретаИзмененияДанных();
	КонецЕсли;
	

КонецПроцедуры

Процедура ЗаполнитьЕдиницыИзмеренияСправочникаСпецификацииНоменклатуры()
	
	Спр = Справочники.СпецификацииНоменклатуры.Выбрать();
	Пока Спр.Следующий() Цикл
		
		Если Спр.ЭтоГруппа Тогда
			Продолжить;	
		КонецЕсли;
		
		Объект =  Спр.ПолучитьОбъект();
		
		Объект.ЕдиницаИзмерения = Объект.Владелец.ЕдиницаХраненияОстатков;
		
		ТЧ = Объект.ИсходныеКомплектующие;
		Для каждого СтрокаТЧ Из ТЧ Цикл
		
			СтрокаТЧ.ЕдиницаИзмерения = СтрокаТЧ.Номенклатура.ЕдиницаХраненияОстатков;
		
		КонецЦикла;
		
		Объект.ОбменДанными.Загрузка = Истина;
		Объект.Записать();
	
	КонецЦикла;
	
КонецПроцедуры


///////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ по обновлению реквизитов НалоговоеНазначение(ДоходовИЗатрат)

Процедура ЗаполнитьНалоговыеНазначения(ЗаполнятьДокументы = Ложь, ДатаНачалаОбработки = '20110401') ЭКСПОРТ
	
	СтруктураНН = Новый Структура;
	
	СписокНалоговыхНазначенийНКУ_НП = Неопределено;
	СписокНалоговыхНазначенийНКУ_НДС = Неопределено;
	ПолучитьСпискиНовыхНалоговыхНазначений(СписокНалоговыхНазначенийНКУ_НП, СписокНалоговыхНазначенийНКУ_НДС);
	СтруктураНН.Вставить("СписокНалоговыхНазначенийНКУ_НП",  СписокНалоговыхНазначенийНКУ_НП);
	СтруктураНН.Вставить("СписокНалоговыхНазначенийНКУ_НДС", СписокНалоговыхНазначенийНКУ_НДС);
	
	СоответствиеНалоговыхНазначений_НП = Неопределено;
	СоответствиеНалоговыхНазначений_НДС = Неопределено;
	ПолучитьСоответствиеСтарыхИНовыхНалоговыхНазначений(СоответствиеНалоговыхНазначений_НП, СоответствиеНалоговыхНазначений_НДС);
	СтруктураНН.Вставить("СоответствиеНалоговыхНазначений_НП",  СоответствиеНалоговыхНазначений_НП);
	СтруктураНН.Вставить("СоответствиеНалоговыхНазначений_НДС", СоответствиеНалоговыхНазначений_НДС);
	
	Если ЗаполнятьДокументы = Ложь Тогда
		ТаблицаОбъектов = ЗаполнитьТаблицуОбъектовНалоговыеНазначенияСправочники();
	Иначе	
		ТаблицаОбъектов = ЗаполнитьТаблицуОбъектовНалоговыеНазначенияДокументы();
	КонецЕсли;
	
	ПредИмяОбъекта = "";
	ПредВидОбъекта = "";
	МассивСтруктурРеквизитов = Новый Массив;
	
	Для Каждого СтрокаОбъект Из ТаблицаОбъектов Цикл
		
		ИмяОбъекта = СтрокаОбъект.ИмяОбъекта;
		Если ПредИмяОбъекта <> ИмяОбъекта Тогда
			Если НЕ ПредИмяОбъекта = "" Тогда
				ОбработатьОбъектНалоговыеНазначения(ПредВидОбъекта, МассивСтруктурРеквизитов, СтруктураНН, ДатаНачалаОбработки);	
			КонецЕсли; 
			МассивСтруктурРеквизитов = Новый Массив;
		КонецЕсли; 
		
		СтруктураРеквизитов = Новый Структура(
			"ИмяОбъекта, 
			|ИмяТабличнойЧасти, 
			|ИмяРеквизитНалоговоеНазначение, 
			|ИмяРеквизитНалоговоеНазначениеДоходовИЗатрат",
			СтрокаОбъект.ИмяОбъекта, 
			СтрокаОбъект.ИмяТабличнойЧасти,
			СтрокаОбъект.ИмяРеквизитНалоговоеНазначение, 
			СтрокаОбъект.ИмяРеквизитНалоговоеНазначениеДоходовИЗатрат
			);
		МассивСтруктурРеквизитов.Добавить(СтруктураРеквизитов);
		
		
		ПредИмяОбъекта = ИмяОбъекта;
		ПредВидОбъекта = СтрокаОбъект.ВидОбъекта;
		
	КонецЦикла; 
	
	Если НЕ ПредИмяОбъекта = "" Тогда
		ОбработатьОбъектНалоговыеНазначения(ПредВидОбъекта, МассивСтруктурРеквизитов, СтруктураНН, ДатаНачалаОбработки);	
	КонецЕсли;	
	
КонецПроцедуры

