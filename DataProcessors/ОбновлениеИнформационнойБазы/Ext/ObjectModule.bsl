КонецПроцедуры

// Процедура изменяет ставшие неуникальными коды предопределенных элементов
//
Процедура УстановитьЗначениеКодаПредопределенныхЭлементов(СписокПредопределенныхЭлементов)
	
	МассивЭлементов = Новый Массив;
	
	Пока СписокПредопределенныхЭлементов.Количество()>0 Цикл
		
		МассивЭлементов.Очистить();
		КолвоЭлементовВСписке = СписокПредопределенныхЭлементов.Количество();
		ТекушийТипЗначения = ТипЗнч(СписокПредопределенныхЭлементов [КолвоЭлементовВСписке-1].Значение);
		
		МетаданныеТипа = Метаданные.НайтиПоТипу(ТекушийТипЗначения);		
		Если Метаданные.Справочники.Содержит(МетаданныеТипа) Тогда
			МенеджерТекущегоТипа = Справочники[МетаданныеТипа.Имя];
		ИначеЕсли Метаданные.ПланыВидовХарактеристик.Содержит(МетаданныеТипа) Тогда
			МенеджерТекущегоТипа = ПланыВидовХарактеристик[МетаданныеТипа.Имя];
		ИначеЕсли Метаданные.ПланыСчетов.Содержит(МетаданныеТипа) Тогда
			МенеджерТекущегоТипа = ПланыСчетов[МетаданныеТипа.Имя];	
		ИначеЕсли Метаданные.ПланыВидовРасчета.Содержит(МетаданныеТипа) Тогда
			МенеджерТекущегоТипа = ПланыВидовРасчета[МетаданныеТипа.Имя];
		Иначе
			МенеджерТекущегоТипа = Неопределено;
		КонецЕсли;
		
		Для ОбратныйИндекс = 1 По КолвоЭлементовВСписке Цикл
			ЭлементСписка = СписокПредопределенныхЭлементов [КолвоЭлементовВСписке - ОбратныйИндекс];
			
			Если ТипЗнч(ЭлементСписка.Значение) = ТекушийТипЗначения Тогда				
				ЕСли МетаданныеТипа.ДлинаКода <> 0 И МенеджерТекущегоТипа <> Неопределено Тогда
					МассивЭлементов.Добавить(ЭлементСписка.Значение);
				КонецЕсли;				
				СписокПредопределенныхЭлементов.Удалить(ЭлементСписка);				
			КонецЕсли;			
		КонецЦикла;
		
		Если МассивЭлементов.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.Текст = "
		|ВЫБРАТЬ
		|	Предопределенные.Ссылка
		|ИЗ
		|	" + МетаданныеТипа.ПолноеИмя() + " КАК Предопределенные
		|ВНУТРЕННЕЕ СОЕДИНЕНИЕ " + МетаданныеТипа.ПолноеИмя() + " КАК Пользовательские
		|		ПО Предопределенные.Код = Пользовательские.Код
		|
		|ГДЕ
		|	Предопределенные.Ссылка В(&СписокЭлементов)
		|    И Пользовательские.Ссылка НЕ В(&СписокЭлементов)";
		
		Запрос.УстановитьПараметр("СписокЭлементов", МассивЭлементов);
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Объект = Выборка.Ссылка.ПолучитьОбъект();			
			Объект.УстановитьНовыйКод();			
			Если МенеджерТекущегоТипа.НайтиПоКоду(Объект.Код).Пустая() Тогда
				
				// Поскольку меняем только код элемента, проверку корректности заполнения
				// дополнительных реквизитов объекта не выполняем.
				Объект.ОбменДанными.Загрузка = Истина;
				
				Объект.Записать();
			КонецЕсли;			
		КонецЦикла;	
		
	КонецЦикла;

КонецПроцедуры

Процедура ОбновитьСчетаУчетаНоменклатуры()
	// заполним сразу весь регистр сведений
	Запрос = Новый Запрос();
	
	Запрос.Текст = "ВЫБРАТЬ
	         |	СчетаУчетаНоменклатуры.Организация,
	         |	СчетаУчетаНоменклатуры.Номенклатура,
			 //заполняем вид номенуклатуры
			 |	СчетаУчетаНоменклатуры.Номенклатура.ВидНоменклатуры КАК ВидНоменклатуры,
			 //заполняем вид номенуклатуры
			 |	СчетаУчетаНоменклатуры.Склад,
	         |	СчетаУчетаНоменклатуры.ТипСклада,
	         |	СчетаУчетаНоменклатуры.СчетУчетаБУ,
	         |	СчетаУчетаНоменклатуры.СчетУчетаЗабалансовыйБУ,
	         |	СчетаУчетаНоменклатуры.СчетУчетаПередачиБУ,
	         |	СчетаУчетаНоменклатуры.СчетУчетаПередачиЗабалансовыйБУ,
	         |	СчетаУчетаНоменклатуры.СхемаРеализации,
	         |	СчетаУчетаНоменклатуры.СтатьяПриростаУбылиЗапасов,
	         |	СчетаУчетаНоменклатуры.НалоговоеНазначение,
	         |	СчетаУчетаНоменклатуры.УчитыватьКакЗапасНУ
	         |ИЗ
	         |	РегистрСведений.СчетаУчетаНоменклатуры КАК СчетаУчетаНоменклатуры";
	
	ОбновленнаяТаблицаРегистраЗаписей = Запрос.Выполнить().Выгрузить();
	
	СчетаУчета = РегистрыСведений.СчетаУчетаНоменклатуры.СоздатьНаборЗаписей();	
	СчетаУчета.Загрузить(ОбновленнаяТаблицаРегистраЗаписей);
	СчетаУчета.Записать(Истина);
	
КонецПроцедуры


Функция ПолучитьТаблицуДокументовПринятиеКУчетуНМА(СсылкаНач)
	
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 500
	|	Док.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ПринятиеКУчетуНМА КАК Док
	|ГДЕ
	|		Док.ВидОперации = &ПустойВидОперации"
	+?(СсылкаНач = Неопределено,""," И Док.Ссылка > &СсылкаНач ")+"
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка";

	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;

	Запрос.УстановитьПараметр("СсылкаНач", 			СсылкаНач);
	Запрос.УстановитьПараметр("ПустойВидОперации",	Перечисления.ВидыОперацийПринятияКУчетуНМА.ПустаяСсылка());

	Возврат Запрос.Выполнить().Выбрать();
	
КонецФункции // ПолучитьТаблицуДокументовПринятиеКУчетуНМА()

//Процедура заполняет новый реквизит ВидОперации в документе "ПринятиеКУчетуНМА"
//Запускается при обновлении на 1.2
Процедура ЗаполнитьРеквизитВидОперацииДокументаПринятиеКУчетуНМА() Экспорт
	
	ЕстьДокументы = Истина;
	ДокументСсылка = Неопределено;
	
	Пока ЕстьДокументы Цикл
			
		ВыборкаДокументов = ПолучитьТаблицуДокументовПринятиеКУчетуНМА(ДокументСсылка);
			
		ЕстьДокументы = ВыборкаДокументов.Количество()>0;
			
		Пока ВыборкаДокументов.Следующий() цикл
	
			ДокументСсылка = ВыборкаДокументов.ссылка;
			ДокументОбъект = ВыборкаДокументов.ссылка.ПолучитьОбъект();	
			Если ДокументОбъект.ВводНачальныхОстатков Тогда
				ДокументОбъект.ВидОперации = Перечисления.ВидыОперацийПринятияКУчетуНМА.ВводНачальныхОстатков;
			Иначе	
				ДокументОбъект.ВидОперации = Перечисления.ВидыОперацийПринятияКУчетуНМА.НематериальныеАктивы;
			КонецЕсли;	
			ДокументОбъект.Записать();
			
		КонецЦикла;
		
	КонецЦикла;

КонецПроцедуры



Функция ПолучитьТаблицуДокументовПередачаМалоценкиВЭксплуатацию(СсылкаНач)
	
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 500
	|	Док.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ПередачаМалоценкиВЭксплуатацию КАК Док
	|ГДЕ
	|	Док.МалоценныеАктивы.Качество = &ПустоеКачество"
	+?(СсылкаНач = Неопределено,""," И Док.Ссылка > &СсылкаНач ")+"
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка";

	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;

	Запрос.УстановитьПараметр("СсылкаНач", 		СсылкаНач);
	Запрос.УстановитьПараметр("ПустоеКачество",	Справочники.Качество.ПустаяСсылка());

	Возврат Запрос.Выполнить().Выбрать();
	
КонецФункции // ПолучитьТаблицуДокументовПринятиеКУчетуНМА()

//Процедура заполняет новый реквизит табличной части Качество в документе "ПередачаМалоценкиВЭксплуатацию"
Процедура ЗаполнитьКачествоДокументаПередачаМалоценкиВЭксплуатацию()

	ЕстьДокументы = Истина;
	ДокументСсылка = Неопределено;
	
	Пока ЕстьДокументы Цикл
			
		ВыборкаДокументов = ПолучитьТаблицуДокументовПередачаМалоценкиВЭксплуатацию(ДокументСсылка);
			
		ЕстьДокументы = ВыборкаДокументов.Количество()>0;
			
		Пока ВыборкаДокументов.Следующий() цикл
	
			ДокументСсылка = ВыборкаДокументов.ссылка;
			ДокументОбъект = ВыборкаДокументов.ссылка.ПолучитьОбъект();	

			Для Каждого СтрокаТЧ Из ДокументОбъект.МалоценныеАктивы Цикл
				Если НЕ ЗначениеЗаполнено(СтрокаТЧ.Качество) Тогда
					СтрокаТЧ.Качество = Справочники.Качество.Новый;
				КонецЕсли;	
			КонецЦикла;	
			
			ДокументОбъект.Записать();
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры	

// В документе "Требование-накладная" аналитика затрат по УУ перенесена из таблчиной части в шапку
// Если аналитика во всей табличной части одинакова - заполним шапку этой одинаковой аналитикой
Процедура ПереносТребованиеНакладнаяАналитикаЗатратПоУУ()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТребованиеНакладнаяМатериалы.Ссылка КАК Ссылка,
	|	ТребованиеНакладнаяМатериалы.Ссылка.Представление КАК ПредставлениеДокумента,
	|	ТребованиеНакладнаяМатериалы.СтатьяЗатрат КАК СтатьяЗатрат,
	|	ТребованиеНакладнаяМатериалы.НоменклатурнаяГруппа КАК НоменклатурнаяГруппа,
	|	ТребованиеНакладнаяМатериалы.ОбъектСтроительства КАК ОбъектСтроительства
	|ИЗ
	|	Документ.ТребованиеНакладная.Материалы КАК ТребованиеНакладнаяМатериалы
	|ИТОГИ ПО
	|	Ссылка";
	
	Результат = Запрос.Выполнить();
	ВыборкаПоДокументам = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаПоДокументам.Следующий() Цикл
		Выборка = ВыборкаПоДокументам.Выбрать();
		Если Выборка.Количество() = 1 Тогда
			// все необходимые реквизиты в табличной части одинаковы, можно заполнить шапку
			Выборка.Следующий();
			
			ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();
			
			ДокументОбъект.СтатьяЗатрат = Выборка.СтатьяЗатрат;
			ДокументОбъект.НоменклатурнаяГруппа = Выборка.НоменклатурнаяГруппа;
			ДокументОбъект.ОбъектСтроительства = Выборка.ОбъектСтроительства;
			
			Попытка
				ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
			Исключение
				Сообщить(НСтр("ru='Невозможно записать документ <';uk='Неможливо записати документ <'")+Выборка.ПредставлениеДокумента+">!", СтатусСообщения.Внимание);
			КонецПопытки;

		Иначе
			Продолжить;
		КонецЕсли; 		
	КонецЦикла;
	 

КонецПроцедуры // ПереносТребованиеНакладнаяАналитикаЗатратПоУУ()
 
