Процедура ПерезаполнитьПроводкиПоЗарплатнымДокументамНалоговымиНазначениямиНКУ()
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("ДатаНач", '20110401');
	Запрос.Текст = "ВЫБРАТЬ
	               |	НачислениеЗарплатыРаботникамОрганизаций.Ссылка,
	               |	НачислениеЗарплатыРаботникамОрганизаций.Проведен
	               |ИЗ
	               |	Документ.НачислениеЗарплатыРаботникамОрганизаций КАК НачислениеЗарплатыРаботникамОрганизаций
	               |ГДЕ
	               |	НачислениеЗарплатыРаботникамОрганизаций.Дата >= &ДатаНач
	               |	И НачислениеЗарплатыРаботникамОрганизаций.Проведен";
				   
	Выборка = Запрос.Выполнить().Выбрать();				   
	Пока Выборка.Следующий() Цикл
		
		Док = Выборка.Ссылка.ПолучитьОбъект();
		
	    Сотрудники = Док.РаботникиОрганизации.ВыгрузитьКолонку("Сотрудник");
		
		Док.Записать(РежимЗаписиДокумента.ОтменаПроведения);
		
		Если Док.НачисленияПроводки.Количество() = 0 И 
			 Док.УдержанияПроводки.Количество() = 0 И 
			 Док.ВзносыПроводки.Количество() = 0 И 
			 Док.ВзносыФОТПроводки.Количество() = 0 И 
			 Док.НДФЛПроводки.Количество() = 0 
			Тогда
			Сообщить(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСТР("ru='Не удалось автоматически обработать документ: %1"
"    Перезаполните бухгалтерские проводки вручную!';uk='Не вдалося автоматично обробити документ: %1"
"    Перезаповніть бухгалтерські проведення вручну!'"), Док));	
			Продолжить;
		КонецЕсли;
		
	    Док.НачисленияПроводки.Очистить();
	    Док.ВзносыФОТПроводки.Очистить();
		Док.Записать(РежимЗаписиДокумента.Запись);
	    Док.РассчитатьНачисленияПроводки( Сотрудники );
	    Док.РассчитатьВзносыФОТПроводки( Сотрудники );
	    Док.АвтозаполнениеПроводок();
		
		Попытка
			Если Выборка.Проведен = Истина Тогда
			    Док.Записать(РежимЗаписиДокумента.Проведение);
			Иначе	
				Док.ОбменДанными.Загрузка = Истина;
				Док.Записать(РежимЗаписиДокумента.Запись);
			КонецЕсли;
		Исключение
			Сообщить(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСТР("ru='Не удалось обработать документ: %1"
"    Перезаполните бухгалтерские проводки вручную!';uk='Не вдалося обробити документ: %1"
"    Перезаповніть бухгалтерські проведення вручну!'"), Док));	
		КонецПопытки	
	
	КонецЦикла;
	
КонецПроцедуры

