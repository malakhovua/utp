Функция ПолучитьВыборкуДокументов(ТипДокумента, ДатаНач, СсылкаНач)
	
	
	УсловиеСсылка = " Ссылка > &СсылкаНач ";
	УсловиеДата = " ВыборкаДокументы.Дата >= &ДатаНач ";
	
	Условие = "";
	
	Если СсылкаНач = Неопределено Тогда
		Если ЗначениеЗаполнено(ДатаНач) Тогда
			Условие = " ГДЕ " + УсловиеДата;
		КонецЕсли;
	Иначе
		Если ЗначениеЗаполнено(ДатаНач) Тогда
			Условие = " ГДЕ " + УсловиеСсылка + " И " + УсловиеДата;
		Иначе
			Условие = " ГДЕ " + УсловиеСсылка;
		КонецЕсли;
	КонецЕсли; 	
	
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("СсылкаНач", СсылкаНач);
	Запрос.УстановитьПараметр("ДатаНач",   ДатаНач);

	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 500
	|	ВыборкаДокументы.Ссылка КАК Ссылка
	|ИЗ
	|	Документ." + ТипДокумента + " КАК ВыборкаДокументы 
	| " +
	Условие + "
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка";
	
    Возврат Запрос.Выполнить().Выбрать();

КонецФункции

Процедура УвеличениеДлиныНомеровДокументов(ТипДокумента, ДатаНач) Экспорт
	
	НоваяДлинаНомера = Метаданные.Документы[ТипДокумента].ДлинаНомера;
	
	ЕстьДокументы = Истина;
	ДокументСсылка = Неопределено;
	
	Пока ЕстьДокументы Цикл
		
		Выборка = ПолучитьВыборкуДокументов(ТипДокумента, ДатаНач, ДокументСсылка);
		ЕстьДокументы = Выборка.Количество() > 0;
		
		Пока Выборка.Следующий() Цикл
			
			ДокументСсылка = Выборка.Ссылка;
			
			ДокументОбъект = ДокументСсылка.ПолучитьОбъект();
			
			СтарыйНомер = СокрЛП(ДокументОбъект.Номер);
			
			// ищем с конца до начала первую не цифру - то что нашли - числовая часть номера 
			// ее дополняем 0-ми до новой длины, остальное префикс - оставляем неизменным и затем дополняем
			ДлинаСтарогоНомера = СтрДлина(СтарыйНомер);
			
			ДополняющихНулей = НоваяДлинаНомера - ДлинаСтарогоНомера;
			Если ДополняющихНулей <= 0 Тогда
				Продолжить;
			КонецЕсли;
			
			Для н = 0 по ДлинаСтарогоНомера - 1 Цикл
				Если НЕ ОбщегоНазначения.ТолькоЦифрыВСтроке(Сред(СтарыйНомер, ДлинаСтарогоНомера - н, 1), Истина, Ложь) Тогда
					Прервать;
				КонецЕсли;
			КонецЦикла;
			
			ДлинаЧисловойЧастиНомера = н;
			
			Если ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.НалоговаяНакладная") Тогда
				ОбособленноеПодразделение = ДокументОбъект.ОбособленноеПодразделение;
			ИначеЕсли ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.Приложение2КНалоговойНакладной") Тогда
				ОбособленноеПодразделение = ДокументОбъект.НалоговаяНакладная.ОбособленноеПодразделение;
			КонецЕсли;
			Если ЗначениеЗаполнено(ОбособленноеПодразделение) Тогда
				
				ПрефиксОбособленногоПодразделения = ОбособленноеПодразделение.Префикс;
				ДлинаПрефиксаОбособленногоПодразделения = СтрДлина(ПрефиксОбособленногоПодразделения);
				Если ДлинаПрефиксаОбособленногоПодразделения > 0 Тогда
					
					ДлинаЧисловойЧастиПрефиксаОбособленногоПодразделения = 0;
					Для к = 0 по СтрДлина(ПрефиксОбособленногоПодразделения) - 1 Цикл
						Если ОбщегоНазначения.ТолькоЦифрыВСтроке(Сред(ПрефиксОбособленногоПодразделения, ДлинаПрефиксаОбособленногоПодразделения - к, 1), Истина, Ложь) Тогда
							ДлинаЧисловойЧастиПрефиксаОбособленногоПодразделения = ДлинаЧисловойЧастиПрефиксаОбособленногоПодразделения + 1;
						Иначе
							Прервать;
						КонецЕсли;
					КонецЦикла;
					
					Если ДлинаЧисловойЧастиПрефиксаОбособленногоПодразделения > 0 Тогда
						ЧисловаяЧастьПрефиксаОбособленногоПодразделения = Сред(ПрефиксОбособленногоПодразделения, ДлинаПрефиксаОбособленногоПодразделения -
							ДлинаЧисловойЧастиПрефиксаОбособленногоПодразделения + 1, ДлинаЧисловойЧастиПрефиксаОбособленногоПодразделения);
							
						ЧисловаяЧастьНомера = Сред(СтарыйНомер, ДлинаСтарогоНомера - н + 1);
						Если ЧисловаяЧастьПрефиксаОбособленногоПодразделения = Лев(ЧисловаяЧастьНомера, ДлинаЧисловойЧастиПрефиксаОбособленногоПодразделения) Тогда
							ДлинаЧисловойЧастиНомера = ДлинаЧисловойЧастиНомера - ДлинаЧисловойЧастиПрефиксаОбособленногоПодразделения;
						КонецЕсли;
							
					КонецЕсли;
					
				КонецЕсли;
					
			КонецЕсли;
			
			Префикс = Сред(СтарыйНомер, 1, ДлинаСтарогоНомера - ДлинаЧисловойЧастиНомера);
			ЧисловаяЧастьНомера = Сред(СтарыйНомер, ДлинаСтарогоНомера - ДлинаЧисловойЧастиНомера + 1);
			
			Для к = 1 По ДополняющихНулей Цикл
				ЧисловаяЧастьНомера = "0" + ЧисловаяЧастьНомера;
			КонецЦикла;
			
			НовыйНомер = Префикс + ЧисловаяЧастьНомера;
			
			ДокументОбъект.Номер = НовыйНомер;

			ДокументОбъект.ОбменДанными.Загрузка = Истина;
			ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
			
		КонецЦикла;		
	КонецЦикла;
	
КонецПроцедуры

