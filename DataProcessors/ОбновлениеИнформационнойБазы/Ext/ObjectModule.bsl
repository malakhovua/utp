КонецПроцедуры 

Процедура ОбработатьОбъектНалоговыеНазначения(ВидОбъекта, МассивСтруктурРеквизитов, СтруктураНН, ДатаНачалаОбработки)
	
	Если ВидОбъекта = "Справочник" Тогда
		ОбработатьСправочникДокументНалоговыеНазначения(МассивСтруктурРеквизитов, 1, СтруктураНН, ДатаНачалаОбработки);
	ИначеЕсли ВидОбъекта = "Документ" Тогда
		ОбработатьСправочникДокументНалоговыеНазначения(МассивСтруктурРеквизитов, 2, СтруктураНН, ДатаНачалаОбработки);
	ИначеЕсли ВидОбъекта = "РегистрСведений" Тогда
		ОбработатьРегистрСведенийНалоговыеНазначения(МассивСтруктурРеквизитов, 2, СтруктураНН);
	КонецЕсли; 
	
КонецПроцедуры 

Процедура ОбработатьРегистрСведенийНалоговыеНазначения(МассивСтруктурРеквизитов, ВидРегистра, СтруктураНН)
	
	ИмяРегистра = МассивСтруктурРеквизитов[0].ИмяОбъекта;

	НаборДвижений = РегистрыСведений[ИмяРегистра].СоздатьНаборЗаписей();
			
	НаборДвижений.Прочитать();

	ИзмененыДвижения = Ложь;
	Для Каждого Движение Из НаборДвижений Цикл
		
		Для Каждого СтруктураРеквизитов Из МассивСтруктурРеквизитов Цикл
			
			// определим реквизит, который необходимо использовать как источник данных для преобразования
			ННИсточник 			= ?(ЗначениеЗаполнено(СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначение), СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначение, СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначениеДоходовИЗатрат); 
			ЗначениеННИсточника = Движение[ННИсточник];
			
			// пустой реквизит - преобразовывать нечего
			Если НЕ ЗначениеЗаполнено(ЗначениеННИсточника) Тогда
				Продолжить;
			КонецЕсли;
			
			// реквизит уже преобразован
			Если    НЕ СтруктураНН.СписокНалоговыхНазначенийНКУ_НДС.НайтиПоЗначению(ЗначениеННИсточника) = Неопределено
				ИЛИ НЕ СтруктураНН.СписокНалоговыхНазначенийНКУ_НП.НайтиПоЗначению(ЗначениеННИсточника)  = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			// выполняем преобразование
			Если ЗначениеЗаполнено(СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначение) Тогда
				Движение[СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначение] = СтруктураНН.СоответствиеНалоговыхНазначений_НДС.Получить(ЗначениеННИсточника);
				ИзмененыДвижения = Истина;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначениеДоходовИЗатрат) Тогда
				Движение[СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначениеДоходовИЗатрат] = СтруктураНН.СоответствиеНалоговыхНазначений_НП.Получить(ЗначениеННИсточника);
				ИзмененыДвижения = Истина;
			КонецЕсли;
			
		КонецЦикла; 
			
	КонецЦикла; 	
		
	Если ИзмененыДвижения Тогда
		НаборДвижений.ОбменДанными.Загрузка = Истина;
		НаборДвижений.Записать(Истина);
	КонецЕсли;
	
КонецПроцедуры 

Процедура ОбработатьСправочникДокументНалоговыеНазначения(МассивСтруктурРеквизитов, Вид, СтруктураНН, ДатаНачалаОбработки)
	
	ИмяОбъекта = МассивСтруктурРеквизитов[0].ИмяОбъекта;
	
	ЕстьДокументы = Истина;
	ДокументСсылка = Неопределено;
	
	МассивТабЧастей = Новый Массив;
	Для Каждого СтруктураРеквизитов Из МассивСтруктурРеквизитов Цикл
		Если СтруктураРеквизитов.ИмяТабличнойЧасти <> "" Тогда
			Если МассивТабЧастей.Найти(СтруктураРеквизитов.ИмяТабличнойЧасти) = Неопределено Тогда
				МассивТабЧастей.Добавить(СтруктураРеквизитов.ИмяТабличнойЧасти)
			КонецЕсли; 
		КонецЕсли; 
	КонецЦикла;	
	
	Пока ЕстьДокументы Цикл
		
		ТаблицаДокументов = ПолучитьТаблицуСправочниковДокументов(ДокументСсылка, ИмяОбъекта, Вид, ДатаНачалаОбработки);
		
		ЕстьДокументы = ТаблицаДокументов.Количество() > 0;
		
		Для Каждого Строка Из ТаблицаДокументов Цикл
			
			ДокументСсылка = Строка.Ссылка;
			
			ДокументОбъект = ДокументСсылка.ПолучитьОбъект();
			
			ОбъектИзменен = Ложь;
			
			// обрабатываем шапку
			Для Каждого СтруктураРеквизитов Из МассивСтруктурРеквизитов Цикл
				
				Если СтруктураРеквизитов.ИмяТабличнойЧасти <> "" Тогда
					Продолжить;
				КонецЕсли; 
				
				Если Вид = 1 И ДокументОбъект.ЭтоГруппа Тогда // Вид = 1 - Справочник
					Продолжить;
				КонецЕсли;	
				
				Если ИмяОбъекта = "РасходыБудущихПериодов" Тогда
					// заполняем отсутствующие в предыдущей редакции реквизиты
					
					// особый справочник, НН в нем не было в ред. 1.1
					Если    ЗначениеЗаполнено(ДокументОбъект[СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначение])
						ИЛИ ЗначениеЗаполнено(ДокументОбъект[СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначениеДоходовИЗатрат]) Тогда
						
						// обновлен ранее
						Продолжить;	
					
					КонецЕсли;
					
					ОбъектИзменен = Истина;
					ДокументОбъект[СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначениеДоходовИЗатрат] = Справочники.НалоговыеНазначенияАктивовИЗатрат.НКУ_ХозДеятельность;
					
					ХарактерЗатрат = УправлениеПроизводством.ПолучитьХарактерЗатратПоСчетуЗатрат(ДокументОбъект.СчетБУ, Неопределено);
					ТипОбъектСтроительста = Тип("СправочникСсылка.ОбъектыСтроительства");
					ТипНМА                = Тип("СправочникСсылка.НематериальныеАктивы");
					ТипНГ                 = Тип("СправочникСсылка.НоменклатурныеГруппы");
					
					Если    ХарактерЗатрат = "Производство"
						ИЛИ ХарактерЗатрат = "Строительство" Тогда
						
						ЦелевоеНалоговоеНазначение = Неопределено;
						
						Для Н = 1 По 3 Цикл
							
							ЗначениеСубконто = ДокументОбъект["СубконтоБУ" + Н];
							
							Если ТипЗнч(ЗначениеСубконто) = ТипНГ Тогда
								
								ЦелевоеНалоговоеНазначение = ДокументОбъект["СубконтоБУ" +Н].НалоговоеНазначениеВПроизводстве;
								Прервать;
								
							ИначеЕсли ТипЗнч(ЗначениеСубконто) = ТипОбъектСтроительста
								ИЛИ ТипЗнч(ЗначениеСубконто) = ТипНМА Тогда
								
								ЦелевоеНалоговоеНазначение = ДокументОбъект["СубконтоБУ" +Н].НалоговоеНазначение;
								Прервать;
								
							КонецЕсли;
							
						КонецЦикла;
						
						ДокументОбъект[СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначение] = ЦелевоеНалоговоеНазначение;
						
					КонецЕсли;						
					
				ИначеЕсли  ИмяОбъекта = "ИзменениеНалоговогоНазначенияЗапасов"
					   ИЛИ ИмяОбъекта = "ИзменениеНалоговогоНазначенияОС" 
					   ИЛИ ИмяОбъекта = "КорректировкаОжидаемогоИПодтвержденногоНДС"
					   ИЛИ ИмяОбъекта = "НалоговаяНакладная"
					   ИЛИ ИмяОбъекта = "СписаниеНМА"
					   ИЛИ ИмяОбъекта = "СписаниеОС"
					   
					   Тогда	
					   
					// заполняем по-умолчанию для прибыли
					Если НЕ ЗначениеЗаполнено(ДокументОбъект.НалоговоеНазначениеДоходовИЗатрат) Тогда
						ОбъектИзменен = Истина;
						ДокументОбъект.НалоговоеНазначениеДоходовИЗатрат = Справочники.НалоговыеНазначенияАктивовИЗатрат.НКУ_ХозДеятельность;
					КонецЕсли;	
						
				ИначеЕсли  ИмяОбъекта = "ПоступлениеНМА"
					Тогда	
					   
					// заполняем по-умолчанию в ТЧ ДокументыРасчетовСКонтрагентом из НН НМА из первой строки док
					Если  ДокументОбъект.ДокументыРасчетовСКонтрагентом.Количество() > 0
						И НЕ ЗначениеЗаполнено(ДокументОбъект.ДокументыРасчетовСКонтрагентом[0].НалоговоеНазначение)
						И ДокументОбъект.НМА.Количество() > 0 Тогда
						
						ОбъектИзменен = Истина;
						ЗначениеННИсточника = ДокументОбъект.НМА[0].НематериальныйАктив.НалоговоеНазначение;
						НовоеЗначениеНН = СтруктураНН.СоответствиеНалоговыхНазначений_НДС.Получить(ЗначениеННИсточника);
						Для каждого СтрОб Из ДокументОбъект.ДокументыРасчетовСКонтрагентом Цикл
						
							СтрОб.НалоговоеНазначение = НовоеЗначениеНН;
						
						КонецЦикла;
						
					КонецЕсли;	
						
				Иначе	
					
					// определим реквизит, который необходимо использовать как источник данных для преобразования
					ННИсточник 			= ?(ЗначениеЗаполнено(СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначение), СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначение, СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначениеДоходовИЗатрат); 
					ЗначениеННИсточника = ДокументОбъект[ННИсточник];
					
					// пустой реквизит - преобразовывать нечего
					Если НЕ ЗначениеЗаполнено(ЗначениеННИсточника) Тогда
						Продолжить;
					КонецЕсли;
					
					// реквизит уже преобразован
					Если    НЕ СтруктураНН.СписокНалоговыхНазначенийНКУ_НДС.НайтиПоЗначению(ЗначениеННИсточника) = Неопределено
						ИЛИ НЕ СтруктураНН.СписокНалоговыхНазначенийНКУ_НП.НайтиПоЗначению(ЗначениеННИсточника)  = Неопределено Тогда
						Продолжить;
					КонецЕсли;
					
					// выполняем преобразование
					Если ЗначениеЗаполнено(СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначение) Тогда
						ДокументОбъект[СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначение] = СтруктураНН.СоответствиеНалоговыхНазначений_НДС.Получить(ЗначениеННИсточника);
						ОбъектИзменен = Истина;
					КонецЕсли;
					
					Если ЗначениеЗаполнено(СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначениеДоходовИЗатрат) Тогда
						ДокументОбъект[СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначениеДоходовИЗатрат] = СтруктураНН.СоответствиеНалоговыхНазначений_НП.Получить(ЗначениеННИсточника);
						ОбъектИзменен = Истина;
					КонецЕсли;
					
					// заполняем зависимые реквизиты шапки
					Если ИмяОбъекта = "ВводВЭксплуатациюОС" Тогда
						ДокументОбъект.НалоговоеНазначениеОборудования = ДокументОбъект.НалоговоеНазначение;
					КонецЕсли;
					
				КонецЕсли;
			
			КонецЦикла; 
			
			// обрабатываем таб. части
			Для Каждого ИмяТабЧасти Из МассивТабЧастей Цикл
				Для Каждого СтрокаТабЧасти Из ДокументОбъект[ИмяТабЧасти] Цикл
					
					ЕстьУдалитьПропорциональныйНДС = НЕ ДокументОбъект.Метаданные().ТабличныеЧасти[ИмяТабЧасти].Реквизиты.Найти("УдалитьПропорциональныйНДС") = Неопределено;					
					
					Для Каждого СтруктураРеквизитов Из МассивСтруктурРеквизитов Цикл
				
						Если СтруктураРеквизитов.ИмяТабличнойЧасти <> ИмяТабЧасти Тогда
							Продолжить;
						КонецЕсли; 
						
						Если    (ИмяОбъекта  = "ВводНачальныхОстатков" И ИмяТабЧасти = "МалоценныеАктивы")
							ИЛИ ИмяОбъекта = "ВводНачальныхОстатковМалоценкиВЭксплуатации"
							ИЛИ ИмяОбъекта = "ПеремещениеМалоценкиВЭксплуатации"
							ИЛИ ИмяОбъекта = "ПередачаМалоценкиВЭксплуатацию"
							Тогда
							 
							// заполняем отсутствующие в предыдущей редакции реквизиты
							Если НЕ ЗначениеЗаполнено(СтрокаТабЧасти.НалоговоеНазначение) Тогда
							
								ОбъектИзменен = Истина;
								СтрокаТабЧасти.НалоговоеНазначение = Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_Облагаемая;
							
							КонецЕсли;
							
						ИначеЕсли  (ИмяОбъекта = "ОтчетПроизводстваЗаСмену" И ИмяТабЧасти = "Услуги")
							   ИЛИ ИмяОбъекта = "ПередачаНМА" 
							   ИЛИ ИмяОбъекта = "ПередачаОС" 
							Тогда     
							 
							// заполняем отсутствующие в предыдущей редакции реквизиты
							Если НЕ ЗначениеЗаполнено(СтрокаТабЧасти.НалоговоеНазначениеДоходовИЗатрат) Тогда
							
								ОбъектИзменен = Истина;
								СтрокаТабЧасти.НалоговоеНазначениеДоходовИЗатрат = Справочники.НалоговыеНазначенияАктивовИЗатрат.НКУ_ХозДеятельность;
								
							КонецЕсли;
	
						ИначеЕсли ИмяОбъекта = "ИзменениеНалоговогоНазначенияОС" Тогда	
							
							Если НЕ ЗначениеЗаполнено(СтрокаТабЧасти.НалоговоеНазначение) Тогда
							
								ОбъектИзменен = Истина;
								СтрокаТабЧасти.НалоговоеНазначениеНовое = СтруктураНН.СоответствиеНалоговыхНазначений_НДС.Получить(ДокументОбъект.УдалитьНалоговоеНазначение);
								
								ДанныеПоСтаромуНН =РегистрыСведений.НалоговыеНазначенияОС.СрезПоследних(ДокументОбъект.МоментВремени(), Новый Структура("Организация, ОсновноеСредство", ДокументОбъект.Организация, СтрокаТабЧасти.ОсновноеСредство));
								Если ДанныеПоСтаромуНН.Количество() > 0  Тогда
									СтароеНН = ДанныеПоСтаромуНН[0].НалоговоеНазначение;	
									Если СтруктураНН.СписокНалоговыхНазначенийНКУ_НДС.НайтиПоЗначению(СтароеНН) = Неопределено Тогда
									    СтрокаТабЧасти.НалоговоеНазначение = СтруктураНН.СоответствиеНалоговыхНазначений_НДС.Получить(СтароеНН);
									Иначе	
										СтрокаТабЧасти.НалоговоеНазначение = СтароеНН;
									КонецЕсли;
								КонецЕсли;
								
							КонецЕсли;
							
						ИначеЕсли ИмяОбъекта = "ПередачаОборудованияВМонтаж" Тогда	
							
							Если НЕ ЗначениеЗаполнено(СтрокаТабЧасти.НалоговоеНазначение) Тогда
								ОбъектИзменен = Истина;
								СтрокаТабЧасти.НалоговоеНазначение = ДокументОбъект.ОбъектСтроительства.НалоговоеНазначение;
							КонецЕсли;				
							
						ИначеЕсли (ИмяОбъекта = "ПередачаТоваров" И ИмяТабЧасти = "ВозвратнаяТара")
							
							Тогда
							
							Если НЕ ЗначениеЗаполнено(СтрокаТабЧасти.НалоговоеНазначение) Тогда
							
								ОбъектИзменен = Истина;
								СтрокаТабЧасти.НалоговоеНазначение = Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_НеоблагаемаяХозДеятельность;
								СтрокаТабЧасти.НалоговоеНазначениеДоходовИЗатрат = Справочники.НалоговыеНазначенияАктивовИЗатрат.НКУ_ХозДеятельность;
								
							КонецЕсли;
							
						//ИначеЕсли (ИмяОбъекта = "ПоступлениеИзПереработки" И ИмяТабЧасти = "ВозвратнаяТара")
						//	
						//	Тогда
						//	
						//	Если НЕ ЗначениеЗаполнено(СтрокаТабЧасти.НалоговоеНазначение) Тогда
						//	
						//		ОбъектИзменен = Истина;
						//		СтрокаТабЧасти.НалоговоеНазначение = Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_НеоблагаемаяХозДеятельность;
						//		
						//	КонецЕсли;
							
						ИначеЕсли (ИмяОбъекта = "ПоступлениеИзПереработки" И ИмяТабЧасти = "ИспользованныеМатериалы")
							  ИЛИ (ИмяОбъекта = "ПоступлениеИзПереработки" И ИмяТабЧасти = "Услуги")	
							Тогда
							
							Если НЕ ЗначениеЗаполнено(СтрокаТабЧасти.НалоговоеНазначение) Тогда
							
								ОбъектИзменен = Истина;
								СтрокаТабЧасти.НалоговоеНазначение 				 = ДокументОбъект.НоменклатурнаяГруппа.НалоговоеНазначениеВПроизводстве;
								//Если ИмяТабЧасти = "Услуги" Тогда
								//	СтрокаТабЧасти.НалоговоеНазначениеДоходовИЗатрат = Справочники.НалоговыеНазначенияАктивовИЗатрат.НКУ_ХозДеятельность;	
								//КонецЕсли;
								
							КонецЕсли;
							
						Иначе
							
							// определим реквизит, который необходимо использовать как источник данных для преобразования
							ННИсточник 			= ?(ЗначениеЗаполнено(СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначение), СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначение, СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначениеДоходовИЗатрат); 
							ЗначениеННИсточника = СтрокаТабЧасти[ННИсточник];
							
							// пустой реквизит - преобразовывать нечего
							Если НЕ ЗначениеЗаполнено(ЗначениеННИсточника) Тогда
								Продолжить;
							КонецЕсли;
							
							// реквизит уже преобразован
							Если    НЕ СтруктураНН.СписокНалоговыхНазначенийНКУ_НДС.НайтиПоЗначению(ЗначениеННИсточника) = Неопределено
								ИЛИ НЕ СтруктураНН.СписокНалоговыхНазначенийНКУ_НП.НайтиПоЗначению(ЗначениеННИсточника)  = Неопределено Тогда
								Продолжить;
							КонецЕсли;
							
							// выполняем преобразование
							Если ЗначениеЗаполнено(СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначение) Тогда
								Если  ЕстьУдалитьПропорциональныйНДС
									И СтрокаТабЧасти["УдалитьПропорциональныйНДС"] = Истина Тогда
									СтрокаТабЧасти[СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначение] = Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_Пропорционально;
								Иначе
									СтрокаТабЧасти[СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначение] = СтруктураНН.СоответствиеНалоговыхНазначений_НДС.Получить(ЗначениеННИсточника);
									ОбъектИзменен = Истина;
								КонецЕсли;
							КонецЕсли;
							
							Если ЗначениеЗаполнено(СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначениеДоходовИЗатрат) Тогда
								СтрокаТабЧасти[СтруктураРеквизитов.ИмяРеквизитНалоговоеНазначениеДоходовИЗатрат] = СтруктураНН.СоответствиеНалоговыхНазначений_НП.Получить(ЗначениеННИсточника);
								ОбъектИзменен = Истина;
							КонецЕсли;
							
							// заполняем зависимые реквизиты шапки по первой обработанной строке документа
							// налоговое назначение по прибыли берем из первой строки ТЧ
							Если    ИмяОбъекта = "ГТДИмпорт"
								ИЛИ ИмяОбъекта = "СписаниеТоваров"
								ИЛИ ИмяОбъекта = "ТребованиеНакладная"
								ИЛИ ИмяОбъекта = "ОприходованиеТоваров" 
							    ИЛИ ИмяОбъекта = "КорректировкаДолга" Тогда
								Если НЕ ЗначениеЗаполнено(ДокументОбъект.НалоговоеНазначениеДоходовИЗатрат)
									И ОбъектИзменен = Истина Тогда
									ДокументОбъект.НалоговоеНазначениеДоходовИЗатрат = СтруктураНН.СоответствиеНалоговыхНазначений_НП.Получить(ЗначениеННИсточника);
								КонецЕсли;
							КонецЕсли;
							
							// Признак Амортизируется в платежных документах установим исходя из старого НН
							Если    ИмяТабЧасти = "РасшифрокаПлатежа"
								ИЛИ ИмяТабЧасти = "ОплатаПоставщикам" Тогда
							
								СтрокаТабЧасти.Амортизируется = ЗначениеННИсточника.Амортизируется;
								
							КонецЕсли;
						КонецЕсли;
						
					КонецЦикла;
				КонецЦикла; 
			КонецЦикла;	
			
			Если ОбъектИзменен Тогда
				ДокументОбъект.ОбменДанными.Загрузка = Истина;
				ДокументОбъект.Записать();
			КонецЕсли; 
				
		КонецЦикла;
		
	КонецЦикла;

КонецПроцедуры // 

Функция ПолучитьТаблицуРегистраторов(СсылкаНач, ИмяРегистра, ВидРегистра)
	
	ТекстЗапроса = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 500
	|	РегистрУчета.Регистратор КАК Регистратор
	|ИЗ 	
	|	Регистр"+?(ВидРегистра=1,"Накопления","Сведений")+"." + ИмяРегистра + " КАК РегистрУчета "
	+ ?(СсылкаНач = Неопределено,""," ГДЕ РегистрУчета.Регистратор > &СсылкаНач ") + "
	|
	|УПОРЯДОЧИТЬ ПО Регистратор
	|";
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;

	Запрос.УстановитьПараметр("СсылкаНач", 				СсылкаНач);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции // ПолучитьТаблицуРегистраторов()

Функция ПолучитьТаблицуСправочниковДокументов(СсылкаНач, ИмяСправочникаДокумента, Вид, ДатаНачалаОбработки)
	
	ТекстЗапроса = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 500
	|	Таблица.Ссылка КАК Ссылка
	|ИЗ 	
	|	"+?(Вид = 1, "Справочник", "Документ")+"." + ИмяСправочникаДокумента + " КАК Таблица 
	| ГДЕ "
	+ ?(СсылкаНач = Неопределено,"ИСТИНА "," Таблица.Ссылка > &СсылкаНач ")  
	+ ?(Вид = 1, "", " И  Дата >= &ДатаНачалаОбработки ") + "
	|
	|УПОРЯДОЧИТЬ ПО Ссылка
	|";
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;

	Запрос.УстановитьПараметр("СсылкаНач", 				СсылкаНач);
	Запрос.УстановитьПараметр("ДатаНачалаОбработки", 				ДатаНачалаОбработки);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции // ПолучитьТаблицуСправочниковДокументов()

Процедура ПолучитьСпискиНовыхНалоговыхНазначений(ПоПрибыли = Неопределено, ПоНДС = Неопределено)

	ПоНДС = Новый СписокЗначений();
	ПоНДС.Добавить(Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_НеоблагаемаяНеХозДеятельность);
	ПоНДС.Добавить(Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_НеоблагаемаяХозДеятельность);
	ПоНДС.Добавить(Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_Облагаемая);
	ПоНДС.Добавить(Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_Пропорционально);

	ПоПрибыли = Новый СписокЗначений();
	ПоПрибыли.Добавить(Справочники.НалоговыеНазначенияАктивовИЗатрат.НКУ_БытУслуги);
	ПоПрибыли.Добавить(Справочники.НалоговыеНазначенияАктивовИЗатрат.НКУ_ИгорБизнес);
	ПоПрибыли.Добавить(Справочники.НалоговыеНазначенияАктивовИЗатрат.НКУ_НеХозДеятельность);
	ПоПрибыли.Добавить(Справочники.НалоговыеНазначенияАктивовИЗатрат.НКУ_ОбмВалюты);
	ПоПрибыли.Добавить(Справочники.НалоговыеНазначенияАктивовИЗатрат.НКУ_Освобожденная);
	ПоПрибыли.Добавить(Справочники.НалоговыеНазначенияАктивовИЗатрат.НКУ_Распределяемая);
	ПоПрибыли.Добавить(Справочники.НалоговыеНазначенияАктивовИЗатрат.НКУ_ТоргДеятельность);
	ПоПрибыли.Добавить(Справочники.НалоговыеНазначенияАктивовИЗатрат.НКУ_ХозДеятельность);

КонецПроцедуры

Процедура ПолучитьСоответствиеСтарыхИНовыхНалоговыхНазначений(ПоПрибыли = Неопределено, ПоНДС = Неопределено) 
	
	ПоНДС = Новый Соответствие;
	ПоНДС.Вставить(Справочники.НалоговыеНазначенияАктивовИЗатрат.НеХозДеятельность				   , Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_НеоблагаемаяНеХозДеятельность);
	ПоНДС.Вставить(Справочники.НалоговыеНазначенияАктивовИЗатрат.НеХозДеятельностьАморт            , Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_НеоблагаемаяНеХозДеятельность);
	ПоНДС.Вставить(Справочники.НалоговыеНазначенияАктивовИЗатрат.НеХозДеятельностьАмортНеОблагНДС  , Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_НеоблагаемаяНеХозДеятельность);
