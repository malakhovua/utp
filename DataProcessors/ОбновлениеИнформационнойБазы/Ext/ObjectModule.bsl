		КонецЦикла;
		
	КонецЦикла;
	
	
	Запрос = Новый Запрос;
	ТекстЗапроса = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	 Надбавки.ПодразделениеОрганизации.Владелец КАК Организация,
