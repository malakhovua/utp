Процедура УстановитьПараметрыСчетовБУНалоговыйУчетС2015_8класс() Экспорт
	
	НачатьТранзакцию();
		
	СчетаУчетПоНалоговымНазначениямНДС = Новый Массив;
	СчетаУчетПоНалоговымНазначениямНДС.Добавить(ПланыСчетов.Хозрасчетный.ЗатратыПоЭлементам);
	Если НЕ БухгалтерскийУчет.ПолучитьИспользоватьКлассыСчетовВКачествеГрупп() Тогда
		СчетаУчетПоНалоговымНазначениямНДС.Добавить(ПланыСчетов.Хозрасчетный.МатериальныеЗатраты);
		СчетаУчетПоНалоговымНазначениямНДС.Добавить(ПланыСчетов.Хозрасчетный.ЗатратыНаОплатуТруда);
		СчетаУчетПоНалоговымНазначениямНДС.Добавить(ПланыСчетов.Хозрасчетный.ОтчисленияНаСоциальныеМероприятия);
		СчетаУчетПоНалоговымНазначениямНДС.Добавить(ПланыСчетов.Хозрасчетный.Амортизация);
		СчетаУчетПоНалоговымНазначениямНДС.Добавить(ПланыСчетов.Хозрасчетный.ДругиеОперационныеЗатраты);
		СчетаУчетПоНалоговымНазначениямНДС.Добавить(ПланыСчетов.Хозрасчетный.ДругиеЗатратыПоЭлементам);
	КонецЕсли; 
	

	ВыборкаСчетов = ПланыСчетов.Хозрасчетный.ВыбратьИерархически();
	Пока ВыборкаСчетов.Следующий() Цикл
		
		Объект = ВыборкаСчетов.Ссылка.ПолучитьОбъект();
		Если Объект.НалоговыйУчет Тогда
			Если СчетПринадлежитРодителю(ВыборкаСчетов.Ссылка, СчетаУчетПоНалоговымНазначениямНДС) Тогда
				Объект.УчетПоНалоговымНазначениямНДС = Истина;
				Объект.Записать();
			КонецЕсли;
		КонецЕсли; 
		
	КонецЦикла;

	ЗафиксироватьТранзакцию();

КонецПроцедуры

Процедура ОбновитьСтатьиВПроводкахПоРИ() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Т.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.ОжидаемыеНалоговыеРазницы КАК Т
	|ГДЕ
	|	Т.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|	И Т.Активность
	|	И Т.СуммаРИПлюс <> 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	Регистратор
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	СчетРИ = ПланыСчетов.Хозрасчетный.РазницыПоНалогуНаПрибыльРучныеКорректировки;
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Док = Выборка.Регистратор;
		Период = КонецМесяца(Док.Дата);
		
		СуммыРИПоСтатьям = Новый Структура;
		СуммыРИПоСтатьям.Вставить("Оплата1", Новый Структура("Статья, Сумма", Справочники.СтатьиНалоговыхДеклараций.НП15_РИ_Фин_Аванс_ЕН, 0));
		СуммыРИПоСтатьям.Вставить("Оплата2", Новый Структура("Статья, Сумма", Справочники.СтатьиНалоговыхДеклараций.НП15_РИ_Фин_ОплатаТоваров_ЕН, 0));
		СуммыРИПоСтатьям.Вставить("Продажа1", Новый Структура("Статья, Сумма", Справочники.СтатьиНалоговыхДеклараций.НП15_РИ_Фин_СС_Товаров_ЕН, 0));
		СуммыРИПоСтатьям.Вставить("Продажа2", Новый Структура("Статья, Сумма", Справочники.СтатьиНалоговыхДеклараций.НП15_РИ_Фин_СС_Товаров, 0));
		
		//до 01.08.2023 налоговая разница существовала только по статье 4.1.5.1.
		РедакцияНКУ = 1;
		Если Период >= '20230801' Тогда
			РедакцияНКУ = 2;
		КонецЕсли;
		
		НаборЗаписей = РегистрыНакопления.ОжидаемыеНалоговыеРазницы.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Регистратор.Установить(Док);
		НаборЗаписей.Прочитать();
		
		Для каждого Запись Из НаборЗаписей Цикл
			
			Если Запись.ВидДвижения = ВидДвиженияНакопления.Приход
				ИЛИ Запись.СуммаРИПлюс = 0 Тогда
				
				Продолжить;
				
			КонецЕсли;
			
			СуммаРИСтарая = Запись.СуммаРИПлюс;
			Запись.СуммаРИПлюс = 0;
			Запись.СуммаРИМинус = 0;
			
			Если Запись.Аванс Тогда
				
				КоэфРИ = ?(Запись.СуммаДоходовВтороеСобытие - Запись.СебестоимостьВтороеСобытие = СуммаРИСтарая, 1, 
					СуммаРИСтарая / (Запись.СуммаДоходовВтороеСобытие - Запись.СебестоимостьВтороеСобытие));  
				
				Если РедакцияНКУ > 1 Тогда
					Запись.СуммаРИПлюс = Запись.СебестоимостьВтороеСобытие * КоэфРИ;
					Запись.СуммаРИМинус = Запись.СуммаДоходовВтороеСобытие * КоэфРИ;
					СуммыРИПоСтатьям.Оплата1.Сумма = СуммыРИПоСтатьям.Оплата1.Сумма + Запись.СуммаРИМинус;
					СуммыРИПоСтатьям.Продажа2.Сумма = СуммыРИПоСтатьям.Продажа2.Сумма + Запись.СуммаРИПлюс;
				КонецЕсли;
				
			Иначе

				КоэфРИ = ?(Запись.СуммаДоходов - Запись.Себестоимость = СуммаРИСтарая, 1, 
					СуммаРИСтарая / (Запись.СуммаДоходов - Запись.Себестоимость));  
				
				Запись.СуммаРИПлюс = Запись.СуммаДоходов * КоэфРИ;
				СуммыРИПоСтатьям.Оплата2.Сумма = СуммыРИПоСтатьям.Оплата2.Сумма + Запись.СуммаРИПлюс;
				
				Если РедакцияНКУ > 1 Тогда
					Запись.СуммаРИМинус = Запись.Себестоимость * КоэфРИ;
					СуммыРИПоСтатьям.Продажа1.Сумма = СуммыРИПоСтатьям.Продажа1.Сумма + Запись.СуммаРИМинус;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла; 
		
		НаборЗаписей.ОбменДанными.Загрузка = Истина;
		НаборЗаписей.Записать();
	
		Проводки = РегистрыБухгалтерии.Хозрасчетный.СоздатьНаборЗаписей();
		Проводки.Отбор.Регистратор.Установить(Док);
		Проводки.Прочитать();
		
		ОбратныйИндекс = Проводки.Количество() - 1;
			
		Пока ОбратныйИндекс >= 0 Цикл
			
			Запись = Проводки.Получить(ОбратныйИндекс);
			Если Запись.СчетДт = СчетРИ Тогда
				Проводки.Удалить(ОбратныйИндекс);
			КонецЕсли;                   
			
			ОбратныйИндекс = ОбратныйИндекс - 1;
			
		КонецЦикла;
		
		Для каждого КЗ ИЗ СуммыРИПоСтатьям Цикл
			
			СуммаПоСтатье = КЗ.Значение;
			
			Если ЗначениеЗаполнено(СуммаПоСтатье.Сумма) Тогда	
				
				ПроводкаБУ                                 = Проводки.Добавить();
				ПроводкаБУ.Период                          = Период;
				ПроводкаБУ.Организация                     = Док.Организация;
				
