Перем МассивДокументов;

#Область ЗагрузкиДанных

//Выполнить загрузку данных из внешнего источника
//
Процедура ВыполнитьЗагрузку()Экспорт
	
	ТаблицаЗначений = Новый ТаблицаЗначений;
	
	РасширениеФайла = РаботаСФайлами.ПолучитьРасширениеФайла(ПутьКФайлу);
	
	Если РасширениеФайла = "dbf" Тогда
		
		db_file = Новый XBase;
		db_file.Кодировка = КодировкаXBase.OEM;
		db_file.ОткрытьФайл(ПутьКФайлу);
		
		Если Не db_file.Открыта()
			Тогда
			#Если Клиент Тогда
				Сообщить("Файл базы не открыт.", СтатусСообщения.Важное);	
			#КонецЕсли
			Возврат
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Организация)
			Тогда
			#Если Клиент Тогда
				Сообщить("Организация не заполнена.", СтатусСообщения.Важное);	
			#КонецЕсли
			Возврат
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(БанковскийСчет)
			Тогда
			#Если Клиент Тогда
				Сообщить("Банковский счет не заполнен.", СтатусСообщения.Важное);	
			#КонецЕсли
			Возврат
		КонецЕсли;
		
		ТаблицаЗначений = ПодготовитьТаблицуЗначений_dbf(db_file);
		
	ИначеЕсли РасширениеФайла = "csv" Тогда
		
		ТаблицаЗначений = ПодготовитьТаблицуЗначений_csv(ПутьКФайлу);
		
	КонецЕсли;
	
	МассивДокументов.Очистить();
	
	СоздатьДокумент(ТаблицаЗначений);
	
	ПровестиДокументы();
	
КонецПроцедуры

//Возвращает таблицу значений полученную из внешнего источника dbf 
//
Функция ПодготовитьТаблицуЗначений_dbf(db_file)
	
	ТаблицаЗначений = Новый ТаблицаЗначений();
	
	Для Каждого Поле из db_file.поля Цикл
		ТаблицаЗначений.Колонки.Добавить(Поле.Имя);	
	КонецЦикла;
	
	Пока Истина  Цикл
		НоваяСтрока = ТаблицаЗначений.Добавить();
		Для Каждого Поле из db_file.поля Цикл
			НоваяСтрока[Поле.Имя] = db_file.ПолучитьЗначениеПоля(Поле.Имя);
		КонецЦикла;
		
		Если Не db_file.Следующая()
			Тогда
			Прервать
		КонецЕсли
		
	КонецЦикла;
	
	Возврат ТаблицаЗначений
	
КонецФункции

//Возвращает таблицу значений полученную из внешнего источника
//
Функция ПодготовитьТаблицуЗначений_csv(ПутьКФайлу)
	
	ФайлCSV = Новый текстовыйДокумент;
	ФайлCSV.Прочитать(ПутьКФайлу);
	
	ТаблицаЗначений = Новый ТаблицаЗначений;
	ИспользуемыйРазделитель =";";
	
	//*** Если есть шапка таблицы ***
	ШапкаCSV = ФайлCSV.ПолучитьСтроку(1);
	// Чтение и разделение на отдельные значения в массив (по разделителю)
	МассивCSV = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ШапкаCSV, ИспользуемыйРазделитель);//СтрРазделить(ШапкаCSV, ИспользуемыйРазделитель);
	//***************************
	Для Каждого СтрокаНом Из МассивCSV Цикл
		
		// Удаляем пробелы т.к. в названии столбцов они не допускаются
		ИмяБП = СтрЗаменить(СтрокаНом," ","_");
		ТаблицаЗначений.Колонки.Добавить(ИмяБП,, СтрокаНом);
		
	КонецЦикла;
	
	Для НомерСтроки=2 По ФайлCSV.КоличествоСтрок() Цикл // Если без шапки, то начинаем с первой строчки
		
		// Получаем строку по-порядку
		СтрокаCSV = ФайлCSV.ПолучитьСтроку(НомерСтроки);
		
		// Разделяем с помощью выбранного разделителя каждую строку на столбцы
		МассивCSV = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СтрокаCSV, ИспользуемыйРазделитель);//СтрРазделить(СтрокаCSV, ИспользуемыйРазделитель);
		НоваяСтрочка= ТаблицаЗначений.Добавить();// Добавляем строку в ТЗ
		
		Для НомСтолбца=1 По МассивCSV.Количество() Цикл
			
			ТекЗначениеCSV = МассивCSV[НомСтолбца-1];
			ИмяКолонкиCSV = ТаблицаЗначений.Колонки[НомСтолбца-1].Имя;
			НоваяСтрочка[ИмяКолонкиCSV] = ТекЗначениеCSV;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ТаблицаЗначений;
	
КонецФункции

//Создадим платежный документ
//
Процедура СоздатьДокумент(ТаблицаЗначений)
	
	Для Каждого СтрокаЗначения Из ТаблицаЗначений Цикл
		СчетТранзитный = Ложь;
		ТипДокумента   = ПолучитьТипДокумента(СтрокаЗначения);
		// Определим транзитная операция или нет
		
		СруктураДанныхТранзита = ПолучитьСруктураДанныхТранзита(БанковскийСчет, СтрокаЗначения, ТипДокумента);
		
		Если  Не СруктураДанныхТранзита = Неопределено
			Тогда 
			СчетТранзитный = Истина
		КонецЕсли;
		
		
		Если ТипДокумента = Неопределено
			Тогда
			#Если Клиент Тогда
				Сообщить("Определите тип документа в настройках обмена с ""Клиент-банком"".", СтатусСообщения.Важное);	
			#КонецЕсли
			Продолжить
		КонецЕсли;
		
		Документ = Документы[ТипДокумента].СоздатьДокумент();
		Документ.ОбменДанными.Загрузка = Истина;
		Документ.ОтражатьВБухгалтерскомУчете  = Истина;
		Документ.ОтражатьВУправленческомУчете = Истина;
		Документ.Оплачено = Истина;
		Документ.Организация = Организация;
		Документ.СчетОрганизации = БанковскийСчет;
		Документ.УстановитьНовыйНомер(Организация.Префикс);
		
		// Заполним шапку документа
		СответствиеРеквизитов = ПолучитьСответствиеРеквизитов(ТипДокумента, "СоответствиеРеквизитовПолей");
			
		// Опредилим сначала назначение
		Для Каждого Элемент Из СответствиеРеквизитов Цикл
			
			Если Элемент.Значение = "НазначениеПлатежа"  Тогда
				Документ[Элемент.Значение] = СтрокаЗначения[Элемент.Ключ];
			КонецЕсли;
			
		КонецЦикла;
				
		// Установим Нашу оплату
		Назначение =  Документ.НазначениеПлатежа;
		мЕДРПОУ = "";
		НашаОплата = Ложь;
		
		Если БанковскийСчет.ОплатаОтТретьихЛиц Тогда // 22/12/20
			НашаОплата = ПлатежОтТретьихЛиц(ТипДокумента, Назначение, мЕДРПОУ);
			Документ.umk_НашаОплата = НашаОплата;
		КонецЕсли;
		
		Для Каждого Элемент Из СответствиеРеквизитов Цикл
			
			Если Элемент.Значение = "Контрагент"
				Тогда
				Если Не НашаОплата
					Тогда
					мЕДРПОУ = СокрЛП(Строка(СтрокаЗначения[Элемент.Ключ]));
					Документ[Элемент.Значение] =  ПолучитьКонтрагентаУМК(СокрЛП(Строка(СтрокаЗначения[Элемент.Ключ])));//Справочники.Контрагенты.НайтиПоРеквизиту("КодПоЕДРПОУ",СокрЛП(Строка(СтрокаЗначения[Элемент.Ключ]))); 
					//Попроуем найти по ЕДРПОУ
					Если не ЗначениеЗаполнено(Документ[Элемент.Значение]) Тогда
						Документ[Элемент.Значение] =  Справочники.Контрагенты.НайтиПоРеквизиту("КодПоЕДРПОУ",мЕДРПОУ);
					КонецЕсли;
				КонецЕсли;
			ИначеЕсли Элемент.Значение = "ВалютаДокумента"
				Тогда
				Валюта = Справочники.Валюты.НайтиПоКоду(СокрЛП(Строка(СтрокаЗначения[Элемент.Ключ])));
				Валюта = ?(ЗначениеЗаполнено(Валюта), Валюта, глЗначениеПеременной("ВалютаРегламентированногоУчета"));
				Документ[Элемент.Значение] = Валюта; 	
			ИначеЕсли Элемент.Значение = "ДатаОплаты"
				Тогда
				ДатаДокумента = СтрокаЗначения[Элемент.Ключ];
				ДатаДокумента = ФорматДаты(ДатаДокумента);
				Документ[Элемент.Значение] = ДатаДокумента; 	
			Иначе
				Документ[Элемент.Значение] = СтрокаЗначения[Элемент.Ключ];
			КонецЕсли;
			
		КонецЦикла;
		
		Если Документ.umk_НашаОплата Тогда
			
			Документ.Контрагент = КонтрагентПоНазначению(Документ.НазначениеПлатежа, ТипДокумента, мЕДРПОУ);
			
		КонецЕсли;
		
		Документ.Дата = КонецДня(Документ.ДатаОплаты);
		
		Если ВыборкаПоДате() Тогда
			
			Если Не Дата = НачалоДня(Документ.Дата) Тогда  
				СтараяДата =  Документ.Дата;
				Документ.Дата = КонецДня(Дата);
				Документ.ДатаОплаты = Документ.Дата; 
				
				#Если Клиент Тогда
					Сообщить("Дата обработки на равна дате документа ""Клиент-банка"" " + Строка(СтараяДата)  
					+ ". " + Документ.НазначениеПлатежа, СтатусСообщения.Важное);	
				#КонецЕсли
				
				//Продолжить
			КонецЕсли;
			
		КонецЕсли;
			
		Если ТипДокумента = "ПлатежноеПоручениеВходящее" Тогда
			Документ.ВидОперации = Перечисления.ВидыОперацийПоступлениеБезналичныхДенежныхСредств.ОплатаПокупателя;
			
			//06.05.20
			Если ЭтоВозвратДенежныхСредств(Назначение) Тогда
				Документ.ВидОперации = Перечисления.ВидыОперацийПоступлениеБезналичныхДенежныхСредств.ВозвратДенежныхСредствПоставщиком;	
			КонецЕсли;
				
			// Если Транзитный установим значения
			Если СчетТранзитный Тогда
				Документ.ВидОперации     = СруктураДанныхТранзита.ВидОперации;
				Документ.Оплачено        = СруктураДанныхТранзита.ВыполнятьДвижения;
				Документ.СчетУчетаРасчетовСКонтрагентом = СруктураДанныхТранзита.СчетБУ;
			КонецЕсли;
			// КонецПо транзиту
			
			Документ.НомерВходящегоДокумента = СокрЛП(Документ.НомерВходящегоДокумента);
			Документ.КлючПоиска = Документ.НомерВходящегоДокумента + мЕДРПОУ;
			
			//Установим вид оплаты субконто в зависимости от банк. счета
			УстановитьВидОплатыСубконтоППвх(Документ, СтрокаЗначения);
			
			Если Документ.Дата <= '20250401235959' Тогда 
				
				Если ЕстьЗаписанныйДокументВБазу(ТипДокумента,"НомерВходящегоДокумента", Документ.Дата, Документ.НомерВходящегоДокумента)
					Тогда
					Продолжить // Не будем записывать в базу
				КонецЕсли;
				
			Иначе // Другой алгоритм поиска
				
				Если ЕстьЗаписанныйДокументВБазу(ТипДокумента,"КлючПоиска", Документ.Дата, Документ.КлючПоиска)
					Тогда
					Продолжить // Не будем записывать в базу
				КонецЕсли;
				
			КонецЕсли;
			
		ИначеЕсли ТипДокумента = "ПлатежноеПоручениеИсходящее" Тогда
			Документ.ВидОперации = Перечисления.ВидыОперацийППИсходящее.ОплатаПоставщику;
						
			// Если Транзитный установим значения
			Если СчетТранзитный Тогда
				
				Документ.ВидОперации     = СруктураДанныхТранзита.ВидОперации;
				Документ.СчетКонтрагента = СруктураДанныхТранзита.СчетПолучатель;
				Документ.Оплачено        = СруктураДанныхТранзита.ВыполнятьДвижения;
				Документ.СчетУчетаРасчетовСКонтрагентом = СруктураДанныхТранзита.СчетБУ;
				
			КонецЕсли;
			// КонецПо транзиту
			
			//Установим вид оплаты субконто в зависимости от банк. счета
			УстановитьВидОплатыСубконтоППисх(Документ, СтрокаЗначения);
			
			Документ.НомерПоручения = СокрЛП(Документ.НомерПоручения);
			
			Если ЕстьЗаписанныйДокументВБазу(ТипДокумента,"НомерПоручения", Документ.Дата, Документ.НомерПоручения)
				Тогда
				Продолжить // Не будем записывать в базу
			КонецЕсли;
			
		КонецЕсли;
		
		Если Не НашаОплата И Не ЗначениеЗаполнено(Документ.Контрагент)  Тогда
			
			#Если Клиент Тогда
				
				Режим = РежимДиалогаВопрос.ДаНет;
				Ответ = Вопрос("В базе не найден контрагент с кодом ЕДРПОУ " + мЕДРПОУ + ". Хотите создать?", Режим, 0);
				
				Если Ответ = КодВозвратаДиалога.Нет Тогда
					Документ.Контрагент = Справочники.Контрагенты.ПустаяСсылка();
				Иначе
					Документ.Контрагент = СоздатьКонтрагента(мЕДРПОУ, Документ.umk_КонтрагентСтрокой, ТипДокумента);
				КонецЕсли;
				
			#Иначе	
				Документ.Контрагент = СоздатьКонтрагента(мЕДРПОУ, Документ.umk_КонтрагентСтрокой, ТипДокумента);
			#КонецЕсли
			
		КонецЕсли;
		
		// Заполним расшифровку платежа
		СтрокаПлатеж = Документ.РасшифровкаПлатежа.Добавить();
		
		СответствиеРеквизитовТаб = ПолучитьСответствиеРеквизитов(ТипДокумента, "СоответствиеРеквизитовПолейТаб");
		
		Для Каждого Элемент Из СответствиеРеквизитовТаб Цикл
			
			СтрокаПлатеж[Элемент.Значение] = СтрокаЗначения[Элемент.Ключ];
			
		КонецЦикла;
		
		// Дозаполним недостающие реквизиты
		Если ТипДокумента = "ПлатежноеПоручениеВходящее" Тогда
			
			// Установим договор
			СписокДопустимыхВидовДоговоров          = УправлениеВзаиморасчетами.ОпределитьВидДоговораСКонтрагентом(Документ.ВидОперации);
			СтруктураПараметровДляПолученияДоговора = Новый Структура ("СписокДопустимыхВидовДоговоров", СписокДопустимыхВидовДоговоров);
			СтрокаПлатеж.ДоговорКонтрагента         = ЗаполнениеДокументов.ПолучитьДоговорПоОрганизацииИКонтрагенту(
			Документ.Организация, Документ.Контрагент, СтруктураПараметровДляПолученияДоговора);
				
			// При изменении договора			
			СтрокаПлатеж.СтатьяДвиженияДенежныхСредств = СтрокаПлатеж.ДоговорКонтрагента.ОсновнаяСтатьяДвиженияДенежныхСредств; 
			УправлениеДенежнымиСредствами.УстановитьСтатьюДДСПоУмолчанию(СтрокаПлатеж, Документ.ВидОперации);
			
			СтрокаПлатеж.ДокументПланированияПлатежа=Документы.ПланируемоеПоступлениеДенежныхСредств.ПустаяСсылка();
			
			мТекущаяВалютаВзаиморасчетов = СтрокаПлатеж.ДоговорКонтрагента.ВалютаВзаиморасчетов;
			
			СтруктураКурсаВзаиморасчетов = МодульВалютногоУчета.ПолучитьКурсВалюты(мТекущаяВалютаВзаиморасчетов, ?(НЕ ЗначениеЗаполнено(Документ.ДатаОплаты),Документ.Дата,Документ.ДатаОплаты));
			
			СтрокаПлатеж.КурсВзаиморасчетов      = СтруктураКурсаВзаиморасчетов.Курс;
			СтрокаПлатеж.КратностьВзаиморасчетов = СтруктураКурсаВзаиморасчетов.Кратность;
			
			//РассчитатьСуммуВзаиморасчетов
			Если мТекущаяВалютаВзаиморасчетов = Документ.ВалютаДокумента Тогда
				
				СтрокаПлатеж.СуммаВзаиморасчетов = СтрокаПлатеж.СуммаПлатежа;
				
			ИначеЕсли (Документ.КурсДокумента <> 0) И (СтрокаПлатеж.КратностьВзаиморасчетов <> 0) И (СтрокаПлатеж.КурсВзаиморасчетов <> 0) Тогда
				
				СтрокаПлатеж.СуммаВзаиморасчетов=МодульВалютногоУчета.ПересчитатьИзВалютыВВалюту(СтрокаПлатеж.СуммаПлатежа, Документ.ВалютаДокумента,
				мТекущаяВалютаВзаиморасчетов,
				Документ.КурсДокумента, СтрокаПлатеж.КурсВзаиморасчетов,
				Документ.КратностьДокумента, СтрокаПлатеж.КратностьВзаиморасчетов);
				
			Иначе
				
				СтрокаПлатеж.СуммаВзаиморасчетов = 0;
				
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрокаПлатеж.ДоговорКонтрагента.ОсновнойПроект) Тогда
				СтрокаПлатеж.Проект = СтрокаПлатеж.ДоговорКонтрагента.ОсновнойПроект;
			КонецЕсли;
			
			СчетаУчета = Неопределено;
			
			ОпределитьСчетаУчетаРасчетовСКонтрагентомППВХ (СтрокаПлатеж,,Документ);
			
			Если Не ЗначениеЗаполнено(СтрокаПлатеж.СтавкаНДС) Тогда
				СтрокаПлатеж.СтавкаНДС = УправлениеПользователями.ПолучитьЗначениеПоУмолчанию(глЗначениеПеременной("глТекущийПользователь"),"ОсновнаяСтавкаНДС");
			КонецЕсли;
			
			УправлениеДенежнымиСредствами.ПересчитатьСуммуНДС(СтрокаПлатеж);
			
			СтрокаПлатеж.Сделка = Неопределено;
			СтрокаПлатеж.ДокументРасчетовСКонтрагентом = Неопределено;
				
		КонецЕсли;
		
		Если ТипДокумента = "ПлатежноеПоручениеИсходящее" Тогда
			
			//Установим договор
			СписокДопустимыхВидовДоговоров          = УправлениеВзаиморасчетами.ОпределитьВидДоговораСКонтрагентом(Документ.ВидОперации);
			СтруктураПараметровДляПолученияДоговора = Новый Структура ("СписокДопустимыхВидовДоговоров", СписокДопустимыхВидовДоговоров);
			СтрокаПлатеж.ДоговорКонтрагента         = ЗаполнениеДокументов.ПолучитьДоговорПоОрганизацииИКонтрагенту(
			Документ.Организация, Документ.Контрагент, СтруктураПараметровДляПолученияДоговора);
						
			ПриИзмененииДоговораППИСХ(Документ, СтрокаПлатеж);	
			
		КонецЕсли;
			
		Документ.Ответственный = глЗначениеПеременной("глТекущийПользователь");
		Документ.СчетБанк = ПланыСчетов.Хозрасчетный.ТекущиеСчетаВНациональнойВалюте;
		Документ.СуммаДокумента = Документ.РасшифровкаПлатежа.Итог("СуммаПлатежа");
		
		Документ.Записать();
		
		МассивДокументов.Добавить(Документ.Ссылка);
		
		Сообщить("Загружен документ " + Документ.Ссылка);
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ВспомогательныхПроцедурИФункций

//Преобразует тип строки в тип дата
//
Функция ФорматДаты(ДатаДокумента)
	
	
	Если ТипЗнч(ДатаДокумента) =  Тип("Дата") Тогда
		Возврат ДатаДокумента
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ДатаДокумента) Тогда
		Возврат '00010101'
	КонецЕсли;
	
	МассивДат = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ДатаДокумента,".");
	
	//Проверим порядок ГГГГ.ММ.ДД
	Если СтрДлина(МассивДат[0])= 2 Тогда //Перевернем массив
		Возврат Дата(МассивДат[2],МассивДат[1],МассивДат[0]);
	КонецЕсли;
	
	Возврат Дата(МассивДат[0],МассивДат[1],МассивДат[2]);
	
КонецФункции

//Возвращает соответствие типов
//
Функция ПолучитьТипДокумента(СтрокаЗначения)
	
	ЗначениеПоФормуле = "";
	
	// Получим ключ
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СоответствиеТиповДокументаДляКлиентБанка.Ключ,
	|	СоответствиеТиповДокументаДляКлиентБанка.ВычислитьЗначение
	|ИЗ
	|	РегистрСведений.umk_СоответствиеТиповДокументаДляКлиентБанка КАК СоответствиеТиповДокументаДляКлиентБанка
	|ГДЕ
	|	СоответствиеТиповДокументаДляКлиентБанка.Организация = &Организация
	|	И СоответствиеТиповДокументаДляКлиентБанка.БанковскийСчет = &БанковскийСчет";
	
	Запрос.УстановитьПараметр("БанковскийСчет", БанковскийСчет);
	Запрос.УстановитьПараметр("Организация", Организация);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий()
		Тогда
		Ключ = Выборка.Ключ;
		ЗначениеПоФормуле = Выборка.ВычислитьЗначение;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	Значение =  СтрокаЗначения[Ключ];
		
	Если ЗначениеЗаполнено(ЗначениеПоФормуле) Тогда
		Попытка
			Значение = Вычислить(ЗначениеПоФормуле);
		Исключение
			ВызватьИсключение;
		КонецПопытки
	КонецЕсли;
	
	// Получим значение 	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СоответствиеТиповДокументаДляКлиентБанка.ТипДокумента
	|ИЗ
	|	РегистрСведений.umk_СоответствиеТиповДокументаДляКлиентБанка КАК СоответствиеТиповДокументаДляКлиентБанка
	|ГДЕ
	|	СоответствиеТиповДокументаДляКлиентБанка.Организация = &Организация
	|	И СоответствиеТиповДокументаДляКлиентБанка.БанковскийСчет = &БанковскийСчет
	|	И СоответствиеТиповДокументаДляКлиентБанка.Значение = &Значение";
	
	
	Запрос.УстановитьПараметр("БанковскийСчет", БанковскийСчет);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Значение", Строка(Значение));
	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий()
		Тогда Возврат Выборка.ТипДокумента;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

//Возвращает булево
//
Функция ПлатежОтТретьихЛиц(ТипДокумента, Назначение, ЕДРПОУ = "")
	//// Уберем этот механизм пока
	//Запрос = Новый Запрос;
	//Запрос.Текст = 
	//	"ВЫБРАТЬ
	//	|	СоответствиеРеквизитовДляКлиентБанка.ОплатаОтТретьихЛиц КАК ОплатаОтТретьихЛиц
	//	|ИЗ
	//	|	РегистрСведений.umk_СоответствиеРеквизитовДляКлиентБанка КАК СоответствиеРеквизитовДляКлиентБанка
	//	|ГДЕ
	//	|	СоответствиеРеквизитовДляКлиентБанка.Организация = &Организация
	//	|	И СоответствиеРеквизитовДляКлиентБанка.БанковскийСчет = &БанковскийСчет
	//	|	И СоответствиеРеквизитовДляКлиентБанка.ТипДокумента = &ТипДокумента";
	//
	//Запрос.УстановитьПараметр("БанковскийСчет", БанковскийСчет);
	//Запрос.УстановитьПараметр("Организация", Организация);
	//Запрос.УстановитьПараметр("ТипДокумента", ТипДокумента);
	//
	//РезультатЗапроса = Запрос.Выполнить();
	//
	//Выборка = РезультатЗапроса.Выбрать();
	//
	//Если Выборка.Следующий() Тогда
	//	Возврат  Выборка.ОплатаОтТретьихЛиц
	//Иначе
	//	Возврат Ложь
	//КонецЕсли;
	//
	
	////Провека платежа от третьих лиц будем проводить по назначению платежа
	//
	//Если Найти(Назначение,"Сплата за продукцію код ") = 1 ИЛИ 
	//	Найти(Назначение,"Сплата за продукц_ю код ") = 1 ИЛИ
	//	Найти(Назначение,"Сплата за прод.") = 1 ИЛИ
	//	Найти(Назначение,"Сплата за аренду код ") = 1  Тогда
	//	Возврат Истина
	//Иначе
	//	Возврат Ложь;
	//КонецЕсли;
	
	//с 24/09/2020  - новый механизм. Если находим в назначении платежа КодЕДРПОУ (8 или 10 знаков) то
	//полагаем, что это оплата от третьего лица
	
	Если ТипДокумента = "ПлатежноеПоручениеИсходящее" Тогда
		Возврат Ложь
	КонецЕсли;
	
	МассивДлинСимволов = Новый Массив();
	
	МассивДлинСимволов.Добавить(11); //Физлицо 10 зн. + 1 пробел.
	МассивДлинСимволов.Добавить(9); //Юрлицо 8 зн. + 1 пробел.
	
	
	Для Каждого ДлинаЕДРПОУ Из МассивДлинСимволов Цикл
		
		НомерСимвола = 1;
		СтрокаСЧислом = Назначение;
		ДлинаСтроки = СтрДлина(СтрокаСЧислом) -ДлинаЕДРПОУ;
		
		Пока НомерСимвола <= ДлинаСтроки Цикл
			Попытка
				
				ЕДРПОУ_Строка = Сред(СтрокаСЧислом,НомерСимвола,ДлинаЕДРПОУ);
				
				//Если разделитель тогда пропускаем
				Если Найти(ЕДРПОУ_Строка,".") ИЛИ Найти(ЕДРПОУ_Строка,",") ИЛИ НЕ
					ЗначениеЗаполнено(ЕДРПОУ_Строка)
					Тогда
					НомерСимвола = НомерСимвола + 1;
					Продолжить
				КонецЕсли;
				
				ЕДРПОУ_число = Число(ЕДРПОУ_Строка);
				ЕДРПОУ = Формат(ЕДРПОУ_число,"ЧЦ="+Строка(ДлинаЕДРПОУ-1)+"; ЧДЦ=0; ЧГ=");
				
				//Если знаков не 8 и не 10 то это не ЕДРПОУ
				Если НЕ СтрДлина(ЕДРПОУ) = 8
					И
					НЕ СтрДлина(ЕДРПОУ) = 10
					Тогда
					НомерСимвола = НомерСимвола + 1;
					Продолжить
				КонецЕсли;
				
				//Полагаем, что таких ЕДРПОУ нет.
				Если Не Прав(ЕДРПОУ,ДлинаЕДРПОУ-1) = "0" //Не лидирующий 0
					Тогда
					Возврат Истина
				КонецЕсли;		
			Исключение
			КонецПопытки;
			НомерСимвола = НомерСимвола + 1;
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Ложь
	
	
КонецФункции

// Определяем тип документа в зависимости от назначения платежа. Для Возврата денежных средств
Функция ЭтоВозвратДенежныхСредств(Назначение)
	
	Если Найти(Назначение,"Повернення ") = 1 ИЛИ 
		Найти(Назначение,"Поверн. ") = 1 ИЛИ
		Найти(Назначение,"Возврат ") = 1  Тогда
		Возврат Истина
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
