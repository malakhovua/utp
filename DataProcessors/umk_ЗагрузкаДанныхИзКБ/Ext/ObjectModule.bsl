//Возвращает соответствие реквизитов документов
//
Функция ПолучитьСответствиеРеквизитов(ТипДокумента, ПоляВыбора)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	umk_СоответствиеРеквизитовДляКлиентБанка."+ ПоляВыбора + " КАК Поля
	|ИЗ
	|	РегистрСведений.umk_СоответствиеРеквизитовДляКлиентБанка КАК umk_СоответствиеРеквизитовДляКлиентБанка
	|ГДЕ
	|	umk_СоответствиеРеквизитовДляКлиентБанка.Организация = &Организация
	|	И umk_СоответствиеРеквизитовДляКлиентБанка.БанковскийСчет = &БанковскийСчет
	|	И umk_СоответствиеРеквизитовДляКлиентБанка.ТипДокумента = &ТипДокумента";
	
	Запрос.УстановитьПараметр("БанковскийСчет", БанковскийСчет);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ТипДокумента", ТипДокумента);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		ТаблицаРеквизитов = Выборка.Поля.Получить();
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	СоответствиеПолей = Новый Соответствие;
	
	Для Каждого Строка Из ТаблицаРеквизитов Цикл
		
		СоответствиеПолей.Вставить(Строка.Ключ, Строка.Значение)
		
	КонецЦикла;
	
	Возврат СоответствиеПолей
	
КонецФункции

//Проверяет наличие уже записанных в базу документов
//
Функция ЕстьЗаписанныйДокументВБазу(ТипДокумента, Реквизит, Документ_Дата, Номер)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ПлатежныйДокумент.Ссылка
	|ИЗ
	|	Документ." + ТипДокумента + " КАК ПлатежныйДокумент
	|ГДЕ
	|	ПлатежныйДокумент.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ПлатежныйДокумент." + Реквизит + " = &Номер");
	
	Запрос.УстановитьПараметр("ДатаНачала", НачалоДня(Документ_Дата));
	Запрос.УстановитьПараметр("ДатаОкончания", КонецДня(Документ_Дата));
	Запрос.УстановитьПараметр("Номер", Номер);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Возврат Выборка.Следующий()
	
	
КонецФункции

//Возвращает контрагента по назначению платежа
//
Функция КонтрагентПоНазначению(Назначение, ТипДокумента, ЕДРПОУ)
	//Возможные варианты
	//Назначение = СтрЗаменить(Назначение,"Сплата за продукцію код ",""); 
	//Назначение = СтрЗаменить(Назначение,"Сплата за продукц_ю код ","");
	//Назначение = СтрЗаменить(Назначение,"Сплата за аренду код ", "");
	//
	//ЕДРПОУ = Лев(Назначение,10);
	//ЕДРПОУ = СокрЛП(ЕДРПОУ);
	//// Если есть пробелы в едрпоу, то скорее всего это платеж от юр. лица и у едрпоу - 8 знаков
	//Если Найти(ЕДРПОУ, " ") Тогда
	//	ЕДРПОУ = СокрЛП(Лев(ЕДРПОУ, Найти(ЕДРПОУ, " ")));	
	//КонецЕсли;
	//
	
	Контрагент =  ПолучитьКонтрагентаУМК(ЕДРПОУ);//Справочники.Контрагенты.НайтиПоРеквизиту("КодПоЕДРПОУ",ЕДРПОУ);
	
	Если Не значениеЗаполнено(Контрагент) Тогда//Контрагент.Пустая() Тогда
		
		ПараметрПоиска = ", від "; // Место с которого начнем искать Наименование контрагента
		
		ПозицияНаименования = Найти(Назначение, ПараметрПоиска);
		
		Если ПозицияНаименования = 0
			Тогда
			Возврат Справочники.Контрагенты.ПустаяСсылка(); // Не будем создавать
		Иначе
			НачальныйНомер = ПозицияНаименования + СтрДлина(ПараметрПоиска);
			Наименование =  Сред(Назначение,НачальныйНомер,100); 
			Наименование = СокрЛП(Наименование);
		КонецЕсли;
		
		#Если Клиент Тогда
			
			Режим = РежимДиалогаВопрос.ДаНет;
			Ответ = Вопрос("В базе не найден контрагент с кодом ЕДРПОУ " + ЕДРПОУ + ". Хотите создать?", Режим, 0);
			
			Если Ответ = КодВозвратаДиалога.Нет Тогда
				Возврат Справочники.Контрагенты.ПустаяСсылка();
			Иначе
				Контрагент = СоздатьКонтрагента(ЕДРПОУ, Наименование, ТипДокумента);
			КонецЕсли;
		#Иначе
			Контрагент = СоздатьКонтрагента(ЕДРПОУ, Наименование, ТипДокумента);	
		#КонецЕсли
		
	КонецЕсли;
	
	
	Возврат Контрагент
	
КонецФункции

//Возвращает нового контрагента
//Создает договор
//
Функция СоздатьКонтрагента(ЕДРПОУ, Наименование, ТипДокумента)
	
	Если ЕДРПОУ = ""
		Тогда
		Возврат 
		Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;
	
	Если Наименование = "" Тогда
		Наименование = "Новый контрагент, код ЕДРПОУ: " + ЕДРПОУ;
	КонецЕсли;
	
	
	Контрагент = Справочники.Контрагенты.СоздатьЭлемент();
	Контрагент.Наименование = Наименование;
	Контрагент.НаименованиеПолное = Наименование;
	Контрагент.КодПоЕДРПОУ = ЕДРПОУ;
	Контрагент.Покупатель = ТипДокумента = "ПлатежноеПоручениеВходящее";
	Контрагент.Поставщик =  ТипДокумента = "ПлатежноеПоручениеИсходящее";
	Контрагент.ЮрФизЛицо = ?(СтрДлина(ЕДРПОУ) = 10, Перечисления.ЮрФизЛицо.ФизЛицо, Перечисления.ЮрФизЛицо.ЮрЛицо);
	Контрагент.Записать();
	ПроверитьОсновнойДоговорКонтрагента(Контрагент);
	Контрагент.Родитель = КаталогДляНовыхКонтрагентов;
	Контрагент.Записать();
	
	Возврат Контрагент.Ссылка
	
КонецФункции

// Получаем выборку по транзитным счетам
Функция ПолучитьСруктураДанныхТранзита(БанковскийСчет, СтрокаЗначения, ТипДокумента)
	
	// Получи ключ - получатель
	Если ТипДокумента = "ПлатежноеПоручениеИсходящее" Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	НастройкаТранзитныхСчетов.Ключ_получатель,
		|	НастройкаТранзитныхСчетов.ВыполнятьДвижения,
		|	НастройкаТранзитныхСчетов.СчетПолучатель.НомерСчета КАК СчетПолучательНомер,
		|	НастройкаТранзитныхСчетов.СчетПолучатель КАК СчетПолучатель,
		|	НастройкаТранзитныхСчетов.ВидОперации,
		|	НастройкаТранзитныхСчетов.СчетБУПолучатель
		|ИЗ
		|	РегистрСведений.НастройкаТранзитныхСчетов КАК НастройкаТранзитныхСчетов
		|ГДЕ
		|	НастройкаТранзитныхСчетов.СчетОтправитель = &СчетОтправитель";
		
		Запрос.УстановитьПараметр("СчетОтправитель", БанковскийСчет);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
		
		
		Пока Выборка.Следующий() Цикл
			ЗаписиВРегистре = Истина;  // Нашли записи в регистре соответствий
			
			КлючПолучатель         = Выборка.Ключ_получатель;
			ВидОперации            = Выборка.ВидОперации;
			СчетПолучательНомер    = Выборка.СчетПолучательНомер;
			СчетПолучатель         = Выборка.СчетПолучатель;
			ВыполнятьДвижения      = Выборка.ВыполнятьДвижения;
			СчетБУ                 = Выборка.СчетБУПолучатель;
			
			// Если счет транзитный
			// Попробуем получить строку по ключу, обходим всю выборку пока не найдем 		
			Попытка
				Строка = СокрЛП(СтрокаЗначения[КлючПолучатель]);
			Исключение
				Продолжить	
			КонецПопытки;
			
			// Нашли ключ:
			
			Если СокрЛП(СтрокаЗначения[КлючПолучатель]) = СокрЛП(СчетПолучательНомер) Тогда
				СруктураДанных = Новый Структура("СчетПолучатель,ВыполнятьДвижения,ВидОперации, СчетБУ",
				СчетПолучатель,ВыполнятьДвижения,ВидОперации, СчетБУ);
				Возврат СруктураДанных
			КонецЕсли;
			
		КонецЦикла;
		
		// не нашли ничего.	
		Возврат Неопределено;		
		
		
		
	ИначеЕсли  ТипДокумента = "ПлатежноеПоручениеВходящее" Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	НастройкаТранзитныхСчетов.Ключ_отправитель,
		|	НастройкаТранзитныхСчетов.СчетОтправитель.НомерСчета КАК СчетОтправительНомер,
		|	НастройкаТранзитныхСчетов.СчетОтправитель,
		|	НастройкаТранзитныхСчетов.ВидОперацииППвх,
		|	НастройкаТранзитныхСчетов.СчетБУПолучатель
		|ИЗ
		|	РегистрСведений.НастройкаТранзитныхСчетов КАК НастройкаТранзитныхСчетов
		|ГДЕ
		|	НастройкаТранзитныхСчетов.СчетПолучатель = &СчетПолучатель";
		
		Запрос.УстановитьПараметр("СчетПолучатель", БанковскийСчет);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
		ЗаписиВРегистре = Ложь;
		
		Пока Выборка.Следующий() Цикл
			ЗаписиВРегистре = Истина;  // Нашли записи в регистре соответствий
			КлючОтправитель      = Выборка.Ключ_отправитель;
			СчетОтправительНомер = Выборка.СчетОтправительНомер;
			ВидОперации          = Выборка.ВидОперацииППвх;
			СчетБУ               = Выборка.СчетБУПолучатель;
			// Если счет транзитный
			// Попробуем получить строку по ключу, обходим всю выборку пока не найдем 		
			Попытка
				Строка = СокрЛП(СтрокаЗначения[КлючОтправитель]);
			Исключение
				Продолжить	
			КонецПопытки;
			
			// Нашли ключ:
			
			Если СокрЛП(СтрокаЗначения[КлючОтправитель]) = СокрЛП(СчетОтправительНомер) Тогда
				СруктураДанных = Новый Структура("ВыполнятьДвижения,ВидОперации,СчетБУ",
				Ложь,ВидОперации, СчетБУ);
				Возврат СруктураДанных
			КонецЕсли;
			
		КонецЦикла;
		
		// не нашли ничего.
		Возврат Неопределено;		
		
		
	КонецЕсли;
	
КонецФункции

// Устанавливает вид платежа и субконто ПП исх
Процедура УстановитьВидОплатыСубконтоППисх(Документ, СтрокаЗначения)
	// Выбираем значение ключа р/сч
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ОплатаИсходящаяБК.КлючСчетаПолучателя КАК Ключ
	|ИЗ
	|	РегистрСведений.ОплатаИсходящаяБК КАК ОплатаИсходящаяБК
	|ГДЕ
	|	ОплатаИсходящаяБК.БанкСчет = &БанкСчет";
	
	Запрос.УстановитьПараметр("БанкСчет", Документ.СчетОрганизации);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Не Выборка.Следующий() Тогда
		Возврат
	КонецЕсли;
	
	Ключ = Выборка.Ключ;
	
	//выборка по регистру с отбором по счету получателю.
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ОплатаИсходящаяБК.ВидОперации,
	|	ОплатаИсходящаяБК.СчетУчетаРасчетовСКонтрагентом,
	|	ОплатаИсходящаяБК.СубконтоДт1,
	|	ОплатаИсходящаяБК.СубконтоДт2,
	|	ОплатаИсходящаяБК.СубконтоДт3,
	|	ОплатаИсходящаяБК.СтатьяДвиженияДенежныхСредств,
	|	ОплатаИсходящаяБК.БанкСчет,
	|	ОплатаИсходящаяБК.СчетКонтрагента
	|ИЗ
	|	РегистрСведений.ОплатаИсходящаяБК КАК ОплатаИсходящаяБК
	|ГДЕ
	|	ОплатаИсходящаяБК.НомерСчетаПолучателя = &НомерСчетаПолучателя";
	
	НомерСчетаПолучателя = СтрокаЗначения[Ключ];
	Запрос.УстановитьПараметр("НомерСчетаПолучателя", СтрокаЗначения[Ключ]);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаПоРегистру = РезультатЗапроса.Выбрать();
	
	Если ВыборкаПоРегистру.Следующий() Тогда
		
		ЗаполнитьЗначенияСвойств(Документ, ВыборкаПоРегистру);
		
	КонецЕсли;
	
КонецПроцедуры

