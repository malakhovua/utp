#Область СлужебныеПроцедурыИФункции

Процедура УстановитьПараметрыСписков()
	
	//Товары
	Товары.Параметры.УстановитьЗначениеПараметра("НачалоПериода", Период.ДатаНачала);
	Товары.Параметры.УстановитьЗначениеПараметра("ОкончаниеПериода", Период.ДатаОкончания);
	
КонецПроцедуры

&НаКлиенте
Процедура РазукомплектоватьНаСервере(МассивДанных)
	
	ДанныеРазукомплектации = Обработки.ОбработкаСписанныхТоваровИзВозвратныхНакладных.РазукомплектоватьТоварныеПозиции(МассивДанных);
	Комплектации.Очистить();
	
	Для Каждого СтуктураДанных Из ДанныеРазукомплектации.МассивКомплектов Цикл
		НоваяСтрока = Комплектации.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтуктураДанных);
	КонецЦикла;
	
	Элементы.Товары.Обновить();
	
	ОткрытьФорму("Документ.РеализацияТоваровУслуг.Форма.ФормаДокумента",Новый Структура("Ключ", ДанныеРазукомплектации.РеализацияТоваров));
	
КонецПроцедуры

&НаКлиенте
Процедура Разукомплектовать(Команда)
	
	МассивДанных = Новый  Массив;
	
	Для Каждого ВыделеннаяСтрока Из Элементы.Товары.ВыделенныеСтроки Цикл
		
		ДанныеСтроки = Элементы.Товары.ДанныеСтроки(ВыделеннаяСтрока);
		
		Если ДанныеСтроки=Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Данные = Новый Структура("ДокументСписания, ВозвратТовара, Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения, Коэффициент, СчетУчетаБУ, Количество, Склад, Дата");
		ЗаполнитьЗначенияСвойств(Данные, ДанныеСтроки);
		МассивДанных.Добавить(Данные);
		
	КонецЦикла;
	
	РазукомплектоватьНаСервере(МассивДанных);
	
КонецПроцедуры


