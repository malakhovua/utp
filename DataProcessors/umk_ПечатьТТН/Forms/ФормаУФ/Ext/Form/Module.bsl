&НаСервере
Функция ПолучитьКладовщика()
	
	ФИОДолжность = Новый Структура("ФИОКладовщик, Физлицо");
	
	Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	umk_ГрафикиРаботыСкладскихРаботников.Сотрудник.Физлицо.Наименование КАК ФИОСотрудник,
		|	umk_ГрафикиРаботыСкладскихРаботников.Сотрудник.Физлицо КАК Физлицо
		|ИЗ
		|	РегистрСведений.umk_ГрафикиРаботыСкладскихРаботников КАК umk_ГрафикиРаботыСкладскихРаботников
		|ГДЕ
		|	umk_ГрафикиРаботыСкладскихРаботников.Период = &Дата");
	
	Запрос.УстановитьПараметр("Дата", НачалоДня(Объект.Дата));
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		ФИОДолжность.Вставить("ФИОСотрудник", Выборка.ФИОСотрудник);
		ФИОДолжность.Вставить("Физлицо", Выборка.Физлицо)
	Иначе
		ФИОДолжность.Вставить("ФИОСотрудник", "");
		ФИОДолжность.Вставить("Физлицо", "")		
	КонецЕсли;
	
	Возврат ФИОДолжность
	
КонецФункции

&НаСервере
Функция ПолучитьУК()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	УдостоверениеКачества.Номер,
		|	УдостоверениеКачества.Дата КАК Дата
		|ИЗ
		|	Документ.УдостоверениеКачества КАК УдостоверениеКачества
		|ГДЕ
		|	УдостоверениеКачества.Дата <= &Дата
		|	И УдостоверениеКачества.ПометкаУдаления = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	Дата УБЫВ";
	
	Запрос.УстановитьПараметр("Дата", КонецДня(Объект.Дата)); 
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат ", декларацiя виробника №" + Выборка.Номер + " вiд " +  Формат(Выборка.Дата, "ДФ=dd.MM.yyyy");
	Иначе
		Возврат ""
	КонецЕсли;

КонецФункции

&НаСервере
Процедура УстановитьНомер()
	
	НомерТТН = ОбщегоНазначения.ПолучитьНомерНаПечать(Документ);
	Если ТипЗнч(Документ) = Тип("ДокументСсылка.РеализацияТоваровУслуг") И НомерТТН <> "" Тогда
		
		НомерТТН = "Р" + НомерТТН;
		
	ИначеЕсли ТипЗнч(Документ) = Тип("ДокументСсылка.РасходныйОрдерНаТовары") И НомерТТН <> "" Тогда
		
		НомерТТН = "РО" + НомерТТН;
		
	ИначеЕсли ТипЗнч(Документ) = Тип("ДокументСсылка.ПеремещениеТоваров") И НомерТТН <> "" Тогда
		
		НомерТТН = "П" + НомерТТН;
		
	Иначе
		
		НомерТТН = "";
	
	КонецЕсли;
	
	Объект.НомерТТН = НомерТТН;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьВыборкуПоРегистру()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|*
		|ИЗ
		|	РегистрСведений.umk_ДанныеПутевыеЛисты КАК umk_ДанныеПутевыеЛисты
		|ГДЕ
		|	umk_ДанныеПутевыеЛисты.Документ = &Документ";
	
	Запрос.УстановитьПараметр("Документ", Документ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выбрать();
	
КонецФункции

&НаСервере
Процедура УстановитьМассу()
	
	Если Не КорректировкаМассы Тогда
		
		Если ЗначениеЗаполнено(Документ) Тогда
			Масса = 0;
			МасссаДок = Документ.Товары.Итог("Количество")* КратностьПечати;
			Если Цел(МасссаДок) <> МасссаДок Тогда
				МасссаДок = Цел(МасссаДок) + 1;
			КонецЕсли;
			Масса = Масса + МасссаДок;
			КГВЯщике = Константы.umk_КГВЯщике.Получить();
			Объект.КвоМест = ?(КГВЯщике = 0, 0, Макс(Окр(Масса / КГВЯщике, 0), 1));
			Объект.Масса = Масса / 1000;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьТипЦен()

	Если ТипЗнч(Документ) = Тип("ДокументСсылка.ПеремещениеТоваров")
	 ИЛИ ТипЗнч(Документ) = Тип("ДокументСсылка.РасходныйОрдерНаТовары") Тогда

		Если НЕ ЗначениеЗаполнено(Объект.ТипЦен) Тогда
			Объект.ТипЦен = УправлениеПользователями.ПолучитьЗначениеПоУмолчанию(глЗначениеПеременной("глТекущийПользователь"), "ОсновнойТипЦенПродажи");
		КонецЕсли;
	Иначе
		Объект.ТипЦен = Неопределено;
	КонецЕсли;

КонецПроцедуры 

&НаСервере
Процедура УстановитьВидимостьДоступность()

	Если ТипЗнч(Документ) = Тип("ДокументСсылка.ПеремещениеТоваров")
	 ИЛИ ТипЗнч(Документ) = Тип("ДокументСсылка.РасходныйОрдерНаТовары") Тогда
		ДоступностьТипаЦен = Истина;
	Иначе
		ДоступностьТипаЦен = Ложь;
	КонецЕсли;
	
	Элементы.ТипЦен.Доступность        = ДоступностьТипаЦен;

КонецПроцедуры

&НаСервере
Процедура УстановитьВидПеревозки()
	
	НашаОрганизация = Справочники.Организации.НайтиПоНаименованию(СокрЛП(Объект.Перевозчик));
	ГоловнаяОрганизация = Константы.umk_ГоловнаяОрганизация.Получить();
	Если ЗначениеЗаполнено(НашаОрганизация) Тогда
		// Если это ФОП то всегда межгород.
		ЭтоФОП = Не (Строка(СокрЛП(НашаОрганизация)) = Строка(СокрЛП(ГоловнаяОрганизация)));
		Если ЭтоФОП Тогда
			Объект.Межгород = Истина;
			ВидПеревозки();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ВидПеревозки()
	
	Объект.ВидПеревозки = ?(Объект.Город, "міські", "міжміські");

КонецПроцедуры

&НаСервере
Процедура ПриИзмененииАвтомобиля()
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	umk_ПараметрыТранспортаСрезПоследних.ГосНомер КАК ГосНомер,
		|	umk_ПараметрыТранспортаСрезПоследних.Водитель,
		|	umk_ПараметрыТранспортаСрезПоследних.ОсновноеСредство.НаименованиеПолное КАК Марка,
		|	umk_ПараметрыТранспортаСрезПоследних.Водитель.umk_УдостоверениеВодителя КАК УдостоверениеВодителя
		|ИЗ
		|	РегистрСведений.umk_ПараметрыТранспорта.СрезПоследних(&Период, ОсновноеСредство = &ОсновноеСредство) КАК umk_ПараметрыТранспортаСрезПоследних";
	
	Запрос.УстановитьПараметр("Период", Объект.Дата);
	Запрос.УстановитьПараметр("ОсновноеСредство", АвтомобильСсылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() тогда
		 Объект.Водитель= Выборка.Водитель;
		 Объект.Удостоверение = Выборка.УдостоверениеВодителя;
		 Объект.МаркаИГосНомерАвтомобиля = СокрЛП(Выборка.Марка);//СокрП(Выборка.ГосНомер) + " " + СокрП(Выборка.Марка);
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Функция ЗначениеРеквизитаСервер(ОбъектСсылка, ИмяРеквизита)
	 Возврат ОбъектСсылка[ИмяРеквизита]
КонецФункции

#КонецОбласти