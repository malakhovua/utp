// Сохраняет настройки формы в РС 
Процедура СохранитьНастройки()Экспорт
	
	// Очистим
	НаборЗаписей = РегистрыСведений.umk_ПараметрыПодключенияКБазеСклад.СоздатьНаборЗаписей();
	НаборЗаписей.Записать();
	
	//Запишем
	ЗаписьРС = РегистрыСведений.umk_ПараметрыПодключенияКБазеСклад.СоздатьМенеджерЗаписи();
