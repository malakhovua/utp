// ПЕРЕМЕННЫЕ
Перем РодительскиеТипыОбъектовМетаданных;
Перем мФайлПротоколаДанных Экспорт; // файл для ведения протокола обмена данными


//ПРОЦЕДУРЫ ЗАПОЛНЕНИЯ ТАБЛИЦ ОБРАБОТКИ

// Процедуры заполнения списка к проведению
Процедура ПередатьКПроведению() Экспорт
	
	Для Каждого СтрокаИмен Из СписокМетаданных Цикл
		Если СтрокаИмен.Пометка Тогда
			СтрокаКПроведению = МетаданныеКПроведению.Добавить();
			СтрокаКПроведению.ИмяДокумента = СтрокаИмен.ИмяДокумента;
			СтрокаКПроведению.Синоним = СтрокаИмен.Синоним;
		КонецЕсли
	КонецЦИкла;
	
	МетаданныеКПроведению.Свернуть("ИмяДокумента, Синоним");
	
КонецПроцедуры

// Процедуры заполнения списка метаданных
Процедура ЗаполнитьСписокМетаданных()Экспорт
	
	РодительскиеТипыОбъектовМетаданных = Новый Структура;
	вДобавитьРодительскийТип(РодительскиеТипыОбъектовМетаданных,"Документ","Документы");
	вСчитатьИзКонфигурации();
	
КонецПроцедуры

// Процедура считывает структуру метаданных текущей конфигурации
// в дерево значений
Процедура вСчитатьИзКонфигурации()
	//ТекОтбор = ВладелецФормы.ЭлементыФормы.ПроводимыеОбъекты.ОтборСтрок.Метаданные;
	СписокМетаданных.Очистить();
	Для каждого  РодительскийТип Из  РодительскиеТипыОбъектовМетаданных Цикл
		Для каждого  ДочернийТип Из  Метаданные[РодительскийТип.Значение.ИмяМножественное] Цикл
			НоваяСтрока = СписокМетаданных.Добавить();
			НоваяСтрока.ИмяДокумента = СокрЛП(ДочернийТип.Имя);
			НоваяСтрока.Синоним = СокрЛП(ДочернийТип.Синоним);
			НоваяСтрока.Пометка = Истина;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

Процедура вДобавитьРодительскийТип(Типы,ДобавляемыйТип,ИмяМножественное,СтрокаСоставаМетаданных = "")
	Если Метаданные[ИмяМножественное].Количество() <> 0 Тогда
		СтруктураСоставаМетаданных = Новый Структура;
		Строка = СокрЛП(СтрокаСоставаМетаданных);
		Пока Строка <> "" Цикл
			ПозЗПТ = Найти(Строка,",");
			Если ПозЗПТ <>  0 Тогда
				СоставМетаданного = СокрЛП(Лев(СоставМетаданного,ПозЗПТ-1));
				Строка = СокрЛП(Сред(СоставМетаданного,ПозЗПТ+1));
			Иначе
				СоставМетаданного = СокрЛП(Строка);
				Строка = "";
			КонецЕсли;
			СтруктураСоставаМетаданных.Вставить(СоставМетаданного,Истина);
		КонецЦикла;
		Структура = Новый Структура;
		Структура.Вставить("ИмяМножественное",ИмяМножественное);
		Структура.Вставить("Метаданные",Метаданные[ИмяМножественное]);
		Структура.Вставить("СоставМетаданных",СтруктураСоставаМетаданных);
		Типы.Вставить(ДобавляемыйТип,Структура)
	КонецЕсли;
КонецПроцедуры // ДобавитьРодительскийТип()

// Возвращает массив документов для проведения
Функция ПолучитьМассивДокументов(МассивИмен)
	
	ТаблицаДокументов = Новый ТаблицаЗначений;
	ТаблицаДокументов.Колонки.Добавить("Ссылка");
	ТаблицаДокументов.Колонки.Добавить("Дата");

	Если ПровестиПоОтрицательным Тогда // Проводим только по дукументам с отрицательными остатками по партиям, по счету 26
		
		// Номенклатура с отрицательным остатком
		
		СчетаОстатков = Новый Массив;
		СчетаОстатков.Добавить(ПланыСчетов.Хозрасчетный.ГотоваяПродукция);
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("СчетаОстатков", СчетаОстатков);
		Запрос.УстановитьПараметр("ДатаОкончания", КонецДня(ДатаОкончания));
		Запрос.УстановитьПараметр("Организация", Организация);
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ХозрасчетныйОстатки.Субконто1 КАК Субконто1,
		|	ХозрасчетныйОстатки.Субконто2,
		|	ХозрасчетныйОстатки.Субконто3,
		|	ХозрасчетныйОстатки.Субконто4,
		|	ХозрасчетныйОстатки.КоличествоОстаток
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.Остатки(&ДатаОкончания, Счет В (&СчетаОстатков), , Организация = &Организация) КАК ХозрасчетныйОстатки
		|ГДЕ
		|	ХозрасчетныйОстатки.КоличествоОстаток < 0" ;
		
		Результат = Запрос.Выполнить().Выгрузить();
		Результат.Свернуть("Субконто1");
		МассивНоменклатуры = Результат.ВыгрузитьКолонку("Субконто1");
		
		// Выберим документы движения с этими позициями 
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ХозрасчетныйОбороты.Регистратор КАК Ссылка,
		|	ХозрасчетныйОбороты.Субконто1,
		|	ХозрасчетныйОбороты.Счет,
		|	ХозрасчетныйОбороты.Регистратор.Дата КАК РегистраторДата
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.Обороты(
		|			&ДатаНачала,
		|			&ДатаОкончания,
		|			Регистратор,
		|			Счет В (&МассивСчетов),
		|			,
		|			Субконто1 В (&Номенклатура)
		|				И Организация = &Организация,
		|			,
		|			) КАК ХозрасчетныйОбороты
		|ГДЕ
		|	НЕ ТИПЗНАЧЕНИЯ(ХозрасчетныйОбороты.Регистратор) = ТИП(Документ.ОтчетПроизводстваЗаСмену)
		|
		|УПОРЯДОЧИТЬ ПО
		|	РегистраторДата";
		
		Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
		Запрос.УстановитьПараметр("ДатаОкончания", КонецДня(ДатаОкончания));
		Запрос.УстановитьПараметр("МассивСчетов", СчетаОстатков);
		Запрос.УстановитьПараметр("Номенклатура", МассивНоменклатуры);
		Запрос.УстановитьПараметр("Организация",Организация);
		
		ТаблицаДокументов = Запрос.Выполнить().Выгрузить();
		ТаблицаДокументов.Свернуть("Ссылка");
		
		Возврат ТаблицаДокументов.ВыгрузитьКолонку("Ссылка");
		
		
	Иначе
		
		
		
		Для Каждого ИмяДокумента Из МассивИмен Цикл
			
			
			Текст = 
			"ВЫБРАТЬ
			|	%ИмяДокумента%.Ссылка,
			|	%ИмяДокумента%.Дата КАК Дата
			|ИЗ
			|	Документ.%ИмяДокумента% КАК %ИмяДокумента%
			|ГДЕ
			|	%ИмяДокумента%.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
			|	И %ИмяДокумента%.ПометкаУдаления = ЛОЖЬ
			|	И %ИмяДокумента%.Проведен = ИСТИНА
			|	И %ИмяДокумента%.Организация = &Организация
			|
			|УПОРЯДОЧИТЬ ПО
		    |	Дата" ;
			
			
			Текст = СтрЗаменить(Текст,"%ИмяДокумента%", ИмяДокумента); 
			
			
			Запрос = Новый Запрос(Текст);
			Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
			Запрос.УстановитьПараметр("ДатаОкончания", КонецДня(ДатаОкончания));
			Запрос.УстановитьПараметр("Организация", Организация);
			
			Результат = Запрос.Выполнить().Выгрузить();
			
			Для Каждого Строка Из Результат Цикл
				
				НоваяСтрока = ТаблицаДокументов.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
				
			КонецЦикла
			
		КонецЦикла;
		
		ТаблицаДокументов.Сортировать("Дата Возр");
		
		Возврат ТаблицаДокументов.ВыгрузитьКолонку("Ссылка");
		
	КонецЕсли;
	
КонецФункции

// ОБРАБОТКА ПРОВЕДЕНИЯ ДОКУМЕНТОВ
Процедура ПровестиДокументы()Экспорт
	
	ИнициализироватьВедениеПротоколаОбмена();
	
	МассивИмен = МетаданныеКПроведению.ВыгрузитьКолонку("ИмяДокумента");
	
	ПроводимыеДокументы = ПолучитьМассивДокументов(МассивИмен);
	
	
	Форма = ПолучитьФорму("Форма");
	
	Если Форма.Открыта() Тогда
		Прогресс = Форма.ЭлементыФормы.Индикатор;
		Прогресс.Значение = 0;
		Прогресс.МаксимальноеЗначение = ПроводимыеДокументы.Количество();
	КонецЕсли;
	
	
	НомерДокументаВПорции = 0;
	
	Для Каждого ДокументСсылка Из ПроводимыеДокументы Цикл
		
		ОбработкаПрерыванияПользователя();
		
		
		Если НомерДокументаВПорции >= ДокументПорция
			Тогда
			umk_Доработки.Пауза(ПаузаМеждуПорциями);
			НомерДокументаВПорции = 0
		КонецЕсли;
		
		Состояние(ДокументСсылка.Ссылка);
		ЗаписатьВПротоколВыполнения("Начало проведения: " + Строка(ДокументСсылка.Ссылка));
		
		ДокументПроведен = ПровестиДокументОбъект(ДокументСсылка.Ссылка);
		
		Если Не ДокументПроведен  Тогда
			Текст = Строка(ТекущаяДата()) + ". Операция прервана при попытке проведения документа: " + Строка(ДокументСсылка.Ссылка);
			Сообщить(Текст, СтатусСообщения.ОченьВажное);
			ЗаписатьВПротоколВыполнения(Текст);
			ЗавершитьВедениеПротокола();
			Возврат
		КонецЕсли;
		
		НомерДокументаВПорции = НомерДокументаВПорции +1;
		
		
		Если Форма.Открыта() тогда
			
			Прогресс.Значение = Прогресс.Значение + 1;	
			
		КонецЕсли;
		
		
	КонецЦикла; // По проводимым документам
	
	ЗавершитьВедениеПротокола();
			
	#Если Клиент Тогда
		
	#КонецЕсли

	
Конецпроцедуры

Функция  ПровестиДокументОбъект(ДокументСсылка)
	
	Попытка
		Документ = ДокументСсылка.ПолучитьОбъект();
	Исключение
		
		Сообщить(ОписаниеОшибки());
		
		ЗаписатьВПротоколВыполнения(ОписаниеОшибки());
		
		ЗавершитьВедениеПротокола();
		
		Возврат Ложь;
		
	КонецПопытки;

	
	ДокументЗаписан = Ложь;
	
	Если Документ.Проведен Тогда
		ЗаписатьДокумент(Документ, 0, ДокументЗаписан);
	КонецЕсли;
	
	Возврат ДокументЗаписан
	
КонецФункции

Процедура ЗаписатьДокумент(ДокументОбъект, НомерПопытки, ДокументЗаписан, ПерваяПопытка = Истина)
	
	ОбработкаПрерыванияПользователя();
	
	Если Не  ПерваяПопытка Тогда
		
		umk_Доработки.Пауза(ПаузаМеждуПопытками);
		
	КонецЕсли;
	
	Если НомерПопытки >= КоличествоПопыток И Не ПерваяПопытка
		
		Тогда
		
		ДокументЗаписан = Ложь;
		
		Возврат
		
	КонецЕсли;
	
	
	Попытка						
		
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
				
		ДокументЗаписан = Истина;
		
		Возврат 
		
	Исключение
		
		НомерПопытки = НомерПопытки + 1;
		ПерваяПопытка = Ложь;
		
		ЗаписатьВПротоколВыполнения("Номер попытки:" + Строка(НомерПопытки));

		ЗаписатьВПротоколВыполнения(ОписаниеОшибки());
		
		ЗаписатьДокумент(ДокументОбъект, НомерПопытки, ДокументЗаписан, Ложь);
		
	КонецПопытки;

	
КонецПроцедуры

