// ПРОЦЕДУРЫ И ФУНКЦИИ РАБОТЫ С ПРОТОКОЛОМ ОБМЕНА

// Выполняет инициализацию файла для записи событий 
//
// Параметры:
//  Нет.
// 
Процедура ИнициализироватьВедениеПротоколаОбмена() Экспорт
	
	Если ПустаяСтрока(ИмяФайлаПротокола) Тогда
		
		мФайлПротоколаДанных = Неопределено;
			
		Возврат;
		
	КонецЕсли;
	
	мФайлПротоколаДанных = Новый ЗаписьТекста(ИмяФайлаПротокола, КодировкаТекста.ANSI, , Истина) ;
	
КонецПроцедуры

// Закрывает файл протокола обмена данными. Файл сохраняется на диск
//
Процедура ЗавершитьВедениеПротокола() Экспорт 
	
	Если мФайлПротоколаДанных <> Неопределено Тогда
		
		мФайлПротоколаДанных.Закрыть();
				
	КонецЕсли;	
	
	мФайлПротоколаДанных = Неопределено;
	
КонецПроцедуры

// Сохраняет в протокол выполнения  сообщения  
// 
Процедура ЗаписатьВПротоколВыполнения(Текст) Экспорт
	
	Если мФайлПротоколаДанных <> Неопределено Тогда
		
		Текст = Строка(ТекущаяДата()) + " " + Текст;
		мФайлПротоколаДанных.ЗаписатьСтроку(Текст);	
		
	КонецЕсли;
			
КонецПроцедуры


