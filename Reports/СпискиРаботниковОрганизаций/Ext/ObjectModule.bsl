#Если Клиент Тогда
Процедура СформироватьОтчет(ДокументРезультат, ПоказыватьЗаголовок = Ложь, ВысотаЗаголовка = 0, ТолькоЗаголовок = Ложь) Экспорт

	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("ДатаАктуальности", ОбщийОтчет.ДатаКон);
	Если НЕ ЗначениеЗаполнено(ОбщийОтчет.ДатаКон) Тогда 
		ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("ДатаАктуальности_Год", Год(РабочаяДата));
		ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("ДатаАктуальности_Месяц", Месяц(РабочаяДата));
		ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("ДатаАктуальности_День", День(РабочаяДата));
	Иначе 
		ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("ДатаАктуальности_Год", Год(ОбщийОтчет.ДатаКон));
		ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("ДатаАктуальности_Месяц", Месяц(ОбщийОтчет.ДатаКон));
		ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("ДатаАктуальности_День", День(ОбщийОтчет.ДатаКон));
	КонецЕсли;
	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("Уволен", Перечисления.ПричиныИзмененияСостояния.Увольнение);
	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("Прием", Перечисления.ПричиныИзмененияСостояния.ПриемНаРаботу);
	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("Истина", Истина);
	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("Ложь", Ложь);
	ОбщийОтчет.СформироватьОтчет(ДокументРезультат, ПоказыватьЗаголовок, ВысотаЗаголовка, ТолькоЗаголовок);

КонецПроцедуры

Процедура ЗаполнитьНачальныеНастройки() Экспорт
	
	ОбщийОтчет.ИмяРегистра = "-";
	ОбщийОтчет.мНазваниеОтчета = НСтр("ru='Списки работников организации';uk='Списки працівників організації'");
	
	ПостроительОтчета = ОбщийОтчет.ПостроительОтчета;
	
	// структура представлений полей
	СтруктураПредставлениеПолей = Новый Структура();
	
	ТекстЗапроса = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РаботникиОрганизации.ФизЛицо КАК ФизЛицо
	|	//ДОПОЛНИТЕЛЬНЫЕ ПОЛЯ
	|
	|{ВЫБРАТЬ
	|	// данные о работнике организации
	|	РаботникиОрганизации.Сотрудник КАК Сотрудник,
	|	РаботникиОрганизации.Сотрудник.ФизЛицо	КАК ФизЛицо,
	|	РаботникиОрганизации.ПодразделениеОрганизации.* КАК ПодразделениеОрганизации,
	|	РаботникиОрганизации.ПодразделениеОрганизации.Владелец.* КАК Организация,
	|	РаботникиОрганизации.Должность.* КАК Должность,
	|	РаботникиОрганизации.ГрафикРаботы.* КАК ГрафикРаботы,
	|	РаботникиОрганизации.Организация.* КАК ГоловнаяОрганизация,
	|	РаботникиОрганизации.Сотрудник.Код КАК ТабельныйНомер,
	|	РаботникиОрганизации.ЗанимаемыхСтавок КАК ЗанимаемыхСтавок,
	|	РаботникиОрганизации.ПодразделениеУпр.* КАК ПодразделениеУпр,
	|	РаботникиОрганизации.ДолжностьУпр.* КАК ДолжностьУпр,
	|	РаботникиОрганизации.ЗанимаемыхСтавокУпр КАК ЗанимаемыхСтавокУпр,
	|	РаботникиОрганизации.ГрафикРаботыУпр.* КАК ГрафикРаботыУпр,
	|	РаботникиОрганизации.Сотрудник.ПоНаправлениюОргановЗанятости КАК ПоНаправлениюОргановЗанятости,
	|	РаботникиОрганизации.ПринятНаНовоеРабочееМесто КАК ПринятНаНовоеРабочееМесто,
	|	ПриказыОПриеме.ДатаПриема КАК ДатаПриема,
	|	ПриказыОПриеме.ВидЗанятости КАК ВидЗанятости,
	|	ВЫБОР
	|		КОГДА РаботникиОрганизации.ПричинаИзмененияСостояния = &Уволен
	|			ТОГДА РаботникиОрганизации.Период
	|		ИНАЧЕ ""-""
	|	КОНЕЦ КАК ДатаУвольнения,
	|	ПлановыеНачисленияРаботниковСрез.ВидРасчета КАК ВидРасчета,
	|	ПлановыеНачисленияРаботниковСрез.Валюта1 КАК Валюта1,
	|	ПлановыеНачисленияРаботниковСрез.Валюта2 КАК Валюта2,
	|	ПлановыеНачисленияРаботниковСрез.Валюта3 КАК Валюта3,
	|	ПлановыеНачисленияРаботниковСрез.Показатель1 КАК Показатель1,
	|	ПлановыеНачисленияРаботниковСрез.Показатель2 КАК Показатель2,
	|	ПлановыеНачисленияРаботниковСрез.Показатель3 КАК Показатель3,
	|	ВЫБОР КОГДА РаботникиОрганизации.ПричинаИзмененияСостояния = &Уволен 
	|		  	ТОГДА ""Уволен"" 
	|		  КОГДА ((СостояниеРаботниковОрганизации.Состояние) ЕСТЬ NULL)И((РаботникиОрганизации.ПодразделениеОрганизации) ЕСТЬ NULL)  
	|			ТОГДА """" 
	|		  КОГДА (СостояниеРаботниковОрганизации.Состояние) ЕСТЬ NULL  
	|			ТОГДА ""Работает"" 
	|		  ИНАЧЕ СостояниеРаботниковОрганизации.Состояние 
	|	КОНЕЦ КАК Состояние,
	|	ВЫБОР КОГДА РаботникиОрганизации.ПричинаИзмененияСостоянияУпр = &Уволен 
	|		  	ТОГДА ""Уволен"" 
	|		  КОГДА ((СостояниеРаботников.Состояние) ЕСТЬ NULL)И((РаботникиОрганизации.ПодразделениеУпр) ЕСТЬ NULL)  
	|			ТОГДА """" 
	|		  КОГДА (СостояниеРаботников.Состояние) ЕСТЬ NULL  
	|			ТОГДА ""Работает"" 
	|		  ИНАЧЕ СостояниеРаботников.Состояние 
	|	КОНЕЦ КАК СостояниеУпр,
	|	ВЫБОР КОГДА (РаботникиОрганизации.ЗанимаемыхСтавок > 0) ИЛИ (РаботникиОрганизации.ЗанимаемыхСтавокУпр > 0)
	|			ТОГДА ""Работает"" 
	|		  ИНАЧЕ ""Не работает"" 
	|	КОНЕЦ КАК СостояниеОбщ
	|	//ДАННЫЕ О ФИЗЛИЦЕ: ПОЛЯ
	|	//ДОПОЛНИТЕЛЬНЫЕ ПОЛЯ
	|	//КОНТАКТНАЯ ИНФОРМАЦИЯ: ПОЛЯ 
	|	//СВОЙСТВА
	|}
	|
	|ИЗ
	|   (ВЫБРАТЬ РАЗЛИЧНЫЕ
	|   ВЫБОР КОГДА НЕ (РаботникиОрганизации.Сотрудник ЕСТЬ NULL) 
	|	ТОГДА РаботникиОрганизации.Сотрудник
	|	ИНАЧЕ СотрудникиОрганизаций.Ссылка
	|   КОНЕЦ КАК Сотрудник,
	|   ВЫБОР КОГДА НЕ (РаботникиОрганизации.Сотрудник ЕСТЬ NULL) 
	|	ТОГДА РаботникиОрганизации.Сотрудник.ФизЛицо
	|	ИНАЧЕ СотрудникиОрганизаций.ФизЛицо
	|   КОНЕЦ КАК ФизЛицо,
	|	РаботникиОрганизации.Период КАК Период,
	|	РаботникиОрганизации.ПодразделениеОрганизации КАК ПодразделениеОрганизации,
	|	РаботникиОрганизации.ПодразделениеОрганизации.Владелец КАК Организация,
	|	РаботникиОрганизации.Должность КАК Должность,
	|	РаботникиОрганизации.ГрафикРаботы КАК ГрафикРаботы,
	|	РаботникиОрганизации.Организация КАК ГоловнаяОрганизация,
	|	РаботникиОрганизации.Сотрудник.Код КАК ТабельныйНомер,
	|	РаботникиОрганизации.ПричинаИзмененияСостояния КАК ПричинаИзмененияСостояния,
	|	РаботникиОрганизации.ЗанимаемыхСтавок КАК ЗанимаемыхСтавок,
	|	РаботникиОрганизации.Сотрудник.ПоНаправлениюОргановЗанятости КАК ПоНаправлениюОргановЗанятости,
	|	РаботникиОрганизации.ПринятНаНовоеРабочееМесто КАК ПринятНаНовоеРабочееМесто,
	|	Работники.Период КАК ПериодУпр,
	|	Работники.Подразделение КАК ПодразделениеУпр,
	|	Работники.Должность КАК ДолжностьУпр,
	|	Работники.ПричинаИзмененияСостояния КАК ПричинаИзмененияСостоянияУпр,
	|	Работники.ГрафикРаботы КАК ГрафикРаботыУпр,
	|	Работники.ЗанимаемыхСтавок КАК ЗанимаемыхСтавокУпр
	|   ИЗ
    |	РегистрСведений.РаботникиОрганизаций.СрезПоследних(&ДатаАктуальности) КАК РаботникиОрганизации
	|		ПОЛНОЕ СОЕДИНЕНИЕ РегистрСведений.Работники.СрезПоследних(&ДатаАктуальности) КАК Работники
	|		ПО РаботникиОрганизации.Сотрудник.ФизЛицо  = Работники.ФизЛицо
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СотрудникиОрганизаций КАК СотрудникиОрганизаций
	|		ПО Работники.ФизЛицо = СотрудникиОрганизаций.ФизЛицо	) КАК РаботникиОрганизации
	|		{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостояниеРаботниковОрганизаций.СрезПоследних(&ДатаАктуальности) КАК СостояниеРаботниковОрганизации
	|		ПО РаботникиОрганизации.Сотрудник= СостояниеРаботниковОрганизации.Сотрудник И РаботникиОрганизации.Организация = СостояниеРаботниковОрганизации.Организация}
	|		{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостояниеРаботников.СрезПоследних(&ДатаАктуальности) КАК СостояниеРаботников
	|		ПО РаботникиОрганизации.Сотрудник.ФизЛицо  = СостояниеРаботников.ФизЛицо}
	|		//ДАННЫЕ О ФИЗЛИЦЕ: СОЕДИНЕНИЯ
	|		//КОНТАКТНАЯ ИНФОРМАЦИЯ: СОЕДИНЕНИЯ
	|		//СОЕДИНЕНИЯ
	|		{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПлановыеНачисленияРаботниковОрганизаций.СрезПоследних(&ДатаАктуальности) КАК ПлановыеНачисленияРаботниковСрез
	|		ПО РаботникиОрганизации.Сотрудник  = ПлановыеНачисленияРаботниковСрез.Сотрудник И РаботникиОрганизации.Организация = ПлановыеНачисленияРаботниковСрез.Организация
	|		 И 	ПлановыеНачисленияРаботниковСрез.Актуальность = &Истина}
	|		{ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ДатыПоследнихДвиженийРаботников.Период КАК ДатаПриема,
	|			ДатыПоследнихДвиженийРаботников.Организация,
	|			ДатыПоследнихДвиженийРаботников.Сотрудник				КАК Сотрудник,
	|			ДатыПоследнихДвиженийРаботников.Сотрудник.ФизЛицо		КАК ФизЛицо,
	|			ДанныеПоРаботникуПриНазначении.Сотрудник.ВидЗанятости КАК ВидЗанятости
	|		ИЗ
	|			(ВЫБРАТЬ
	|				ТЧРаботникиОрганизации.Организация,
	|				МАКСИМУМ(Работники.Период) КАК Период,
	|				ТЧРаботникиОрганизации.Сотрудник КАК Сотрудник,
	|				ТЧРаботникиОрганизации.Сотрудник.ФизЛицо КАК ФизЛицо
	|			ИЗ
	|				РегистрСведений.РаботникиОрганизаций.СрезПоследних(&ДатаАктуальности,) КАК ТЧРаботникиОрганизации
	|					ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РаботникиОрганизаций КАК Работники
	|					ПО ТЧРаботникиОрганизации.Сотрудник = Работники.Сотрудник
	|						И ТЧРаботникиОрганизации.Организация = Работники.Организация
	|						И Работники.Период <= ТЧРаботникиОрганизации.Период
	|						И (Работники.ПричинаИзмененияСостояния = &Прием)
	|			{ГДЕ
	|				ТЧРаботникиОрганизации.Должность КАК Должность,
	|				ТЧРаботникиОрганизации.ГрафикРаботы КАК ГрафикРаботы,
	|				ТЧРаботникиОрганизации.Сотрудник		КАК Сотрудник,
	|				ТЧРаботникиОрганизации.Сотрудник.ФизЛицо КАК ФизЛицо,
	|				ТЧРаботникиОрганизации.ЗанимаемыхСтавок КАК ЗанимаемыхСтавок,
	|				ТЧРаботникиОрганизации.ПодразделениеОрганизации.Владелец КАК ОбособленноеПодразделение,
	|				ТЧРаботникиОрганизации.ПодразделениеОрганизации КАК Подразделение}
	|			
	|			СГРУППИРОВАТЬ ПО
	|				ТЧРаботникиОрганизации.Организация,
	|				ТЧРаботникиОрганизации.Сотрудник,
	|				ТЧРаботникиОрганизации.Сотрудник.ФизЛицо) КАК ДатыПоследнихДвиженийРаботников
	|				ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РаботникиОрганизаций КАК ДанныеПоРаботникуПриНазначении
	|				ПО ДанныеПоРаботникуПриНазначении.Период = ДатыПоследнихДвиженийРаботников.Период
	|					И ДатыПоследнихДвиженийРаботников.Сотрудник = ДанныеПоРаботникуПриНазначении.Сотрудник
	|					И (ДатыПоследнихДвиженийРаботников.Организация = ДанныеПоРаботникуПриНазначении.Организация)) КАК ПриказыОПриеме
	|		ПО ПриказыОПриеме.Организация = РаботникиОрганизации.Организация
	|			И ПриказыОПриеме.Сотрудник = РаботникиОрганизации.Сотрудник}
	|
	|{ГДЕ
	|	РаботникиОрганизации.Сотрудник КАК Сотрудник,
	|	РаботникиОрганизации.Сотрудник.ФизЛицо 	КАК ФизЛицо,
	|	РаботникиОрганизации.ПодразделениеОрганизации.* КАК ПодразделениеОрганизации,
	|	РаботникиОрганизации.ПодразделениеУпр.* КАК ПодразделениеУпр,
	|	РаботникиОрганизации.ПодразделениеОрганизации.Владелец.* КАК Организация,
	|	РаботникиОрганизации.Должность.* КАК Должность,
	|	РаботникиОрганизации.ДолжностьУпр.* КАК ДолжностьУпр,
	|	РаботникиОрганизации.ГрафикРаботы.* КАК ГрафикРаботы,
	|	РаботникиОрганизации.ГрафикРаботыУпр.* КАК ГрафикРаботыУпр,
	|	РаботникиОрганизации.Организация.* КАК ГоловнаяОрганизация,
	|	РаботникиОрганизации.Сотрудник.Код КАК ТабельныйНомер,
	|	РаботникиОрганизации.ЗанимаемыхСтавок КАК ЗанимаемыхСтавок,
	|	РаботникиОрганизации.ЗанимаемыхСтавокУпр КАК ЗанимаемыхСтавокУпр,
	|	РаботникиОрганизации.Сотрудник.ПоНаправлениюОргановЗанятости КАК ПоНаправлениюОргановЗанятости,
	|	РаботникиОрганизации.ПринятНаНовоеРабочееМесто КАК ПринятНаНовоеРабочееМесто,
	|	ПриказыОПриеме.ДатаПриема КАК ДатаПриема,
	|	ПриказыОПриеме.ВидЗанятости КАК ВидЗанятости,
	|	ВЫБОР
	|		КОГДА РаботникиОрганизации.ПричинаИзмененияСостояния = &Уволен
	|			ТОГДА РаботникиОрганизации.Период
	|		ИНАЧЕ ""-""
	|	КОНЕЦ КАК ДатаУвольнения,
	|	ПлановыеНачисленияРаботниковСрез.ВидРасчета КАК ВидРасчета,
	|	ПлановыеНачисленияРаботниковСрез.Валюта1 КАК Валюта1,
	|	ПлановыеНачисленияРаботниковСрез.Валюта2 КАК Валюта2,
	|	ПлановыеНачисленияРаботниковСрез.Валюта3 КАК Валюта3,
	|	ВЫБОР КОГДА (РаботникиОрганизации.ЗанимаемыхСтавок > 0) ИЛИ (РаботникиОрганизации.ЗанимаемыхСтавокУпр > 0)
	|			ТОГДА ""Работает"" 
	|		  ИНАЧЕ ""Не работает"" 
	|	КОНЕЦ КАК СостояниеОбщ,
	|	ВЫБОР КОГДА РаботникиОрганизации.ПричинаИзмененияСостояния = &Уволен 
	|		  	ТОГДА ""Уволен"" 
	|		  КОГДА ((СостояниеРаботниковОрганизации.Состояние) ЕСТЬ NULL)И((РаботникиОрганизации.ПодразделениеОрганизации) ЕСТЬ NULL)  
	|			ТОГДА """" 
	|		  КОГДА (СостояниеРаботниковОрганизации.Состояние) ЕСТЬ NULL  
	|			ТОГДА ""Работает"" 
	|		  ИНАЧЕ СостояниеРаботниковОрганизации.Состояние 
	|	КОНЕЦ КАК Состояние,
	|	ВЫБОР КОГДА РаботникиОрганизации.ПричинаИзмененияСостоянияУпр = &Уволен 
	|		  	ТОГДА ""Уволен"" 
	|		  КОГДА ((СостояниеРаботников.Состояние) ЕСТЬ NULL)И((РаботникиОрганизации.ПодразделениеУпр) ЕСТЬ NULL)  
	|			ТОГДА """" 
