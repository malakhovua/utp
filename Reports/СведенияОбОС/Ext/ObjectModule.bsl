// Процедура перегружает значения отбора
// из реквизита обработки "Отбор"
// в отбор построителя запроса
// 
Процедура СкопироватьОтбор(ОтборИсточник, ОтборПриемник, ТолькоИспользуемые = Ложь) Экспорт
	
	// Очистка отбора приемника
	КвоЭлементов = ОтборПриемник.Количество() - 1;
	
	Для Н = 0 По КвоЭлементов Цикл
	
		ОтборПриемник.Удалить(КвоЭлементов - Н);	
	
	КонецЦикла;
	
	// Загрузка элементов отбора
	КвоЭлементов = ОтборИсточник.Количество() - 1;
	
	Для Н = 0 По КвоЭлементов Цикл
		
		ОбратныйИндекс = КвоЭлементов - Н;
		Элемент        = ОтборИсточник[ОбратныйИндекс];
		
		Если (НЕ ТолькоИспользуемые) ИЛИ Элемент.Использование Тогда
			
			Если ЗначениеЗаполнено(Элемент.ПутьКДанным) Тогда
				
				ЭлементПриемника = ОтборПриемник.Добавить(Элемент.ПутьКДанным);
				
			Иначе
				
				ЭлементПриемника = Неопределено;
				
			КонецЕсли;
			
			Если ЭлементПриемника <> Неопределено Тогда
				
				Попытка
				
					ЭлементПриемника.ВидСравнения  = Элемент.ВидСравнения;
					ЭлементПриемника.Значение	   = Элемент.Значение;
					ЭлементПриемника.ЗначениеС	   = Элемент.ЗначениеС;
					ЭлементПриемника.ЗначениеПо	   = Элемент.ЗначениеПо;
					ЭлементПриемника.Использование = Элемент.Использование;
					
				
				Исключение
					
					ОбщегоНазначения.СообщитьОбОшибке(НСтр("ru='Элемент отбора <';uk='Елемент відбору <'", КодЯзыкаПечать) + Элемент + ">:" + Символы.ПС + Символы.Таб + ОписаниеОшибки()
					                 + Символы.ПС + Символы.Таб + НСтр("ru='Элемент удален.';uk='Елемент вилучений.'", КодЯзыкаПечать));
					
					ОтборПриемник.Удалить(ОтборПриемник.Индекс(ЭлементПриемника));
					ОтборИсточник.Удалить(ОбратныйИндекс);
					
				КонецПопытки;
				
			Иначе
				
				ОбщегоНазначения.СообщитьОбОшибке(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Элемент отбора <%1> не входит в число допустимых."
"	Элемент удален.';uk='Елемент відбору <%1> не входить до числа припустимих."
"	Елемент вилучено.'", КодЯзыкаПечать), Элемент));
				ОтборИсточник.Удалить(ОбратныйИндекс);
				
			КонецЕсли;
			
		КонецЕсли;
	
	КонецЦикла;

КонецПроцедуры 

Функция СформироватьНадписьОтбора()
	
	ТекстОтбора = "";
	Разделитель = "";
	
	Для каждого ЭлементОтбора Из ПостроительЗапроса.Отбор Цикл
	
		Если ЭлементОтбора.Использование Тогда
			
			ТекстОтбора = ТекстОтбора + Разделитель + ЭлементОтбора;
			Разделитель = "; "
			
		КонецЕсли;
	
	КонецЦикла;
	
	Если НЕ ЗначениеЗаполнено(ТекстОтбора) Тогда
		
		ТекстОтбора = НСтр("ru='Отбор не установлен';uk='Відбір не встановлений'", КодЯзыкаПечать);
		
	Иначе
		
		ТекстОтбора = НСтр("ru='Отбор: ';uk='Відбір: '", КодЯзыкаПечать) + ТекстОтбора;
		
	КонецЕсли;
	
	Возврат ТекстОтбора;

КонецФункции // СформироватьЗаголовокФормы()

Процедура СформироватьОтчет(ДокументРезультат, ТолькоЗаголовок = Ложь) Экспорт

	// Перегрузка значений из реквизита формы "Отбор"
	// в отбор построителя запроса
	СкопироватьОтбор(Отбор, ПостроительЗапроса.Отбор, Истина);
	
	ДокументРезультат.Очистить();
	
	Макет     = ПолучитьМакет("Макет");
	// 37490 <<
	Макет.КодЯзыкаМакета = КодЯзыкаПечать;
	// 37490 >>
	НаДату    = ?(НЕ ЗначениеЗаполнено(ДатаСведений), РабочаяДата, ДатаСведений);
	НаДату    = КонецДня(НаДату);
	
	ОбластьМакета = Макет.ПолучитьОбласть("Заголовок");
	ОбластьМакета.Параметры.ТекстОтбора  = СформироватьНадписьОтбора();
	ОбластьМакета.Параметры.ДатаСведений = НаДату;
	
	ДокументРезультат.Вывести(ОбластьМакета);
	ВысотаЗаголовка = ДокументРезультат.ВысотаТаблицы;
	
	Если ТолькоЗаголовок Тогда
		
		Возврат
		
	КонецЕсли;
	
	ПостроительЗапроса.Параметры.Вставить("ДатаСведений", НаДату + 1);
	
	ПостроительЗапроса.Выполнить();
	
	Если ПостроительЗапроса.Результат.Пустой() Тогда
		
		ОбластьНетДанных = Макет.ПолучитьОбласть("НетДанных");
		ДокументРезультат.Вывести(ОбластьНетДанных);
		Возврат;
		                                                                              
	КонецЕсли;
	
	Выборка           = ПостроительЗапроса.Результат.Выбрать();
	Разделитель        = Макет.ПолучитьОбласть("Разделитель");
	ВывестиРазделитель = Ложь;
	ДокументРезультат.НачатьАвтогруппировкуСтрок();
	
	Пока Выборка.Следующий() Цикл
		
		Если ВывестиРазделитель Тогда
			
			ДокументРезультат.Вывести(Разделитель, 1);
			
		КонецЕсли;
		
		ОбластьМакета = Макет.ПолучитьОбласть("Наименование");
		ОбластьМакета.Параметры.Заполнить(Выборка);
		ДокументРезультат.Вывести(ОбластьМакета, 1);
		
		ОбластьМакета = Макет.ПолучитьОбласть("ПостоянныеСведения");
		ОбластьМакета.Параметры.Заполнить(Выборка);
		ДокументРезультат.Вывести(ОбластьМакета, 2);
		
        // Управленческий учет
		ОбластьМакета = Макет.ПолучитьОбласть("ШапкаУпр");
		ОбластьМакета.Параметры.Заполнить(Выборка);
		ДокументРезультат.Вывести(ОбластьМакета, 1);
			
		ОбластьМакета = Макет.ПолучитьОбласть("УпрУчет");
		ОбластьМакета.Параметры.Заполнить(Выборка);
			
		ДокументРезультат.Вывести(ОбластьМакета, 2);
		
		// Регламентированный учет
		Если Выборка.Организация <> Null Тогда
			
			//ОбластьМакета = Макет.ПолучитьОбласть("ШапкаОсновныеСведения");
			//ОбластьМакета.Параметры.Заполнить(Выборка);
			//ДокументРезультат.Вывести(ОбластьМакета, 1);
			//
			//ОбластьМакета = Макет.ПолучитьОбласть("ОбщиеСведения");
			//ОбластьМакета.Параметры.Заполнить(Выборка);
			//
			//Если ЗначениеЗаполнено(Выборка.ОрганизацияНаименованиеПолное) Тогда
			//	
			//	ОбластьМакета.Параметры.ОрганизацияПредставление = Выборка.ОрганизацияНаименованиеПолное;
			//	
			//КонецЕсли;
			//
			//ДокументРезультат.Вывести(ОбластьМакета, 2);
			
			ОбластьМакета = Макет.ПолучитьОбласть("ШапкаБух");
			ОбластьМакета.Параметры.Заполнить(Выборка);
			ДокументРезультат.Вывести(ОбластьМакета, 1);
			
			ОбластьМакета = Макет.ПолучитьОбласть("БухУчет");
			ОбластьМакета.Параметры.Заполнить(Выборка);
			
			Если ЗначениеЗаполнено(Выборка.ОрганизацияНаименованиеПолное) Тогда
				
				ОбластьМакета.Параметры.ОрганизацияПредставление = Выборка.ОрганизацияНаименованиеПолное;
				
			КонецЕсли;
			
			ДокументРезультат.Вывести(ОбластьМакета, 2);
			
			ОбластьМакета = Макет.ПолучитьОбласть("ШапкаНал");
			ОбластьМакета.Параметры.Заполнить(Выборка);
			ДокументРезультат.Вывести(ОбластьМакета, 1);
			
			ОбластьМакета = Макет.ПолучитьОбласть("НалУчет");
			ОбластьМакета.Параметры.Заполнить(Выборка);
			ДокументРезультат.Вывести(ОбластьМакета, 2);
			
		КонецЕсли;
		
		ВывестиРазделитель = Истина;
	
	КонецЦикла;
	
	ДокументРезультат.ЗакончитьАвтогруппировкуСтрок();
	ДокументРезультат.ТолькоПросмотр                = Истина;
	ДокументРезультат.ВерхнийКолонтитул.Выводить    = Истина;
	ДокументРезультат.ВерхнийКолонтитул.ТекстСправа = НСтр("ru='Дата сведений: ';uk='Дата відомостей: '", КодЯзыкаПечать) + НаДату;
	ДокументРезультат.НижнийКолонтитул.Выводить     = Истина;
	ДокументРезультат.ОбластьПечати = ДокументРезультат.Область(1, 2, ДокументРезультат.ВысотаТаблицы,
	                                                                  ДокументРезультат.ШиринаТаблицы);
	ДокументРезультат.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_СведенияОбОС";
	
КонецПроцедуры // СформироватьОтчет()
                                                                                                    
