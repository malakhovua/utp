	|			ПО ПервоначальныеСведенияОСУУ.ОсновноеСредство = ВыработкаОСУУ.ОсновноеСредство
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СпособыОтраженияРасходовПоАмортизацииОС.СрезПоследних(&ДатаСведений, {ОсновноеСредство.* КАК ОсновноеСредство}) КАК СпособыОтраженияРасходовПоАмортизацииУУ
	|			ПО ПервоначальныеСведенияОСУУ.ОсновноеСредство = СпособыОтраженияРасходовПоАмортизацииУУ.ОсновноеСредство
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.СтоимостьОС.Остатки(&ДатаСведений, {ОсновноеСредство.* КАК ОсновноеСредство}) КАК СтоимостьОСУУ
	|			ПО ПервоначальныеСведенияОСУУ.ОсновноеСредство = СтоимостьОСУУ.ОсновноеСредство
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияОС КАК ВводВЭксплуатациюУУ
	|			ПО ПервоначальныеСведенияОСУУ.ОсновноеСредство = ВводВЭксплуатациюУУ.ОсновноеСредство
	|				И (ВводВЭксплуатациюУУ.Состояние = &СостояниеВвода)
	|				И (ВводВЭксплуатациюУУ.ДатаСостояния <= &ДатаСведений)
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НачислениеАмортизацииОС.СрезПоследних(&ДатаСведений, {ОсновноеСредство.* КАК ОсновноеСредство}) КАК НачислениеАмортизацииОСУУ
	|			ПО ПервоначальныеСведенияОСУУ.ОсновноеСредство = НачислениеАмортизацииОСУУ.ОсновноеСредство
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПараметрыАмортизацииОС.СрезПоследних(&ДатаСведений, {ОсновноеСредство.* КАК ОсновноеСредство}) КАК ПараметрыАмортизацииОСУУ
	|			ПО ПервоначальныеСведенияОСУУ.ОсновноеСредство = ПараметрыАмортизацииОСУУ.ОсновноеСредство
	|		ПО ОсновныеСредства.Ссылка = ПервоначальныеСведенияОСУУ.ОсновноеСредство
	|ГДЕ
	|	(НЕ ОсновныеСредства.ЭтоГруппа)
	|{ГДЕ
	|	ОсновныеСредства.Ссылка.* КАК ОсновноеСредство,
	|	ПервоначальныеСведенияОСБУ.Организация.* КАК Организация,
	|	МестонахождениеОС.МОЛ.* КАК МОЛ,
	|	МестонахождениеОС.Местонахождение.* КАК ПодразделениеОрганизации,
	|	ПервоначальныеСведенияОСБУ.ИнвентарныйНомер КАК ИнвентарныйНомер,
	|	ПервоначальныеСведенияОСБУ.СпособНачисленияАмортизации КАК СпособНачисленияАмортизации,
	|	СпособыОтраженияРасходовПоАмортизацииБУ.СпособыОтраженияРасходовПоАмортизации КАК СпособОтраженияРасходовПоАмортизацииБУ,
	|	ПервоначальныеСведенияОСБУ.ПараметрВыработки.* КАК ПараметрВыработки,
	|	ГрафикиАмортизацииОС.ГрафикАмортизации.* КАК ГрафикАмортизации,
	|	НачислениеАмортизацииОСБУ.НачислятьАмортизацию КАК НачислятьАмортизациюБУ,
	|	ПараметрыАмортизацииОСБУ.СрокПолезногоИспользования КАК СрокПолезногоИспользования,
	|	НалоговыеНазначенияОС.НалоговоеНазначение КАК НалоговоеНазначение,
	|	МестонахождениеОСУУ.МОЛ.* КАК МОЛУУ,
	|	МестонахождениеОСУУ.Местонахождение.* КАК Подразделение,
	|	СпособыОтраженияРасходовПоАмортизацииУУ.СпособыОтраженияРасходовПоАмортизации КАК СпособыОтраженияРасходовПоАмортизацииУУ,
	|	ГрафикиАмортизацииОСУУ.ГрафикАмортизации.* КАК ГрафикАмортизацииУУ,
	|	ПервоначальныеСведенияОСУУ.ПараметрВыработки.*,
	|	ПараметрыАмортизацииОСУУ.СрокПолезногоИспользования КАК СрокПолезногоИспользованияУУ,
	|	ПервоначальныеСведенияОСУУ.СпособНачисленияАмортизации КАК СпособНачисленияАмортизацииУУ,
	|	НачислениеАмортизацииОСУУ.НачислятьАмортизацию КАК НачислятьАмортизациюУУ}
	|
	|УПОРЯДОЧИТЬ ПО
	|	Наименование";
	
	Параметры = ПостроительЗапроса.Параметры;
	
	
	Параметры.Вставить("СубконтоОС"                , ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ОсновныеСредства);
	Параметры.Вставить("СостояниеВвода"            , Перечисления.СостоянияОС.ВведеноВЭксплуатацию);
	Параметры.Вставить("СостояниеВыбытия"          , Перечисления.СостоянияОС.СнятоСУчета);

	ДоступныеПоля = ПостроительЗапроса.ДоступныеПоля;
	
	// Заполнение пользовательских представлений для доступных полей
	СтруктураПредставлениеПолей = Новый Структура;
	
	СтруктураПредставлениеПолей.Вставить("Организация"							 	, НСтр("ru='Организация';uk='Організація'", КодЯзыкаПечать));
	СтруктураПредставлениеПолей.Вставить("Подразделение"						 	, НСтр("ru='Подразделение';uk='Підрозділ'", КодЯзыкаПечать));
	СтруктураПредставлениеПолей.Вставить("МОЛ"							 		 	, НСтр("ru='МОЛ';uk='МВО'", КодЯзыкаПечать));
	
	СтруктураПредставлениеПолей.Вставить("ОсновноеСредство"                      	, НСтр("ru='Основное средство';uk='Основний засіб'", КодЯзыкаПечать));
	СтруктураПредставлениеПолей.Вставить("ИнвентарныйНомер"                      	, НСтр("ru='Инвентарный номер';uk='Інвентарний номер'", КодЯзыкаПечать));
	СтруктураПредставлениеПолей.Вставить("СпособНачисленияАмортизации"           	, НСтр("ru='Способ начисления амортизации';uk='Спосіб нарахування амортизації'", КодЯзыкаПечать));
	СтруктураПредставлениеПолей.Вставить("ПараметрВыработки"                     	, НСтр("ru='Параметр выработки';uk='Параметр виробітку'", КодЯзыкаПечать));
	СтруктураПредставлениеПолей.Вставить("ГрафикАмортизации"                     	, НСтр("ru='График амортизации';uk='Графік амортизації'", КодЯзыкаПечать));
	СтруктураПредставлениеПолей.Вставить("НачислятьАмортизациюБУ"                	, НСтр("ru='Начислять амортизацию (БУ)';uk='Нараховувати амортизацію (БО)'", КодЯзыкаПечать));
	СтруктураПредставлениеПолей.Вставить("СрокПолезногоИспользования"            	, НСтр("ru='Срок полезного использования';uk='Строк корисного використання'", КодЯзыкаПечать));
	СтруктураПредставлениеПолей.Вставить("СрокИспользованияДляВычисленияАмортизации", НСтр("ru='Срок использования для вычисления амортизации, мес.';uk='Строк використання для обчислення амортизації, міс.'", КодЯзыкаПечать));
	СтруктураПредставлениеПолей.Вставить("НалоговоеНазначение"                   	, НСтр("ru='Налоговое назначение';uk='Податкове призначення'", КодЯзыкаПечать));
	СтруктураПредставлениеПолей.Вставить("СпособОтраженияРасходовПоАмортизацииБУ"	, НСтр("ru='Способ отражения расходов по амортизации';uk='Спосіб відображення витрат по амортизації'", КодЯзыкаПечать));
	
	Для каждого КлючЗначение Из СтруктураПредставлениеПолей Цикл
		
		Поле = ДоступныеПоля.Найти(КлючЗначение.Ключ);
		
		Если Поле <> Неопределено  Тогда
			
			Поле.Представление = КлючЗначение.Значение;			
			
		КонецЕсли;		
	
	КонецЦикла;
	
	// заполнение доступных полей для реквизита обработки
	Отбор.УстановитьДоступныеПоля(ДоступныеПоля);
	
	// поля по умолчанию                                                                
	Отбор.Добавить("ОсновноеСредство");
	Отбор.Добавить("Организация");
	
КонецПроцедуры // ЗаполнитьНачальныеНастройки()

КодЯзыкаПечать = ЛокализацияПовтИсп.ПолучитьЯзыкФормированияПечатныхФормОтчетов();

#КонецЕсли
