Процедура СформироватьОтчет(ДокументРезультат, ПоказыватьЗаголовок = Ложь, ВысотаЗаголовка = 0, ТолькоЗаголовок = Ложь) Экспорт

	ОбщийОтчет.СформироватьОтчет(ДокументРезультат, ПоказыватьЗаголовок, ВысотаЗаголовка, ТолькоЗаголовок);

КонецПроцедуры

Процедура ЗаполнитьНачальныеНастройки() Экспорт
	
	МассивОтбора = Новый Массив;
	ОбщийОтчет.ИмяРегистра = "";
	ОбщийОтчет.мНазваниеОтчета = НСтр("ru='Отражение зарплаты в управленческом учете';uk='Відображення зарплати в управлінському обліку'");
	ОбщийОтчет.мВыбиратьИспользованиеСвойств = Ложь;
	ПостроительОтчета = ОбщийОтчет.ПостроительОтчета;

	ТекстЗапроса =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОтражениеЗарплатыВУпрУчетеОтражениеВУчете.Ссылка.Ответственный КАК Ответственный,
	|	ОтражениеЗарплатыВУпрУчетеОтражениеВУчете.Ссылка,
	|	ОтражениеЗарплатыВУпрУчетеОтражениеВУчете.Подразделение,
	|	ОтражениеЗарплатыВУпрУчетеОтражениеВУчете.СтатьяЗатрат,
	|	ОтражениеЗарплатыВУпрУчетеОтражениеВУчете.НоменклатурнаяГруппа,
	|	ОтражениеЗарплатыВУпрУчетеОтражениеВУчете.ОбъектСтроительства,
	|	СУММА(ОтражениеЗарплатыВУпрУчетеОтражениеВУчете.Сумма) КАК Сумма
	|ИЗ
	|	Документ.НачислениеЗарплатыРаботникамОрганизаций.ОтражениеВУпрУчете КАК ОтражениеЗарплатыВУпрУчетеОтражениеВУчете
	|
	|ГДЕ
	|	(ОтражениеЗарплатыВУпрУчетеОтражениеВУчете.Ссылка.ПериодРегистрации МЕЖДУ НАЧАЛОПЕРИОДА(&ДатаНач, МЕСЯЦ) И КОНЕЦПЕРИОДА(&ДатаНач, МЕСЯЦ)) И
	|	(ОтражениеЗарплатыВУпрУчетеОтражениеВУчете.Ссылка.ПометкаУдаления = ЛОЖЬ)
	|
	|СГРУППИРОВАТЬ ПО
	|	Ссылка,
	|	Подразделение,
	|	ОтражениеЗарплатыВУпрУчетеОтражениеВУчете.СтатьяЗатрат,
	|	ОтражениеЗарплатыВУпрУчетеОтражениеВУчете.НоменклатурнаяГруппа,
	|	ОтражениеЗарплатыВУпрУчетеОтражениеВУчете.ОбъектСтроительства	
	|
	|ИТОГИ СУММА(Сумма) ПО
	|	ОБЩИЕ	
	|	
	|{ВЫБРАТЬ
	|	Ссылка,
	|	Подразделение,
	|	СтатьяЗатрат,
	|	НоменклатурнаяГруппа,
	|	Ссылка.Ответственный,
	|	ОбъектСтроительства
	|}
	|{ИТОГИ ПО
	|	Подразделение,
	|	Ссылка,
	|	СтатьяЗатрат,
	|	НоменклатурнаяГруппа,
	|	Ссылка.Ответственный,
	|	ОбъектСтроительства	
	|}
	|{УПОРЯДОЧИТЬ ПО
	|	Подразделение,
	|	Ссылка,
	|	СтатьяЗатрат,
	|	НоменклатурнаяГруппа,
	|	Ссылка.Ответственный,
	|	ОбъектСтроительства	
	|}
	|{ГДЕ
	|	Подразделение,
	|	Ссылка,
	|	СтатьяЗатрат,
	|   НоменклатурнаяГруппа,
	|	Ссылка.Ответственный,
	|   ОбъектСтроительства
	|}
	|";

	
	ПостроительОтчета.Текст = ТекстЗапроса;
	
	МассивОтбора.Добавить("Подразделение");
	МассивОтбора.Добавить("СтатьяЗатрат");
	МассивОтбора.Добавить("НоменклатурнаяГруппа");
	МассивОтбора.Добавить("ОбъектСтроительства");
	МассивОтбора.Добавить("Ответственный");
	
	ОбщийОтчет.ЗаполнитьПоказатели("Сумма", "Сумма", Истина, "ЧЦ=15; ЧДЦ=2");
	
	СтруктураПредставлениеПолей = Новый Структура("Подразделение,Докумдент,СтатьяЗатрат,НоменклатурнаяГруппа,ОбъектСтроительства",
	"Подразделение",
	"Докумдент",
	"Статья затрат",
	"Номенклатурная группа",
	"Объект строительства");
	
	УправлениеОтчетами.ЗаполнитьПредставленияПолей(СтруктураПредставлениеПолей, ПостроительОтчета);
	
	ОбщийОтчет.ВыводитьИтогиПоВсемУровням = Истина;

	УправлениеОтчетами.ОчиститьДополнительныеПоляПостроителя(ПостроительОтчета);
	УправлениеОтчетами.ЗаполнитьОтбор(МассивОтбора, ПостроительОтчета);
	
	ПустаяСтруктура = Новый Структура;
	
	ОбщийОтчет.мСтруктураСвязиПоказателейИИзмерений.Вставить("Сумма", ПустаяСтруктура);
	
	ОбщийОтчет.ВыводитьПоказателиВСтроку = Истина;

	ПустаяСтруктура = Новый Структура;
	
	ОбщийОтчет.мСтруктураСвязиПоказателейИИзмерений.Вставить("Сумма", ПустаяСтруктура);	

	ОбщийОтчет.РаскрашиватьИзмерения = Истина;
	ОбщийОтчет.ВыводитьПоказателиВСтроку = Истина;

	
КонецПроцедуры

