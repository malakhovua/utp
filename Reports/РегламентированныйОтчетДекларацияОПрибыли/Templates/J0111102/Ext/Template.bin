<?xml version="1.0" encoding="windows-1251"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
	<xs:annotation>
		<xs:documentation>Додаток ІВ
до рядка 06.4 Податкової декларації з податку на прибуток підприємства
(ЗАТВЕРДЖЕНО Наказ Міністерства фінансів України  28.09.11 №1213) </xs:documentation>
	</xs:annotation>
	<xs:include schemaLocation="common_types.xsd"/>
	<xs:element name="DECLAR" type="DeclarContent"/>
	<xs:complexType name="DeclarContent">
		<xs:sequence>
			<xs:element name="DECLARHEAD" type="DHead"/>
			<xs:element name="DECLARBODY" type="DBody"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="DHead">
		<xs:sequence>
			<xs:element name="TIN" type="DGLong"/>
			<xs:element name="C_DOC" type="xs:string" fixed="J01"/>
			<xs:element name="C_DOC_SUB" type="xs:string" fixed="111"/>
			<xs:element name="C_DOC_VER" type="xs:string" fixed="2"/>
			<xs:element name="C_DOC_TYPE" type="xs:nonNegativeInteger"/>
			<xs:element name="C_DOC_CNT" type="xs:nonNegativeInteger"/>
			<xs:element name="C_REG" type="DGsti"/>
			<xs:element name="C_RAJ" type="DGsti"/>
			<xs:element name="PERIOD_MONTH" type="DGMonth"/>
			<xs:element name="PERIOD_TYPE" type="DGPType"/>
			<xs:element name="PERIOD_YEAR" type="DGYear"/>
			<xs:element name="C_STI_ORIG" type="DGc_dpi"/>
			<xs:element name="C_DOC_STAN" type="DGSTAN"/>
			<xs:element name="LINKED_DOCS" nillable="true" minOccurs="0">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="DOC" maxOccurs="unbounded">
							<xs:complexType>
								<xs:sequence>
									<xs:element name="C_DOC" type="DGC_DOC"/>
									<xs:element name="C_DOC_SUB" type="DGC_DOC_SUB"/>
									<xs:element name="C_DOC_VER" type="DGC_DOC_VER"/>
									<xs:element name="C_DOC_TYPE" type="xs:nonNegativeInteger"/>
									<xs:element name="C_DOC_CNT" type="xs:nonNegativeInteger"/>
									<xs:element name="C_DOC_STAN" type="DGSTAN"/>
									<xs:element name="FILENAME" type="DGFilename"/>
								</xs:sequence>
								<xs:attribute name="NUM" type="xs:nonNegativeInteger"/>
								<xs:attribute name="TYPE" type="DGTypeLinkDoc"/>
							</xs:complexType>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
				<xs:unique name="UH_DOC_NUM">
					<xs:selector xpath="DOC"/>
					<xs:field xpath="@NUM"/>
				</xs:unique>
			</xs:element>
			<xs:element name="D_FILL" type="DGDate"/>
			<xs:element name="SOFTWARE" type="xs:string" nillable="true" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="DBody">
		<xs:sequence>
			<!--HEAD-->
			<xs:choice>
				<xs:element name="HZ" type="DGchk"/>
				<xs:element name="HZN" type="DGchk"/>
				<xs:element name="HZU" type="DGchk"/>
			</xs:choice>

			<xs:element name="HZK" type="DGchk" nillable="true" minOccurs="0"/>

			<xs:element name="HTIN" type="DGHTINJ"/>

			<xs:element name="HZY" type="DGYear"/>
			<xs:choice>
				<xs:element name="H1KV" type="DGchk"/>
				<xs:element name="HHY" type="DGchk"/>
				<xs:element name="H3KV" type="DGchk"/>
				<xs:element name="HY" type="DGchk"/>
				<xs:element name="H2KV" type="DGchk"/>
				<xs:element name="H23KV" type="DGchk"/>
				<xs:element name="H24KV" type="DGchk"/>
			</xs:choice>

			<!--BODY-->
			<xs:element name="R064G3" type="DGdecimal0" nillable="true" minOccurs="0"/>

			<xs:element name="R06401G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06402G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06403G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06404G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06405G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06406G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06407G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06408G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06409G3" type="DGdecimal0" nillable="true" minOccurs="0"/>

			<xs:element name="R06410G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06411G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06412G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06413G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06414G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06415G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06416G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06417G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06418G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06419G3" type="DGdecimal0" nillable="true" minOccurs="0"/>

			<xs:element name="R06420G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06421G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06422G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06423G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06424G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06425G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06426G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06427G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06428G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06429G3" type="DGdecimal0" nillable="true" minOccurs="0"/>

			<xs:element name="R06430G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06431G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R064311G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06432G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R064321G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06433G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R064331G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06434G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06435G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06436G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06437G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06438G3" type="DGdecimal0" nillable="true" minOccurs="0"/>
			<xs:element name="R06439G3" type="DGdecimal0" nillable="true" minOccurs="0"/>

			<!--FOOTER-->
			<xs:element name="HBOS" type="DGHBOS"/>
			<xs:element name="HBUH" type="DGHBUH" nillable="true" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
</xs:schema>
