Процедура СформироватьОтчет(ДокументРезультат, ПоказыватьЗаголовок = Ложь, ВысотаЗаголовка = 0, ТолькоЗаголовок = Ложь) Экспорт

	ВидыРасчетаПоИЛ = Новый Массив;
	ВидыРасчетаПоИЛ.Добавить(ПланыВидовРасчета.Удержания.АлиментыПроцентом);
	ВидыРасчетаПоИЛ.Добавить(ПланыВидовРасчета.Удержания.АлиментыПроцентомДоПредела);
	ВидыРасчетаПоИЛ.Добавить(ПланыВидовРасчета.Удержания.АлиментыФиксированнойСуммой);
	ВидыРасчетаПоИЛ.Добавить(ПланыВидовРасчета.Удержания.АлиментыФиксированнойСуммойДоПредела);
	ВидыРасчетаПоИЛ.Добавить(ПланыВидовРасчета.Удержания.ИЛПроцентом);
	ВидыРасчетаПоИЛ.Добавить(ПланыВидовРасчета.Удержания.ИЛПроцентомДоПредела);
	ВидыРасчетаПоИЛ.Добавить(ПланыВидовРасчета.Удержания.ИЛФиксированнойСуммой);
	ВидыРасчетаПоИЛ.Добавить(ПланыВидовРасчета.Удержания.ИЛФиксированнойСуммойДоПредела);
	ВидыРасчетаПоИЛ.Добавить(ПланыВидовРасчета.Удержания.ПочтовыйСбор);
	
	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("ВидыРасчетаПоИЛ", ВидыРасчетаПоИЛ);
	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("ПочтовыйСборПоИЛ", ПланыВидовРасчета.Удержания.ПочтовыйСбор);
	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("Адрес", Перечисления.ТипыКонтактнойИнформации.Адрес);
	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("ФактическийАдрес", Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента);

	ОбщийОтчет.СформироватьОтчет(ДокументРезультат, ПоказыватьЗаголовок, ВысотаЗаголовка, ТолькоЗаголовок);

КонецПроцедуры

Процедура ЗаполнитьНачальныеНастройки() Экспорт
	
	ОбщийОтчет.ИмяРегистра = "-";
	ОбщийОтчет.мНазваниеОтчета = Метаданные().Синоним;
	
	ПостроительОтчета = ОбщийОтчет.ПостроительОтчета;
	
	// структура представлений полей
	СтруктураПредставлениеПолей = Новый Структура();
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	Удержания.Результат КАК Результат,
	|	Удержания.ПочтовыйСбор КАК ПочтовыйСбор,
	|	Удержания.Сотрудник КАК Сотрудник,
	|	Удержания.Сотрудник.ФизЛицо КАК ФизЛицо
	|{ВЫБРАТЬ
	|	ФактическийАдрес.Представление КАК ФактическийАдрес,
	|	Удержания.Показатель1,
	|	Удержания.ДокументОснование,
	|	Удержания.ПорядокРасчета,
	|	Удержания.ДокументОснование.Получатель.* КАК Получатель,
	|	Удержания.ДокументОснование.ВидИсполнительногоДокумента КАК ВидИсполнительногоДокумента
	|	}
	|ИЗ
	|	(ВЫБРАТЬ
	|		УдержанияРаботниковОрганизаций.Сотрудник КАК Сотрудник,
	|		СУММА(ВЫБОР
	|				КОГДА УдержанияРаботниковОрганизаций.ВидРасчета = &ПочтовыйСборПоИЛ
	|					ТОГДА 0
	|				ИНАЧЕ УдержанияРаботниковОрганизаций.Результат
	|			КОНЕЦ) КАК Результат,
	|		СУММА(ВЫБОР
	|				КОГДА УдержанияРаботниковОрганизаций.ВидРасчета = &ПочтовыйСборПоИЛ
	|					ТОГДА УдержанияРаботниковОрганизаций.Результат
	|				ИНАЧЕ 0
	|			КОНЕЦ) КАК ПочтовыйСбор,
	|		УдержанияРаботниковОрганизаций.Показатель1 КАК Показатель1,
	|		УдержанияРаботниковОрганизаций.ДокументОснование КАК ДокументОснование,
	|		ВЫБОР
	|			КОГДА УдержанияРаботниковОрганизаций.ВидРасчета = &ПочтовыйСборПоИЛ
	|				ТОГДА ""% от удержанных сумм""
	|			КОГДА УдержанияРаботниковОрганизаций.ДокументОснование.СпособРасчетаИЛ = 1
	|				ТОГДА ""% заработка""
	|			ИНАЧЕ ""фиксированная сумма""
	|		КОНЕЦ КАК ПорядокРасчета,
	|		УдержанияРаботниковОрганизаций.Организация КАК Организация,
	|		УдержанияРаботниковОрганизаций.ПериодРегистрации КАК ПериодРегистрации
	|	ИЗ
	|		РегистрРасчета.Удержания КАК УдержанияРаботниковОрганизаций
	|	ГДЕ
	|		УдержанияРаботниковОрганизаций.ВидРасчета В(&ВидыРасчетаПоИЛ)
	|		И УдержанияРаботниковОрганизаций.ПериодРегистрации МЕЖДУ &ДатаНач И &ДатаКон
	|	{ГДЕ
	|		УдержанияРаботниковОрганизаций.Организация,
	|		УдержанияРаботниковОрганизаций.Сотрудник,
	|		УдержанияРаботниковОрганизаций.ДокументОснование}
	|	
	|	СГРУППИРОВАТЬ ПО
	|		УдержанияРаботниковОрганизаций.Сотрудник,
	|		УдержанияРаботниковОрганизаций.Сотрудник.ФизЛицо,
	|		УдержанияРаботниковОрганизаций.Показатель1,
	|		УдержанияРаботниковОрганизаций.ДокументОснование,
	|		УдержанияРаботниковОрганизаций.Организация,
	|		УдержанияРаботниковОрганизаций.ПериодРегистрации,
	|		ВЫБОР
	|			КОГДА УдержанияРаботниковОрганизаций.ВидРасчета = &ПочтовыйСборПоИЛ
	|				ТОГДА ""% от удержанных сумм""
	|			КОГДА УдержанияРаботниковОрганизаций.ДокументОснование.СпособРасчетаИЛ = 1
	|				ТОГДА ""% заработка""
	|			ИНАЧЕ ""фиксированная сумма""
	|		КОНЕЦ) КАК Удержания
	|		{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтактнаяИнформация КАК ФактическийАдрес
	|		ПО (ФактическийАдрес.Тип = &Адрес)
	|			И (ФактическийАдрес.Вид = &ФактическийАдрес)
	|			И Удержания.ДокументОснование.Получатель = ФактическийАдрес.Объект}
	|{УПОРЯДОЧИТЬ ПО
	|	Сотрудник,
	|	ФизЛицо,
	|	Удержания.ДокументОснование,
	|	Удержания.ДокументОснование.Получатель КАК Получатель,
	|	Удержания.Показатель1}
	|ИТОГИ
	|	СУММА(Результат),
	|	СУММА(ПочтовыйСбор)
	|ПО
	|	ОБЩИЕ
	|{ИТОГИ ПО
	|	Удержания.Организация,
	|	Удержания.ПериодРегистрации,
	|	Удержания.Сотрудник,
	|	Удержания.Сотрудник.ФизЛицо,
	|	Удержания.ДокументОснование}";	
	
	ПостроительОтчета.Текст = ТекстЗапроса;							  
							  
	//представление полей запроса
	СтруктураПредставлениеПолей.Вставить("ВидИсполнительногоДокумента",	НСтр("ru='Вид исполнительного документа';uk='Вид виконавчого документа'"));
	СтруктураПредставлениеПолей.Вставить("ДокументОснование",		НСтр("ru='Исполнительный документ';uk='Виконавчий документ'"));
	СтруктураПредставлениеПолей.Вставить("Показатель1",					НСтр("ru='Размер удержания';uk='Розмір утримання'"));
	СтруктураПредставлениеПолей.Вставить("ПорядокРасчета",			НСтр("ru='Порядок расчета удержания';uk='Порядок розрахунку утримання'"));
	СтруктураПредставлениеПолей.Вставить("Сотрудник",					"Работник");
	СтруктураПредставлениеПолей.Вставить("ФактическийАдрес",		НСтр("ru='Адрес получателя';uk='Адреса одержувача'"));
	СтруктураПредставлениеПолей.Вставить("ФизЛицоПредставление",	"Работник");
	СтруктураПредставлениеПолей.Вставить("ПериодРегистрации",		НСтр("ru='Месяц начисления';uk='Місяць нарахування'"));
	
	УправлениеОтчетами.ЗаполнитьПредставленияПолей(СтруктураПредставлениеПолей, ПостроительОтчета);
	
	ОбщийОтчет.ЗаполнитьПоказатели("Результат", НСтр("ru='Удержано по исполнительным листам';uk='Утримано за виконавчими листами'"), Истина, "ЧЦ=15; ЧДЦ=2");
	ОбщийОтчет.ЗаполнитьПоказатели("ПочтовыйСбор", НСтр("ru='Почтовый сбор';uk='Поштовий збір'"), Истина, "ЧЦ=15; ЧДЦ=2");
	
	// формат полей
	ОбщийОтчет.СтруктураФорматаПолей.Вставить("ПериодРегистрации", "ДФ='ММММ гггг ""г.""'");
	
	// группировки по умолчанию
	ПостроительОтчета.ИзмеренияСтроки.Добавить("Организация");
	ПостроительОтчета.ИзмеренияСтроки.Добавить("ПериодРегистрации");
	
	// Упорядочение
	ПостроительОтчета.Порядок.Добавить("Сотрудник");
	
	// отборы по умолчанию
	МассивОтбора = Новый Массив;
	МассивОтбора.Добавить("Организация");
	МассивОтбора.Добавить("Сотрудник");
	УправлениеОтчетами.ЗаполнитьОтбор(МассивОтбора, ПостроительОтчета);
	
	// поля по умолчанию
	ПостроительОтчета.ВыбранныеПоля.Очистить();
	
	// настройки отчета
	ОбщийОтчет.РаскрашиватьИзмерения = Истина;
	ОбщийОтчет.ВыводитьИтогиПоВсемУровням = Ложь;
	ОбщийОтчет.ВыводитьПоказателиВСтроку = Истина;
	ОбщийОтчет.мРежимВводаПериода = 0; // произвольный период
	ОбщийОтчет.мВыбиратьИспользованиеСвойств = Ложь;
	ОбщийОтчет.мВыбиратьИмяРегистра = Ложь;
	
КонецПроцедуры

