	СтруктураПредставлениеПолей.Вставить( "ОрганизацияЮрФизЛицо",           НСтр("ru='Юр. / физ. лицо';uk='Юр. / фіз. особа'"));
	СтруктураПредставлениеПолей.Вставить( "ОсновноеСредство",               НСтр("ru='Основное средство';uk='Основний засіб'"));
	СтруктураПредставлениеПолей.Вставить( "Изготовитель",                   НСтр("ru='Изготовитель';uk='Виробник'"));
	СтруктураПредставлениеПолей.Вставить( "НомерПаспорта",                  НСтр("ru='Номер паспорта ОС';uk='Номер паспорта ОЗ'"));
	СтруктураПредставлениеПолей.Вставить( "ЗаводскойНомер",                 НСтр("ru='Заводской номер ОС';uk='Заводський номер ОЗ'"));
	СтруктураПредставлениеПолей.Вставить( "ДатаВыпуска",                    НСтр("ru='Дата выпуска (постройки)';uk='Дата випуску (побудови)'"));
	СтруктураПредставлениеПолей.Вставить( "Модель",                         НСтр("ru='Модель, тип, марка';uk='Модель, тип, марка'"));
	СтруктураПредставлениеПолей.Вставить( "ДатаВводаВЭксплуатацию",         НСтр("ru='Дата ввода в эксплуатацию';uk='Дата введення в експлуатацію'"));
	СтруктураПредставлениеПолей.Вставить( "ДатаСнятияСУчета",         		НСтр("ru='Дата снятия с учета';uk='Дата зняття з обліку'"));
	СтруктураПредставлениеПолей.Вставить( "СчетУчета",         				НСтр("ru='Счет учета';uk='Рахунок'"));
	СтруктураПредставлениеПолей.Вставить( "ВидНалоговойДеятельности",       НСтр("ru='Вид налоговой деятельности';uk='Вид податкової діяльності'"));
	СтруктураПредставлениеПолей.Вставить( "НалоговаяГруппаОС",              НСтр("ru='Налоговая группа';uk='Податкова група'"));
	СтруктураПредставлениеПолей.Вставить( "КодОС",                          НСтр("ru='Код ОС';uk='Код ОЗ'"));
	
	СтруктураПредставлениеПолей.Вставить( "ИнвентарныйНомер", 				НСтр("ru='Инв. номер';uk='Інв. номер'"));
	
	СтруктураПредставлениеПолей.Вставить( "СтоимостьНачальныйОстаток",      НСтр("ru='Стоимость на начало периода';uk='Вартість на початок періоду'"));
	СтруктураПредставлениеПолей.Вставить( "СтоимостьОборотДт",              НСтр("ru='Стоимость (приход)';uk='Вартість (надходження)'"));
	СтруктураПредставлениеПолей.Вставить( "АмортизацияОборот",              НСтр("ru='Амортизация за период';uk='Амортизація за період'"));
	СтруктураПредставлениеПолей.Вставить( "СтоимостьОборотКт",              НСтр("ru='Стоимость (расход)';uk='Вартість (витрата)'"));
	СтруктураПредставлениеПолей.Вставить( "СтоимостьКонечныйОстаток",       НСтр("ru='Стоимость на конец периода';uk='Вартість на кінець періоду'"));

	СтруктураПредставлениеПолей.Вставить( "СтоимостьДляВычисленияАмортизации", НСтр("ru='Стоимость для амортизации';uk='Вартість для амортизації'"));
	СтруктураПредставлениеПолей.Вставить( "СрокПолезногоИспользования"               , НСтр("ru='Срок полезного использования';uk='Строк корисного використання'"));
	СтруктураПредставлениеПолей.Вставить( "СрокИспользованияДляВычисленияАмортизации", НСтр("ru='Срок исп. для амортизации';uk='Строк викор. для амортизації'"));
	СтруктураПредставлениеПолей.Вставить( "НалоговоеНазначение",            НСтр("ru='Налоговое назначение';uk='Податкове призначення'"));
	
	
	
	ПостроительОтчета.Текст     = Текст;
	
	УправлениеОтчетами.ЗаполнитьПредставленияПолей(СтруктураПредставлениеПолей, ПостроительОтчета);
	УправлениеОтчетами.ОчиститьДополнительныеПоляПостроителя(ПостроительОтчета);
	
	ОбщийОтчет.ЗаполнитьПоказатели( "СтоимостьНачальныйОстаток",      НСтр("ru='Стоимость на начало периода';uk='Вартість на початок періоду'"),       Истина, 	"ЧЦ=15; ЧДЦ=2");
	ОбщийОтчет.ЗаполнитьПоказатели( "СтоимостьОборотДт",              НСтр("ru='Стоимость (приход)';uk='Вартість (надходження)'"),                Истина, 	"ЧЦ=15; ЧДЦ=2");
	ОбщийОтчет.ЗаполнитьПоказатели( "АмортизацияОборот",              НСтр("ru='Амортизация за период';uk='Амортизація за період'"),             Истина, 	"ЧЦ=15; ЧДЦ=2");
	ОбщийОтчет.ЗаполнитьПоказатели( "СтоимостьОборотКт",              НСтр("ru='Стоимость (расход)';uk='Вартість (витрата)'"),                Ложь, 	"ЧЦ=15; ЧДЦ=2");
	ОбщийОтчет.ЗаполнитьПоказатели( "СтоимостьКонечныйОстаток",       НСтр("ru='Стоимость на конец периода';uk='Вартість на кінець періоду'"),        Ложь, 	"ЧЦ=15; ЧДЦ=2");
	
	
	МассивОтбора = Новый Массив;
	МассивОтбора.Добавить("ОсновноеСредство");
	
	УправлениеОтчетами.ЗаполнитьОтбор(МассивОтбора, ПостроительОтчета);
	
	ПостроительОтчета.Параметры.Вставить( "СостояниеВвода"       , Перечисления.СостоянияОС.ВведеноВЭксплуатацию);
	ПостроительОтчета.Параметры.Вставить( "СостояниеСнятияСУчета", Перечисления.СостоянияОС.СнятоСУчета);
	ПостроительОтчета.Параметры.Вставить( "СубконтоОС"           , ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ОсновныеСредства);
	ПостроительОтчета.Параметры.Вставить( "НеОблНеХоз"           , Справочники.НалоговыеНазначенияАктивовИЗатрат.НДС_НеоблагаемаяНеХозДеятельность);
	
	ОбщийОтчет.ВыводитьПоказателиВСтроку = Истина;
	ОбщийОтчет.РаскрашиватьИзмерения     = Истина;
	
КонецПроцедуры // ЗаполнитьНачальныеНастройки()

