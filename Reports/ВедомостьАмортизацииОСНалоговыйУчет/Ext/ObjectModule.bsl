#Если Клиент Тогда
	
// Настройка периода
Перем НП Экспорт;

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ 
// 

Процедура СформироватьОтчет(ДокументРезультат, ПоказыватьЗаголовок = Ложь, ВысотаЗаголовка = 0, ТолькоЗаголовок = Ложь) Экспорт

	// не выводим общие
	ОбщийОтчет.мСтруктураНевыводимыхГруппировок.Вставить("Общие", 1);
	
	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить( "Организация", Организация);
	
	Если НЕ ЗначениеЗаполнено(Документ) Тогда
		
		ОтчетПоДокументу = Ложь;
		
	КонецЕсли;
	
	Если ОтчетПоДокументу Тогда
		
		МоментДокумента = Документ.МоментВремени();
		ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("НачДата"   , МоментДокумента.Дата);
		ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("КонДата"   , МоментДокумента.Дата);
		ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("НачГраница", МоментДокумента);
		ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("КонГраница", МоментДокумента);
		
		Запрос       = Новый Запрос;
		Запрос.УстановитьПараметр("СубконтоОС" , ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ОсновныеСредства);
		Запрос.УстановитьПараметр("Регистратор", Документ);
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ХозрасчетныйСубконто.Значение КАК ОС
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.Субконто КАК ХозрасчетныйСубконто
		|ГДЕ
		|	ХозрасчетныйСубконто.Вид = &СубконтоОС
		|	И ХозрасчетныйСубконто.Регистратор = &Регистратор";
		СписокОС = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ОС");
		
		ОтборПоОС = ОбщийОтчет.ПостроительОтчета.Отбор.Найти("ОсновноеСредство");
		
		Если ОтборПоОС = Неопределено Тогда
			
			ОтборПоОС = ОбщийОтчет.ПостроительОтчета.Отбор.Добавить("ОсновноеСредство");	
			
		КонецЕсли;
		
		Если ОтборПоОС <> Неопределено Тогда
			
			ОтборПоОС.Использование = Истина;
			ОтборПоОС.ВидСравнения  = ВидСравнения.ВСписке;         
			ОтборПоОС.Значение.ЗагрузитьЗначения(СписокОС);
			
		КонецЕсли;
		
	Иначе
		
		ОбщийОтчет.ПостроительОтчета.Параметры.Вставить( "НачДата"   , ОбщийОтчет.ДатаНач);
		ОбщийОтчет.ПостроительОтчета.Параметры.Вставить( "КонДата"   , КонецДня(ОбщийОтчет.ДатаКон));
		ОбщийОтчет.ПостроительОтчета.Параметры.Вставить( "НачГраница", ОбщийОтчет.ДатаНач);
		
		Если НЕ ЗначениеЗаполнено(ОбщийОтчет.ДатаКон) Тогда
			
			ОбщийОтчет.ПостроительОтчета.Параметры.Вставить( "КонГраница", Неопределено);
			
		Иначе
			
			ОбщийОтчет.ПостроительОтчета.Параметры.Вставить( "КонГраница", КонецДня(ОбщийОтчет.ДатаКон));
			
		КонецЕсли;
	
	КонецЕсли; 
	
	ОбщийОтчет.СформироватьОтчет(ДокументРезультат, ПоказыватьЗаголовок, ВысотаЗаголовка, ТолькоЗаголовок);
	
	Если ОтчетПоДокументу Тогда
		// Очищается отбор	
		
		ОтборПоОС = ОбщийОтчет.ПостроительОтчета.Отбор.Найти("ОсновноеСредство");
		
		Если ОтборПоОС <> Неопределено Тогда
			
			ОтборПоОС.Использование = Ложь;
			ОтборПоОС.ВидСравнения  = ВидСравнения.Равно;         
			ОтборПоОС.Значение      = Справочники.ОсновныеСредства.ПустаяСсылка();
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры // СформироватьОтчет()

// Процедура - заполняет начальные настройки отчета
//
Процедура ЗаполнитьНачальныеНастройки() Экспорт
	
	ПостроительОтчета = ОбщийОтчет.ПостроительОтчета;
	ОбщийОтчет.ВыводитьДополнительныеПоляВОтдельнойКолонке = Истина;
	
	Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Стоимость.Организация                                   КАК Организация,
	|	ПРЕДСТАВЛЕНИЕ(Стоимость.Организация)                    КАК ОрганизацияПредставление,
	|	Стоимость.Счет                                          КАК СчетУчета,
	|	ПРЕДСТАВЛЕНИЕ(Стоимость.Счет)                           КАК СчетУчетаПредставление,
	|	Стоимость.НалоговоеНазначение                           КАК НалоговоеНазначение,
	|	ПРЕДСТАВЛЕНИЕ(Стоимость.НалоговоеНазначение)            КАК НалоговоеНазначениеПредставление,
	|	Стоимость.Субконто1                                     КАК ОсновноеСредство,
	|	ПРЕДСТАВЛЕНИЕ(Стоимость.Субконто1)                      КАК ОсновноеСредствоПредставление,
	|	РегСостоянияОС.ДатаВводаВЭксплуатацию                   КАК ДатаВводаВЭксплуатацию,
	|	РегСостоянияОС.ДатаСнятияСУчета                         КАК ДатаСнятияСУчета,
	|	СУММА(Стоимость.СуммаНУНачальныйОстаток)                КАК СтоимостьНачальныйОстаток,
	|	СУММА(Стоимость.СуммаНУОборотДт)                        КАК СтоимостьОборотДт,
	|	СУММА(Амортизация.СуммаНУОборотКт)                      КАК АмортизацияОборот,
	|	СУММА(Стоимость.СуммаНУОборотКт)                        КАК СтоимостьОборотКт,
	|	СУММА(Стоимость.СуммаНУКонечныйОстаток)                 КАК СтоимостьКонечныйОстаток,
	|	ПервоначальныеСведения.НалоговаяГруппаОС                КАК НалоговаяГруппаОС,
	|	ПРЕДСТАВЛЕНИЕ(ПервоначальныеСведения.НалоговаяГруппаОС) КАК НалоговаяГруппаОСПредставление,
	|	ПервоначальныеСведенияБУ.ИнвентарныйНомер               КАК ИнвентарныйНомер,
	|	ПараметрыАмортизацииОС.СрокПолезногоИспользования 		КАК СрокПолезногоИспользования,
	|	ПараметрыАмортизацииОС.СрокИспользованияДляВычисленияАмортизации   		КАК СрокИспользованияДляВычисленияАмортизации,
	|	ПараметрыАмортизацииОС.СтоимостьДляВычисленияАмортизации   				КАК СтоимостьДляВычисленияАмортизации,
	|	Стоимость.Субконто1.Код                                 КАК КодОС
	|{ВЫБРАТЬ
	|	Стоимость.Организация.*            КАК Организация,
	|	Стоимость.НалоговоеНазначение      КАК НалоговоеНазначение,
	|	Стоимость.Субконто1                КАК ОсновноеСредство,
	|	ВЫРАЗИТЬ(Стоимость.Субконто1.Изготовитель КАК Строка(1024))   КАК Изготовитель,
	|	ВЫРАЗИТЬ(Стоимость.Субконто1.НомерПаспорта КАК Строка(1024))  КАК НомерПаспорта,
	|	ВЫРАЗИТЬ(Стоимость.Субконто1.ЗаводскойНомер КАК Строка(1024)) КАК ЗаводскойНомер,
	|	Стоимость.Субконто1.ДатаВыпуска    КАК ДатаВыпуска,
	|	ВЫРАЗИТЬ(Стоимость.Субконто1.Модель КАК Строка(1024))         КАК Модель,
	|	ДатаВводаВЭксплуатацию             КАК ДатаВводаВЭксплуатацию,
	|	ДатаСнятияСУчета                   КАК ДатаСнятияСУчета,
	|	СчетУчета.*                        КАК СчетУчета,
	|	НалоговаяГруппаОС 				   КАК НалоговаяГруппаОС,
	|	ПервоначальныеСведенияБУ.ИнвентарныйНомер КАК ИнвентарныйНомер,
	|	Стоимость.Субконто1.Код            КАК КодОС,
	|	ПараметрыАмортизацииОС.СрокПолезногоИспользования КАК СрокПолезногоИспользования,
	|	ПараметрыАмортизацииОС.СрокИспользованияДляВычисленияАмортизации   		КАК СрокИспользованияДляВычисленияАмортизации,
	|	ПараметрыАмортизацииОС.СтоимостьДляВычисленияАмортизации   				КАК СтоимостьДляВычисленияАмортизации}
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(&ДатаНач, &ДатаКон, , ,
	|	                   Счет В
	|		                       	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		                         	СчетаУчета.СчетУчета
	|		                         ИЗ
	|		                         	РегистрСведений.СчетаБухгалтерскогоУчетаОС.СрезПоследних(
	|		                         	                &НачДата, Организация = &Организация
	|		                         	                {ОсновноеСредство.* КАК ОсновноеСредство}) КАК СчетаУчета
	|		
	|		                         ОБЪЕДИНИТЬ
	|		
	|		                         ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		                         	СчетаУчета.СчетУчета
	|		                         ИЗ
	|		                         	РегистрСведений.СчетаБухгалтерскогоУчетаОС КАК СчетаУчета
	|		                         ГДЕ
	|		                         	СчетаУчета.Период МЕЖДУ &НачДата И &КонДата
	|		                         	 И СчетаУчета.Организация = &Организация
	|		                         {ГДЕ
	|		                         	СчетаУчета.ОсновноеСредство.* КАК ОсновноеСредство}),
	|		                       &СубконтоОС,
	|		                       Организация = &Организация
	|		                       {ВЫРАЗИТЬ(Субконто1 КАК Справочник.ОсновныеСредства).* КАК ОсновноеСредство}) КАК Стоимость
	|		ЛЕВОЕ СОЕДИНЕНИЕ (
	|			ВЫБРАТЬ
	|				НалоговыеНазначенияОС.Организация         КАК Организация,
	|				НалоговыеНазначенияОС.ОсновноеСредство    КАК ОсновноеСредство,
	|				НалоговыеНазначенияОС.НалоговоеНазначение КАК НалоговоеНазначение,
	|				ВЫБОР
	|					КОГДА НалоговыеНазначенияОС.НалоговоеНазначение = &НеОблНеХоз
	|						ТОГДА NULL
	|					ИНАЧЕ ПервоначальныеСведения.НалоговаяГруппаОС
	|				КОНЕЦ 			                   		  КАК НалоговаяГруппаОС
	|			ИЗ
	|				РегистрСведений.НалоговыеНазначенияОС.СрезПоследних(&ДатаКон,
	|                               Организация = &Организация
	|				                {ОсновноеСредство КАК ОсновноеСредство}) КАК НалоговыеНазначенияОС
	|					ЛЕВОЕ СОЕДИНЕНИЕ 
	|						РегистрСведений.ПервоначальныеСведенияОСНалоговыйУчет.СрезПоследних(
	|						                &ДатаКон, Организация = &Организация
	|										{ОсновноеСредство КАК ОсновноеСредство}) КАК ПервоначальныеСведения
	|					ПО НалоговыеНазначенияОС.Организация = ПервоначальныеСведения.Организация
	|					   И НалоговыеНазначенияОС.ОсновноеСредство = ПервоначальныеСведения.ОсновноеСредство) КАК ПервоначальныеСведения
	|		ПО Стоимость.Организация = ПервоначальныеСведения.Организация
	|			И Стоимость.НалоговоеНазначение = ПервоначальныеСведения.НалоговоеНазначение
	|			И Стоимость.Субконто1 = ПервоначальныеСведения.ОсновноеСредство
	|		ЛЕВОЕ СОЕДИНЕНИЕ 
	|			РегистрСведений.ПервоначальныеСведенияОСБухгалтерскийУчет.СрезПоследних(
	|				                &ДатаКон, Организация = &Организация
	|								{ОсновноеСредство КАК ОсновноеСредство}) КАК ПервоначальныеСведенияБУ
	|		ПО Стоимость.Организация = ПервоначальныеСведенияБУ.Организация
	|			И Стоимость.Субконто1 = ПервоначальныеСведенияБУ.ОсновноеСредство
	|		ЛЕВОЕ СОЕДИНЕНИЕ 
	|			РегистрСведений.ПараметрыАмортизацииОСНалоговыйУчет.СрезПоследних(
	|				                &ДатаКон, Организация = &Организация
	|								{ОсновноеСредство КАК ОсновноеСредство}) КАК ПараметрыАмортизацииОС
	|		ПО Стоимость.Организация = ПараметрыАмортизацииОС.Организация
	|			И Стоимость.Субконто1 = ПараметрыАмортизацииОС.ОсновноеСредство
	|		ЛЕВОЕ СОЕДИНЕНИЕ 
	|			(ВЫБРАТЬ
	|				СостоянияОС.Организация      КАК Организация,
	|				СостоянияОС.ОсновноеСредство КАК ОсновноеСредство,
	|				МАКСИМУМ(ВЫБОР
	|						 	КОГДА СостоянияОС.Состояние = &СостояниеВвода
	|								ТОГДА СостоянияОС.ДатаСостояния
	|						 	ИНАЧЕ NULL
	|					     КОНЕЦ) КАК ДатаВводаВЭксплуатацию,
	|				МАКСИМУМ(ВЫБОР
	|						 	КОГДА СостоянияОС.Состояние = &СостояниеСнятияСУчета
	|								ТОГДА СостоянияОС.ДатаСостояния
	|						 	ИНАЧЕ NULL
	|					     КОНЕЦ) КАК ДатаСнятияСУчета
	|			ИЗ
	|				РегистрСведений.СостоянияОСОрганизаций КАК СостоянияОС
	|			ГДЕ
	|				СостоянияОС.Организация = &Организация
	|			{ГДЕ
	|				СостоянияОС.ОсновноеСредство}
	|		
	|			СГРУППИРОВАТЬ ПО
	|				СостоянияОС.Организация,
	|				СостоянияОС.ОсновноеСредство) КАК РегСостоянияОС
	|		ПО Стоимость.Организация = РегСостоянияОС.Организация
	|			И Стоимость.Субконто1 = РегСостоянияОС.ОсновноеСредство
	|		ЛЕВОЕ СОЕДИНЕНИЕ 
	|			РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(
	|		                       &НачГраница,
	|		                       &КонГраница, , ,
	|		                       Счет В
	|		                       	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		                         	СчетаУчета.СчетНачисленияАмортизации
	|		                         ИЗ
	|		                         	РегистрСведений.СчетаБухгалтерскогоУчетаОС.СрезПоследних(
	|		                         	                &НачДата, Организация = &Организация
	|		                         	                {ОсновноеСредство.* КАК ОсновноеСредство}) КАК СчетаУчета
	|		
	|		                         ОБЪЕДИНИТЬ
	|		
	|		                         ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		                         	СчетаУчета.СчетНачисленияАмортизации
	|		                         ИЗ
	|		                         	РегистрСведений.СчетаБухгалтерскогоУчетаОС КАК СчетаУчета
	|		                         ГДЕ
	|		                         	СчетаУчета.Период МЕЖДУ &НачДата И &КонДата
	|		                         	 И СчетаУчета.Организация = &Организация
	|		                         {ГДЕ
	|		                         	СчетаУчета.ОсновноеСредство.* КАК ОсновноеСредство}),
	|		                       &СубконтоОС,
	|		                       Организация = &Организация
	|		                       {ВЫРАЗИТЬ(Субконто1 КАК Справочник.ОсновныеСредства).* КАК ОсновноеСредство}) КАК Амортизация
	|		ПО Стоимость.Организация = Амортизация.Организация
	|			И Стоимость.Субконто1 = Амортизация.Субконто1
	|{ГДЕ
	|	РегСостоянияОС.ДатаВводаВЭксплуатацию    КАК ДатаВводаВЭксплуатацию,
	|	РегСостоянияОС.ДатаСнятияСУчета          КАК ДатаСнятияСУчета,
	|	ПервоначальныеСведения.НалоговаяГруппаОС КАК НалоговаяГруппаОС,
	|	ПараметрыАмортизацииОС.СрокПолезногоИспользования КАК СрокПолезногоИспользования,
	|	ПараметрыАмортизацииОС.СрокИспользованияДляВычисленияАмортизации   		КАК СрокИспользованияДляВычисленияАмортизации,
	|	ПараметрыАмортизацииОС.СтоимостьДляВычисленияАмортизации   				КАК СтоимостьДляВычисленияАмортизации}
	|
	|СГРУППИРОВАТЬ ПО
	|	Стоимость.Организация,
	|	Стоимость.НалоговоеНазначение,
	|	Стоимость.Субконто1,
	|	РегСостоянияОС.ДатаВводаВЭксплуатацию,
	|	РегСостоянияОС.ДатаСнятияСУчета,
	|	Стоимость.Счет,
	|	ПараметрыАмортизацииОС.СрокПолезногоИспользования,
	|	ПараметрыАмортизацииОС.СрокИспользованияДляВычисленияАмортизации,
	|	ПараметрыАмортизацииОС.СтоимостьДляВычисленияАмортизации,
	|	ПервоначальныеСведенияБУ.ИнвентарныйНомер,
	|	ПервоначальныеСведения.НалоговаяГруппаОС
	|{УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	НалоговоеНазначение,
	|	ОсновноеСредство,
	|	СтоимостьНачальныйОстаток,
	|	СтоимостьОборотДт,
	|	СтоимостьКонечныйОстаток,
	|	АмортизацияОборот,
	|	СтоимостьОборотКт,
	|	СчетУчета.*,
	|	ПараметрыАмортизацииОС.СрокПолезногоИспользования,
	|	ПараметрыАмортизацииОС.СрокИспользованияДляВычисленияАмортизации,
	|	ПараметрыАмортизацииОС.СтоимостьДляВычисленияАмортизации,
	|	НалоговаяГруппаОС.*}
	|ИТОГИ
	|	СУММА(СтоимостьНачальныйОстаток),
	|	СУММА(СтоимостьОборотДт),
	|	СУММА(АмортизацияОборот),
	|	СУММА(СтоимостьОборотКт),
	|	СУММА(СтоимостьКонечныйОстаток)
	|ПО
	|	ОБЩИЕ,
	|	Организация,
	|	НалоговоеНазначение,
	|	НалоговаяГруппаОС
	|{ИТОГИ ПО
	|	Организация,
	|	СчетУчета.*,
	|	НалоговоеНазначение,
	|	ОсновноеСредство,
	|	НалоговаяГруппаОС}
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	
	СтруктураПредставлениеПолей = Новый Структура;
	СтруктураПредставлениеПолей.Вставить( "Организация",                    НСтр("ru='Организация';uk='Організація'"));
