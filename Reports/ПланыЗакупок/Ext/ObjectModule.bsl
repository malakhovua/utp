	УниверсальныйОтчет.ДобавитьПоказатель("СтоимостьПоТипуЦенРегл", НСтр("ru='По типу цен';uk='По типу цін'"), ложь, "ЧЦ=15; ЧДЦ=2", "СтоимостьРегл");
