		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ПутевойЛист.Ссылка,
	ПутевойЛист.Склад,
	Топливо_.Расход,
	Топливо_.Выдано,
	Топливо_.Остаток,
	ТопливоА_.РасходА,
	ТопливоА_.ВыданоА,
	ТопливоА_.ОстатокА,
	ПутевойЛист.Дата,
	ПутевойЛист.Спидометр КАК ПоказанияСпидометраНач,
	ПутевойЛист.СпидометрПр КАК ПоказанияСпидометраКон,
	ПутевойЛист.СпидометрПр - ПутевойЛист.Спидометр КАК КМ,
	СУММА(ПутевойЛистМаршруты.ВесГруза) КАК ВесГруза,
	(РАЗНОСТЬДАТ(ПутевойЛист.ДатаВыезда, ПутевойЛист.ДатаПриезда, СЕКУНДА) + РАЗНОСТЬДАТ(ПутевойЛист.ВремяВыезда, ПутевойЛист.ВремяПриезда, СЕКУНДА)) / 3600 КАК ВремяВПути,
	"" КАК МестоСледования,
	ПутевойЛист.НормаРасхода КАК Норма,
	Топливо_.Топливо,
	ТопливоА_.ТопливоА
ИЗ
	Документ.ПутевойЛист.Маршруты КАК ПутевойЛистМаршруты
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПутевойЛист КАК ПутевойЛист
			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
				ПутевойЛист.Ссылка КАК Путевой,
				ПутевойЛист.Склад КАК Склад,
				ПутевойЛист.ТМЦ КАК Топливо,
				ВыданоГСМ.Выдано КАК Выдано,
				ЕСТЬNULL(ХозрасчетныйОстаткиИОбороты.КоличествоОборотКт, 0) КАК Расход,
				ЕСТЬNULL(ХозрасчетныйОстаткиИОбороты.КоличествоКонечныйОстаток, 0) КАК Остаток
			ИЗ
				РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(&amp;НачалоПериода, &amp;ОкончаниеПериода, Регистратор, , Счет В ИЕРАРХИИ (&amp;Счет20), , ) КАК ХозрасчетныйОстаткиИОбороты
					ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПутевойЛист КАК ПутевойЛист
						ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
							ЕСТЬNULL(ХозрасчетныйОборотыДтКт.КоличествоОборотДт, 0) КАК Выдано,
							ХозрасчетныйОборотыДтКт.СубконтоДт2 КАК СкладПрихода,
							ХозрасчетныйОборотыДтКт.СубконтоДт1 КАК ГСМ,
							ХозрасчетныйОборотыДтКт.Регистратор КАК Перемещение
						ИЗ
							РегистрБухгалтерии.Хозрасчетный.ОборотыДтКт(&amp;НачалоПериода, &amp;ОкончаниеПериода, Регистратор, СчетДт В ИЕРАРХИИ (&amp;Счет20), , , , ) КАК ХозрасчетныйОборотыДтКт) КАК ВыданоГСМ
						ПО ПутевойЛист.Склад = ВыданоГСМ.СкладПрихода
							И ПутевойЛист.ТМЦ = ВыданоГСМ.ГСМ
							И ПутевойЛист.ПеремещениеЗапр = ВыданоГСМ.Перемещение
					ПО (ПутевойЛист.Ссылка = ХозрасчетныйОстаткиИОбороты.Регистратор)
						И (ПутевойЛист.ТМЦ = ХозрасчетныйОстаткиИОбороты.Субконто1)
						И (ПутевойЛист.Склад = ХозрасчетныйОстаткиИОбороты.Субконто2)) КАК Топливо_
			ПО ПутевойЛист.Ссылка = Топливо_.Путевой
			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
				ПутевойЛист.Ссылка КАК Путевой,
				ПутевойЛист.Склад КАК Склад,
				ПутевойЛист.ТМЦА КАК ТопливоА,
				ВыданоГСМА.Выдано КАК ВыданоА,
				ЕСТЬNULL(ХозрасчетныйОстаткиИОбороты.КоличествоОборотКт, 0) КАК РасходА,
				ЕСТЬNULL(ХозрасчетныйОстаткиИОбороты.КоличествоКонечныйОстаток, 0) КАК ОстатокА
			ИЗ
				РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(&amp;НачалоПериода, &amp;ОкончаниеПериода, Регистратор, , Счет В ИЕРАРХИИ (&amp;Счет20), , ) КАК ХозрасчетныйОстаткиИОбороты
					ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПутевойЛист КАК ПутевойЛист
						ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
							ЕСТЬNULL(ХозрасчетныйОборотыДтКт.КоличествоОборотДт, 0) КАК Выдано,
							ХозрасчетныйОборотыДтКт.СубконтоДт2 КАК СкладПрихода,
							ХозрасчетныйОборотыДтКт.СубконтоДт1 КАК ГСМ,
							ХозрасчетныйОборотыДтКт.Регистратор КАК Перемещение
						ИЗ
							РегистрБухгалтерии.Хозрасчетный.ОборотыДтКт(&amp;НачалоПериода, &amp;ОкончаниеПериода, Регистратор, СчетДт В ИЕРАРХИИ (&amp;Счет20), , , , ) КАК ХозрасчетныйОборотыДтКт) КАК ВыданоГСМА
						ПО ПутевойЛист.ТМЦА = ВыданоГСМА.ГСМ
							И ПутевойЛист.Склад = ВыданоГСМА.СкладПрихода
							И ПутевойЛист.ПеремещениеЗапр = ВыданоГСМА.Перемещение
					ПО (ПутевойЛист.Ссылка = ХозрасчетныйОстаткиИОбороты.Регистратор)
						И (ПутевойЛист.ТМЦА = ХозрасчетныйОстаткиИОбороты.Субконто1)
						И (ПутевойЛист.Склад = ХозрасчетныйОстаткиИОбороты.Субконто2)) КАК ТопливоА_
			ПО ПутевойЛист.Ссылка = ТопливоА_.Путевой
		ПО ПутевойЛистМаршруты.Ссылка = ПутевойЛист.Ссылка
ГДЕ
	ПутевойЛист.Дата МЕЖДУ &amp;НачалоПериода И &amp;ОкончаниеПериода
	И НЕ ПутевойЛист.ПометкаУдаления = ИСТИНА

СГРУППИРОВАТЬ ПО
	ПутевойЛист.Ссылка,
	ПутевойЛист.Склад,
	Топливо_.Расход,
	Топливо_.Выдано,
	Топливо_.Остаток,
	ТопливоА_.РасходА,
	ТопливоА_.ВыданоА,
	ТопливоА_.ОстатокА,
	ПутевойЛист.Дата,
	ПутевойЛист.Спидометр,
	ПутевойЛист.СпидометрПр,
	(РАЗНОСТЬДАТ(ПутевойЛист.ДатаВыезда, ПутевойЛист.ДатаПриезда, СЕКУНДА) + РАЗНОСТЬДАТ(ПутевойЛист.ВремяВыезда, ПутевойЛист.ВремяПриезда, СЕКУНДА)) / 3600,
	ПутевойЛист.НормаРасхода,
	Топливо_.Топливо,
	ТопливоА_.ТопливоА</query>
	</dataSet>
	<calculatedField>
		<dataPath>МестоСледования</dataPath>
		<expression>umk_Доработки.ПолучитьКонкатенациюРегионов (Ссылка)</expression>
