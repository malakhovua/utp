		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ХозрасчетныйОстаткиИОбороты.Субконто1 КАК КонтрагентСправочник,
	ХозрасчетныйОстаткиИОбороты.Субконто2 КАК Договор,
	ВЫРАЗИТЬ(ВЫБОР
			КОГДА &amp;Лимит
				ТОГДА ВЫБОР
						КОГДА ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстатокДт &gt;= 10000
							ТОГДА 10000
						ИНАЧЕ ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстатокДт
					КОНЕЦ
			ИНАЧЕ ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстатокДт
		КОНЕЦ КАК ЧИСЛО(15, 1)) КАК Сумма,
	ВЫРАЗИТЬ(ХозрасчетныйОстаткиИОбороты.Субконто1.umk_НаименованиеДляПрочихДокументов КАК СТРОКА(40)) КАК Контрагент,
	ВЫРАЗИТЬ(ХозрасчетныйОстаткиИОбороты.Субконто2.Номер КАК СТРОКА(11)) КАК НомерДог,
	&amp;Период КАК ДатаОтчета,
	ВЫРАЗИТЬ(ВЫБОР
			КОГДА ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстатокДт &gt; &amp;ЛимитПроцентБанка
				ТОГДА ВЫБОР
						КОГДА &amp;Лимит
							ТОГДА ВЫБОР
									КОГДА ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстатокДт &gt;= 10000
										ТОГДА 10000
									ИНАЧЕ ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстатокДт
								КОНЕЦ
						ИНАЧЕ ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстатокДт
					КОНЕЦ * &amp;ПроцентБанка * 0.01
			ИНАЧЕ &amp;МинСуммаБанковскихУслуг
		КОНЕЦ КАК ЧИСЛО(15, 1)) КАК УслугиБанка
ИЗ
	РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(&amp;Период, &amp;Период, , , Счет В (&amp;Счета), , ) КАК ХозрасчетныйОстаткиИОбороты
ГДЕ
	ХозрасчетныйОстаткиИОбороты.Субконто1.umk_ОплатаУМК = ИСТИНА
	И (ВЫРАЗИТЬ(ВЫБОР
				КОГДА &amp;Лимит
					ТОГДА ВЫБОР
							КОГДА ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстатокДт &gt;= 10000
								ТОГДА 10000
							ИНАЧЕ ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстатокДт
						КОНЕЦ
				ИНАЧЕ ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстатокДт
			КОНЕЦ КАК ЧИСЛО(15, 1))) &lt;&gt; 0

УПОРЯДОЧИТЬ ПО
	Контрагент</query>
