#Если Клиент Тогда

////////////////////////////////////////////////////////////////////////////////
// ПЕРЕМЕННЫЕ МОДУЛЯ

Перем НП Экспорт;  				  // Настройка периода


////////////////////////////////////////////////////////////////////////////////
// ВСПОМОГАТЕЛЬНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ 
// 

// Функция формирует основной запрос по сбору данных для расчетных листков.
//
// Параметры
//
// Возвращаемое значение:
//   РезультатЗапроса   – результат запроса.
//
Функция СформироватьЗапрос()

	ОтборРаботника     = (ТипЗнч(СохраненныеНастройки) = Тип("Структура"));
	ОтборОрганизации   = ОтборРаботника;
	ОтборПодразделения = ОтборРаботника;
	
	Если ОтборРаботника Тогда
		
		ОтборОрганизации		  = СохраненныеНастройки.ФлажокНастройкиОрганизация;
		ВидСравненияОрганизации	  = СохраненныеНастройки.ПолеВидаСравненияОрганизация;
		Организация				  = СохраненныеНастройки.ПолеНастройкиОрганизация;
		ОтборПодразделения		  = СохраненныеНастройки.ФлажокНастройкиПодразделение;
		ВидСравненияПодразделения = СохраненныеНастройки.ПолеВидаСравненияПодразделение;
		Подразделение			  = СохраненныеНастройки.ПолеНастройкиПодразделение;
		ОтборРаботника			  = СохраненныеНастройки.ФлажокНастройкиРаботник;
		ВидСравненияРаботника	  = СохраненныеНастройки.ПолеВидаСравненияРаботник;
		Работник				  = СохраненныеНастройки.ПолеНастройкиРаботник;
		
	КонецЕсли;
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НачПериода",             ДатаНач);
	Запрос.УстановитьПараметр("НачПериодаСмещенное",    КонецДня(ДатаНач) + 1);
	Запрос.УстановитьПараметр("КонПериода",             КонецДня(ДатаКон));
	
	МассивРасчетов = Новый Массив;
	МассивРасчетов.Добавить(Неопределено);
	МассивРасчетов.Добавить(ПланыВидовРасчета.Начисления.ПустаяСсылка());
	Запрос.УстановитьПараметр("ПустойВидРасчета",       МассивРасчетов);
	
	Запрос.УстановитьПараметр("СпособРасчетаВзносы", Перечисления.СпособыРасчетаОплатыТруда.Взносы);
	Запрос.УстановитьПараметр("ВидДвиженияРасход",   ВидДвиженияНакопления.Расход );
	
	ВидыВзаиморасчетов = Новый Массив(3);
	ВидыВзаиморасчетов[0] = ПланыСчетов.Хозрасчетный.РасчетыПоНачисленнымДивидендам;
	ВидыВзаиморасчетов[1] = ПланыСчетов.Хозрасчетный.ДивидендыПолученные;
	Запрос.УстановитьПараметр("ПарамДивиденды", ВидыВзаиморасчетов);
	
	Запрос.УстановитьПараметр("парамУвольнение",	Перечисления.ПричиныИзмененияСостояния.Увольнение);
	
	КодыОперацииВыплата = Новый СписокЗначений;
	КодыОперацииВыплата.Добавить(Перечисления.КодыОперацийВзаиморасчетыСРаботникамиОрганизаций.Выплата);
	Запрос.УстановитьПараметр("ПарамКодыОперацииВыплата", КодыОперацииВыплата);
	
	ЗапросОтбор = Новый Запрос;
	ЗапросОтбор.УстановитьПараметр("НачПериода",		НачалоДня(ДатаНач));
	ЗапросОтбор.УстановитьПараметр("КонПериода",		КонецДня(ДатаКон));
	ЗапросОтбор.УстановитьПараметр("парамУвольнение",	Перечисления.ПричиныИзмененияСостояния.Увольнение);
	
	КодЯзыкаПечать = ЛокализацияПовтИсп.ПолучитьЯзыкФормированияПечатныхФормОтчетов();

	Если УпрУчет Тогда
		ТекстЗапросаРаботники = "
		|		ВЫБРАТЬ  
		|			Сотрудники.Организация		КАК Организация,
		|			Сотрудники.Ссылка			КАК Сотрудник,
		|			МАКСИМУМ(Работники.Период)	КАК Период
		|
		|		ИЗ РегистрСведений.Работники КАК Работники 
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СотрудникиОрганизаций КАК Сотрудники
		|       ПО Работники.ФизЛицо = Сотрудники.ФизЛицо
		|          И Сотрудники.ВидЗанятости <> ЗНАЧЕНИЕ(Перечисление.ВидыЗанятостиВОрганизации.ВнутреннееСовместительство)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УчетнаяПолитикаПоПерсоналу КАК УчПолитика
		|       ПО Сотрудники.Организация = УчПолитика.Организация
		|          И Сотрудники.ВидЗанятости <> ЗНАЧЕНИЕ(Перечисление.ВидыЗанятостиВОрганизации.ВнутреннееСовместительство)
		|		ГДЕ Работники.Период <= &КонПериода    
		|			И( Работники.ЗанимаемыхСтавок > 0
		|			ИЛИ    Работники.ЗанимаемыхСтавок = 0 И ПричинаИзмененияСостояния = &парамУвольнение)
		|           И УчПолитика.ОтражатьВУпрУчете
		|
		|		СГРУППИРОВАТЬ ПО
		|			Сотрудники.Организация,
		|			Сотрудники.Ссылка
		|";
		
		ТекстЗапросаОтбор = "
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Работники.Организация	КАК Организация,
		|	Работники.Сотрудник		КАК Сотрудник,
		|	РаботникиПодразделение.Подразделение КАК Подразделение
		|ИЗ ( " + ТекстЗапросаРаботники + "  ) КАК Работники
		| 
		| ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Работники КАК РаботникиПодразделение
		| ПО	Работники.Сотрудник.ФизЛицо = РаботникиПодразделение.ФизЛицо
		|	И	Работники.Период = РаботникиПодразделение.Период
		|
		|ГДЕ Истина
		|
		|";

	Иначе	
		ТекстЗапросаРаботники = "
		|		ВЫБРАТЬ 
		|			РаботникиОрганизаций.Организация		КАК Организация,
		|			РаботникиОрганизаций.Сотрудник			КАК Сотрудник,
		|			МАКСИМУМ(РаботникиОрганизаций.Период)	КАК Период
		|
		|			ИЗ РегистрСведений.РаботникиОрганизаций КАК РаботникиОрганизаций 
		|			
		|			ГДЕ РаботникиОрганизаций.Период <= &КонПериода    
		|			И( РаботникиОрганизаций.ЗанимаемыхСтавок > 0
		|			ИЛИ    РаботникиОрганизаций.ЗанимаемыхСтавок = 0 И ПричинаИзмененияСостояния = &парамУвольнение)
		|
		|		СГРУППИРОВАТЬ ПО
		|			РаботникиОрганизаций.Организация,
		|			РаботникиОрганизаций.Сотрудник
		|		
		|		ОБЪЕДИНИТЬ
		|			
		|		ВЫБРАТЬ
		|			ДоговорникиОрганизаций.Организация		КАК Организация,
		|			ДоговорникиОрганизаций.Сотрудник		КАК Сотрудник,
		|			ДоговорникиОрганизаций.ДатаОкончания	КАК Период
		|		ИЗ
		|			Документ.ДоговорНаВыполнениеРаботСФизЛицом	КАК ДоговорникиОрганизаций
		|		ГДЕ
		|			ДоговорникиОрганизаций.ДатаНачала <= &КонПериода
		//:|			И ДоговорникиОрганизаций.ДатаОкончания >= &НачПериода
		|			И ДоговорникиОрганизаций.Проведен
		|
		|";
		
		ТекстЗапросаОтбор = "
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Работники.Организация	КАК Организация,
		|	Работники.Сотрудник		КАК Сотрудник,
		|	РаботникиПодразделение.ПодразделениеОрганизации КАК ПодразделениеОрганизации
		|ИЗ ( " + ТекстЗапросаРаботники + "  ) КАК Работники
		| 
		| ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РаботникиОрганизаций КАК РаботникиПодразделение
		| ПО		Работники.Организация = РаботникиПодразделение.Организация
		|	И	Работники.Сотрудник = РаботникиПодразделение.Сотрудник
		|	И	Работники.Период = РаботникиПодразделение.Период
		|
		|ГДЕ Истина
		|
		|";

	КонецЕсли;	
	
		
	Если ОтборОрганизации Тогда
		
		ЗапросОтбор.УстановитьПараметр("ПарамОрганизация", Организация);
		ВидСравненияОрганизация = УправлениеОтчетами.ПолучитьВидСравненияСтрокой(ВидСравненияОрганизации);
		ТекстЗапросаОтбор = ТекстЗапросаОтбор + "
		|		И Работники.Организация " + ВидСравненияОрганизация + " (&ПарамОрганизация)";
		
	КонецЕсли;  
	
	Если НЕ УпрУчет И ОтборПодразделения Тогда
		
		ЗапросОтбор.УстановитьПараметр("ПарамПодразделение", Подразделение);
		ВидСравненияПодразделение = УправлениеОтчетами.ПолучитьВидСравненияСтрокой(ВидСравненияПодразделения);
		ТекстЗапросаОтбор = ТекстЗапросаОтбор + "
		|		И РаботникиПодразделение.ПодразделениеОрганизации " + ВидСравненияПодразделение + " (&ПарамПодразделение)";
		
	КонецЕсли;  
	
	Если ОтборРаботника Тогда
		
		ЗапросОтбор.УстановитьПараметр("ПарамСотрудник", Работник);
	    ВидСравненияРаботник = УправлениеОтчетами.ПолучитьВидСравненияСтрокой(ВидСравненияРаботника);
		ТекстЗапросаОтбор = ТекстЗапросаОтбор + "
		|		И Работники.Сотрудник " + ВидСравненияРаботник + " (&ПарамСотрудник)";
		
	КонецЕсли;
	
	ЗапросОтбор.Текст = ТекстЗапросаОтбор;
	ТаблицаФизЛиц = ЗапросОтбор.Выполнить().Выгрузить();
	ТаблицаОрганизаций = ТаблицаФизЛиц.Скопировать();
	
	ТаблицаФизЛиц.Свернуть("Сотрудник");
	МассивФизЛиц = ТаблицаФизЛиц.ВыгрузитьКолонку("Сотрудник");
	Запрос.УстановитьПараметр("ПарамСотрудник",	МассивФизЛиц);
	
	Запрос.УстановитьПараметр("Приход", ВидДвиженияНакопления.Приход);
	
	ТаблицаОрганизаций.Свернуть("Организация");
	МассивОрганизаций = ТаблицаОрганизаций.ВыгрузитьКолонку("Организация");
	Запрос.УстановитьПараметр("ПарамОрганизация",	МассивОрганизаций);
	
	
	МенеджерВременныхТаблиц =  Новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	ТекстЗапросаВТ = "ВЫБРАТЬ
	|	ВзаиморасчетыСРаботниками.Организация КАК Организация,
	|	ВзаиморасчетыСРаботниками.Сотрудник КАК Сотрудник,
	|	ВзаиморасчетыСРаботниками.Период КАК Период
	|   ПОМЕСТИТЬ ВТВзаиморасчетыСРаботниками
	|	ИЗ	РегистрНакопления.ВзаиморасчетыСРаботникамиОрганизаций.ОстаткиИОбороты(
	|			                  &НачПериода, &КонПериода, Месяц, , 
	|								Сотрудник в (&ПарамСотрудник)  
	|							И	Организация в (&ПарамОрганизация)
	|							  ) КАК ВзаиморасчетыСРаботниками
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|   Сотрудник,
	|	Период
	|";
	Запрос.Текст = ТекстЗапросаВТ;
	Запрос.Выполнить();
	
	ТекстЗапросаВТ = "ВЫБРАТЬ  
	|	ПлановыеНачисления.Организация КАК Организация,
	|	ПлановыеНачисления.Сотрудник КАК Сотрудник,
	|	ПлановыеНачисления.Регистратор КАК Регистратор,
	|	&НачПериода КАК Период,
	|	ПлановыеНачисления.Показатель1 КАК Размер
	|   ПОМЕСТИТЬ ВТПлановыеНачисленияЗаПериод
	|ИЗ
	|	РегистрСведений.ПлановыеНачисленияРаботниковОрганизаций.СрезПоследних(&НачПериода, ВидРасчетаИзмерение.Код ЕСТЬ NULL И Сотрудник в (&ПарамСотрудник) И Организация в (&ПарамОрганизация)) КАК ПлановыеНачисления
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ПлановыеНачисления.Организация,
	|	ПлановыеНачисления.Сотрудник,
	|	ПлановыеНачисления.Регистратор КАК Регистратор,
	|	ПлановыеНачисления.Период,
	|	ПлановыеНачисления.Показатель1
	|ИЗ
	|	РегистрСведений.ПлановыеНачисленияРаботниковОрганизаций КАК ПлановыеНачисления
	|ГДЕ
	|	ПлановыеНачисления.ВидРасчетаИзмерение.Код ЕСТЬ NULL
	|	И ПлановыеНачисления.Период > &НачПериода
	|	И ПлановыеНачисления.Период <= &КонПериода
	|	И ПлановыеНачисления.Сотрудник в (&ПарамСотрудник)
	|	И ПлановыеНачисления.Организация в (&ПарамОрганизация)
	|   И ПлановыеНачисления.Актуальность
	|";
	Запрос.Текст = ТекстЗапросаВТ;
	Запрос.Выполнить();
	
	Если УпрУчет Тогда
		ТекстЗапросаВТ = "ВЫБРАТЬ
		|	Сотрудники.Организация КАК Организация,
		|	Сотрудники.Ссылка КАК Сотрудник,
		|	Работники.Регистратор КАК Регистратор,
		|	&НачПериода КАК Период,
		|	Работники.Подразделение КАК Подразделение,
		|	Работники.Должность КАК Должность
		|ПОМЕСТИТЬ ВТРаботникиОрганизацийЗаПериод
		|ИЗ
		|	РегистрСведений.Работники.СрезПоследних(&НачПериода, ) КАК Работники
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СотрудникиОрганизаций КАК Сотрудники
		|		ПО Работники.ФизЛицо = Сотрудники.Физлицо
		|ГДЕ
		|	Сотрудники.Ссылка В(&парамСотрудник)
		|	И Сотрудники.Организация В(&парамОрганизация)
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	Сотрудники.Организация,
		|	Сотрудники.Ссылка,
		|	Работники.Регистратор,
		|	Работники.Период,
		|	Работники.Подразделение,
		|	Работники.Должность
		|ИЗ
		|	РегистрСведений.Работники КАК Работники
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СотрудникиОрганизаций КАК Сотрудники
		|		ПО Работники.ФизЛицо = Сотрудники.Физлицо
		|ГДЕ
		|	Сотрудники.Ссылка В(&парамСотрудник)
		|	И Сотрудники.Организация В(&парамОрганизация)
		|	И Работники.Период > &НачПериода
		|	И Работники.Период <= &КонПериода"
		
	Иначе
		
		ТекстЗапросаВТ = "ВЫБРАТЬ
		|	РаботникиОрганизаций.Организация КАК Организация,
		|	РаботникиОрганизаций.Сотрудник КАК Сотрудник,
		|	РаботникиОрганизаций.Регистратор КАК Регистратор,
		|	&НачПериода КАК Период,
		|	РаботникиОрганизаций.ПодразделениеОрганизации,
		|	РаботникиОрганизаций.Должность
		|ПОМЕСТИТЬ ВТРаботникиОрганизацийЗаПериод
		|ИЗ
		|	РегистрСведений.РаботникиОрганизаций.СрезПоследних(
		|			&НачПериода,
		|			ПричинаИзмененияСостояния <> &парамУвольнение
		|				И Сотрудник В (&ПарамСотрудник)
		|				И Организация В (&ПарамОрганизация)) КАК РаботникиОрганизаций
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	РаботникиОрганизаций.Организация,
		|	РаботникиОрганизаций.Сотрудник,
		|	РаботникиОрганизаций.Регистратор,
		|	РаботникиОрганизаций.Период,
		|	РаботникиОрганизаций.ПодразделениеОрганизации,
		|	РаботникиОрганизаций.Должность
		|ИЗ
		|	РегистрСведений.РаботникиОрганизаций КАК РаботникиОрганизаций
		|ГДЕ
		|	РаботникиОрганизаций.Сотрудник В(&ПарамСотрудник)
		|	И РаботникиОрганизаций.Организация В(&ПарамОрганизация)
		|	И РаботникиОрганизаций.Период > &НачПериода
		|	И РаботникиОрганизаций.Период <= &КонПериода"
	КонецЕсли;
	Запрос.Текст = ТекстЗапросаВТ;
	Запрос.Выполнить();
	
	ТекстЗапросаВТ = "ВЫБРАТЬ
	|	ВзаиморасчетыСРаботниками.Период КАК ПериодРегистрации,
	|	ПлановыеНачисления.Сотрудник КАК Сотрудник,
	|	ПлановыеНачисления.Организация КАК Организация,
	|	ПлановыеНачисления.Размер КАК Размер,
	|	ПлановыеНачисления.Регистратор КАК Регистратор
	|ПОМЕСТИТЬ ВТПлановыеНачисления
	|ИЗ
	|	ВТВзаиморасчетыСРаботниками КАК ВзаиморасчетыСРаботниками
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
