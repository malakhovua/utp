// ПРОЦЕДУРЫ И ФУНКЦИИ ФОРМИРОВАНИЯ ОТЧЕТА 
	
// Процедура формирования отчета
//
Процедура СформироватьОтчет(ТабличныйДокумент) Экспорт
	
	// Перед формирование отчета можно установить необходимые параметры универсального отчета.
	
	УниверсальныйОтчет.ПостроительОтчета.Параметры.Вставить("Приход", 						ВидДвиженияНакопления.Приход);
	УниверсальныйОтчет.ПостроительОтчета.Параметры.Вставить("ОблагаемыйВидДеятельностиНДС",Перечисления.ВидыДеятельностиНДС.Облагаемая);
	УниверсальныйОтчет.ПостроительОтчета.Параметры.Вставить("ПропорциональныйВидДеятельностиНДС",Перечисления.ВидыДеятельностиНДС.ПропорциональноОблагаемая);
	УниверсальныйОтчет.ПостроительОтчета.Параметры.Вставить("Гривна",  					глЗначениеПеременной("ВалютаРегламентированногоУчета"));
	
	УниверсальныйОтчет.СформироватьОтчет(ТабличныйДокумент);
	
КонецПроцедуры // СформироватьОтчет()

