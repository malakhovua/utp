#Если Клиент Тогда
	
////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ НАЧАЛЬНОЙ НАСТРОЙКИ ОТЧЕТА

// Процедура установки начальных настроек отчета по метаданным регистра накопления
//
Процедура УстановитьНачальныеНастройки(ДополнительныеПараметры = Неопределено) Экспорт
	
	// Настройка общих параметров универсального отчета
	
	// Содержит название отчета, которое будет выводиться в шапке.
	// Тип: Строка.
	// Пример:
	// УниверсальныйОтчет.мНазваниеОтчета = "Название отчета";
	УниверсальныйОтчет.мНазваниеОтчета = СокрЛП(ЭтотОбъект.Метаданные().Синоним);
	
	// Содержит признак необходимости отображения надписи и поля выбора раздела учета в форме настройки.
	// Тип: Булево.
	// Значение по умолчанию: Истина.
	// Пример:
	// УниверсальныйОтчет.мВыбиратьИмяРегистра = Ложь;
	УниверсальныйОтчет.мВыбиратьИмяРегистра = Ложь;
	
	// Содержит имя регистра, по метаданным которого будет выполняться заполнение настроек отчета.
	// Тип: Строка.
	// Пример:
	// УниверсальныйОтчет.ИмяРегистра = "ТоварыНаСкладах";
	УниверсальныйОтчет.ИмяРегистра = "ОжидаемыйИПодтвержденныйНДСПриобретений";
	
	// Содержит признак необходимости вывода отрицательных значений показателей красным цветом.
	// Тип: Булево.
	// Значение по умолчанию: Ложь.
	// Пример:
	// УниверсальныйОтчет.ОтрицательноеКрасным = Истина;
	
	// Содержит признак необходимости вывода в отчет общих итогов.
	// Тип: Булево.
	// Значение по умолчанию: Истина.
	// Пример:
	УниверсальныйОтчет.ВыводитьОбщиеИтоги = Ложь;
	
	// Содержит признак необходимости вывода детальных записей в отчет.
	// Тип: Булево.
	// Значение по умолчанию: Ложь.
	// Пример:
	// УниверсальныйОтчет.ВыводитьДетальныеЗаписи = Истина;
	
	// Содержит признак необходимости отображения флага использования свойств и категорий в форме настройки.
	// Тип: Булево.
	// Значение по умолчанию: Истина.
	// Пример:
	УниверсальныйОтчет.мВыбиратьИспользованиеСвойств = Ложь;
	
	// Содержит признак использования свойств и категорий при заполнении настроек отчета.
	// Тип: Булево.
	// Значение по умолчанию: Ложь.
	// Пример:
	// УниверсальныйОтчет.ИспользоватьСвойстваИКатегории = Истина;
	
	// Содержит признак использования простой формы настроек отчета без группировок колонок.
	// Тип: Булево.
	// Значение по умолчанию: Ложь.
	// Пример:
	// УниверсальныйОтчет.мРежимФормыНастройкиБезГруппировокКолонок = Истина;
	
	// Дополнительные параметры, переданные из отчета, вызвавшего расшифровку.
	// Информация, передаваемая в переменной ДополнительныеПараметры, может быть использована
	// для реализации специфичных для данного отчета параметрических настроек.
	
	
	// Описание исходного текста запроса.
	
    ТекстЗапроса = 
		  "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		  |	НДС.Организация КАК Организация,
		  |	ВЫБОР
		  |		КОГДА НДС.ДоговорКонтрагента = ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)
		  |				ИЛИ НДС.ДоговорКонтрагента.Внешнеэкономический = ЛОЖЬ
		  |			ТОГДА &Гривна
		  |		ИНАЧЕ НДС.ДоговорКонтрагента.ВалютаВзаиморасчетов
		  |	КОНЕЦ КАК Валюта,
		  |	НДС.ДоговорКонтрагента.Владелец КАК Контрагент,
		  |	НДС.ДоговорКонтрагента КАК ДоговорКонтрагента,
		  |	ВЫБОР
		  |		КОГДА НДС.ВозвратнаяТара = ИСТИНА
		  |			ТОГДА ""Возвратная тара""
		  |		ИНАЧЕ ""Товары""
		  |	КОНЕЦ КАК ВозвратнаяТара,
		  |	НДС.СобытиеНДС КАК СобытиеНДС,
		  |	НДС.СтавкаНДС КАК СтавкаНДС,
		  |	НДС.Сделка КАК Сделка,
		  |	ВЫБОР
		  |		КОГДА НДС.ДляХозяйственнойДеятельности = ИСТИНА
		  |			ТОГДА ""Для хоз. деят.""
		  |		ИНАЧЕ ""Для не хоз. деят.""
		  |	КОНЕЦ КАК ДляХозяйственнойДеятельности,
		  |	ВЫБОР
		  |		КОГДА НДС.ВидДеятельностиНДС = &ОблагаемыйВидДеятельностиНДС
		  |			ТОГДА ""Для обл. НДС""
		  |		КОГДА НДС.ВидДеятельностиНДС = &ПропорциональныйВидДеятельностиНДС
		  |			ТОГДА ""Пропорц. НДС""
		  |		ИНАЧЕ ""Для не обл. НДС""
		  |	КОНЕЦ КАК ДляОперацийОблагаемыхНДС,
		  |	ВЫБОР
		  |		КОГДА НДС.Амортизируется
		  |			ТОГДА ""Амортизируется""
		  |		ИНАЧЕ ""Не амортизируется""
		  |	КОНЕЦ КАК Амортизируется,
		  |	ВЫБОР
		  |		КОГДА НДС.ВидДвижения = &Приход
		  |			ТОГДА НДС.БазаНДС
		  |		ИНАЧЕ 0
		  |	КОНЕЦ КАК ОжидаемыйБазаНДС,
		  |	ВЫБОР
		  |		КОГДА НДС.ВидДвижения = &Приход
		  |			ТОГДА НДС.СуммаНДС
		  |		ИНАЧЕ 0
		  |	КОНЕЦ КАК ОжидаемыйСуммаНДС,
		  |	ВЫБОР
		  |		КОГДА НДС.ВидДвижения = &Приход
		  |			ТОГДА НДС.СуммаНДСПропорционально
		  |		ИНАЧЕ 0
		  |	КОНЕЦ КАК ОжидаемыйСуммаНДСПропорционально,
		  |	ВЫБОР
		  |		КОГДА (НЕ НДС.ВидДвижения = &Приход)
		  |			ТОГДА НДС.БазаНДС
		  |		ИНАЧЕ 0
		  |	КОНЕЦ КАК ПодтвержденныйБазаНДС,
		  |	ВЫБОР
		  |		КОГДА (НЕ НДС.ВидДвижения = &Приход)
		  |			ТОГДА НДС.СуммаНДС
		  |		ИНАЧЕ 0
		  |	КОНЕЦ КАК ПодтвержденныйСуммаНДС,
		  |	ВЫБОР
		  |		КОГДА (НЕ НДС.ВидДвижения = &Приход)
		  |			ТОГДА НДС.СуммаНДСПропорционально
		  |		ИНАЧЕ 0
		  |	КОНЕЦ КАК ПодтвержденныйСуммаНДСПропорционально,
		  |	ВЫБОР
		  |		КОГДА НДС.ВидДвижения = &Приход
		  |			ТОГДА НДС.БазаНДС
		  |		ИНАЧЕ -НДС.БазаНДС
		  |	КОНЕЦ КАК НеПодтвержденныйБазаНДС,
		  |	ВЫБОР
		  |		КОГДА НДС.ВидДвижения = &Приход
		  |			ТОГДА НДС.СуммаНДС
		  |		ИНАЧЕ -НДС.СуммаНДС
		  |	КОНЕЦ КАК НеПодтвержденныйСуммаНДС,
		  |	ВЫБОР
		  |		КОГДА НДС.ВидДвижения = &Приход
		  |			ТОГДА НДС.СуммаНДСПропорционально
		  |		ИНАЧЕ -НДС.СуммаНДСПропорционально
		  |	КОНЕЦ КАК НеПодтвержденныйСуммаНДСПропорционально
		  |{ВЫБРАТЬ
		  |	Организация.*,
		  |	НДС.ДоговорКонтрагента.Владелец.* КАК Контрагент,
		  |	ДоговорКонтрагента.*,
		  |	НДС.Сделка.*,
		  
		  |	ОжидаемыйБазаНДС,
		  |	ОжидаемыйСуммаНДС,
		  |	ПодтвержденныйБазаНДС,
		  |	ПодтвержденныйСуммаНДС,
		  |	НеПодтвержденныйБазаНДС,
		  |	НеПодтвержденныйСуммаНДС,
		  |	ОжидаемыйСуммаНДСПропорционально,
		  |	ПодтвержденныйСуммаНДСПропорционально,
		  |	НеПодтвержденныйСуммаНДСПропорционально
		  |}
		  |ИЗ
		  |	РегистрНакопления.ОжидаемыйИПодтвержденныйНДСПриобретений КАК НДС
		  |ГДЕ
		  |	НДС.Период >= &ДатаНачала
		  |	И НДС.Период <= &ДатаКонца
		  | И НДС.Активность = Истина
		  |
		  |{ГДЕ
		  |	НДС.Организация.*,
		  |	НДС.ДоговорКонтрагента.Владелец.* КАК Контрагент,
		  |	НДС.ДоговорКонтрагента.*,
		  |	НДС.ВозвратнаяТара КАК ВозвратнаяТара,
		  |	НДС.СобытиеНДС,
		  |	НДС.СтавкаНДС,
		  |	НДС.Сделка.*,
		  |	НДС.ДляХозяйственнойДеятельности КАК ДляХозяйственнойДеятельности,
		  |	НДС.Амортизируется КАК Амортизируется,
		  |	НДС.ВидДеятельностиНДС КАК ДляОперацийОблагаемыхНДС,
		  |	(ВЫБОР
		  |			КОГДА НДС.ДоговорКонтрагента = ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)
		  |					ИЛИ НДС.ДоговорКонтрагента.Внешнеэкономический = ЛОЖЬ
		  |				ТОГДА &Гривна
		  |			ИНАЧЕ НДС.ДоговорКонтрагента.ВалютаВзаиморасчетов
		  |		КОНЕЦ).* КАК Валюта}
		  |
		  |УПОРЯДОЧИТЬ ПО
		  |	СобытиеНДС УБЫВ
		  |{УПОРЯДОЧИТЬ ПО
		  |	СобытиеНДС,
		  |	Организация.*,
		  |	Контрагент.*,
		  |	ДоговорКонтрагента.*}
		  |ИТОГИ
		  |	СУММА(ОжидаемыйБазаНДС),
		  |	СУММА(ОжидаемыйСуммаНДС),
		  |	СУММА(ПодтвержденныйБазаНДС),
		  |	СУММА(ПодтвержденныйСуммаНДС),
		  |	СУММА(НеПодтвержденныйБазаНДС),
		  |	СУММА(НеПодтвержденныйСуммаНДС),
		  |	СУММА(ОжидаемыйСуммаНДСПропорционально),
		  |	СУММА(ПодтвержденныйСуммаНДСПропорционально),
		  |	СУММА(НеПодтвержденныйСуммаНДСПропорционально)
		  |ПО
		  |	ОБЩИЕ,
		  |	Организация,
		  |	Валюта,
		  |	Контрагент,
		  |	ДоговорКонтрагента,
		  |	Сделка,
		  |	ВозвратнаяТара,
		  |	СтавкаНДС,
		  |	ДляХозяйственнойДеятельности,
		  |	ДляОперацийОблагаемыхНДС,
		  |	Амортизируется
		  |{ИТОГИ ПО
		  |	Организация,
		  |	Валюта,
		  |	НДС.ДоговорКонтрагента.Владелец.* КАК Контрагент,
		  |	ДоговорКонтрагента.*,
		  |	(ВЫБОР
		  |			КОГДА НДС.ВозвратнаяТара = ИСТИНА
		  |				ТОГДА ""Возвратная тара""
		  |			ИНАЧЕ ""Товары""
		  |		КОНЕЦ) КАК ВозвратнаяТара,
		  |	НДС.СобытиеНДС,
		  |	НДС.СтавкаНДС,
		  |	НДС.Сделка.*,
		  |	(ВЫБОР
		  |			КОГДА НДС.ДляХозяйственнойДеятельности = ИСТИНА
		  |				ТОГДА ""Для хоз. деят.""
		  |			ИНАЧЕ ""Для не хоз. деят.""
		  |		КОНЕЦ) КАК ДляХозяйственнойДеятельности,
		  |	(ВЫБОР
		  |			КОГДА НДС.ВидДеятельностиНДС = &ОблагаемыйВидДеятельностиНДС
		  |				ТОГДА ""Для обл. НДС""
		  |		КОГДА НДС.ВидДеятельностиНДС = &ПропорциональныйВидДеятельностиНДС
		  |			ТОГДА ""Пропорц. НДС""
		  |			ИНАЧЕ ""Для не обл. НДС""
		  |		КОНЕЦ) КАК ДляОперацийОблагаемыхНДС,
		  |	(ВЫБОР
		  |			КОГДА НДС.Амортизируется
		  |				ТОГДА ""Амортизируется""
		  |			ИНАЧЕ ""Не амортизируется""
		  |		КОНЕЦ) КАК Амортизируется}";

		  
	Если ЛокализацияПовтИсп.ПолучитьЯзыкФормированияПечатныхФормОтчетов() = "uk" Тогда
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, """Для хоз. деят.""", """Для госп. діял.""");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, """Для не хоз. деят.""", """Для не госп. діял.""");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, """Для не обл. НДС""", """Для неопод. ПДВ""");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, """Пропорц. НДС""", """Пропорц.ПДВ""");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, """Для обл. НДС""", """Для опод. ПДВ""");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, """Амортизируется""", """Амортизується""");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, """Не амортизируется""", """Не амортизується""");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, """Возвратная тара""", """Поворотна тара""");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, """Товары""", """Товари""");
		
	КонецЕсли;
	// Инициализация текста запроса построителя отчета
	УниверсальныйОтчет.ПостроительОтчета.Текст = ТекстЗапроса;
	
	// Представления полей отчета.
	// Необходимо вызывать для каждого поля запроса.
	// УниверсальныйОтчет.мСтруктураПредставлениеПолей.Вставить(<ИмяПоля>, <ПредставлениеПоля>);
	УниверсальныйОтчет.мСтруктураПредставлениеПолей.Вставить("ДоговорКонтрагента",		 	НСтр("ru='Договор';uk='Договір'"));
	УниверсальныйОтчет.мСтруктураПредставлениеПолей.Вставить("Контрагент",	 				НСтр("ru='Контрагент';uk='Контрагент'"));
	УниверсальныйОтчет.мСтруктураПредставлениеПолей.Вставить("ВозвратнаяТара", 				НСтр("ru='За тару';uk='За тару'"));
	УниверсальныйОтчет.мСтруктураПредставлениеПолей.Вставить("СобытиеНДС", 					НСтр("ru='Поступление/возврат';uk='Надходження/повернення'"));
	УниверсальныйОтчет.мСтруктураПредставлениеПолей.Вставить("Сделка", 						НСтр("ru='Сделка';uk='Угода'"));
	УниверсальныйОтчет.мСтруктураПредставлениеПолей.Вставить("СтавкаНДС", 					НСтр("ru='Ставка НДС';uk='Ставка ПДВ'"));
	УниверсальныйОтчет.мСтруктураПредставлениеПолей.Вставить("ДляХозяйственнойДеятельности",НСтр("ru='Хоз. деятельность';uk='Госп. діяльність'"));
	УниверсальныйОтчет.мСтруктураПредставлениеПолей.Вставить("ДляОперацийОблагаемыхНДС", 	НСтр("ru='Облаг. НДС деятельность';uk='Оподатк. ПДВ діяльність'"));
	УниверсальныйОтчет.мСтруктураПредставлениеПолей.Вставить("Амортизируется", 				НСтр("ru='Амортизируется';uk='Амортизується'"));
	УниверсальныйОтчет.мСтруктураПредставлениеПолей.Вставить("Организация",		 			НСтр("ru='Организация';uk='Організація'"));
	УниверсальныйОтчет.мСтруктураПредставлениеПолей.Вставить("Валюта",		 			    НСтр("ru='Валюта';uk='Валюта'"));
	
	// Добавление показателей
	// Необходимо вызывать для каждого добавляемого показателя.
	// УниверсальныйОтчет.ДобавитьПоказатель(<ИмяПоказателя>, <ПредставлениеПоказателя>, <ВключенПоУмолчанию>, <Формат>, <ИмяГруппы>, <ПредставлениеГруппы>);
	
	УниверсальныйОтчет.ДобавитьПоказатель("ОжидаемыйБазаНДС", 			НСтр("ru='База НДС';uk='База ПДВ'"), Истина, "ЧЦ=15; ЧДЦ=2","ОжидаемыйНДС", НСтр("ru='Ожидаемый НДС';uk='Очікуваний ПДВ'"));
	УниверсальныйОтчет.ДобавитьПоказатель("ОжидаемыйСуммаНДС", 			НСтр("ru='НДС';uk='ПДВ'"), 		Истина, "ЧЦ=15; ЧДЦ=2","ОжидаемыйНДС");
	УниверсальныйОтчет.ДобавитьПоказатель("ПодтвержденныйБазаНДС", 		НСтр("ru='База НДС';uk='База ПДВ'"), Истина, "ЧЦ=15; ЧДЦ=2","ПодтвержденныйНДС", НСтр("ru='Подтвержденный НДС';uk='Підтверджений ПДВ'"));
	УниверсальныйОтчет.ДобавитьПоказатель("ПодтвержденныйСуммаНДС", 	НСтр("ru='НДС';uk='ПДВ'"), 		Истина, "ЧЦ=15; ЧДЦ=2","ПодтвержденныйНДС");
	УниверсальныйОтчет.ДобавитьПоказатель("НеПодтвержденныйБазаНДС", 	НСтр("ru='База НДС';uk='База ПДВ'"), Истина, "ЧЦ=15; ЧДЦ=2","НеПодтвержденныйНДС", НСтр("ru='Не подтвержденный НДС';uk='Не підтверджений ПДВ'"));
