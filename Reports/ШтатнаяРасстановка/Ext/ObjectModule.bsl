#Если Клиент Тогда
Процедура СформироватьОтчет(ДокументРезультат, ПоказыватьЗаголовок = Ложь, ВысотаЗаголовка = 0, ТолькоЗаголовок = Ложь) Экспорт

	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("ДатаАктуальности", ОбщийОтчет.ДатаКон);
	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("ДатаПослеАктуальности", ОбщийОтчет.ДатаКон+ 1);
	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("Уволен", Перечисления.ПричиныИзмененияСостояния.Увольнение);
	ОбщийОтчет.СформироватьОтчет(ДокументРезультат, ПоказыватьЗаголовок, ВысотаЗаголовка, ТолькоЗаголовок);

КонецПроцедуры

Процедура ЗаполнитьНачальныеНастройки() Экспорт
	
	ОбщийОтчет.ИмяРегистра = "-";
	ОбщийОтчет.мНазваниеОтчета = НСтр("ru='Штатная расстановка';uk='Штатна розстановка'");
	
	ПостроительОтчета = ОбщийОтчет.ПостроительОтчета;
	
	ПостроительОтчета.Текст = "
	|ВЫБРАТЬ
    |	КадровыйПлан.Подразделение КАК Подразделение,
    |	КадровыйПлан.Должность КАК Должность,
	|	КадровыйПланСрезПоследних.ПлановыеЕжемесячныеЗатраты КАК ПлановыеЕжемесячныеЗатраты,
	|	КадровыйПланСрезПоследних.Валюта КАК Валюта,
	|	Работники.ЗанимаемыхСтавок КАК Количество,
	|   Работники.ФизЛицо КАК ФизЛицо
	|
	|ИЗ
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		КадровыйПланСрезПоследних.Подразделение КАК Подразделение,
	|		КадровыйПланСрезПоследних.Должность КАК Должность
	|	ИЗ
	|		РегистрСведений.КадровыйПлан КАК КадровыйПланСрезПоследних
	|	
	|	ОБЪЕДИНИТЬ
	|	
	|	ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		РаботникиСрезПоследних.Подразделение,
	|		РаботникиСрезПоследних.Должность
	|	ИЗ
	|		РегистрСведений.Работники КАК РаботникиСрезПоследних) КАК КадровыйПлан
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КадровыйПлан.СрезПоследних(&ДатаАктуальности) КАК КадровыйПланСрезПоследних
	|		ПО КадровыйПлан.Подразделение = КадровыйПланСрезПоследних.Подразделение И КадровыйПлан.Должность = КадровыйПланСрезПоследних.Должность 
	|		{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Работники.СрезПоследних(&ДатаАктуальности, ) КАК Работники
	|		ПО КадровыйПлан.Подразделение = Работники.Подразделение И КадровыйПлан.Должность = Работники.Должность И (Работники.ПричинаИзмененияСостояния <> &Уволен)
	|		}
	|
	|ГДЕ
	|	(НЕ((Работники.ФизЛицо) ЕСТЬ NULL ))
	|
	|ИТОГИ СУММА(Количество) ПО
	|	ОБЩИЕ
	|
	|{ВЫБРАТЬ
	|   ФизЛицо.* КАК ФизЛицо,
	|	КадровыйПлан.Подразделение.* КАК Подразделение,
	|	КадровыйПлан.Должность.* КАК Должность,
	|	ПлановыеЕжемесячныеЗатраты,
	|	Валюта.* КАК Валюта,
	|	Количество
	|}
	|
	|{ГДЕ
	|	КадровыйПлан.Подразделение.* КАК Подразделение,
	|	КадровыйПлан.Должность.* КАК Должность,
	|	Валюта.* КАК Валюта,
	|	ПлановыеЕжемесячныеЗатраты,
	|	Количество
	|}
	|
	|{УПОРЯДОЧИТЬ ПО
	|   ФизЛицо.* КАК ФизЛицо,
	|	КадровыйПлан.Подразделение.*,
	|	КадровыйПлан.Должность.*	
	|}
	|
	|{ИТОГИ ПО 
	|	КадровыйПлан.Подразделение.*,
	|	КадровыйПлан.Должность.*
	|}
	|";
	
	// группировки по умолчанию
	ПостроительОтчета.ИзмеренияСтроки.Добавить("Подразделение");
	
	// список показателей и форматы их предстовления
	ОбщийОтчет.ЗаполнитьПоказатели("Количество", НСтр("ru='Количество занятых рабочих мест';uk='Кількість зайнятих робочих місць'"), Истина, "ЧЦ=15; ЧДЦ=2");
	
	// представление полей
	СтруктураПредставлениеПолей = Новый Структура();
	СтруктураПредставлениеПолей.Вставить("ФизЛицо", НСтр("ru='Работник';uk='Працівник'"));
	СтруктураПредставлениеПолей.Вставить("Подразделение", НСтр("ru='Подразделение';uk='Підрозділ'"));
	СтруктураПредставлениеПолей.Вставить("Должность", НСтр("ru='Должность';uk='Посада'"));
	СтруктураПредставлениеПолей.Вставить("ПлановыеЕжемесячныеЗатраты", НСтр("ru='Плановые ежемесячные затраты';uk='Планові щомісячні витрати'"));
	УправлениеОтчетами.ЗаполнитьПредставленияПолей(СтруктураПредставлениеПолей, ПостроительОтчета);
	
	// очистка автозаполненных полей построителя
	ПостроительОтчета.ВыбранныеПоля.Очистить();
	
	// Выбранные поля
	ПостроительОтчета.ВыбранныеПоля.Добавить("Должность");
	ПостроительОтчета.ВыбранныеПоля.Добавить("ФизЛицо");
	
	// отборы по умолчанию
	МассивОтбора = Новый Массив;
	МассивОтбора.Добавить("Подразделение");
	МассивОтбора.Добавить("Должность");
	УправлениеОтчетами.ЗаполнитьОтбор(МассивОтбора, ПостроительОтчета);
	
	// параметры отчета
	ОбщийОтчет.ВыводитьИтогиПоВсемУровням = Истина;
	ОбщийОтчет.ВыводитьПоказателиВСтроку = Истина;
	ОбщийОтчет.мРежимВводаПериода = 1; // Дата
	ОбщийОтчет.мВыбиратьИмяРегистра = Ложь;
	ОбщийОтчет.мВыбиратьИспользованиеСвойств = Ложь;
	
КонецПроцедуры

