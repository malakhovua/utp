// ПРОЦЕДУРЫ И ФУНКЦИИ 
// 

Процедура СформироватьОтчет(ДокументРезультат, ПоказыватьЗаголовок = Ложь, ВысотаЗаголовка = 0, ТолькоЗаголовок = Ложь) Экспорт

	
	ДатаНач = ОбщийОтчет.ДатаНач;
	ДатаКон = ОбщийОтчет.ДатаКон;

	
	Измерение = Новый Массив(2);
	Измерение[0] = "Сотрудник";
	Измерение[1] = "Организация"; 	
		
	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("ИзмОсн",Измерение);
	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить("ИзмБаз",Измерение);
	  
	КонецПериода = КонецДня(КонецМесяца(ОбщийОтчет.ДатаНач));
  
	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить( "НачалоПериода", ОбщийОтчет.ДатаНач );
	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить( "КонецПериода", КонецПериода );
	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить( "ПериодРегистрации", НачалоМесяца(ОбщийОтчет.ДатаНач));

	СписокСпособовРасчета = ПолучитьСписокСпособовРасчетовИспонителныеЛисты(); 
	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить( "СписокВидовРасчета", 	СписокСпособовРасчета);


	СписокВидовРасчетаПроцентов = Новый СписокЗначений;
	Элемент = ПланыВидовРасчета.Удержания.ПочтовыйСбор;
	СписокВидовРасчетаПроцентов.Добавить(Элемент);
	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить( "СписокВидовРасчетаПроцентов", СписокВидовРасчетаПроцентов);
	
	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить( "ВидКонтактнойИнформации", Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента);
  
	
	СписокНалоговыхДеклараций =ПолучитьСписокСтатьиНалоговыхДекларацийПоВзносамРаботников();
	ОбщийОтчет.ПостроительОтчета.Параметры.Вставить( "СписокНалоговыхДеклараций", СписокНалоговыхДеклараций);
	
	ОбщийОтчет.ПостроительОтчета.Макет = Неопределено;
		
	ОбщийОтчет.СформироватьОтчет(ДокументРезультат, ПоказыватьЗаголовок, ВысотаЗаголовка, ТолькоЗаголовок);

КонецПроцедуры // СформироватьОтчет()

// Процедура - заполняет начальные настройки отчета
//
Процедура ЗаполнитьНачальныеНастройки() Экспорт
	
	ПостроительОтчета = ОбщийОтчет.ПостроительОтчета;
	ОбщийОтчет.ВыводитьДополнительныеПоляВОтдельнойКолонке = Истина;		
	
	Текст = 
	"ВЫБРАТЬ
	|	УдержанияБаза.РезультатБаза 									КАК НачисленнаяЗП,
	|	УдержанияБаза.ВидРасчета 										КАК ВидРасчета,
	|	УдержанияБаза.Сотрудник											КАК Сотрудник,
	|	УдержанияБаза.ФизЛицо											КАК ФизЛицо,
	|	УдержанияБаза.ДокументОснование 								КАК ДокументОснование,
	|	ИсполнительныйЛист.ВидИсполнительногоДокумента 					КАК ВидИсполнительногоДокумента,
	|	ИсполнительныйЛист.Получатель 									КАК Получатель,
	|	ВзаиморасчетыПоНДФЛОбороты.НалогПриход 							КАК НДФЛ,
	|	ВзносыВФонды.Результат								 			КАК СуммаВзносов,
	|	УдержанияРаботниковОрганизацийПроценты.Результат 				КАК СуммаПроцент,
	|	ВЫБОР
	|		Когда УдержанияРаботниковОрганизацийПроценты.Результат ЕСТЬ NULL 
	|			Тогда УдержанияРаботниковОрганизаций.Результат
	|		Иначе
	|			УдержанияРаботниковОрганизаций.Результат + УдержанияРаботниковОрганизацийПроценты.Результат
	|		КОНЕЦ 														КАК СуммаПоЛисту,
	|	
	|	ВЫБОР
	|		Когда УдержанияРаботниковОрганизацийПроценты.Результат ЕСТЬ NULL 
	|			Тогда УдержанияБаза.РезультатБаза - УдержанияРаботниковОрганизаций.Результат - ВзаиморасчетыПоНДФЛОбороты.НалогПриход - ВзносыВФонды.Результат 
	|		Иначе
	|			УдержанияБаза.РезультатБаза - УдержанияРаботниковОрганизаций.Результат - УдержанияРаботниковОрганизацийПроценты.Результат - ВзаиморасчетыПоНДФЛОбороты.НалогПриход - ВзносыВФонды.Результат
	|		КОНЕЦ 														КАК СуммаКВыдаче, 
	|	РаботникиОрганизацииСрезПоследних.Организация					КАК Организация,
	|	РаботникиОрганизацииСрезПоследних.ПодразделениеОрганизации 		КАК Подразделение,
	| РаботникиОрганизацииСрезПоследних.Сотрудник.Код 					КАК ТабельныйНомер,
	| Реквизиты.Счет  													КАК Счет,
	| Реквизиты.НомерСчета 												КАК НомерСчета,
	| Реквизиты.Банк 													КАК Банк,
	| Реквизиты.Адрес 													КАК Адрес
	|
	| {
	| ВЫБРАТЬ 
	|  РаботникиОрганизацииСрезПоследних.ПодразделениеОрганизации.* КАК Подразделение,
	|  РаботникиОрганизацииСрезПоследних.Организация.* КАК Организация,
	|  ИсполнительныйЛист.ВидИсполнительногоДокумента.* КАК ВидИсполнительногоДокумента,
	|  РаботникиОрганизацииСрезПоследних.Сотрудник.Код.* КАК ТабельныйНомер,
	|  Реквизиты.Счет.* КАК Счет,
	|  Реквизиты.НомерСчета.* КАК НомерСчета,
	|  Реквизиты.Банк.* КАК Банк,
	|  Реквизиты.Адрес КАК Адрес  
	| }
	|ИЗ
	|	(
	|   ВЫБРАТЬ
	|		УдержанияБазаОсновныеНРО.РезультатБаза 		КАК РезультатБаза,
	|		УдержанияБазаОсновныеНРО.ВидРасчета 		КАК ВидРасчета,
	|		УдержанияБазаОсновныеНРО.Сотрудник			КАК Сотрудник,
	|		УдержанияБазаОсновныеНРО.Сотрудник.ФизЛицо 	КАК ФизЛицо,
	|		УдержанияБазаОсновныеНРО.ДокументОснование 	КАК ДокументОснование,
	|		УдержанияБазаОсновныеНРО.ДокументОснование.Ссылка КАК ДокументОснованиеСсылка
	|	ИЗ
	|		РегистрРасчета.Удержания.БазаНачисления(&ИзмОсн, &ИзмБаз, , ВидРасчета.СпособРасчета В (&СписокВидовРасчета) И ПериодРегистрации = &ПериодРегистрации) КАК УдержанияБазаОсновныеНРО
	|	
	|	ОБЪЕДИНИТЬ
	|	
	|	ВЫБРАТЬ
	|		УдержанияБазаДополнительныеНРО.РезультатБаза,
	|		УдержанияБазаДополнительныеНРО.ВидРасчета,
	|		УдержанияБазаДополнительныеНРО.Сотрудник,
	|		УдержанияБазаДополнительныеНРО.Сотрудник.ФизЛицо,
	|		УдержанияБазаДополнительныеНРО.ДокументОснование,
	|		УдержанияБазаДополнительныеНРО.ДокументОснование.Ссылка
	|	ИЗ
	|		РегистрРасчета.Удержания.БазаНачисления(&ИзмОсн, &ИзмБаз, , ВидРасчета В (&СписокВидовРасчета) И ПериодРегистрации = &ПериодРегистрации) КАК УдержанияБазаДополнительныеНРО
	|    ) КАК УдержанияБаза
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ИсполнительныйЛист КАК ИсполнительныйЛист
	|			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|				Контрагенты.ОсновнойБанковскийСчет КАК Счет,
	|				КонтактнаяИнформация.Представление КАК Адрес,
	|				Контрагенты.Ссылка КАК Контрагент,
	|				Контрагенты.ОсновнойБанковскийСчет.НомерСчета КАК НомерСчета,
	|				Контрагенты.ОсновнойБанковскийСчет.Банк КАК Банк
	|			ИЗ
	|				Справочник.Контрагенты КАК Контрагенты
	|					ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтактнаяИнформация КАК КонтактнаяИнформация
	|					ПО КонтактнаяИнформация.Объект = Контрагенты.Ссылка
  	|
	|			ГДЕ
	|				КонтактнаяИнформация.Вид = &ВидКонтактнойИнформации) КАК Реквизиты				
	|			ПО ИсполнительныйЛист.Получатель = Реквизиты.Контрагент
	|		ПО УдержанияБаза.ДокументОснование = ИсполнительныйЛист.Ссылка
  	|
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрРасчета.ВзносыВФонды КАК ВзносыВФонды
	|		ПО	УдержанияБаза.Сотрудник = ВзносыВФонды.Сотрудник
	//|		И	ВзносыВФонды.Организация = УдержанияБаза.Организация
	|		И	ВзносыВФонды.ПериодРегистрации <= &НачалоПериода
  	|       И	ВзносыВФонды.ПериодРегистрации >= &КонецПериода
  	|       И	ВзносыВФонды.СтатьяНалоговойДекларации В (&СписокНалоговыхДеклараций)
  	|
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ВзаиморасчетыПоНДФЛ.Обороты(&НачалоПериода, &КонецПериода, , ) КАК ВзаиморасчетыПоНДФЛОбороты
	|		ПО УдержанияБаза.Сотрудник = ВзаиморасчетыПоНДФЛОбороты.Сотрудник
	//|		И УдержанияБаза.Организация = УдержанияБаза.Организация
  	|
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрРасчета.Удержания КАК УдержанияРаботниковОрганизаций
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрРасчета.Удержания КАК УдержанияРаботниковОрганизацийПроценты
	|			ПО УдержанияРаботниковОрганизаций.ДокументОснование = УдержанияРаботниковОрганизацийПроценты.ДокументОснование
	|			И  УдержанияРаботниковОрганизацийПроценты.ВидРасчета В (&СписокВидовРасчетаПроцентов) 
	|		ПО УдержанияБаза.ВидРасчета = УдержанияРаботниковОрганизаций.ВидРасчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РаботникиОрганизаций.СрезПоследних(&КонецПериода, ) КАК РаботникиОрганизацииСрезПоследних
	|		ПО УдержанияБаза.Сотрудник = РаботникиОрганизацииСрезПоследних.Сотрудник
	|
	|ГДЕ                                                                               
	//|	УдержанияРаботниковОрганизацийПроценты.ВидРасчета В(&СписокВидовРасчетаПроцентов) И
	|	УдержанияРаботниковОрганизаций.ПериодРегистрации = &ПериодРегистрации
	|И	(УдержанияРаботниковОрганизацийПроценты.Результат ЕСТЬ NULL ИЛИ УдержанияРаботниковОрганизацийПроценты.ПериодРегистрации = &ПериодРегистрации)
	|	{ГДЕ РаботникиОрганизацииСрезПоследних.ПодразделениеОрганизации.* КАК Подразделение,
	|	РаботникиОрганизацииСрезПоследних.Организация.* КАК Организация,
	|	ИсполнительныйЛист.СпособПеречисления.* КАК ВидОплаты}
	| ИТОГИ СУММА(НачисленнаяЗП),
	|       СУММА(НДФЛ),
	|	      СУММА(СуммаВзносов),
	|	      СУММА(СуммаКВыдаче),
	|	      СУММА(СуммаПроцент),
	|	      СУММА(СуммаПоЛисту)          
	|                           ПО ОБЩИЕ,
	|                              Подразделение, 
	|                              Сотрудник,
	|								ФизЛицо,
	|  						                 Получатель, 
	|											         ВидИсполнительногоДокумента,
	|                              ДокументОснование
	|													  
	|
	|{ИТОГИ ПО
	|	      Организация.*, Подразделение.*, ФизЛицо.*, Получатель.*, ВидИсполнительногоДокумента.* , ДокументОснование.* }
  	|";

			
	
	СтруктураПредставлениеПолей = Новый Структура;
	
	СтруктураПредставлениеПолей.Вставить( "Подразделение",       НСтр("ru='Подразделение';uk='Підрозділ'"));
	СтруктураПредставлениеПолей.Вставить( "ФизЛицо",             НСтр("ru='ФИО плательщика';uk='ПІБ платника'"));
	СтруктураПредставлениеПолей.Вставить( "Получатель",          НСтр("ru='ФИО получателя';uk='ПІБ отримувача'"));
  	СтруктураПредставлениеПолей.Вставить( "ВидИсполнительногоДокумента", НСтр("ru='Вид исполнительного документа';uk='Вид виконавчого документа'"));
  	СтруктураПредставлениеПолей.Вставить( "ДокументОснование",   НСтр("ru='Документ основание';uk='Документ підстава'"));
  	СтруктураПредставлениеПолей.Вставить( "ТабельныйНомер", НСтр("ru='Табельный номер';uk='Табельний номер'"));
  	СтруктураПредставлениеПолей.Вставить( "Счет", НСтр("ru='Банковский счет получателя';uk='Банківський рахунок одержувача'"));
  	СтруктураПредставлениеПолей.Вставить( "Адрес", НСтр("ru='Адрес получателя';uk='Адреса одержувача'"));
  	СтруктураПредставлениеПолей.Вставить( "НомерСчета", НСтр("ru='Номер счета';uk='Номер рахунку'"));
  	СтруктураПредставлениеПолей.Вставить( "Банк", НСтр("ru='Наименование банка';uk='Найменування банку'"));

  	
	ПостроительОтчета.Текст = Текст;
	УправлениеОтчетами.ЗаполнитьПредставленияПолей(СтруктураПредставлениеПолей, ПостроительОтчета);	
	УправлениеОтчетами.ОчиститьДополнительныеПоляПостроителя(ПостроительОтчета);
	

	ОбщийОтчет.ЗаполнитьПоказатели( "НачисленнаяЗП",       НСтр("ru='Начисленная З/П';uk='Нарахована З/П'"),                Истина, "ЧЦ=15; ЧДЦ=2");
	ОбщийОтчет.ЗаполнитьПоказатели( "НДФЛ",                НСтр("ru='НДФЛ';uk='ПДФО'"),                           Истина, "ЧЦ=15; ЧДЦ=2");
	ОбщийОтчет.ЗаполнитьПоказатели( "СуммаВзносов",        НСтр("ru='Сумма взносов';uk='Сума внесків'"),                  Истина, "ЧЦ=15; ЧДЦ=2");
